[{"start": 0.34, "end": 1.7199999, "text": "Por ejemplo, ¿con quién?", "speaker": null}, {"start": 2.6799998, "end": 4.88, "text": "Pues, la barrotera de la esquina de la casa, ¿no?", "speaker": null}, {"start": 5.54, "end": 6.92, "text": "La tiendita de la esquina.", "speaker": null}, {"start": 7.98, "end": 9.04, "text": "La miscelánea.", "speaker": null}, {"start": 10.599999, "end": 12.82, "text": "A esos cuates que no les dan crédito, normalmente.", "speaker": null}, {"start": 13.719999, "end": 14.719999, "text": "Normalmente es cash.", "speaker": null}, {"start": 15.94, "end": 18.46, "text": "Cuando llega el repartidor de bimbo le dice,", "speaker": null}, {"start": 18.58, "end": 20.539999, "text": "¿cuántos buñuelos quieres?", "speaker": null}, {"start": 21.48, "end": 23.359999, "text": "Pues déjame, no sé, 20 buñuelos.", "speaker": null}, {"start": 23.74, "end": 25.019999, "text": "Déjame 15 donas.", "speaker": null}, {"start": 25.4, "end": 27.68, "text": "Déjame 25 mantecadas.", "speaker": null}, {"start": 27.68, "end": 30.12, "text": "déjame 10 panes de caja", "speaker": null}, {"start": 30.12, "end": 32.04, "text": "déjame tonitas", "speaker": null}, {"start": 32.04, "end": 33.52, "text": "¿me explico?", "speaker": null}, {"start": 33.94, "end": 35.94, "text": "el cuate este le saca su ticket", "speaker": null}, {"start": 35.94, "end": 36.9, "text": "dice", "speaker": null}, {"start": 36.9, "end": 39.78, "text": "son 3 mil pesos caro", "speaker": null}, {"start": 39.78, "end": 41.38, "text": "como que le digan a bingo", "speaker": null}, {"start": 41.38, "end": 42.48, "text": "usted que no es quien cae", "speaker": null}, {"start": 42.48, "end": 43.88, "text": "¿qué dice?", "speaker": null}, {"start": 45.26, "end": 45.64, "text": "cae", "speaker": null}, {"start": 45.64, "end": 48.64, "text": "se habrán dado cuenta que los camioncitos", "speaker": null}, {"start": 48.64, "end": 49.86, "text": "los camionetitas de bingo", "speaker": null}, {"start": 49.86, "end": 52.48, "text": "de coca cola, de pepsi cola", "speaker": null}, {"start": 52.48, "end": 54.92, "text": "de todos esos repartidores", "speaker": null}, {"start": 54.92, "end": 57.48, "text": "normalmente te ponen un letrero afuera", "speaker": null}, {"start": 57.48, "end": 58.8, "text": "¿qué dice?", "speaker": null}, {"start": 59.26, "end": 60.6, "text": "no tiene acceso a la caja", "speaker": null}, {"start": 60.6, "end": 63.1, "text": "trae caja fuerte", "speaker": null}, {"start": 63.1, "end": 65.74, "text": "y el operador no tiene acceso", "speaker": null}, {"start": 65.74, "end": 66.38, "text": "al dinero", "speaker": null}, {"start": 66.38, "end": 68.52, "text": "¿estamos de acuerdo?", "speaker": null}, {"start": 69.18, "end": 71.18, "text": "porque estos cuartos están cobrando el efectivo", "speaker": null}, {"start": 71.18, "end": 73.08, "text": "ellos tienen la obligación", "speaker": null}, {"start": 73.08, "end": 74.479996, "text": "de que la nata que cobra", "speaker": null}, {"start": 74.479996, "end": 76.5, "text": "la echan a la caja", "speaker": null}, {"start": 76.5, "end": 79.2, "text": "obviamente se queda con", "speaker": null}, {"start": 79.2, "end": 81.6, "text": "un fondo fijo", "speaker": null}, {"start": 81.6, "end": 83.159996, "text": "para dar cambio", "speaker": null}, {"start": 83.159996, "end": 85.28, "text": "cuando llegan con otra", "speaker": null}, {"start": 85.28, "end": 85.92, "text": "tienda", "speaker": null}, {"start": 85.92, "end": 87.619995, "text": "pero es mínimo", "speaker": null}, {"start": 87.619995, "end": 89.52, "text": "ellos tienen la obligación de buscarlo a la madre", "speaker": null}, {"start": 89.52, "end": 91.56, "text": "¿por qué? porque los pueden asaltar", "speaker": null}, {"start": 91.56, "end": 93.659996, "text": "como nos andan en las columnas", "speaker": null}, {"start": 93.659996, "end": 95.06, "text": "de negocio a negocio", "speaker": null}, {"start": 95.06, "end": 97.299995, "text": "pues los pueden asaltar", "speaker": null}, {"start": 97.299995, "end": 99.119995, "text": "si se llega un producto", "speaker": null}, {"start": 99.119995, "end": 101.46, "text": "el producto está asegurado pero si se lleva la gana", "speaker": null}, {"start": 101.46, "end": 105.4, "text": "no sé si lo explico", "speaker": null}, {"start": 105.4, "end": 109.02, "text": "eso lo pueden ver ustedes en la vida real", "speaker": null}, {"start": 109.02, "end": 110.78, "text": "no se lo estoy inventando", "speaker": null}, {"start": 110.78, "end": 113.6, "text": "entonces esto tiene una", "speaker": null}, {"start": 113.6, "end": 114.939995, "text": "contracuerda contable", "speaker": null}, {"start": 114.939995, "end": 116.34, "text": "a lo que les enseñaron a ustedes.", "speaker": null}, {"start": 117.06, "end": 119.399994, "text": "A todo cargo corresponde un abono.", "speaker": null}, {"start": 120.27999, "end": 121.56, "text": "Por ejemplo, si aquí yo tengo", "speaker": null}, {"start": 121.56, "end": 124.38, "text": "ventas de 200 mil pesos,", "speaker": null}, {"start": 124.899994, "end": 127.21999, "text": "estas ventas deben estar en su contracuenta.", "speaker": null}, {"start": 128.34, "end": 130.78, "text": "Clientes, clientes están aquí", "speaker": null}, {"start": 130.78, "end": 132.98, "text": "y es una cuenta, digamos,", "speaker": null}, {"start": 133.31999, "end": 135.43999, "text": "de tipo naturaleza deudora.", "speaker": null}, {"start": 136.64, "end": 138.72, "text": "Quiere decir que aumentan unos cargos.", "speaker": null}, {"start": 139.76, "end": 140.76, "text": "¿En dónde está el abono?", "speaker": null}, {"start": 141.59999, "end": 142.68, "text": "En ventas.", "speaker": null}, {"start": 142.68, "end": 145.93999, "text": "ventas es una cuenta de naturaleza", "speaker": null}, {"start": 145.93999, "end": 146.73999, "text": "acreedora", "speaker": null}, {"start": 146.73999, "end": 149.71999, "text": "entonces tenemos cargo por 200", "speaker": null}, {"start": 149.71999, "end": 151.18, "text": "con abono por 200", "speaker": null}, {"start": 151.18, "end": 154.06, "text": "y ahí están las ventas", "speaker": null}, {"start": 154.06, "end": 155.64, "text": "¿sí?", "speaker": null}, {"start": 155.71999, "end": 156.29999, "text": "¿sí vamos viendo?", "speaker": null}, {"start": 157.87999, "end": 159.49998, "text": "ok, entonces ahora", "speaker": null}, {"start": 159.49998, "end": 161.73999, "text": "¿qué es lo que vamos a hacer nosotros para analizar?", "speaker": null}, {"start": 162.98, "end": 163.79999, "text": "vamos a", "speaker": null}, {"start": 163.79999, "end": 166.04, "text": "descomponer nuestras ventas", "speaker": null}, {"start": 166.04, "end": 168.09999, "text": "y tenemos que separar", "speaker": null}, {"start": 168.09999, "end": 170.18, "text": "las ventas que fueron a crédito", "speaker": null}, {"start": 170.18, "end": 171.87999, "text": "que son las que están", "speaker": null}, {"start": 171.87999, "end": 179.13998, "text": "con clientes. Y tengo que separar las ventas que fueron al contado. Las ventas que están", "speaker": null}, {"start": 179.13998, "end": 188.81999, "text": "al contado, ¿a dónde las mandé? A mi cuenta de mayor, por ejemplo, bancos. ¿Correcto?", "speaker": null}, {"start": 189.07999, "end": 194.55998, "text": "Y bancos también van a tener subcuentas. Las empresas normalmente no están casadas", "speaker": null}, {"start": 194.55998, "end": 201.65999, "text": "con un solo banco. Las empresas normalmente pueden tener bancos nacionales y bancos extranjeros.", "speaker": null}, {"start": 201.87999, "end": 206.87999, "text": "Por ejemplo, nosotros si yo en las empresas donde trabajo tenemos bancos nacionales y", "speaker": null}, {"start": 206.87999, "end": 212.43999, "text": "extranjeros. ¿Por qué? Porque cruzamos operaciones a nivel internacional. Entonces yo aquí puedo", "speaker": null}, {"start": 212.43999, "end": 232.278, "text": "tener ejemplo a Citibank por poner un ejemplo a Chess Bank por poner un ejemplo el Manhattan Bank por poner un ejemplo si yo cruzo operaciones con los Estados Unidos Si no las cruzo a lo mejor ustedes van a tener cuentas nacionales", "speaker": null}, {"start": 232.89801, "end": 239.938, "text": "¿Como cuáles? No sé, a lo mejor Banco, Inbao, Vizcaya, Argentano.", "speaker": null}, {"start": 241.238, "end": 243.31801, "text": "Que traducido al castellano, ¿quién demonios es?", "speaker": null}, {"start": 243.31801, "end": 247.298, "text": "van a comer", "speaker": null}, {"start": 247.298, "end": 250.298, "text": "a lo mejor voy a tener cuentas", "speaker": null}, {"start": 250.298, "end": 250.878, "text": "con", "speaker": null}, {"start": 250.878, "end": 253.998, "text": "Banamex", "speaker": null}, {"start": 253.998, "end": 256.918, "text": "a lo mejor puedo tener cuentas", "speaker": null}, {"start": 256.918, "end": 257.318, "text": "con", "speaker": null}, {"start": 257.318, "end": 259.958, "text": "Santander", "speaker": null}, {"start": 259.958, "end": 262.778, "text": "etcétera", "speaker": null}, {"start": 262.778, "end": 263.418, "text": "¿me explico?", "speaker": null}, {"start": 264.298, "end": 266.778, "text": "entonces, mis operaciones en efectivo van a caer", "speaker": null}, {"start": 266.778, "end": 267.378, "text": "a bancos", "speaker": null}, {"start": 267.378, "end": 271.21802, "text": "mis operaciones a crédito, que es lo que me debe", "speaker": null}, {"start": 271.21802, "end": 272.578, "text": "va a caer", "speaker": null}, {"start": 272.578, "end": 283.098, "text": "a clientes. Entonces, nosotros en este ejemplo tenemos que identificar las cifras. Y las", "speaker": null}, {"start": 283.098, "end": 293.338, "text": "cifras me dicen que tome las ventas netas. Bueno, aquí vamos a pensar que yo tengo un", "speaker": null}, {"start": 293.338, "end": 301.958, "text": "total de ventas, por poner un ejemplo, de un millón y medio mil pesos. Por poner un", "speaker": null}, {"start": 301.958, "end": 310.198, "text": "ejemplo, ¿de acuerdo? De esas ventas las voy a separar. ¿Cuáles fueron en efectivo?", "speaker": null}, {"start": 312.758, "end": 325.61798, "text": "Pensemos que de esas ventas en efectivo, ¿correcto? No sé, hayan sido 500 mil pesos. Y a crédito", "speaker": null}, {"start": 325.618, "end": 329.758, "text": "había sido un millón de pesos.", "speaker": null}, {"start": 332.618, "end": 332.778, "text": "¿Sí?", "speaker": null}, {"start": 334.738, "end": 338.71802, "text": "Una vez que yo ya tengo identificadas mis ventas,", "speaker": null}, {"start": 339.398, "end": 340.538, "text": "¿qué me dice la razón?", "speaker": null}, {"start": 342.238, "end": 344.65802, "text": "Toma tus ventas netas.", "speaker": null}, {"start": 346.21802, "end": 350.138, "text": "Señores, hasta aquí yo tengo ventas totales.", "speaker": null}, {"start": 351.61798, "end": 352.838, "text": "¿Quieren que lo pasemos para acá?", "speaker": null}, {"start": 354.078, "end": 354.758, "text": "O a irse a un delito.", "speaker": null}, {"start": 355.61798, "end": 357.73798, "text": "ok", "speaker": null}, {"start": 357.73798, "end": 360.378, "text": "aquí yo tendría que tomar", "speaker": null}, {"start": 360.378, "end": 362.21802, "text": "este millón", "speaker": null}, {"start": 362.21802, "end": 364.17798, "text": "el millón de pesos", "speaker": null}, {"start": 364.17798, "end": 366.55798, "text": "pero se acuerdan", "speaker": null}, {"start": 366.55798, "end": 368.478, "text": "que nosotros cuando vimos el estado de costo", "speaker": null}, {"start": 368.478, "end": 369.538, "text": "pusimos el ejemplo", "speaker": null}, {"start": 369.538, "end": 371.778, "text": "no se con que empresa pero dijimos", "speaker": null}, {"start": 371.778, "end": 374.17798, "text": "no se de lo que yo compre", "speaker": null}, {"start": 374.17798, "end": 375.79797, "text": "tiene que pasar por control de calidad", "speaker": null}, {"start": 375.79797, "end": 377.038, "text": "pues no", "speaker": null}, {"start": 377.038, "end": 379.538, "text": "se me ocurre pensar no se", "speaker": null}, {"start": 379.538, "end": 381.17798, "text": "por poner un ejemplo", "speaker": null}, {"start": 381.17798, "end": 384.438, "text": "o sabritas por poner un ejemplo", "speaker": null}, {"start": 384.438, "end": 386.698, "text": "¿qué hace Sabritas?", "speaker": null}, {"start": 387.498, "end": 389.21802, "text": "pues Sabritas va a comprar papas", "speaker": null}, {"start": 389.21802, "end": 390.938, "text": "y cuando", "speaker": null}, {"start": 390.938, "end": 393.05798, "text": "llegue el trailer lleno de papas", "speaker": null}, {"start": 393.05798, "end": 394.798, "text": "evidentemente", "speaker": null}, {"start": 394.798, "end": 396.578, "text": "va a seleccionar", "speaker": null}, {"start": 396.578, "end": 398.998, "text": "las papas que cumplan con el control de calidad", "speaker": null}, {"start": 398.998, "end": 400.338, "text": "va a haber", "speaker": null}, {"start": 400.338, "end": 402.61798, "text": "algunas papas que lleguen apachurradas", "speaker": null}, {"start": 402.61798, "end": 403.738, "text": "maltratadas", "speaker": null}, {"start": 403.738, "end": 406.938, "text": "los papas van para atrás, ¿qué voy a hacer con esas papas?", "speaker": null}, {"start": 408.938, "end": 410.138, "text": "las voy a devolver", "speaker": null}, {"start": 410.138, "end": 413.378, "text": "entonces", "speaker": null}, {"start": 413.378, "end": 416.118, "text": "lo mismo vamos a hacer nosotros aquí", "speaker": null}, {"start": 416.118, "end": 418.178, "text": "pensemos que de ese", "speaker": null}, {"start": 418.178, "end": 419.05798, "text": "millón de pesos", "speaker": null}, {"start": 419.05798, "end": 421.65802, "text": "que aquí tenemos", "speaker": null}, {"start": 421.65802, "end": 428.458, "text": "le voy a tener que quitar", "speaker": null}, {"start": 428.458, "end": 430.258, "text": "mis devoluciones", "speaker": null}, {"start": 430.258, "end": 432.758, "text": "¿cuánto queremos devolver?", "speaker": null}, {"start": 433.458, "end": 434.498, "text": "no sé, vamos a pensar", "speaker": null}, {"start": 434.498, "end": 435.59802, "text": "que 20 mil pesos", "speaker": null}, {"start": 441.47803, "end": 442.578, "text": "a lo mejor", "speaker": null}, {"start": 442.578, "end": 454.256, "text": "y voy a negociar vamos a decirlo de esa manera puedo negociar Un descuento", "speaker": null}, {"start": 455.316, "end": 455.876, "text": "¿Estamos de acuerdo?", "speaker": null}, {"start": 460.216, "end": 465.056, "text": "Pensemos que logré 15 mil pesos de descuento.", "speaker": null}, {"start": 466.45602, "end": 470.036, "text": "¿Qué más? Descuentos, una rebaja,", "speaker": null}, {"start": 472.036, "end": 473.396, "text": "5 mil pesos.", "speaker": null}, {"start": 475.036, "end": 475.91602, "text": "etc.", "speaker": null}, {"start": 477.11603, "end": 479.13602, "text": "Entonces, en este caso, ¿qué va a pasar?", "speaker": null}, {"start": 479.876, "end": 487.656, "text": "Si yo le descuento al millón, le quito 20 y 15 son 35, y 5, 40 mil pesos.", "speaker": null}, {"start": 488.696, "end": 493.85602, "text": "Entonces, mis ventas netas, ¿a cuánto ascenderían?", "speaker": null}, {"start": 494.85602, "end": 497.936, "text": "Por ejemplo, a 960 mil pesos.", "speaker": null}, {"start": 497.936, "end": 501.096, "text": "luego entonces", "speaker": null}, {"start": 501.096, "end": 502.656, "text": "ahora si ya tengo", "speaker": null}, {"start": 502.656, "end": 505.156, "text": "mis ventas netas", "speaker": null}, {"start": 505.156, "end": 506.656, "text": "a crédito", "speaker": null}, {"start": 506.656, "end": 508.63602, "text": "porque yo partí de las de crédito", "speaker": null}, {"start": 508.63602, "end": 510.316, "text": "no de mis ventas totales", "speaker": null}, {"start": 510.316, "end": 512.676, "text": "porque mis ventas totales incluían", "speaker": null}, {"start": 512.676, "end": 513.396, "text": "efectivo", "speaker": null}, {"start": 513.396, "end": 515.49603, "text": "¿si?", "speaker": null}, {"start": 516.636, "end": 517.81604, "text": "¿qué pasaría ahora?", "speaker": null}, {"start": 519.476, "end": 521.016, "text": "pues yo sustituyo", "speaker": null}, {"start": 521.016, "end": 522.876, "text": "razón de aprobación de cuentas", "speaker": null}, {"start": 522.876, "end": 524.216, "text": "por cobrar al crédito", "speaker": null}, {"start": 524.216, "end": 526.236, "text": "esto es igual a", "speaker": null}, {"start": 526.236, "end": 528.43604, "text": "960 millones", "speaker": null}, {"start": 528.43604, "end": 532.476, "text": "por poner un ejemplo", "speaker": null}, {"start": 532.476, "end": 534.43604, "text": "hasta ahí", "speaker": null}, {"start": 534.43604, "end": 535.216, "text": "dudas", "speaker": null}, {"start": 535.216, "end": 538.176, "text": "las que sean", "speaker": null}, {"start": 538.176, "end": 540.396, "text": "bueno", "speaker": null}, {"start": 540.396, "end": 541.776, "text": "el estado de resultados", "speaker": null}, {"start": 541.776, "end": 543.856, "text": "me faltó porque era", "speaker": null}, {"start": 543.856, "end": 546.396, "text": "ventas, ventas", "speaker": null}, {"start": 546.396, "end": 547.656, "text": "menos costo de ventas", "speaker": null}, {"start": 547.656, "end": 549.856, "text": "cuál es que es igual", "speaker": null}, {"start": 549.856, "end": 551.396, "text": "¿en dónde? aquí", "speaker": null}, {"start": 551.396, "end": 554.036, "text": "ventas, ventas menos costo de ventas", "speaker": null}, {"start": 554.036, "end": 555.336, "text": "te da resultado bruto", "speaker": null}, {"start": 555.336, "end": 558.596, "text": "bueno, nosotros los contadores le ponemos", "speaker": null}, {"start": 558.596, "end": 560.93604, "text": "resultado bruto, tú le puedes poner", "speaker": null}, {"start": 560.93604, "end": 562.016, "text": "utilidad bruta", "speaker": null}, {"start": 562.016, "end": 565.156, "text": "o pérdida bruta", "speaker": null}, {"start": 565.156, "end": 567.216, "text": "nosotros le llamamos resultado porque puede ser", "speaker": null}, {"start": 567.216, "end": 567.776, "text": "una u otra", "speaker": null}, {"start": 567.776, "end": 570.556, "text": "pero si tú quieres ser más específico sería", "speaker": null}, {"start": 570.556, "end": 573.156, "text": "utilidad bruta con su defecto pérdida bruta", "speaker": null}, {"start": 573.156, "end": 575.276, "text": "y entonces eso luego", "speaker": null}, {"start": 575.276, "end": 577.016, "text": "se le resta a los gastos de operación", "speaker": null}, {"start": 577.016, "end": 577.976, "text": "es correcto", "speaker": null}, {"start": 577.976, "end": 579.396, "text": "y queda el resultado de operación", "speaker": null}, {"start": 579.396, "end": 582.096, "text": "hasta ahí nos queda", "speaker": null}, {"start": 582.096, "end": 583.49603, "text": "¿sale?", "speaker": null}, {"start": 583.49603, "end": 585.896, "text": "entonces yo ya tengo", "speaker": null}, {"start": 585.896, "end": 587.616, "text": "el primer dato", "speaker": null}, {"start": 587.616, "end": 590.016, "text": "960 mil", "speaker": null}, {"start": 590.016, "end": 592.116, "text": "si vimos de donde salga", "speaker": null}, {"start": 592.116, "end": 594.256, "text": "ahora me dicen", "speaker": null}, {"start": 594.256, "end": 596.176, "text": "ocupa el segundo dato", "speaker": null}, {"start": 596.176, "end": 597.916, "text": "mis cuentas por cobrar", "speaker": null}, {"start": 597.916, "end": 600.596, "text": "aquí ya habíamos dicho", "speaker": null}, {"start": 600.596, "end": 601.31604, "text": "que en crímenes", "speaker": null}, {"start": 601.31604, "end": 604.49603, "text": "lo mismo les digo", "speaker": null}, {"start": 604.49603, "end": 605.93604, "text": "que la cantidad que ustedes quieran", "speaker": null}, {"start": 605.93604, "end": 606.856, "text": "me da lo mismo", "speaker": null}, {"start": 606.856, "end": 608.536, "text": "yo voy a hacer ese análisis", "speaker": null}, {"start": 608.536, "end": 611.956, "text": "me dijeron", "speaker": null}, {"start": 611.956, "end": 612.49603, "text": "que", "speaker": null}, {"start": 612.49603, "end": 615.596, "text": "el promedio de mis clientes", "speaker": null}, {"start": 615.596, "end": 616.536, "text": "ojo", "speaker": null}, {"start": 616.536, "end": 618.596, "text": "hablando de promedios", "speaker": null}, {"start": 618.596, "end": 622.19604, "text": "¿se acuerdan que nosotros habíamos visto en clases anteriores", "speaker": null}, {"start": 622.19604, "end": 624.876, "text": "que yo tengo periodos contables?", "speaker": null}, {"start": 627.876, "end": 628.916, "text": "enero", "speaker": null}, {"start": 628.916, "end": 631.43604, "text": "febrero", "speaker": null}, {"start": 631.43604, "end": 633.396, "text": "marzo", "speaker": null}, {"start": 633.396, "end": 633.956, "text": "y así", "speaker": null}, {"start": 633.956, "end": 635.836, "text": "¿correcto?", "speaker": null}, {"start": 636.656, "end": 637.856, "text": "entonces yo", "speaker": null}, {"start": 637.856, "end": 640.856, "text": "voy a tener un saldo inicial", "speaker": null}, {"start": 640.856, "end": 643.956, "text": "y voy a tener un saldo final.", "speaker": null}, {"start": 647.056, "end": 648.776, "text": "Pensemos que al inicio,", "speaker": null}, {"start": 649.596, "end": 652.656, "text": "al inicio del periodo que ustedes quieran, febrero,", "speaker": null}, {"start": 653.576, "end": 655.776, "text": "yo tengo un saldo de 200 mil.", "speaker": null}, {"start": 658.676, "end": 661.176, "text": "Es lo que empecé en el mes.", "speaker": null}, {"start": 662.656, "end": 665.476, "text": "Aquí tenemos saldo, 200 mil.", "speaker": null}, {"start": 665.99603, "end": 667.416, "text": "Para ocupar lo que ya tenemos.", "speaker": null}, {"start": 668.99603, "end": 669.876, "text": "Voy bien hasta el último.", "speaker": null}, {"start": 669.876, "end": 681.234, "text": "Pero va a pasar Carlos En el transcurso del mes a febrero viene 28 d normalmente", "speaker": null}, {"start": 682.914, "end": 683.354, "text": "¿Correcto?", "speaker": null}, {"start": 684.914, "end": 686.234, "text": "Día a día,", "speaker": null}, {"start": 687.01404, "end": 688.254, "text": "día a día,", "speaker": null}, {"start": 689.654, "end": 690.614, "text": "yo hago operaciones.", "speaker": null}, {"start": 691.794, "end": 693.19403, "text": "Como empresa, todos los días compro.", "speaker": null}, {"start": 696.114, "end": 698.13403, "text": "Como empresa, todos los días compro.", "speaker": null}, {"start": 698.13403, "end": 700.994, "text": "como empresa todos los días como", "speaker": null}, {"start": 700.994, "end": 704.07404, "text": "y como empresa todos los días pago", "speaker": null}, {"start": 704.07404, "end": 708.51404, "text": "entonces si yo tomo el saldo inicial", "speaker": null}, {"start": 708.51404, "end": 709.57404, "text": "sería un error", "speaker": null}, {"start": 709.57404, "end": 713.89404, "text": "porque estoy descuidando las operaciones de todo el mes", "speaker": null}, {"start": 713.89404, "end": 716.814, "text": "si tomo el saldo final", "speaker": null}, {"start": 716.814, "end": 717.974, "text": "sería un error", "speaker": null}, {"start": 717.974, "end": 721.414, "text": "entonces que me dice la norma", "speaker": null}, {"start": 721.414, "end": 723.434, "text": "quítate de broncas", "speaker": null}, {"start": 723.434, "end": 727.07404, "text": "y como consecuencia que voy a hacer", "speaker": null}, {"start": 727.07404, "end": 729.034, "text": "me dice", "speaker": null}, {"start": 729.034, "end": 732.794, "text": "ocupa el promedio", "speaker": null}, {"start": 732.794, "end": 737.01404, "text": "¿cómo calcularíamos el promedio?", "speaker": null}, {"start": 737.174, "end": 739.594, "text": "¿cómo se les ocurre que calcularíamos el promedio?", "speaker": null}, {"start": 740.034, "end": 741.77405, "text": "sumar el saldo de todos los días", "speaker": null}, {"start": 741.77405, "end": 742.554, "text": "en el 38", "speaker": null}, {"start": 742.554, "end": 746.254, "text": "pudiera ser una forma de hacerlo", "speaker": null}, {"start": 746.254, "end": 747.934, "text": "o el iniciario y el final", "speaker": null}, {"start": 747.934, "end": 749.114, "text": "pero hay que ir en detalle", "speaker": null}, {"start": 749.114, "end": 750.614, "text": "allá voy", "speaker": null}, {"start": 750.614, "end": 753.934, "text": "que tengo que identificar mis cuentas", "speaker": null}, {"start": 754.494, "end": 756.934, "text": "aquí el charla ya se adelantó", "speaker": null}, {"start": 757.07404, "end": 759.754, "text": "yo tengo un saldo inicial", "speaker": null}, {"start": 759.754, "end": 762.39404, "text": "y tengo un saldo final", "speaker": null}, {"start": 762.39404, "end": 763.814, "text": "no se, pensemos que", "speaker": null}, {"start": 763.814, "end": 765.734, "text": "a lo largo del mes", "speaker": null}, {"start": 765.734, "end": 768.594, "text": "compre y vendí", "speaker": null}, {"start": 768.594, "end": 769.834, "text": "pero cobre", "speaker": null}, {"start": 769.834, "end": 772.274, "text": "soy una empresa abusada", "speaker": null}, {"start": 772.274, "end": 773.254, "text": "y voy cobrando", "speaker": null}, {"start": 773.254, "end": 776.57404, "text": "de lo que me debe", "speaker": null}, {"start": 776.57404, "end": 778.154, "text": "al cierre del mes", "speaker": null}, {"start": 778.154, "end": 780.13403, "text": "logre cobrar", "speaker": null}, {"start": 780.13403, "end": 781.874, "text": "a mis clientes", "speaker": null}, {"start": 781.874, "end": 784.01404, "text": "quiere decir que ya me deben menos", "speaker": null}, {"start": 784.01404, "end": 786.434, "text": "puede ser o no puede ser", "speaker": null}, {"start": 786.434, "end": 790.19403, "text": "O podría ser al revés, que en vez de 200 ahora me deban 500.", "speaker": null}, {"start": 791.494, "end": 793.39404, "text": "Eso quiere decir que vendí y me quedaron a deber.", "speaker": null}, {"start": 794.494, "end": 796.294, "text": "Los saludables que yo vaya cobrando.", "speaker": null}, {"start": 797.19403, "end": 799.294, "text": "¿Para qué? Para generar flujo de efectivo.", "speaker": null}, {"start": 800.814, "end": 801.534, "text": "¿Vuelve o no me regreso?", "speaker": null}, {"start": 803.19403, "end": 806.454, "text": "Luego entonces hay dos métodos de determinar promedios.", "speaker": null}, {"start": 807.414, "end": 809.174, "text": "Uno, vuelve a lo mismo.", "speaker": null}, {"start": 809.174, "end": 809.77405, "text": "¿Vuelve o no te escuche?", "speaker": null}, {"start": 812.594, "end": 815.19403, "text": "Es que le veo para los asignos y si yo te traiga más.", "speaker": null}, {"start": 816.434, "end": 825.294, "text": "Cuando hablamos de cuentas que no juegan con el sistema financiero mexicano, el promedio", "speaker": null}, {"start": 825.294, "end": 830.89404, "text": "se determina considerando el saldo inicial más el saldo final entre dos.", "speaker": null}, {"start": 832.414, "end": 839.13403, "text": "Cuando hablamos de cuentas que juegan con el sistema financiero mexicano, o sea, que", "speaker": null}, {"start": 839.13403, "end": 845.854, "text": "que nosotros llevamos a cabo con entidades financieras como los bancos, se saca un saldo", "speaker": null}, {"start": 845.854, "end": 852.07404, "text": "promedio diario, que es lo que decía Carlos, Carlos habló de los OSO, nada más que el", "speaker": null}, {"start": 852.07404, "end": 857.934, "text": "ministro Álvarez dijo, la suma de todos los días, de los saldos del mes, entre el 28,", "speaker": null}, {"start": 858.474, "end": 865.214, "text": "entre el número de 10, es correcto, pero eso es para saldo promedio diario, ¿por qué?", "speaker": null}, {"start": 865.214, "end": 870.394, "text": "porque estaríamos hablando de una cuenta que juega con el sistema financiero mexicano.", "speaker": null}, {"start": 871.114, "end": 875.01404, "text": "Las cuentas que no juegan con el sistema financiero mexicano", "speaker": null}, {"start": 875.01404, "end": 880.574, "text": "se toman el saldo inicial más el saldo final entre dos.", "speaker": null}, {"start": 881.794, "end": 884.354, "text": "En este caso, como hablamos de una empresa normal,", "speaker": null}, {"start": 885.374, "end": 893.374, "text": "estamos hablando de Pepito, de Carlitos, de Lupita, de Pedrito, etc.", "speaker": null}, {"start": 893.374, "end": 895.13403, "text": "¿Qué va a pasar?", "speaker": null}, {"start": 895.214, "end": 898.394, "text": "ahí no juegan con el sistema financiero mexicano", "speaker": null}]