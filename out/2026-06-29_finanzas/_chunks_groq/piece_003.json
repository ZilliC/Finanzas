[{"start": 0.0, "end": 4.38, "text": "Con eso ustedes podrían entender mucho más cosas y más fácilmente.", "speaker": null}, {"start": 5.2, "end": 10.12, "text": "Y no para el área o para la materia de finanzas, para su vida profesional.", "speaker": null}, {"start": 11.42, "end": 13.139999, "text": "Porque ya no van a trabajar con eso.", "speaker": null}, {"start": 13.86, "end": 16.84, "text": "Yo les garantizo que ya han venido ustedes, ya han venido.", "speaker": null}, {"start": 18.26, "end": 22.5, "text": "Ustedes ya han venido dentro del sistema de una enseñanza y no se han dado cuenta.", "speaker": null}, {"start": 23.92, "end": 25.9, "text": "Ya, ya han venido.", "speaker": null}, {"start": 25.9, "end": 28.939999, "text": "Y cuando entran a trabajar, peor.", "speaker": null}, {"start": 30.0, "end": 32.46, "text": "Y dependiendo de donde trabajes, mucho peor.", "speaker": null}, {"start": 36.78, "end": 38.3, "text": "Vamos a hablar un poquito de esto,", "speaker": null}, {"start": 38.44, "end": 39.48, "text": "pero les interesa el mundo.", "speaker": null}, {"start": 41.0, "end": 43.26, "text": "Bueno, cuando nosotros tenemos", "speaker": null}, {"start": 43.26, "end": 48.94, "text": "distintos canales de generación de inflación,", "speaker": null}, {"start": 49.739998, "end": 53.04, "text": "o sea, podemos llegar incluso a una espiral inflación,", "speaker": null}, {"start": 53.239998, "end": 54.68, "text": "o lo que se le llama espiral inflación,", "speaker": null}, {"start": 55.78, "end": 56.92, "text": "que es el caso de México.", "speaker": null}, {"start": 57.96, "end": 58.82, "text": "Es el caso de México.", "speaker": null}, {"start": 58.82, "end": 61.16, "text": "si nosotros hablábamos de inflación", "speaker": null}, {"start": 61.16, "end": 64.32, "text": "y estuviéramos a lo mejor en los Estados Unidos", "speaker": null}, {"start": 64.32, "end": 68.32, "text": "ahí nos obteníamos las preguntas de la inflación", "speaker": null}, {"start": 68.32, "end": 72.479996, "text": "de hecho cuando yo les recomendé algunas bibliografías", "speaker": null}, {"start": 72.479996, "end": 75.7, "text": "les dije, pueden checar la bibliografía en el programa de estudio", "speaker": null}, {"start": 75.7, "end": 79.64, "text": "y ahí ustedes se van a encontrar autores muy buenos, brillantes", "speaker": null}, {"start": 79.64, "end": 85.4, "text": "como es el texto de finanzas corporativas de Cross", "speaker": null}, {"start": 85.4, "end": 95.700005, "text": "como es el texto de finanzas corporativas de Weston, como es el texto de finanzas corporativas de Copenaghen", "speaker": null}, {"start": 95.700005, "end": 102.74, "text": "y hace sucesivamente. Es decir, son excelentes libros, pero aguas con eso.", "speaker": null}, {"start": 103.8, "end": 109.44, "text": "¿Por qué? Porque esos textos son traducciones norteamericanas.", "speaker": null}, {"start": 109.44, "end": 112.1, "text": "y en los casos", "speaker": null}, {"start": 112.1, "end": 113.95999, "text": "en los ejercicios", "speaker": null}, {"start": 113.95999, "end": 115.74, "text": "en los ejemplos", "speaker": null}, {"start": 115.74, "end": 118.17999, "text": "están muy bien desarrollados", "speaker": null}, {"start": 118.17999, "end": 119.71999, "text": "nada más que el tema", "speaker": null}, {"start": 119.71999, "end": 122.27999, "text": "que en la Unión", "speaker": null}, {"start": 122.27999, "end": 123.939995, "text": "Americana ellos no consideran", "speaker": null}, {"start": 123.939995, "end": 124.67999, "text": "la inflación", "speaker": null}, {"start": 124.67999, "end": 127.74, "text": "porque los niveles de inflación", "speaker": null}, {"start": 127.74, "end": 129.7, "text": "en Estados Unidos son muy bajos", "speaker": null}, {"start": 129.7, "end": 132.12, "text": "ellos no se preocupan", "speaker": null}, {"start": 132.12, "end": 133.5, "text": "por eso", "speaker": null}, {"start": 133.5, "end": 135.56, "text": "pero en México", "speaker": null}, {"start": 135.56, "end": 137.87999, "text": "en México tenemos", "speaker": null}, {"start": 137.87999, "end": 140.62, "text": "una variante constante de inflación.", "speaker": null}, {"start": 141.55998, "end": 144.07999, "text": "De hecho, si ustedes tienen la mala costumbre, como yo,", "speaker": null}, {"start": 144.62, "end": 146.93999, "text": "de escuchar las noticias todos los días,", "speaker": null}, {"start": 148.15999, "end": 152.31999, "text": "se van a dar cuenta que los canales financieros", "speaker": null}, {"start": 152.31999, "end": 156.43999, "text": "constantemente nos están indicando el comportamiento", "speaker": null}, {"start": 156.43999, "end": 160.51999, "text": "de los bienes y servicios, de los productos.", "speaker": null}, {"start": 162.95999, "end": 166.34, "text": "A lo mejor a ustedes les vale el ahorro si sube el precio del aguacate,", "speaker": null}, {"start": 166.34, "end": 169.04, "text": "ustedes dirán", "speaker": null}, {"start": 169.04, "end": 171.2, "text": "mi t-shirt es una de las", "speaker": null}, {"start": 171.2, "end": 173.01999, "text": "mil y un cosas que a mi me vale", "speaker": null}, {"start": 173.01999, "end": 173.51999, "text": "borro", "speaker": null}, {"start": 173.51999, "end": 176.04, "text": "porque yo en mi dieta", "speaker": null}, {"start": 176.04, "end": 179.12, "text": "no tengo aguacate", "speaker": null}, {"start": 179.12, "end": 181.12, "text": "felicidades", "speaker": null}, {"start": 181.12, "end": 181.73999, "text": "cabrón", "speaker": null}, {"start": 181.73999, "end": 183.59999, "text": "pero que crees", "speaker": null}, {"start": 183.59999, "end": 187.08, "text": "en los índices nacionales", "speaker": null}, {"start": 187.68, "end": 188.95999, "text": "lo que menos", "speaker": null}, {"start": 188.95999, "end": 190.22, "text": "me preocupa", "speaker": null}, {"start": 190.22, "end": 193.06, "text": "es si tu comes o no comes aguacate", "speaker": null}, {"start": 193.06, "end": 195.12, "text": "porque es un", "speaker": null}, {"start": 195.12, "end": 206.4, "text": "producto que a nivel general sí se considera como qué? Canasta básica. Yo he escuchado", "speaker": null}, {"start": 206.4, "end": 212.93999, "text": "muchas veces ese término. De momento vamos a ocupar la canasta básica, de momento, porque", "speaker": null}, {"start": 212.93999, "end": 219.06, "text": "sí lo he escuchado mucho, y lo peor del caso es que aquí en la facultad. Pero en las noticias", "speaker": null}, {"start": 219.06, "end": 231.438, "text": "es que es parte de la canasta b s S Si yo les preguntara a ustedes consideran como canasta b", "speaker": null}, {"start": 231.97801, "end": 233.738, "text": "¿Qué tendríamos en la canasta básica?", "speaker": null}, {"start": 234.298, "end": 234.97801, "text": "Tortillos.", "speaker": null}, {"start": 235.25801, "end": 235.878, "text": "Tortillos.", "speaker": null}, {"start": 235.998, "end": 236.89801, "text": "Frijoles y huevo.", "speaker": null}, {"start": 237.078, "end": 238.098, "text": "Frijoles, huevo.", "speaker": null}, {"start": 238.39801, "end": 238.938, "text": "Aceite.", "speaker": null}, {"start": 239.238, "end": 239.81801, "text": "Aceite.", "speaker": null}, {"start": 240.25801, "end": 244.25801, "text": "Leche, carne, huevo, chocomil.", "speaker": null}, {"start": 244.858, "end": 245.03801, "text": "¿No?", "speaker": null}, {"start": 245.998, "end": 246.278, "text": "¿Sí?", "speaker": null}, {"start": 246.278, "end": 246.33801, "text": "¿Sí?", "speaker": null}, {"start": 247.158, "end": 249.67801, "text": "¿Sí les parece que sea parte de la canasta básica?", "speaker": null}, {"start": 250.018, "end": 253.61801, "text": "¿Será parte de lo que los mexicanos consumen?", "speaker": null}, {"start": 254.878, "end": 255.698, "text": "Claro que sí.", "speaker": null}, {"start": 256.918, "end": 258.798, "text": "¿A poco hay mexicanos que no consumen tortillas?", "speaker": null}, {"start": 260.478, "end": 263.098, "text": "Todos los mexicanos consumen tortillas.", "speaker": null}, {"start": 263.698, "end": 266.318, "text": "De hecho es lo que está de moda ahorita en el mundial con los tacos.", "speaker": null}, {"start": 268.138, "end": 272.618, "text": "¿Se han visto cómo entrevistan a los gabachundos, a los extranjeros?", "speaker": null}, {"start": 273.758, "end": 276.15802, "text": "Ahorita todos los noticieros están de moda.", "speaker": null}, {"start": 276.15802, "end": 282.618, "text": "entrevistando a la gente, oye, ¿qué le gusta a mí de la comida mexicana?", "speaker": null}, {"start": 283.99802, "end": 284.518, "text": "¿Los tacos?", "speaker": null}, {"start": 284.518, "end": 284.71802, "text": "¿Los tacos?", "speaker": null}, {"start": 287.898, "end": 289.538, "text": "Está bien, está bien.", "speaker": null}, {"start": 291.238, "end": 294.138, "text": "El huevo será importante para la comida mexicana.", "speaker": null}, {"start": 295.758, "end": 298.65802, "text": "¿Por qué no los frijoles y el arroz?", "speaker": null}, {"start": 298.65802, "end": 306.238, "text": "¿Por qué son los productos de mayor consumo, con usos y costumbres?", "speaker": null}, {"start": 306.898, "end": 312.618, "text": "Y aparte de usos y costumbres, por dinero, el costo del dinero.", "speaker": null}, {"start": 314.078, "end": 319.858, "text": "Pero entonces ahí tendríamos que involucrar los productos que me acabas de señalar acá,", "speaker": null}, {"start": 320.498, "end": 322.418, "text": "leche, carne, huevo, chocorri.", "speaker": null}, {"start": 322.418, "end": 327.458, "text": "hay que hablar de lo que se considera", "speaker": null}, {"start": 327.458, "end": 328.698, "text": "un sacrosagra paz", "speaker": null}, {"start": 328.698, "end": 332.398, "text": "pero entonces yo tengo una duda", "speaker": null}, {"start": 332.398, "end": 335.378, "text": "y así se las voy a poner", "speaker": null}, {"start": 335.378, "end": 339.458, "text": "no tenía yo pensado", "speaker": null}, {"start": 339.458, "end": 341.138, "text": "que íbamos a tocar el escondido", "speaker": null}, {"start": 341.138, "end": 342.438, "text": "y no vengo a armar", "speaker": null}, {"start": 342.438, "end": 343.958, "text": "no lo he tenido que hacer", "speaker": null}, {"start": 343.958, "end": 344.878, "text": "no lo preparé", "speaker": null}, {"start": 344.878, "end": 348.938, "text": "pero si ustedes me hablan de paz", "speaker": null}, {"start": 348.938, "end": 351.758, "text": "por ejemplo", "speaker": null}, {"start": 351.758, "end": 361.758, "text": "y eso es una vida real, ya se dieron cuenta. Yo podría decir que igual que todos, igual", "speaker": null}, {"start": 361.758, "end": 368.758, "text": "que todos los mexicanos, igual que todos los humanos, yo tengo algunas debilidades, algunas", "speaker": null}, {"start": 368.758, "end": 381.938, "text": "de moda la palabra", "speaker": null}, {"start": 381.938, "end": 384.958, "text": "para que", "speaker": null}, {"start": 384.958, "end": 389.698, "text": "me creerías que esto es indispensable", "speaker": null}, {"start": 389.698, "end": 390.198, "text": "para mí", "speaker": null}, {"start": 390.198, "end": 395.698, "text": "me creerías que esto es indispensable para mí", "speaker": null}, {"start": 395.698, "end": 398.998, "text": "Mike, ¿me creerías que esto es indispensable?", "speaker": null}, {"start": 399.55798, "end": 401.498, "text": "Si no me crees", "speaker": null}, {"start": 401.498, "end": 404.938, "text": "Yo vengo bien armado", "speaker": null}, {"start": 404.938, "end": 407.938, "text": "9 cintos", "speaker": null}, {"start": 407.938, "end": 411.478, "text": "Mi vida te invito a que vayas a mi coche", "speaker": null}, {"start": 411.478, "end": 414.998, "text": "Y vas a ver que ahí vengo los refuerzos", "speaker": null}, {"start": 414.998, "end": 417.318, "text": "A mí me quitas esto", "speaker": null}, {"start": 417.318, "end": 421.23798, "text": "Y yo salgo disparado y me pego en el escape de mi coche", "speaker": null}, {"start": 421.23798, "end": 424.538, "text": "Yo necesito oxigenar mi CP", "speaker": null}, {"start": 424.538, "end": 427.318, "text": "si CPU no es", "speaker": null}, {"start": 427.318, "end": 427.79797, "text": "tradicional", "speaker": null}, {"start": 427.79797, "end": 430.29797, "text": "no funciona", "speaker": null}, {"start": 430.29797, "end": 432.838, "text": "y aunque me pongan rata", "speaker": null}, {"start": 432.838, "end": 433.29797, "text": "así", "speaker": null}, {"start": 433.29797, "end": 435.858, "text": "infinidad de", "speaker": null}, {"start": 435.858, "end": 437.778, "text": "eslódax", "speaker": null}, {"start": 437.778, "end": 442.038, "text": "para mí esto es indispensable", "speaker": null}, {"start": 442.038, "end": 443.198, "text": "no necesario", "speaker": null}, {"start": 443.198, "end": 452.556, "text": "es indispensable para m esto debe de estar en la canasta m", "speaker": null}, {"start": 456.436, "end": 457.656, "text": "¿Tú qué opinas, Mario?", "speaker": null}, {"start": 462.536, "end": 470.07602, "text": "Chance y nada más. Y por qué chance? Yo sé que tú eres deportable, eres deportista.", "speaker": null}, {"start": 470.07602, "end": 472.216, "text": "a lo mejor para ti", "speaker": null}, {"start": 472.216, "end": 474.29602, "text": "pero igual que yo", "speaker": null}, {"start": 474.29602, "end": 476.256, "text": "a lo mejor allá afuera hay más gente que también", "speaker": null}, {"start": 476.256, "end": 476.95602, "text": "yo no sé qué", "speaker": null}, {"start": 476.95602, "end": 480.11603, "text": "tú Charlie", "speaker": null}, {"start": 480.11603, "end": 480.776, "text": "¿qué opinas?", "speaker": null}, {"start": 481.13602, "end": 483.656, "text": "para mí esto debería estar en la canastrona", "speaker": null}, {"start": 483.656, "end": 486.57602, "text": "soy capaz de salir ahorita y dormir firmas", "speaker": null}, {"start": 486.57602, "end": 488.436, "text": "allá afuera a ver cuántos somos los que sí", "speaker": null}, {"start": 488.436, "end": 489.376, "text": "cuántos somos los que no", "speaker": null}, {"start": 489.376, "end": 492.29602, "text": "creo que es como un tipo de producto", "speaker": null}, {"start": 492.29602, "end": 495.216, "text": "que no le afecta", "speaker": null}, {"start": 495.216, "end": 496.876, "text": "cuando su depresión", "speaker": null}, {"start": 496.876, "end": 497.67603, "text": "es como que si si", "speaker": null}, {"start": 497.67603, "end": 500.056, "text": "tiene un término", "speaker": null}, {"start": 500.056, "end": 506.056, "text": "O sea que es este... que la demanda es invariable del precio, aunque eso vale 100%", "speaker": null}, {"start": 506.056, "end": 515.056, "text": "Porque se llama vicio. Pero yo hablé de, no de precio, yo hablé de que sea necesario.", "speaker": null}, {"start": 515.056, "end": 522.056, "text": "Y yo lo exagere porque dije no es necesario, es indispensable.", "speaker": null}, {"start": 522.056, "end": 524.956, "text": "podemos", "speaker": null}, {"start": 524.956, "end": 526.296, "text": "me apoyarían a meter", "speaker": null}, {"start": 526.296, "end": 528.596, "text": "un documento", "speaker": null}, {"start": 528.596, "end": 530.49603, "text": "para", "speaker": null}, {"start": 530.49603, "end": 533.43604, "text": "que se regule", "speaker": null}, {"start": 533.43604, "end": 535.836, "text": "no", "speaker": null}, {"start": 535.836, "end": 538.376, "text": "todos ustedes son sanos", "speaker": null}, {"start": 538.376, "end": 540.93604, "text": "deportistas", "speaker": null}, {"start": 540.93604, "end": 542.536, "text": "si", "speaker": null}, {"start": 542.536, "end": 545.43604, "text": "lo puedo entender", "speaker": null}, {"start": 545.43604, "end": 546.776, "text": "lo puedo entender", "speaker": null}, {"start": 546.776, "end": 549.356, "text": "usted lo dijo bien claro", "speaker": null}, {"start": 549.356, "end": 550.49603, "text": "para usted si", "speaker": null}, {"start": 550.49603, "end": 553.31604, "text": "para mí no", "speaker": null}, {"start": 553.31604, "end": 557.556, "text": "yo lo podría entender", "speaker": null}, {"start": 557.556, "end": 560.756, "text": "¿no me apoyarías?", "speaker": null}, {"start": 562.476, "end": 562.836, "text": "tampoco", "speaker": null}, {"start": 562.836, "end": 569.036, "text": "pues estamos en derecho", "speaker": null}, {"start": 569.036, "end": 571.336, "text": "yo no lo podría obligar", "speaker": null}, {"start": 573.336, "end": 574.536, "text": "más sin embargo", "speaker": null}, {"start": 574.536, "end": 577.31604, "text": "les tengo una mano", "speaker": null}, {"start": 577.31604, "end": 578.096, "text": "que para decir de la", "speaker": null}, {"start": 580.536, "end": 581.396, "text": "qué pasa", "speaker": null}, {"start": 598.276, "end": 599.076, "text": "d", "speaker": null}, {"start": 599.076, "end": 601.396, "text": "¿Qué?", "speaker": null}, {"start": 602.81604, "end": 606.016, "text": "Pues la última, este desgraciado, me la recuerdo al carnaval.", "speaker": null}, {"start": 606.236, "end": 608.636, "text": "Me fui de agua, que todo se me estiraba después.", "speaker": null}, {"start": 609.81604, "end": 610.236, "text": "Sí, ¿no?", "speaker": null}, {"start": 610.336, "end": 612.076, "text": "Pues sería la...", "speaker": null}, {"start": 612.076, "end": 614.276, "text": "la última más agonónica.", "speaker": null}, {"start": 615.476, "end": 616.456, "text": "¿O no, mi chavo?", "speaker": null}, {"start": 617.536, "end": 618.19604, "text": "Pues sí.", "speaker": null}, {"start": 622.49603, "end": 625.036, "text": "Pues yo lo primero que me preguntaría a mí mismo,", "speaker": null}, {"start": 625.036, "end": 632.336, "text": "mi mismo, estos chavos de verdad saben que no están pagados, mi mismo me va a contestar,", "speaker": null}, {"start": 632.93604, "end": 639.19604, "text": "me tengo que ir. Lo primero que yo les preguntaría a los jóvenes, ¿quién de buenos les dijo", "speaker": null}, {"start": 639.19604, "end": 648.856, "text": "que alguien me canasta? Yo sé que hay mucha gente que se los dijo hasta acá, mi siguiente", "speaker": null}, {"start": 648.856, "end": 652.896, "text": "La siguiente pregunta es, si en sí los dirige de verdad, ¿es un profesor expresado de la", "speaker": null}, {"start": 652.896, "end": 653.536, "text": "cuesta humana?", "speaker": null}, {"start": 656.19604, "end": 657.49603, "text": "Yo como...", "speaker": null}, {"start": 657.49603, "end": 659.556, "text": "Si es que es como muy amigo también.", "speaker": null}, {"start": 659.836, "end": 662.856, "text": "Yo como contador, como contador.", "speaker": null}, {"start": 665.016, "end": 666.356, "text": "¿Y por qué como contador?", "speaker": null}, {"start": 666.536, "end": 683.094, "text": "Pues porque las palabras de mi profesi me exigen que cuando yo abra la boca tengo que juntar y cultivar todo lo que yo digo Y eso se lo sepa a los amigos todav A unos m se pueden enga", "speaker": null}, {"start": 683.094, "end": 686.234, "text": "y a unos médicos se pueden equivocar.", "speaker": null}, {"start": 687.474, "end": 690.334, "text": "¿Por qué? Pues me estoy viendo un caso extremo, un médico.", "speaker": null}, {"start": 691.774, "end": 694.854, "text": "¿Por qué? Pues porque los médicos entierran sus errores, caro.", "speaker": null}, {"start": 696.45404, "end": 698.89404, "text": "Pues lo peor que puede pasar es me echar el volamiento,", "speaker": null}, {"start": 698.89404, "end": 702.89404, "text": "pero su paciente no resistió.", "speaker": null}, {"start": 703.674, "end": 705.45404, "text": "Aunque le haya cajeteado el médico,", "speaker": null}, {"start": 705.714, "end": 708.27405, "text": "por eso hablamos de que ahora se fincan responsabilidades.", "speaker": null}, {"start": 709.07404, "end": 709.674, "text": "Es correcto.", "speaker": null}, {"start": 709.874, "end": 711.19403, "text": "Hoy demandan a los médicos.", "speaker": null}, {"start": 712.034, "end": 714.57404, "text": "Hoy cuando tú vas a un hospital o a una clínica,", "speaker": null}, {"start": 714.654, "end": 716.07404, "text": "lo primero que hacen es que te firmen,", "speaker": null}, {"start": 716.19403, "end": 717.714, "text": "que firmes tu responsiva.", "speaker": null}, {"start": 719.654, "end": 722.234, "text": "Y los médicos te hacen firmar infinidad de cosas.", "speaker": null}, {"start": 722.374, "end": 722.654, "text": "¿Para qué?", "speaker": null}, {"start": 723.474, "end": 724.89404, "text": "Para evitar la responsabilidad.", "speaker": null}, {"start": 726.114, "end": 726.674, "text": "¿O no es cierto?", "speaker": null}, {"start": 726.674, "end": 728.254, "text": "¿No les ha tocado verlo?", "speaker": null}, {"start": 728.89404, "end": 731.814, "text": "pero que crees los votadores", "speaker": null}, {"start": 731.814, "end": 733.95404, "text": "se nos dice todo lo vemos en números", "speaker": null}, {"start": 733.95404, "end": 735.19403, "text": "todo lo calculamos", "speaker": null}, {"start": 735.19403, "end": 736.914, "text": "todo lo vemos lo que me cuesta", "speaker": null}, {"start": 736.914, "end": 739.354, "text": "todo lo vemos a un invierto", "speaker": null}, {"start": 739.354, "end": 741.154, "text": "todo lo vemos en números", "speaker": null}, {"start": 741.154, "end": 743.874, "text": "todo lo cuantificamos en tu vida", "speaker": null}, {"start": 743.874, "end": 744.714, "text": "todo", "speaker": null}, {"start": 744.714, "end": 748.234, "text": "hasta las viejas", "speaker": null}, {"start": 748.234, "end": 749.07404, "text": "si tú me preguntas", "speaker": null}, {"start": 749.07404, "end": 752.63403, "text": "los tabacos que otro día se vienen", "speaker": null}, {"start": 752.63403, "end": 753.814, "text": "no te lo podría decir", "speaker": null}, {"start": 753.814, "end": 754.874, "text": "pero ya te imaginarás", "speaker": null}, {"start": 754.874, "end": 758.51404, "text": "yo cuando veo faldas", "speaker": null}, {"start": 758.51404, "end": 761.034, "text": "como cualquier persona", "speaker": null}, {"start": 761.034, "end": 762.714, "text": "vigoreta y sólica", "speaker": null}, {"start": 762.714, "end": 764.89404, "text": "oh papá", "speaker": null}, {"start": 764.89404, "end": 766.154, "text": "pégale al perro", "speaker": null}, {"start": 766.154, "end": 768.974, "text": "pero mi subconsciente", "speaker": null}, {"start": 768.974, "end": 770.19403, "text": "profesional dice espérate", "speaker": null}, {"start": 770.19403, "end": 771.354, "text": "espérate", "speaker": null}, {"start": 771.354, "end": 774.834, "text": "cuánto te va a costar este vicio", "speaker": null}, {"start": 774.834, "end": 778.094, "text": "pues empiezo a sacar", "speaker": null}, {"start": 778.094, "end": 778.594, "text": "no, no, no, no", "speaker": null}, {"start": 778.594, "end": 781.554, "text": "mejor me compro un carro", "speaker": null}, {"start": 781.554, "end": 784.19403, "text": "y no la mantengo", "speaker": null}, {"start": 784.19403, "end": 787.57404, "text": "a lo mejor el chaco dice", "speaker": null}, {"start": 787.57404, "end": 789.334, "text": "no, yo siempre quiero con la ley.", "speaker": null}, {"start": 790.414, "end": 791.114, "text": "No, muchas veces.", "speaker": null}, {"start": 791.354, "end": 791.594, "text": "Claro.", "speaker": null}, {"start": 792.374, "end": 793.034, "text": "Por supuesto.", "speaker": null}, {"start": 794.01404, "end": 795.554, "text": "El señor es informático,", "speaker": null}, {"start": 795.69403, "end": 796.414, "text": "no es un contador.", "speaker": null}, {"start": 798.054, "end": 799.234, "text": "Se observa la diferencia.", "speaker": null}, {"start": 800.77405, "end": 802.01404, "text": "Pero no debemos aquí", "speaker": null}, {"start": 802.01404, "end": 803.01404, "text": "hablar de profesiones.", "speaker": null}, {"start": 803.474, "end": 805.074, "text": "Dijimos que tanto usted como yo", "speaker": null}, {"start": 805.074, "end": 808.734, "text": "estaríamos obligados a hacerlo", "speaker": null}, {"start": 808.734, "end": 812.51404, "text": "el amor mamado.", "speaker": null}, {"start": 812.51404, "end": 824.214, "text": "Vamos a ver qué dice la luz. Repito, hasta donde yo sé, hasta donde yo sé.", "speaker": null}, {"start": 825.89404, "end": 831.314, "text": "Que no se les va a desacar que hay una canasta. ¿Cuántos productos podrán entrar en la canasta?", "speaker": null}, {"start": 832.534, "end": 833.89404, "text": "Está muy grande, unos 20.", "speaker": null}, {"start": 834.434, "end": 837.714, "text": "20 productos. ¿Tú cuáles crees, Michael?", "speaker": null}, {"start": 837.714, "end": 839.714, "text": "¿Cuánto?", "speaker": null}, {"start": 867.714, "end": 871.874, "text": "y que ese algo", "speaker": null}, {"start": 871.874, "end": 873.554, "text": "son reglamentos", "speaker": null}, {"start": 873.554, "end": 874.934, "text": "¿verdad?", "speaker": null}, {"start": 875.614, "end": 876.63403, "text": "son leyes", "speaker": null}, {"start": 876.63403, "end": 879.434, "text": "son disposiciones legales", "speaker": null}, {"start": 879.434, "end": 881.254, "text": "¿sí?", "speaker": null}, {"start": 882.654, "end": 883.954, "text": "y yo les puedo demostrar", "speaker": null}, {"start": 883.954, "end": 884.654, "text": "que incluso", "speaker": null}, {"start": 884.654, "end": 890.414, "text": "la persona más", "speaker": null}, {"start": 890.414, "end": 892.574, "text": "intelectual", "speaker": null}, {"start": 892.574, "end": 894.13403, "text": "o la persona más ignorante", "speaker": null}, {"start": 894.13403, "end": 894.894, "text": "está obligada", "speaker": null}, {"start": 894.894, "end": 897.114, "text": "a comer con otro material", "speaker": null}, {"start": 897.114, "end": 899.474, "text": "por eso les preguntaba", "speaker": null}]