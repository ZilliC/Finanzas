[{"start": 0.0, "end": 1.6, "text": "No hay.", "speaker": null}, {"start": 6.16, "end": 7.6, "text": "No hay.", "speaker": null}, {"start": 11.68, "end": 12.84, "text": "No.", "speaker": null}, {"start": 15.26, "end": 19.76, "text": "Vamos a tener que continuar.", "speaker": null}, {"start": 21.04, "end": 24.82, "text": "Y aquí vamos a empezar a utilizar parte de esto.", "speaker": null}, {"start": 24.82, "end": 28.68, "text": "y digo parte de esto porque", "speaker": null}, {"start": 28.68, "end": 30.74, "text": "hasta ahorita", "speaker": null}, {"start": 30.74, "end": 34.28, "text": "según lo que estaba viendo en la correa", "speaker": null}, {"start": 34.28, "end": 35.78, "text": "o sea en el teléfono", "speaker": null}, {"start": 42.78, "end": 43.96, "text": "¿estamos regresando?", "speaker": null}, {"start": 45.04, "end": 46.4, "text": "¿en qué nos quedamos?", "speaker": null}, {"start": 46.8, "end": 47.24, "text": "¿ahí?", "speaker": null}, {"start": 49.34, "end": 50.46, "text": "¿es correcto?", "speaker": null}, {"start": 51.82, "end": 52.42, "text": "¿sí, muchacho?", "speaker": null}, {"start": 53.38, "end": 54.7, "text": "¿aquí nos quedamos también?", "speaker": null}, {"start": 54.82, "end": 58.14, "text": "y según me acuerdo", "speaker": null}, {"start": 58.14, "end": 61.06, "text": "ayer vimos hasta el I", "speaker": null}, {"start": 61.06, "end": 63.74, "text": "¿si?", "speaker": null}, {"start": 64.94, "end": 65.52, "text": "o no", "speaker": null}, {"start": 65.52, "end": 67.86, "text": "si me acordeo", "speaker": null}, {"start": 67.86, "end": 70.9, "text": "no me da, hasta ahí llegamos", "speaker": null}, {"start": 70.9, "end": 75.58, "text": "entonces el día de hoy vamos a distraernos", "speaker": null}, {"start": 75.58, "end": 76.34, "text": "un poco más", "speaker": null}, {"start": 76.34, "end": 78.92, "text": "para empezar a analizar", "speaker": null}, {"start": 78.92, "end": 80.68, "text": "otro tipo de", "speaker": null}, {"start": 80.68, "end": 84.84, "text": "de razones", "speaker": null}, {"start": 84.84, "end": 89.2, "text": "para poder seguir aplicando estos métodos", "speaker": null}, {"start": 89.2, "end": 91.12, "text": "porque estos métodos", "speaker": null}, {"start": 91.12, "end": 93.06, "text": "no se conforman nada más", "speaker": null}, {"start": 93.06, "end": 93.86, "text": "con verificar", "speaker": null}, {"start": 93.86, "end": 97.58, "text": "las cuentas de balance", "speaker": null}, {"start": 97.58, "end": 99.4, "text": "nosotros hasta ahorita", "speaker": null}, {"start": 99.4, "end": 100.78, "text": "muchachos se habrán dado cuenta", "speaker": null}, {"start": 100.78, "end": 102.74, "text": "que hemos venido trabajando", "speaker": null}, {"start": 102.74, "end": 104.36, "text": "con cuentas de balance", "speaker": null}, {"start": 104.36, "end": 106.06, "text": "correcto", "speaker": null}, {"start": 106.06, "end": 107.96, "text": "es decir", "speaker": null}, {"start": 107.96, "end": 110.94, "text": "hasta ahorita", "speaker": null}, {"start": 110.94, "end": 113.64, "text": "hemos ocupado", "speaker": null}, {"start": 113.64, "end": 117.82, "text": "algo de esto", "speaker": null}, {"start": 117.82, "end": 119.7, "text": "no sé", "speaker": null}, {"start": 119.7, "end": 121.38, "text": "sea cual sea la estructura", "speaker": null}, {"start": 121.38, "end": 123.62, "text": "estamos ocupando", "speaker": null}, {"start": 123.62, "end": 125.76, "text": "cuentas de activo, cuentas de pasivo", "speaker": null}, {"start": 125.76, "end": 127.58, "text": "y cuentas de capital montado", "speaker": null}, {"start": 127.58, "end": 130.36, "text": "¿cuáles las detenga?", "speaker": null}, {"start": 131.36, "end": 132.12, "text": "de hecho si ustedes", "speaker": null}, {"start": 132.12, "end": 133.84, "text": "ven, pues aquí ustedes mismos", "speaker": null}, {"start": 133.84, "end": 134.76, "text": "fueron armando", "speaker": null}, {"start": 134.76, "end": 137.14, "text": "las estructuras", "speaker": null}, {"start": 137.14, "end": 139.56, "text": "cuánto hay en cada cuenta,", "speaker": null}, {"start": 140.56, "end": 141.5, "text": "que si quiero tener", "speaker": null}, {"start": 141.5, "end": 143.2, "text": "más bancos,", "speaker": null}, {"start": 143.34, "end": 145.66, "text": "aquí discutíamos que no es lo que yo quiero,", "speaker": null}, {"start": 146.66, "end": 147.18, "text": "es lo que", "speaker": null}, {"start": 147.18, "end": 150.0, "text": "las políticas", "speaker": null}, {"start": 150.0, "end": 151.4, "text": "de la empresa me exigen.", "speaker": null}, {"start": 152.4, "end": 153.06, "text": "Regreso a la idea,", "speaker": null}, {"start": 155.0, "end": 155.9, "text": "yo a lo mejor quisiera", "speaker": null}, {"start": 155.9, "end": 157.74, "text": "tener 5 millones de pesos en caja,", "speaker": null}, {"start": 159.26, "end": 160.32, "text": "porque a lo mejor yo digo,", "speaker": null}, {"start": 160.44, "end": 161.46, "text": "pues es tener la plata", "speaker": null}, {"start": 161.46, "end": 162.82, "text": "que voy al banco", "speaker": null}, {"start": 162.82, "end": 164.56, "text": "a meter y sacar dinero.", "speaker": null}, {"start": 164.56, "end": 168.28, "text": "se escucha muy sencillo pero en la vida real", "speaker": null}, {"start": 168.28, "end": 168.94, "text": "eso no funciona", "speaker": null}, {"start": 168.94, "end": 172.18, "text": "hay políticas, hay procedimientos", "speaker": null}, {"start": 172.18, "end": 173.32, "text": "hay normas", "speaker": null}, {"start": 173.32, "end": 176.04, "text": "que te dicen que yo no puedo tener", "speaker": null}, {"start": 176.04, "end": 177.26, "text": "tantísimo dinero", "speaker": null}, {"start": 177.26, "end": 179.16, "text": "disponible en la casa", "speaker": null}, {"start": 179.16, "end": 181.64, "text": "¿por qué? primera porque", "speaker": null}, {"start": 181.64, "end": 183.92, "text": "hay zonas de riesgo", "speaker": null}, {"start": 183.92, "end": 186.36, "text": "imagínate si algún amigo de lo ajeno", "speaker": null}, {"start": 186.36, "end": 188.22, "text": "se entera que", "speaker": null}, {"start": 188.22, "end": 189.46, "text": "en el negocio de charles", "speaker": null}, {"start": 189.46, "end": 192.68, "text": "siempre hay cinco millones de pesos disponibles", "speaker": null}, {"start": 192.68, "end": 194.54, "text": "¿qué podría pasar", "speaker": null}, {"start": 194.54, "end": 197.4, "text": "evidentemente es una tentación", "speaker": null}, {"start": 197.4, "end": 199.98, "text": "tanto para los malandrines", "speaker": null}, {"start": 199.98, "end": 202.02, "text": "como para los mismos sangrientos", "speaker": null}, {"start": 202.02, "end": 205.46, "text": "mucho dinero disponible", "speaker": null}, {"start": 205.46, "end": 207.38, "text": "entonces", "speaker": null}, {"start": 207.38, "end": 210.24, "text": "a lo mejor eso sería el ejemplo más sencillo", "speaker": null}, {"start": 210.24, "end": 211.72, "text": "más sencillo", "speaker": null}, {"start": 211.72, "end": 213.08, "text": "pero tenemos", "speaker": null}, {"start": 213.08, "end": 215.1, "text": "otros criterios que son", "speaker": null}, {"start": 215.1, "end": 216.94, "text": "más allá de eso", "speaker": null}, {"start": 216.94, "end": 219.34, "text": "porque a lo mejor Carlos nos va a decir", "speaker": null}, {"start": 219.34, "end": 229.998, "text": "yo no tengo bronca porque para que llegue alg malandr hasta mi empresa bueno pues a lo mejor primero tiene que pasar por la caseta de vigilancia", "speaker": null}, {"start": 231.518, "end": 232.798, "text": "y ahí tengo policías.", "speaker": null}, {"start": 234.278, "end": 238.498, "text": "Si logra pasar la caseta de vigilancia de acceso a mi empresa,", "speaker": null}, {"start": 239.778, "end": 244.67801, "text": "pues tiene que pasar todavía por los medios de control y vigilancia,", "speaker": null}, {"start": 244.67801, "end": 248.158, "text": "así como los de seguridad para accesar a mis instalaciones.", "speaker": null}, {"start": 250.018, "end": 251.778, "text": "O sea, yo también tengo policías.", "speaker": null}, {"start": 253.158, "end": 259.558, "text": "Y por si fuera poco, pues la caja la tengo hasta atrás y hasta arriba.", "speaker": null}, {"start": 261.098, "end": 265.918, "text": "Tendría que atravesar toda la empresa para poder llegar a la caja.", "speaker": null}, {"start": 268.678, "end": 274.378, "text": "Yo le diría, pensémosle usted, sus recursos los tiene bien resguardados, ¿no?", "speaker": null}, {"start": 275.378, "end": 277.938, "text": "No hay manera de que haya algún abuso.", "speaker": null}, {"start": 277.938, "end": 282.738, "text": "no hay manera de que haya algún riesgo de que se nos quite", "speaker": null}, {"start": 282.738, "end": 286.818, "text": "superamos eso, le contestamos a Charlie", "speaker": null}, {"start": 286.818, "end": 291.558, "text": "pero entonces va a llegar el área financiera", "speaker": null}, {"start": 291.558, "end": 292.698, "text": "y lo va a decir Charlie", "speaker": null}, {"start": 292.698, "end": 296.738, "text": "imagina lo que me cuesta en un común preso", "speaker": null}, {"start": 296.738, "end": 299.938, "text": "tener 5 millones de pesos", "speaker": null}, {"start": 299.938, "end": 302.638, "text": "durmiendo en tu carro fuerte", "speaker": null}, {"start": 302.638, "end": 306.058, "text": "estoy perdiendo que", "speaker": null}, {"start": 306.058, "end": 307.99802, "text": "o de la pesquisa", "speaker": null}, {"start": 307.99802, "end": 308.758, "text": "o de la...", "speaker": null}, {"start": 308.758, "end": 312.49802, "text": "No, no te creo.", "speaker": null}, {"start": 313.298, "end": 313.898, "text": "No te creo.", "speaker": null}, {"start": 315.21802, "end": 316.09802, "text": "Aquí ya habíamos", "speaker": null}, {"start": 316.09802, "end": 317.358, "text": "hablado de la inflación.", "speaker": null}, {"start": 318.758, "end": 320.138, "text": "Ya habíamos visto cómo se cae el humo.", "speaker": null}, {"start": 322.138, "end": 322.65802, "text": "No.", "speaker": null}, {"start": 323.318, "end": 326.398, "text": "No quisiera", "speaker": null}, {"start": 326.398, "end": 327.09802, "text": "entrar a eso.", "speaker": null}, {"start": 328.778, "end": 330.178, "text": "Bueno, se me ha olvidado.", "speaker": null}, {"start": 331.278, "end": 332.338, "text": "Eso no es necesario", "speaker": null}, {"start": 332.338, "end": 332.938, "text": "para ustedes.", "speaker": null}, {"start": 332.938, "end": 334.09802, "text": "No son contables.", "speaker": null}, {"start": 334.09802, "end": 336.878, "text": "si fuera contadores", "speaker": null}, {"start": 336.878, "end": 339.478, "text": "aquí lo primero con lo que le daríamos", "speaker": null}, {"start": 339.478, "end": 340.838, "text": "es una revolcada", "speaker": null}, {"start": 340.838, "end": 343.778, "text": "serían nuestros colegas contadores", "speaker": null}, {"start": 343.778, "end": 344.918, "text": "dime contadores", "speaker": null}, {"start": 344.918, "end": 346.418, "text": "¿quién te paga?", "speaker": null}, {"start": 348.15802, "end": 349.338, "text": "la pregunta", "speaker": null}, {"start": 349.338, "end": 350.638, "text": "y la pereza es la misma", "speaker": null}, {"start": 350.638, "end": 353.65802, "text": "imagínense lo que le puso", "speaker": null}, {"start": 353.65802, "end": 354.21802, "text": "a la empresa", "speaker": null}, {"start": 354.21802, "end": 355.918, "text": "que le dieron un bien", "speaker": null}, {"start": 355.918, "end": 358.098, "text": "que a él", "speaker": null}, {"start": 358.098, "end": 360.578, "text": "le dio 5 millones de pesos", "speaker": null}, {"start": 360.578, "end": 362.998, "text": "con lo que", "speaker": null}, {"start": 362.998, "end": 364.21802, "text": "yo estoy perdiendo", "speaker": null}, {"start": 364.21802, "end": 367.018, "text": "a lo mejor estoy perdiendo más", "speaker": null}, {"start": 367.018, "end": 368.458, "text": "de lo que tú ganas", "speaker": null}, {"start": 368.458, "end": 369.958, "text": "de nombre", "speaker": null}, {"start": 369.958, "end": 372.61798, "text": "lo cual implica que", "speaker": null}, {"start": 372.61798, "end": 374.65802, "text": "mejor pasa que no está el pancho", "speaker": null}, {"start": 374.65802, "end": 377.11798, "text": "en el cartelar del factor humano", "speaker": null}, {"start": 377.11798, "end": 379.078, "text": "pero que mejor pasará", "speaker": null}, {"start": 379.078, "end": 381.038, "text": "el factor humano que te liquide más", "speaker": null}, {"start": 381.038, "end": 383.258, "text": "porque no me sigues", "speaker": null}, {"start": 383.258, "end": 386.198, "text": "tú vas a decir, bueno", "speaker": null}, {"start": 386.198, "end": 388.738, "text": "¿por qué me estás diciendo eso?", "speaker": null}, {"start": 389.738, "end": 391.71802, "text": "estás violando mis derechos laborales", "speaker": null}, {"start": 392.998, "end": 409.398, "text": "Pero se los estoy llorando. Voy a sacar cuentas. En primera, si yo saco ese dinero y lo dividiera, ¿cuánto estoy dejando de ganar? Pues dependiendo la tasa de mercado.", "speaker": null}, {"start": 409.398, "end": 412.67798, "text": "dependiendo de la tasa de mercado", "speaker": null}, {"start": 412.67798, "end": 417.67798, "text": "si yo coloco un instrumento bursátil", "speaker": null}, {"start": 417.67798, "end": 421.018, "text": "vamos a pensar", "speaker": null}, {"start": 421.018, "end": 423.718, "text": "en la bolsa de valores", "speaker": null}, {"start": 423.718, "end": 425.858, "text": "porque con 5 millones de pesos", "speaker": null}, {"start": 425.858, "end": 427.778, "text": "yo ya puedo comprar algún instrumento", "speaker": null}, {"start": 427.778, "end": 428.418, "text": "estamos de acuerdo", "speaker": null}, {"start": 428.418, "end": 431.658, "text": "dime un porcentaje", "speaker": null}, {"start": 431.658, "end": 434.098, "text": "Mike, ¿qué quieres?", "speaker": null}, {"start": 434.278, "end": 434.978, "text": "de rendimiento", "speaker": null}, {"start": 434.978, "end": 436.158, "text": "¿qué es lo que te ocurre?", "speaker": null}, {"start": 436.15802, "end": 458.256, "text": "Un 16 No es bastante elevado pero pensemos pensemos que lo tomamos Si fuera fueron 16 de tasa nominal ahora t contestas es el 16 va a ser anual o mensual", "speaker": null}, {"start": 464.396, "end": 466.35602, "text": "Anual, o sea, anual.", "speaker": null}, {"start": 468.036, "end": 469.996, "text": "Si le sacamos cuentas,", "speaker": null}, {"start": 469.996, "end": 473.63602, "text": "el maestro es muy conservador.", "speaker": null}, {"start": 475.036, "end": 479.396, "text": "Vamos a pensar que esa tasa fuera anual.", "speaker": null}, {"start": 480.73602, "end": 485.156, "text": "¿A cuánto le toca la proporción del sol?", "speaker": null}, {"start": 489.156, "end": 490.436, "text": "¿Y qué es el anual?", "speaker": null}, {"start": 490.436, "end": 491.57602, "text": "¿Cómo se llama esto?", "speaker": null}, {"start": 494.936, "end": 496.476, "text": "1.3", "speaker": null}, {"start": 496.476, "end": 499.63602, "text": "1.3, ¿de acuerdo?", "speaker": null}, {"start": 501.116, "end": 503.896, "text": "De 5, entonces yo digo, ¿lo matemático es 1.5?", "speaker": null}, {"start": 505.036, "end": 511.61603, "text": "A cinco millones de pesos, dime cuánto es un segundo punto de esfuerzo.", "speaker": null}, {"start": 512.116, "end": 515.396, "text": "Voy a hablar de interés interno, no voy a hablar de interés compuesto.", "speaker": null}, {"start": 515.696, "end": 518.756, "text": "Tú sabes que el interés compuesto se capitaliza.", "speaker": null}, {"start": 520.016, "end": 521.31604, "text": "Quiere decir que es más alto.", "speaker": null}, {"start": 527.31604, "end": 528.456, "text": "¿Qué es el segundo punto?", "speaker": null}, {"start": 529.31604, "end": 530.216, "text": "¿Qué es el segundo punto?", "speaker": null}, {"start": 530.216, "end": 530.336, "text": "¿Qué es el segundo punto?", "speaker": null}, {"start": 530.336, "end": 531.856, "text": "¿Qué es el segundo punto?", "speaker": null}, {"start": 531.856, "end": 534.99603, "text": "65 mil", "speaker": null}, {"start": 534.99603, "end": 537.896, "text": "65 mil", "speaker": null}, {"start": 537.896, "end": 538.31604, "text": "pesos", "speaker": null}, {"start": 538.31604, "end": 541.636, "text": "pues tú", "speaker": null}, {"start": 541.636, "end": 543.636, "text": "multiplícalo por .013", "speaker": null}, {"start": 543.636, "end": 545.556, "text": "o no", "speaker": null}, {"start": 545.556, "end": 548.176, "text": "65 mil", "speaker": null}, {"start": 548.176, "end": 548.43604, "text": "pesos", "speaker": null}, {"start": 548.43604, "end": 551.776, "text": "tú crees que ganas 65 mil pesos", "speaker": null}, {"start": 551.776, "end": 552.696, "text": "a la quince", "speaker": null}, {"start": 552.696, "end": 554.796, "text": "a la semana", "speaker": null}, {"start": 554.796, "end": 557.196, "text": "a la decena", "speaker": null}, {"start": 557.196, "end": 559.476, "text": "como verás", "speaker": null}, {"start": 559.476, "end": 561.176, "text": "es más de lo que tú ganas", "speaker": null}, {"start": 561.176, "end": 565.276, "text": "eso es lo que tú estás haciendo que yo pierda", "speaker": null}, {"start": 565.276, "end": 568.43604, "text": "en el mejor de los casos que", "speaker": null}, {"start": 568.43604, "end": 573.31604, "text": "tú hablaste de una pasita del 16% tasa nominal anual", "speaker": null}, {"start": 573.31604, "end": 577.456, "text": "pero tú crees que yo como inversionista me voy a conformar", "speaker": null}, {"start": 577.456, "end": 579.43604, "text": "con un 1.3%", "speaker": null}, {"start": 579.43604, "end": 584.216, "text": "por supuesto que no, yo voy a invertir mi dinero", "speaker": null}, {"start": 584.216, "end": 586.916, "text": "en donde me deje mucho más que eso", "speaker": null}, {"start": 586.916, "end": 589.836, "text": "¿a poco se ha ido?", "speaker": null}, {"start": 591.176, "end": 592.776, "text": "¿En la bolsa?", "speaker": null}, {"start": 593.096, "end": 593.576, "text": "Claro.", "speaker": null}, {"start": 593.956, "end": 596.19604, "text": "Para eso hay instrumentos de renta variable.", "speaker": null}, {"start": 597.896, "end": 600.156, "text": "Esto estamos hablando de una tasa fija,", "speaker": null}, {"start": 600.836, "end": 603.616, "text": "lo cual me dice que es un instrumento de renta fija.", "speaker": null}, {"start": 604.616, "end": 605.636, "text": "¿Por qué es de renta fija?", "speaker": null}, {"start": 605.736, "end": 606.536, "text": "Porque no hay riesgo.", "speaker": null}, {"start": 607.956, "end": 611.93604, "text": "Pero sucede que si yo tengo 5 millones de pesos en una caja,", "speaker": null}, {"start": 613.136, "end": 614.876, "text": "¿cuánto dinero crees que tengo en mi banco?", "speaker": null}, {"start": 615.516, "end": 616.756, "text": "Pues otro 100.", "speaker": null}, {"start": 616.756, "end": 622.256, "text": "¿y tú crees que me voy a conformar con una inversión de renta fija?", "speaker": null}, {"start": 623.176, "end": 625.556, "text": "no, lo voy a meter en un portafolio bursátil", "speaker": null}, {"start": 625.556, "end": 630.176, "text": "en donde probablemente va a ser un ámbito de instrumentos", "speaker": null}, {"start": 630.176, "end": 633.31604, "text": "en donde va a haber una parte fija y una variable", "speaker": null}, {"start": 633.31604, "end": 636.756, "text": "y la variable, como es mayor riesgo", "speaker": null}, {"start": 636.756, "end": 638.956, "text": "la norma financiera que me dice", "speaker": null}, {"start": 638.956, "end": 642.116, "text": "la norma financiera me dice que mayor riesgo", "speaker": null}, {"start": 642.116, "end": 645.056, "text": "mayor rendimiento", "speaker": null}, {"start": 645.056, "end": 648.716, "text": "entonces ¿cuánto me hiciste perder?", "speaker": null}, {"start": 652.396, "end": 653.11597, "text": "¿cuánto?", "speaker": null}, {"start": 654.016, "end": 654.816, "text": "pues mínimo", "speaker": null}, {"start": 654.816, "end": 656.61597, "text": "la inflación", "speaker": null}, {"start": 656.61597, "end": 659.796, "text": "más lo que me hiciste perder", "speaker": null}, {"start": 659.796, "end": 662.176, "text": "por tener durmiendo", "speaker": null}, {"start": 662.176, "end": 662.756, "text": "mi dinero", "speaker": null}, {"start": 662.756, "end": 665.976, "text": "¿cuánto crees que me está costando eso?", "speaker": null}, {"start": 667.776, "end": 669.056, "text": "es algo más barato correr", "speaker": null}, {"start": 669.056, "end": 682.034, "text": "y traerle un cuarto un orej del pol que cuando menos rebusque que sepa que el dinero tiene un valor Ahora t dir qu me dices que lo hice perder", "speaker": null}, {"start": 683.01404, "end": 684.654, "text": "Me hiciste perder por los dos lados.", "speaker": null}, {"start": 685.154, "end": 688.354, "text": "Uno, repito, por inmovilizar mis recursos.", "speaker": null}, {"start": 689.934, "end": 692.554, "text": "Ese dinero lo tengo durmiendo, abajo del coche.", "speaker": null}, {"start": 693.914, "end": 698.834, "text": "Y otro, me hiciste perder por el simple transcurso del tiempo.", "speaker": null}, {"start": 700.054, "end": 708.674, "text": "No pensaba hablar de esto, pero no quiero que me lo salgan allá afuera y no usar.", "speaker": null}, {"start": 709.494, "end": 711.214, "text": "Cuando menos no por mi culpa.", "speaker": null}, {"start": 712.77405, "end": 714.27405, "text": "Han oído hablar de la inflación.", "speaker": null}, {"start": 716.19403, "end": 722.314, "text": "Que casualmente la semana pasada estas autoridades dieron el avance de la inflación.", "speaker": null}, {"start": 723.19403, "end": 724.794, "text": "¿Se acuerdan de lo que les acabamos de decir?", "speaker": null}, {"start": 724.794, "end": 734.554, "text": "y casualmente la semana pasada nos dijeron que nada más estamos arriba del 3% de inflación.", "speaker": null}, {"start": 735.474, "end": 741.994, "text": "Para mucha gente eso no tiene sentido, para mucha gente eso no tiene importancia.", "speaker": null}, {"start": 743.114, "end": 745.794, "text": "Para nosotros en el mundo no tiene sentido toda la inflación.", "speaker": null}, {"start": 747.794, "end": 752.454, "text": "¿Qué tienen ustedes, señores informáticos, por inflación? ¿Qué les han enseñado?", "speaker": null}, {"start": 752.45404, "end": 754.094, "text": "¿Qué es la reducción?", "speaker": null}, {"start": 761.474, "end": 765.594, "text": "Es la reducción del poder adquisitivo del dinero.", "speaker": null}, {"start": 766.234, "end": 768.334, "text": "Es la pérdida, no reducción.", "speaker": null}, {"start": 769.034, "end": 772.754, "text": "Es la pérdida del poder adquisitivo del dinero.", "speaker": null}, {"start": 773.89404, "end": 774.814, "text": "¿Qué quiere decir?", "speaker": null}, {"start": 774.814, "end": 777.534, "text": "Que si hay un nivel de inflación,", "speaker": null}, {"start": 778.294, "end": 780.874, "text": "tengo un pequeño problema.", "speaker": null}, {"start": 780.874, "end": 785.214, "text": "la inflación me puede llegar a generar", "speaker": null}, {"start": 785.214, "end": 789.794, "text": "que mi dinero pierda poder adquisitivo.", "speaker": null}, {"start": 791.13403, "end": 792.654, "text": "¿A qué nos referimos con eso?", "speaker": null}, {"start": 794.174, "end": 798.01404, "text": "A que hay, obviamente, mecanismos que nos llevan", "speaker": null}, {"start": 798.01404, "end": 800.174, "text": "a que se genere inflación.", "speaker": null}, {"start": 801.594, "end": 804.454, "text": "A ustedes, quiero conocer sus materias,", "speaker": null}, {"start": 804.454, "end": 805.57404, "text": "la que hayan tomado,", "speaker": null}, {"start": 805.874, "end": 807.494, "text": "explicado la inflación,", "speaker": null}, {"start": 807.63403, "end": 809.27405, "text": "porque la fuerza de esta caída es tan difícil", "speaker": null}, {"start": 809.27405, "end": 810.934, "text": "si las horas se vienen a ver explicadas.", "speaker": null}, {"start": 812.734, "end": 814.594, "text": "Mi charla, yo le apuesto lo que quiera que sea.", "speaker": null}, {"start": 814.834, "end": 815.77405, "text": "No, no, no.", "speaker": null}, {"start": 815.77405, "end": 816.174, "text": "¿Vale?", "speaker": null}, {"start": 817.474, "end": 817.69403, "text": "No.", "speaker": null}, {"start": 818.054, "end": 818.39404, "text": "Nada.", "speaker": null}, {"start": 818.734, "end": 819.094, "text": "¿Nada?", "speaker": null}, {"start": 819.934, "end": 821.614, "text": "De lo que sea es por mi cuenta, creo.", "speaker": null}, {"start": 822.534, "end": 824.934, "text": "Ok, habrás escuchado por tu cuenta", "speaker": null}, {"start": 824.934, "end": 827.494, "text": "que por ahí nos dicen", "speaker": null}, {"start": 827.494, "end": 830.69403, "text": "que cuando hay ejemplos,", "speaker": null}, {"start": 832.19403, "end": 834.734, "text": "un exceso de dinero en circulación,", "speaker": null}, {"start": 834.994, "end": 836.13403, "text": "ejemplo, provocación.", "speaker": null}, {"start": 837.19403, "end": 838.07404, "text": "Es correcto.", "speaker": null}, {"start": 838.07404, "end": 840.174, "text": "de ahí que existe", "speaker": null}, {"start": 840.174, "end": 841.654, "text": "y yo les pregunté", "speaker": null}, {"start": 841.654, "end": 842.834, "text": "en las clases", "speaker": null}, {"start": 842.834, "end": 844.734, "text": "de la semana pasada", "speaker": null}, {"start": 844.734, "end": 847.834, "text": "que a mi me extrañaba", "speaker": null}, {"start": 847.834, "end": 849.734, "text": "porque les cambiaron mi programa", "speaker": null}, {"start": 849.734, "end": 851.754, "text": "se acuerdan que les", "speaker": null}, {"start": 851.754, "end": 854.554, "text": "hablé y te oí en este grupo", "speaker": null}, {"start": 854.554, "end": 856.354, "text": "porque tengo", "speaker": null}, {"start": 856.354, "end": 857.334, "text": "otro grupo de", "speaker": null}, {"start": 857.334, "end": 859.874, "text": "negocios internacionales", "speaker": null}, {"start": 859.874, "end": 861.554, "text": "donde también tengo informático", "speaker": null}, {"start": 861.554, "end": 866.51404, "text": "hasta les enseñé", "speaker": null}, {"start": 866.51404, "end": 873.51404, "text": "en el otro programa, aunque no es en el estudio universitario, también tocan los dos de ustedes,", "speaker": null}, {"start": 874.354, "end": 879.914, "text": "unos más, unos menos, otros con otro nombre más coqueto, otros más sobrios, así donde", "speaker": null}, {"start": 879.914, "end": 885.614, "text": "directamente se les toca, tienes que saberlo. Pero en el caso de ustedes, les mostré incluso", "speaker": null}, {"start": 885.614, "end": 890.974, "text": "el programa anterior en donde a ustedes se les daba el sistema de medicina. ¿Se acuerdan", "speaker": null}, {"start": 890.974, "end": 891.974, "text": "que les platique de eso.", "speaker": null}, {"start": 892.534, "end": 894.734, "text": "Bueno, pues precisamente", "speaker": null}, {"start": 894.734, "end": 896.834, "text": "por eso es importante. Para mí me extraña", "speaker": null}, {"start": 896.834, "end": 898.314, "text": "que se los haya quitado a ustedes.", "speaker": null}]