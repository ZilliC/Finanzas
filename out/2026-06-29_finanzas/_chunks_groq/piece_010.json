: 558.016, "text": "que bueno", "speaker": null}, {"start": 558.016, "end": 559.776, "text": "oye pero si es al revés", "speaker": null}, {"start": 559.776, "end": 563.93604, "text": "si es al revés que sucedería", "speaker": null}, {"start": 563.93604, "end": 566.296, "text": "ejemplo que yo les de crédito", "speaker": null}, {"start": 566.296, "end": 567.156, "text": "por 30 días", "speaker": null}, {"start": 567.156, "end": 570.336, "text": "y la realidad es que yo estoy", "speaker": null}, {"start": 570.336, "end": 571.916, "text": "cobrando cada 60", "speaker": null}, {"start": 571.916, "end": 574.216, "text": "que está pasando ahí", "speaker": null}, {"start": 574.216, "end": 576.056, "text": "tengo bronques", "speaker": null}, {"start": 576.056, "end": 578.036, "text": "hay que correr", "speaker": null}, {"start": 578.036, "end": 579.076, "text": "correr a quién?", "speaker": null}, {"start": 580.416, "end": 581.656, "text": "al cabrón que está", "speaker": null}, {"start": 581.656, "end": 584.736, "text": "en la área de crédito y cobranza", "speaker": null}, {"start": 584.736, "end": 586.556, "text": "ese cuate me está haciendo", "speaker": null}, {"start": 586.556, "end": 587.236, "text": "su chamba", "speaker": null}, {"start": 587.236, "end": 590.216, "text": "porque está tardando el doble", "speaker": null}, {"start": 590.216, "end": 592.476, "text": "de tiempo en cobrarle", "speaker": null}, {"start": 592.476, "end": 593.136, "text": "a mis clientes", "speaker": null}, {"start": 593.136, "end": 596.036, "text": "entonces me está metiendo en broncas", "speaker": null}, {"start": 596.036, "end": 598.536, "text": "porque yo llegué al momento", "speaker": null}, {"start": 598.536, "end": 600.396, "text": "en que si yo tenía que cobrar", "speaker": null}, {"start": 600.396, "end": 601.376, "text": "cada 30 días", "speaker": null}, {"start": 601.376, "end": 604.076, "text": "y al día 30 no cobró", "speaker": null}, {"start": 604.076, "end": 606.256, "text": "mi área, ¿qué crees?", "speaker": null}, {"start": 606.256, "end": 608.296, "text": "¿con qué demonios voy a pagar la nómina?", "speaker": null}, {"start": 609.916, "end": 610.976, "text": "¿con qué voy a pagar", "speaker": null}, {"start": 610.976, "end": 612.216, "text": "los malditos impuestos?", "speaker": null}, {"start": 613.656, "end": 614.896, "text": "la nómina como quiera", "speaker": null}, {"start": 614.896, "end": 616.736, "text": "a lo mejor a los trabajadores los toreo", "speaker": null}, {"start": 616.736, "end": 617.976, "text": "a lo mejor", "speaker": null}, {"start": 617.976, "end": 620.836, "text": "porque en el momento que el charly se me ponga loco", "speaker": null}, {"start": 620.836, "end": 623.396, "text": "¿qué es esto? no hay lana cabrón, espérate la semana que entra", "speaker": null}, {"start": 623.396, "end": 624.99603, "text": "¿ahora no te parece?", "speaker": null}, {"start": 625.396, "end": 625.716, "text": "vete", "speaker": null}, {"start": 625.716, "end": 628.616, "text": "quedó así el charly", "speaker": null}, {"start": 628.616, "end": 629.856, "text": "no, pues mejor me espero", "speaker": null}, {"start": 629.856, "end": 632.396, "text": "no hay bronca, no pasa nada", "speaker": null}, {"start": 632.396, "end": 634.676, "text": "ahí voy a ver cómo le hace a mi vieja", "speaker": null}, {"start": 634.676, "end": 635.716, "text": "para comer frijoles", "speaker": null}, {"start": 635.716, "end": 639.496, "text": "pero a Hacienda le puedo levantar la voz", "speaker": null}, {"start": 639.496, "end": 641.31604, "text": "y decir ¿qué? no te pago", "speaker": null}, {"start": 641.31604, "end": 645.43604, "text": "o al servicio secreto, al seguro social", "speaker": null}, {"start": 645.43604, "end": 646.576, "text": "¿creen que les pueda hacer eso?", "speaker": null}, {"start": 649.576, "end": 650.056, "text": "no", "speaker": null}, {"start": 650.056, "end": 652.576, "text": "no puedo", "speaker": null}, {"start": 652.576, "end": 654.456, "text": "porque el seguro social me dice", "speaker": null}, {"start": 654.456, "end": 656.736, "text": "no me pagaste hoy, te pago", "speaker": null}, {"start": 656.736, "end": 661.016, "text": "Hacienda me dice no me pagaste hoy, ¿qué crees?", "speaker": null}, {"start": 662.236, "end": 664.236, "text": "te determino ¿qué? accesorios", "speaker": null}, {"start": 664.236, "end": 666.056, "text": "multas", "speaker": null}, {"start": 666.056, "end": 668.296, "text": "actualizaciones", "speaker": null}, {"start": 668.296, "end": 684.63403, "text": "recargos y accesorios o sea que si me deb 500 mil pesos crees claro ahora yo me debes 800 mil entonces me meten en un problema", "speaker": null}, {"start": 684.63403, "end": 687.274, "text": "volviendo me regreso", "speaker": null}, {"start": 687.274, "end": 689.63403, "text": "dudas hasta", "speaker": null}, {"start": 689.63403, "end": 692.474, "text": "las que sea", "speaker": null}, {"start": 700.054, "end": 702.354, "text": "¿Dudas?", "speaker": null}, {"start": 703.414, "end": 706.674, "text": "Todas las dudas posibles, habidas y por haber.", "speaker": null}, {"start": 725.994, "end": 726.95404, "text": "¿Nada?", "speaker": null}, {"start": 726.95404, "end": 729.57404, "text": "¿Seguros?", "speaker": null}, {"start": 730.054, "end": 734.934, "text": "Nosotros somos el de compra", "speaker": null}, {"start": 734.934, "end": 737.674, "text": "El de compra", "speaker": null}, {"start": 737.674, "end": 737.814, "text": "El de compra", "speaker": null}, {"start": 737.814, "end": 738.714, "text": "El de compra", "speaker": null}, {"start": 738.714, "end": 738.874, "text": "El de compra", "speaker": null}, {"start": 738.874, "end": 740.334, "text": "El de compra", "speaker": null}, {"start": 740.334, "end": 741.27405, "text": "El de compra", "speaker": null}, {"start": 741.27405, "end": 742.434, "text": "El de compra", "speaker": null}, {"start": 742.434, "end": 743.034, "text": "El de compra", "speaker": null}, {"start": 743.034, "end": 743.414, "text": "El de compra", "speaker": null}, {"start": 743.414, "end": 744.19403, "text": "El de compra", "speaker": null}, {"start": 744.19403, "end": 745.19403, "text": "El de compra", "speaker": null}, {"start": 745.19403, "end": 747.114, "text": "¿Cuál sería el al contrario?", "speaker": null}, {"start": 748.034, "end": 751.594, "text": "Mi razón de rotación de cuentas por pagar", "speaker": null}, {"start": 751.594, "end": 753.614, "text": "Pero ahora va a ser a proveedores", "speaker": null}, {"start": 753.614, "end": 758.094, "text": "Nosotros pensemos que vamos a hacer algo parecido", "speaker": null}, {"start": 758.094, "end": 759.974, "text": "¿Correcto?", "speaker": null}, {"start": 760.054, "end": 762.854, "text": "y pensamos que vamos a tener", "speaker": null}, {"start": 762.854, "end": 765.114, "text": "ahora en vez", "speaker": null}, {"start": 765.114, "end": 767.27405, "text": "de manejar ventas netas", "speaker": null}, {"start": 767.27405, "end": 768.914, "text": "¿cómo vamos a calcular esto?", "speaker": null}, {"start": 769.814, "end": 771.034, "text": "con nuestras compras", "speaker": null}, {"start": 771.034, "end": 773.794, "text": "netas a crédito", "speaker": null}, {"start": 773.794, "end": 776.654, "text": "¿sobre qué?", "speaker": null}, {"start": 776.654, "end": 778.374, "text": "sobre el promedio", "speaker": null}, {"start": 778.374, "end": 780.294, "text": "de mis cuentas por", "speaker": null}, {"start": 780.294, "end": 782.834, "text": "pagar a proveedores", "speaker": null}, {"start": 782.834, "end": 794.034, "text": "¿Qué vamos a hacer?", "speaker": null}, {"start": 794.174, "end": 795.51404, "text": "Lo mismo que hicimos allá", "speaker": null}, {"start": 795.51404, "end": 798.77405, "text": "Ahora sí nos vamos a ir al estado de costo", "speaker": null}, {"start": 798.77405, "end": 801.094, "text": "¿Se acuerdan del estado de costo?", "speaker": null}, {"start": 801.094, "end": 802.994, "text": "Que yo tenía mis compras totales", "speaker": null}, {"start": 802.994, "end": 803.454, "text": "Menos", "speaker": null}, {"start": 803.454, "end": 804.314, "text": "¿Qué?", "speaker": null}, {"start": 806.454, "end": 808.77405, "text": "Mis descuentos, mis rebajas, mis devoluciones", "speaker": null}, {"start": 808.77405, "end": 810.414, "text": "Y mis modificaciones sobre compras", "speaker": null}, {"start": 810.414, "end": 812.934, "text": "las ventas las saqué de donde?", "speaker": null}, {"start": 813.614, "end": 815.294, "text": "del estado de resultados", "speaker": null}, {"start": 815.294, "end": 817.314, "text": "las compras de donde", "speaker": null}, {"start": 817.314, "end": 818.494, "text": "demonios las voy a sacar?", "speaker": null}, {"start": 819.814, "end": 821.314, "text": "del estado de costo", "speaker": null}, {"start": 822.51404, "end": 823.714, "text": "si o no?", "speaker": null}, {"start": 825.13403, "end": 825.57404, "text": "entonces", "speaker": null}, {"start": 825.57404, "end": 827.554, "text": "pensemos por un momento", "speaker": null}, {"start": 827.554, "end": 829.15405, "text": "que mis", "speaker": null}, {"start": 829.15405, "end": 831.19403, "text": "compras en general", "speaker": null}, {"start": 831.19403, "end": 833.474, "text": "mis compras totales", "speaker": null}, {"start": 833.474, "end": 834.89404, "text": "ejemplo", "speaker": null}, {"start": 834.89404, "end": 836.614, "text": "sean", "speaker": null}, {"start": 836.614, "end": 838.414, "text": "igual, no lo sé", "speaker": null}, {"start": 838.414, "end": 840.114, "text": "si aquí vendimos", "speaker": null}, {"start": 840.114, "end": 840.814, "text": "¿cuánto vendimos?", "speaker": null}, {"start": 842.814, "end": 844.474, "text": "si aquí vendimos", "speaker": null}, {"start": 844.474, "end": 846.214, "text": "un millón", "speaker": null}, {"start": 846.214, "end": 847.234, "text": "quinientos mil pesos", "speaker": null}, {"start": 847.234, "end": 850.054, "text": "obviamente yo si compro", "speaker": null}, {"start": 850.054, "end": 854.174, "text": "compro más barato para ganar", "speaker": null}, {"start": 854.174, "end": 855.434, "text": "¿o no?", "speaker": null}, {"start": 856.69403, "end": 858.434, "text": "pensemos que mis compras totales", "speaker": null}, {"start": 858.434, "end": 860.19403, "text": "sean de un millón doscientos mil", "speaker": null}, {"start": 860.19403, "end": 866.414, "text": "estoy poniendo cifras porque ven que no traigo", "speaker": null}, {"start": 866.414, "end": 867.094, "text": "nada armado", "speaker": null}, {"start": 867.094, "end": 871.51404, "text": "de esto una parte va a ser", "speaker": null}, {"start": 871.51404, "end": 872.19403, "text": "digamos que", "speaker": null}, {"start": 872.19403, "end": 874.054, "text": "en efectivo", "speaker": null}, {"start": 874.054, "end": 876.574, "text": "y otra parte va a ser a crédito", "speaker": null}, {"start": 876.574, "end": 879.614, "text": "pensemos que a crédito", "speaker": null}, {"start": 879.614, "end": 880.174, "text": "fueron", "speaker": null}, {"start": 880.174, "end": 882.834, "text": "una parte", "speaker": null}, {"start": 882.834, "end": 884.874, "text": "800 mil", "speaker": null}, {"start": 884.874, "end": 885.714, "text": "pudiera ser", "speaker": null}, {"start": 885.714, "end": 887.674, "text": "o no pudiera ser", "speaker": null}, {"start": 887.674, "end": 891.094, "text": "porque hubo proveedores que no me dieron crédito", "speaker": null}, {"start": 891.094, "end": 893.054, "text": "tuve que pagar a Chaleco", "speaker": null}, {"start": 893.054, "end": 893.834, "text": "con billetes", "speaker": null}, {"start": 893.834, "end": 896.63403, "text": "aquí es a ver si es lo que yo cobré", "speaker": null}, {"start": 896.63403, "end": 897.39404, "text": "es lo mío", "speaker": null}, {"start": 897.39404, "end": 899.174, "text": "para ti", "speaker": null}]