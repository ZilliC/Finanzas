[{"start": 0.0, "end": 1.3, "text": "¿Qué te dice ahí, Mike?", "speaker": null}, {"start": 2.46, "end": 3.06, "text": "¿Qué me dice?", "speaker": null}, {"start": 3.06, "end": 3.48, "text": "¿Qué dice?", "speaker": null}, {"start": 5.66, "end": 7.3799996, "text": "Perdón, dame un segundo, por favor.", "speaker": null}, {"start": 9.54, "end": 12.04, "text": "Ok, sí, efectivamente.", "speaker": null}, {"start": 13.44, "end": 13.78, "text": "¿Para qué?", "speaker": null}, {"start": 13.88, "end": 15.66, "text": "¿Es que hay un control?", "speaker": null}, {"start": 20.439999, "end": 21.939999, "text": "De ser dinero circulante,", "speaker": null}, {"start": 22.08, "end": 22.56, "text": "es que no es cierto.", "speaker": null}, {"start": 23.64, "end": 24.6, "text": "De alguna manera, sí.", "speaker": null}, {"start": 25.019999, "end": 26.72, "text": "Pero, Mike, los indicados como M,", "speaker": null}, {"start": 26.72, "end": 28.539999, "text": "a ver, ahora sí, ¿qué te dice ahí?", "speaker": null}, {"start": 30.0, "end": 59.22, "text": "¿Cuánto dinero hay en sí?", "speaker": null}, {"start": 60.0, "end": 63.5, "text": "¿Cuántas monedas de peso?", "speaker": null}, {"start": 64.0, "end": 65.34, "text": "De 50 centavos", "speaker": null}, {"start": 65.34, "end": 66.72, "text": "De 10 centavos", "speaker": null}, {"start": 66.72, "end": 68.42, "text": "Porque tenemos monedas de 10 centavos", "speaker": null}, {"start": 68.42, "end": 70.26, "text": "Incluso de 5 centavos", "speaker": null}, {"start": 70.26, "end": 71.92, "text": "¿Ustedes no lo toman en cuenta?", "speaker": null}, {"start": 72.18, "end": 73.5, "text": "Porque todo el mundo las tiramos", "speaker": null}, {"start": 73.5, "end": 75.64, "text": "Por su escaso valor", "speaker": null}, {"start": 75.64, "end": 78.94, "text": "Normalmente todo el mundo lo que menos traemos", "speaker": null}, {"start": 78.94, "end": 80.72, "text": "Son monedas de peso", "speaker": null}, {"start": 80.72, "end": 83.6, "text": "Hoy en día usas hasta monedas de 50 centavos", "speaker": null}, {"start": 83.6, "end": 84.84, "text": "Por el transporte público", "speaker": null}, {"start": 84.84, "end": 86.94, "text": "Pero en términos generales", "speaker": null}, {"start": 86.94, "end": 89.2, "text": "La gente tira las monedas de 50 centavos", "speaker": null}, {"start": 89.2, "end": 90.439995, "text": "Creo que ya ni las imprimen.", "speaker": null}, {"start": 90.799995, "end": 91.52, "text": "Sí, ¿cómo no?", "speaker": null}, {"start": 92.24, "end": 93.799995, "text": "No, las de 10 y 5.", "speaker": null}, {"start": 94.06, "end": 97.119995, "text": "Sí, sí, tú vas al banco y las pides y te las dan.", "speaker": null}, {"start": 97.979996, "end": 101.71999, "text": "Pero, ¿quién paga con 55 centavos?", "speaker": null}, {"start": 102.24, "end": 104.53999, "text": "¿Qué hace la gente?", "speaker": null}, {"start": 105.35999, "end": 106.92, "text": "Que cierra pesos cerrados.", "speaker": null}, {"start": 107.71999, "end": 109.67999, "text": "¿Cuánto le debo, jefe?", "speaker": null}, {"start": 110.5, "end": 114.579994, "text": "Pues me debes, no sé, 20 pesos con 60 centavos.", "speaker": null}, {"start": 114.92, "end": 115.439995, "text": "21.", "speaker": null}, {"start": 115.439995, "end": 115.799995, "text": "¿Qué pasa?", "speaker": null}, {"start": 117.06, "end": 118.06, "text": "Apúntate la placa.", "speaker": null}, {"start": 119.2, "end": 120.78, "text": "Oiga, pero no, que son 60 centavos.", "speaker": null}, {"start": 120.96, "end": 122.119995, "text": "Dame los 60 centavos.", "speaker": null}, {"start": 123.119995, "end": 124.42, "text": "Ah, es que no los traigo.", "speaker": null}, {"start": 124.6, "end": 125.759995, "text": "Son 21 pesos cada.", "speaker": null}, {"start": 126.939995, "end": 129.42, "text": "Y la gente ya no sabe, no sé esas monedas.", "speaker": null}, {"start": 130.08, "end": 132.8, "text": "Pero tenemos monedas de 2, de 5, de 10.", "speaker": null}, {"start": 132.92, "end": 134.78, "text": "Y ahorita las conmemorativas de 20.", "speaker": null}, {"start": 135.51999, "end": 137.22, "text": "La noche no están para ese reloj,", "speaker": null}, {"start": 137.3, "end": 138.42, "text": "porque con mis hijos se lo tienen.", "speaker": null}, {"start": 139.84, "end": 141.04, "text": "Y ya mis hijos se los tienen.", "speaker": null}, {"start": 141.73999, "end": 143.87999, "text": "Porque compramos algunas cosas", "speaker": null}, {"start": 143.87999, "end": 148.78, "text": "en un supermercado.", "speaker": null}, {"start": 149.2, "end": 154.56, "text": "y le dieron cargo a mi hija y a mi hijo y a mi hija, y les habían sacado las pinches monedas en la casa,", "speaker": null}, {"start": 154.8, "end": 160.06, "text": "porque en vez de darle un billete, le dieron monedas de billete.", "speaker": null}, {"start": 161.12, "end": 163.26, "text": "Nueve cintas, nueve cintas.", "speaker": null}, {"start": 163.86, "end": 168.04, "text": "Y me dijeron, sabes que no me juzgan las monedas, las hubieras sacado en los años,", "speaker": null}, {"start": 168.22, "end": 172.16, "text": "y a mí en ese momento no, porque para mí todo esto bastaba mucho.", "speaker": null}, {"start": 173.48, "end": 178.3, "text": "Entonces fuimos a una tienda a comprar unas obras, cosas como sonidoladas de huellas de billetes.", "speaker": null}, {"start": 179.2, "end": 185.78, "text": "y este... entonces mis hijos se bajaron y compraron, los profesores se pagaron las monedas", "speaker": null}, {"start": 185.78, "end": 190.81999, "text": "no hombre, felices de la tienda, que si no teníamos más monedas", "speaker": null}, {"start": 190.81999, "end": 195.08, "text": "porque extrañaría ahorita la conmemoración del mundial", "speaker": null}, {"start": 195.08, "end": 199.84, "text": "digo, no las tengo, pero si las tenías, te las regalo, algo que nos dice hoy de la tienda", "speaker": null}, {"start": 199.84, "end": 203.84, "text": "lo único es que yo las voy a coleccionar, porque son del mundial", "speaker": null}, {"start": 203.84, "end": 207.84, "text": "Si lo que exigiste me regalo, pero no me venden ese santo chiquito.", "speaker": null}, {"start": 207.84, "end": 210.84, "text": "A mí me cambian las condiciones.", "speaker": null}, {"start": 210.84, "end": 215.84, "text": "¿Por qué? Porque, ejemplo, si tú ves, métete a un estacionamiento,", "speaker": null}, {"start": 215.84, "end": 228.31801, "text": "y a m me han pasado y hoy en d ya no te cobran los estacionamientos ni con una persona me lo llevan m Y verifica y no te reciben una serie de cifras", "speaker": null}, {"start": 230.558, "end": 234.89801, "text": "Te recibe la peso de los 5 y de 10, pero no te reciben la cifra de 5.", "speaker": null}, {"start": 235.918, "end": 239.11801, "text": "O sea, hay mucha gente que no recibe muchas cifras.", "speaker": null}, {"start": 239.598, "end": 240.55801, "text": "Yo no la recibo.", "speaker": null}, {"start": 242.17801, "end": 242.998, "text": "Yo no la recibo.", "speaker": null}, {"start": 243.718, "end": 246.478, "text": "Y si me las dan porque me meten a la otra, las queremos de volar.", "speaker": null}, {"start": 246.478, "end": 249.078, "text": "No me saldrá nada.", "speaker": null}, {"start": 250.018, "end": 258.018, "text": "Hay que utilizar redes como de la tecnología. Yo traigo, en cambio, todas. Son puntos de vista.", "speaker": null}, {"start": 258.018, "end": 263.018, "text": "Yo lo doy como una conmemoración. Yo las colecciono.", "speaker": null}, {"start": 263.018, "end": 265.018, "text": "¿Con inversión también?", "speaker": null}, {"start": 265.018, "end": 269.018, "text": "Sí, porque a lo mejor el día de mañana van a subir un precio. No quiero que me des un insipro.", "speaker": null}, {"start": 269.018, "end": 275.018, "text": "Si paras, subas, guardas. Estás en un par de años, en un año, te van a ganar la mano por eso.", "speaker": null}, {"start": 275.018, "end": 283.198, "text": "Y cuando hay cargos, imagínate nuestro guardado de pinches monedas, yo gano más moviendo el dinero que lo que me va a dar la pincha moneda.", "speaker": null}, {"start": 285.418, "end": 295.99802, "text": "Pero bueno, para mis hijos es, bueno mi hija en lo particular, pues ella está estudiando medicina, entonces mi hija no va a escribirme un impiendo,", "speaker": null}, {"start": 295.99802, "end": 299.338, "text": "si yo gano el dinero", "speaker": null}, {"start": 299.338, "end": 301.09802, "text": "yo gano más que lo que me dan", "speaker": null}, {"start": 301.09802, "end": 302.698, "text": "por la pinche moneda de todo el año", "speaker": null}, {"start": 302.698, "end": 304.878, "text": "para qué voy a pagar el dinero", "speaker": null}, {"start": 304.878, "end": 308.378, "text": "y pues me da el dinero", "speaker": null}, {"start": 308.378, "end": 310.678, "text": "pero pues nada más como recuerdo", "speaker": null}, {"start": 310.678, "end": 313.118, "text": "no me interesa recordar", "speaker": null}, {"start": 313.118, "end": 313.958, "text": "que la pinche moneda", "speaker": null}, {"start": 313.958, "end": 316.078, "text": "hay que entender", "speaker": null}, {"start": 316.078, "end": 318.458, "text": "y las pago, las colecciono", "speaker": null}, {"start": 318.458, "end": 319.978, "text": "las colecciono", "speaker": null}, {"start": 319.978, "end": 322.478, "text": "son puntos de vista", "speaker": null}, {"start": 322.478, "end": 323.678, "text": "repito, porque", "speaker": null}, {"start": 323.678, "end": 325.438, "text": "no es transparencia", "speaker": null}, {"start": 325.438, "end": 329.978, "text": "Yo veo que todos los días tenemos un enfrentamiento, mi hija está en la medicina y yo soy el contador.", "speaker": null}, {"start": 330.71802, "end": 333.178, "text": "Y ella ve las cosas de una manera y yo las veo de otra.", "speaker": null}, {"start": 335.138, "end": 338.058, "text": "No, yo veo un pasado que va con la gente.", "speaker": null}, {"start": 338.758, "end": 341.118, "text": "Hay gente que incluso compra, ¿no?", "speaker": null}, {"start": 341.238, "end": 346.978, "text": "Compran los castes tan básicos, que están pendejados, que están perdiendo el mundo.", "speaker": null}, {"start": 348.47803, "end": 352.078, "text": "Yo tengo un amigo que me ha dado un axe la semana pasada en un poste de casa.", "speaker": null}, {"start": 352.078, "end": 354.758, "text": "me estaban enseñando que compró", "speaker": null}, {"start": 354.758, "end": 355.918, "text": "un juego de", "speaker": null}, {"start": 355.918, "end": 357.318, "text": "de", "speaker": null}, {"start": 357.318, "end": 360.53802, "text": "banderitas", "speaker": null}, {"start": 360.53802, "end": 362.53802, "text": "como banderitas", "speaker": null}, {"start": 362.53802, "end": 366.818, "text": "de todos los países que están participando", "speaker": null}, {"start": 366.818, "end": 367.338, "text": "en el mundo", "speaker": null}, {"start": 367.338, "end": 369.678, "text": "y tú lo vas a acumular", "speaker": null}, {"start": 369.678, "end": 372.71802, "text": "de cómo van quedando los juegos", "speaker": null}, {"start": 372.71802, "end": 374.418, "text": "y voy a decir", "speaker": null}, {"start": 374.418, "end": 375.59802, "text": "¿cuánto te costó esta tienda?", "speaker": null}, {"start": 377.09802, "end": 378.758, "text": "5.000 libros", "speaker": null}, {"start": 378.758, "end": 379.678, "text": "¿qué es esto?", "speaker": null}, {"start": 380.878, "end": 382.118, "text": "¿qué es esto?", "speaker": null}, {"start": 383.55798, "end": 384.838, "text": "invertiste en esto", "speaker": null}, {"start": 384.838, "end": 386.55798, "text": "si es que mira", "speaker": null}, {"start": 386.55798, "end": 388.338, "text": "aquí tengo como algo", "speaker": null}, {"start": 388.338, "end": 390.338, "text": "la eliminatoria", "speaker": null}, {"start": 390.338, "end": 392.958, "text": "y utiliza", "speaker": null}, {"start": 392.958, "end": 394.078, "text": "que chingados", "speaker": null}, {"start": 394.078, "end": 396.998, "text": "y dice no, aquí vamos a ir", "speaker": null}, {"start": 396.998, "end": 398.678, "text": "mañana con la mía", "speaker": null}, {"start": 398.678, "end": 400.71802, "text": "o sea, esto es", "speaker": null}, {"start": 400.71802, "end": 401.09802, "text": "yo la mía", "speaker": null}, {"start": 401.09802, "end": 403.178, "text": "entonces", "speaker": null}, {"start": 403.178, "end": 403.21802, "text": "entonces", "speaker": null}, {"start": 403.21802, "end": 407.078, "text": "y", "speaker": null}, {"start": 407.078, "end": 411.778, "text": "Y ahí tienes un porquerías 5.000 pesos.", "speaker": null}, {"start": 413.778, "end": 417.378, "text": "Y si a poco que uno, no, claro, para mí se estira el dinero de la basura,", "speaker": null}, {"start": 418.318, "end": 419.838, "text": "yo no me estiré 5.000 pesos.", "speaker": null}, {"start": 422.03802, "end": 425.878, "text": "A mí, que no me de México, no me de México, es una de las médicos que me recuerdo.", "speaker": null}, {"start": 426.698, "end": 427.758, "text": "A mí no me genera nada.", "speaker": null}, {"start": 428.71802, "end": 430.498, "text": "Al contrario, me perjudica.", "speaker": null}, {"start": 433.738, "end": 436.178, "text": "Pero, pues, por lógica, a mí a mí no me está tardando.", "speaker": null}, {"start": 436.178, "end": 438.178, "text": "es de lo...", "speaker": null}, {"start": 438.178, "end": 440.178, "text": "¿Qué me explico?", "speaker": null}, {"start": 440.178, "end": 442.178, "text": "Él tiene otro mundo, ¿no?", "speaker": null}, {"start": 442.178, "end": 444.178, "text": "Su mundo es diferente.", "speaker": null}, {"start": 444.178, "end": 455.23602, "text": "De hecho yo creo que est aqu en M porque no vive en M vive en Baja California", "speaker": null}, {"start": 455.23602, "end": 459.91602, "text": "no sabe que está de visita con el chico", "speaker": null}, {"start": 459.91602, "end": 467.716, "text": "entonces imagínate como hay gente que, como él es un niño y merece todo mi respeto", "speaker": null}, {"start": 467.716, "end": 474.436, "text": "como yo se lo dije, si no tienes que ir hasta México, pero como ya no puedes ver en la televisión", "speaker": null}, {"start": 474.436, "end": 476.336, "text": "allá en tu rancho", "speaker": null}, {"start": 476.336, "end": 477.936, "text": "no, es que no es el mismo", "speaker": null}, {"start": 477.936, "end": 478.956, "text": "la renalina", "speaker": null}, {"start": 478.956, "end": 481.61603, "text": "pero bueno", "speaker": null}, {"start": 481.61603, "end": 482.836, "text": "ahí", "speaker": null}, {"start": 482.836, "end": 486.096, "text": "no, no le va mal", "speaker": null}, {"start": 486.096, "end": 487.57602, "text": "pero yo no tiene", "speaker": null}, {"start": 487.57602, "end": 488.656, "text": "que tenerlo en la basura", "speaker": null}, {"start": 488.656, "end": 490.456, "text": "él sí", "speaker": null}, {"start": 490.456, "end": 492.156, "text": "merece todo hecho", "speaker": null}, {"start": 492.156, "end": 496.776, "text": "así somos cosas", "speaker": null}, {"start": 496.776, "end": 499.17603, "text": "y te digo", "speaker": null}, {"start": 499.17603, "end": 499.79602, "text": "que es mi amigo", "speaker": null}, {"start": 499.79602, "end": 501.996, "text": "es mi cliente aparte", "speaker": null}, {"start": 501.996, "end": 503.67603, "text": "yo lo conocí", "speaker": null}, {"start": 503.67603, "end": 508.67603, "text": "no soy un cliente, ahora somos grandes amigos, pero él es mi cliente.", "speaker": null}, {"start": 508.67603, "end": 513.676, "text": "Yo le cargo los impuestos y todo lo que debe tener ahí.", "speaker": null}, {"start": 513.676, "end": 519.676, "text": "Porque él también me tiene en las garras, él maneja garras de cruz pasos.", "speaker": null}, {"start": 519.676, "end": 526.676, "text": "Él es diólogo, ¿no? Y la maracaná, contenta, ¿no?", "speaker": null}, {"start": 526.676, "end": 530.676, "text": "Porque todo lo que ellos producen lo exportan, por eso es la nueva caridad.", "speaker": null}, {"start": 530.676, "end": 534.676, "text": "se exporta en Estados Unidos, entonces él gana en dólares.", "speaker": null}, {"start": 534.676, "end": 538.676, "text": "De hecho, él compró boleto para comprar una familia.", "speaker": null}, {"start": 538.676, "end": 542.676, "text": "Él compró boleto para la familia, armarlo,", "speaker": null}, {"start": 542.676, "end": 545.676, "text": "para sentir a todos en una renovación.", "speaker": null}, {"start": 545.676, "end": 548.676, "text": "Cuidado con eso.", "speaker": null}, {"start": 548.676, "end": 552.676, "text": "Imagínate lo que se está gastando en esta casa.", "speaker": null}, {"start": 552.676, "end": 555.676, "text": "El boleto de más de 100 mil pesos.", "speaker": null}, {"start": 555.676, "end": 558.676, "text": "Él pagó más de 100 mil pesos por un piche de boletos.", "speaker": null}, {"start": 558.676, "end": 564.756, "text": "El trasladado de Baja California no está trabajando.", "speaker": null}, {"start": 566.796, "end": 568.076, "text": "Le van a descontar los días.", "speaker": null}, {"start": 569.856, "end": 576.216, "text": "El hotel, porque no vive en él, vive allá.", "speaker": null}, {"start": 576.976, "end": 578.43604, "text": "Porque el hotel está hospedado.", "speaker": null}, {"start": 579.896, "end": 581.776, "text": "Y todo lo que le sigue,", "speaker": null}, {"start": 581.776, "end": 586.636, "text": "¿Qué te digo?", "speaker": null}, {"start": 588.276, "end": 590.356, "text": "¿Por qué no?", "speaker": null}, {"start": 591.136, "end": 594.076, "text": "Si me quejó, ¿por qué te estás tirando de la zona de la computadora?", "speaker": null}, {"start": 594.076, "end": 603.276, "text": "Para mí, ese dinero lo invertiría en algo, algo que produzca, no lo tiraría a la basura.", "speaker": null}, {"start": 604.99603, "end": 606.19604, "text": "¿Cuál es tu utilidad?", "speaker": null}, {"start": 606.576, "end": 608.636, "text": "¿Cuál es tu utilidad?", "speaker": null}, {"start": 608.636, "end": 614.636, "text": "Yo puse un ejemplo drástico, a mí me encantaba, mejor no hablar, pero me refería a otra cosa.", "speaker": null}, {"start": 614.636, "end": 623.636, "text": "Pues él decidió y es un juego, le cuesta, está pagando.", "speaker": null}, {"start": 623.636, "end": 633.636, "text": "Bueno, vamos, son puntos de vista diferentes. Es una persona que no maneja nada de esto y nosotros sí lo manejamos.", "speaker": null}, {"start": 633.636, "end": 638.636, "text": "Como verás, ahí en simples parodias como esas,", "speaker": null}, {"start": 638.636, "end": 640.636, "text": "de barrio Comadre,", "speaker": null}, {"start": 640.636, "end": 643.636, "text": "la literatura civil,", "speaker": null}, {"start": 643.636, "end": 645.636, "text": "la turistía,", "speaker": null}, {"start": 645.636, "end": 647.636, "text": "el salón de clase,", "speaker": null}, {"start": 647.636, "end": 655.636, "text": "como verás, los financieros veamos las cosas de otra manera, completamente.", "speaker": null}, {"start": 655.636, "end": 658.636, "text": "Pues eso es a lo que nos dedicamos.", "speaker": null}, {"start": 658.636, "end": 660.69604, "text": "y que luego nos sucede", "speaker": null}, {"start": 660.69604, "end": 662.176, "text": "en la vida de alguien", "speaker": null}, {"start": 662.176, "end": 663.796, "text": "así les va a pasar a ustedes", "speaker": null}, {"start": 663.796, "end": 666.536, "text": "de la mañana ustedes van a ver las cosas", "speaker": null}, {"start": 666.536, "end": 668.096, "text": "en su profesión", "speaker": null}, {"start": 668.096, "end": 669.516, "text": "en su especialidad", "speaker": null}, {"start": 669.516, "end": 680.474, "text": "ok dudas hasta aqu Las que sean", "speaker": null}, {"start": 681.434, "end": 682.774, "text": "Rápido, para pasar a lo que sigue.", "speaker": null}, {"start": 683.494, "end": 684.19403, "text": "No, no, no.", "speaker": null}, {"start": 684.19403, "end": 686.19403, "text": "No, no, no.", "speaker": null}, {"start": 689.554, "end": 690.274, "text": "No.", "speaker": null}, {"start": 690.914, "end": 696.51404, "text": "Bueno, entonces vamos a pasar, jóvenes, a analizar ahora otro tipo de razones.", "speaker": null}, {"start": 698.314, "end": 699.554, "text": "¿Cómo cuáles?", "speaker": null}, {"start": 700.054, "end": 702.77405, "text": "nosotros hasta ahorita ya atendimos", "speaker": null}, {"start": 702.77405, "end": 704.354, "text": "por ejemplo razones financieras", "speaker": null}, {"start": 704.354, "end": 706.734, "text": "ya tenemos razones de solvencia", "speaker": null}, {"start": 706.734, "end": 710.034, "text": "ya tenemos razones de liquidez", "speaker": null}, {"start": 710.034, "end": 712.69403, "text": "pero dijimos que no nada más hay esas razones", "speaker": null}, {"start": 712.69403, "end": 714.994, "text": "hay mucho más razones", "speaker": null}, {"start": 714.994, "end": 717.354, "text": "digo tampoco vamos a ver todas las razones", "speaker": null}, {"start": 717.354, "end": 718.794, "text": "porque ustedes son informáticos", "speaker": null}, {"start": 718.794, "end": 720.534, "text": "pero mínimo que sepan", "speaker": null}, {"start": 720.534, "end": 722.614, "text": "la diferencia de tipo de razones", "speaker": null}, {"start": 722.614, "end": 724.994, "text": "otro tipo de razones", "speaker": null}, {"start": 724.994, "end": 726.734, "text": "que pudieran ser interesantes a ustedes", "speaker": null}, {"start": 726.734, "end": 728.174, "text": "o que nos marquen el programa", "speaker": null}, {"start": 728.174, "end": 732.01404, "text": "serían, por ejemplo, las razones de rotación.", "speaker": null}, {"start": 734.494, "end": 735.45404, "text": "¿Correcto?", "speaker": null}, {"start": 736.054, "end": 744.07404, "text": "Y en materia de rotación, habíamos dicho que las de rotación, a diferencia de estas,", "speaker": null}, {"start": 744.674, "end": 745.754, "text": "¿cómo las vamos a leer?", "speaker": null}, {"start": 746.354, "end": 751.57404, "text": "En ciclos, veces, vueltas o alternancias.", "speaker": null}, {"start": 752.674, "end": 755.494, "text": "Y existen ese tipo de razones claras.", "speaker": null}, {"start": 755.494, "end": 756.854, "text": "¿Cómo cuáles?", "speaker": null}, {"start": 756.854, "end": 763.214, "text": "ejemplo, la razón de rotación de cuentas por cobrar a clientes.", "speaker": null}, {"start": 765.13403, "end": 769.454, "text": "Si ustedes efectivamente estudiaron el juego que les encomienda y hicieran,", "speaker": null}, {"start": 770.454, "end": 775.01404, "text": "ustedes podrían haber estudiado las razones que financiamos.", "speaker": null}, {"start": 776.13403, "end": 782.094, "text": "Entonces, ¿cuál fue la fórmula que encontraron para determinar la razón de rotación de cuentas por cobrar a clientes?", "speaker": null}, {"start": 782.094, "end": 782.874, "text": "Venga, Dave.", "speaker": null}, {"start": 782.874, "end": 782.914, "text": "¿Qué?", "speaker": null}, {"start": 783.89404, "end": 790.554, "text": "De ventas a crédito entre el promedio de cuentas por correo.", "speaker": null}, {"start": 790.95404, "end": 791.334, "text": "¿Cómo?", "speaker": null}, {"start": 791.994, "end": 796.474, "text": "De ventas a crédito entre el promedio de cuentas por correo.", "speaker": null}, {"start": 796.834, "end": 805.334, "text": "Ok. Entonces, la razón nosotros la determinaríamos considerando las ventas, pero ¿cuáles ventas?", "speaker": null}, {"start": 806.01404, "end": 806.65405, "text": "Son las que hay.", "speaker": null}, {"start": 807.494, "end": 809.15405, "text": "¿Cuáles ventas?", "speaker": null}, {"start": 809.15405, "end": 813.374, "text": "¿Las totales?", "speaker": null}, {"start": 814.554, "end": 815.414, "text": "¿Todo lo que venía?", "speaker": null}, {"start": 819.234, "end": 820.214, "text": "¿O cuáles?", "speaker": null}, {"start": 821.914, "end": 823.374, "text": "Sí, van a ser", "speaker": null}, {"start": 823.374, "end": 825.39404, "text": "muchos de los que se han agredido, pero ¿cuáles?", "speaker": null}, {"start": 829.954, "end": 831.654, "text": "Sí, 500 es el superior", "speaker": null}, {"start": 831.654, "end": 833.414, "text": "puede ser mensual, trimestral", "speaker": null}, {"start": 833.414, "end": 836.054, "text": "trimestral, cuatrimestral, semestral", "speaker": null}, {"start": 836.054, "end": 836.574, "text": "sí", "speaker": null}, {"start": 836.574, "end": 839.034, "text": "pero ¿cuáles ventas?", "speaker": null}, {"start": 839.154, "end": 847.834, "text": "las ventas netas", "speaker": null}, {"start": 847.834, "end": 850.63403, "text": "se acuerdan que cuando vivimos", "speaker": null}, {"start": 850.63403, "end": 851.794, "text": "en el estado de costo", "speaker": null}, {"start": 851.794, "end": 854.654, "text": "que hicimos con las compras", "speaker": null}, {"start": 854.654, "end": 856.934, "text": "ojo, ahí lo vimos con las compras", "speaker": null}, {"start": 856.934, "end": 858.934, "text": "ahora lo vamos a ver con las ventas", "speaker": null}, {"start": 858.934, "end": 860.934, "text": "hoy vamos a regresar con las compras", "speaker": null}, {"start": 860.934, "end": 861.454, "text": "para ver", "speaker": null}, {"start": 861.454, "end": 864.674, "text": "tendrían que ser las ventas netas", "speaker": null}, {"start": 864.674, "end": 865.834, "text": "a crédito", "speaker": null}, {"start": 865.834, "end": 867.314, "text": "sobre", "speaker": null}, {"start": 867.314, "end": 869.63403, "text": "el promedio", "speaker": null}, {"start": 869.63403, "end": 872.63403, "text": "de las cuentas", "speaker": null}, {"start": 872.63403, "end": 874.414, "text": "por cobrar", "speaker": null}, {"start": 874.414, "end": 876.174, "text": "a clientes.", "speaker": null}, {"start": 877.89404, "end": 879.054, "text": "¿Ok?", "speaker": null}, {"start": 880.314, "end": 882.654, "text": "¿Por qué razón, señores?", "speaker": null}, {"start": 884.13403, "end": 886.334, "text": "Muy sencillo.", "speaker": null}, {"start": 887.69403, "end": 888.974, "text": "Porque, primero,", "speaker": null}, {"start": 890.534, "end": 891.674, "text": "hablando de ventas,", "speaker": null}, {"start": 891.674, "end": 893.434, "text": "¿de dónde de Montecuyo voy a sacar", "speaker": null}, {"start": 893.434, "end": 895.374, "text": "ese dato, Carlos?", "speaker": null}, {"start": 895.374, "end": 898.39404, "text": "y el hombre no debe sacar más leyes", "speaker": null}]