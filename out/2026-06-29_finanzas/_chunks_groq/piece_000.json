604, "text": "si, estudiaste en Cochabamba", "speaker": null}, {"start": 540.93604, "end": 543.076, "text": "si, tengo por ahí", "speaker": null}, {"start": 543.076, "end": 546.276, "text": "parece más que perfecto", "speaker": null}, {"start": 546.276, "end": 547.156, "text": "así debe de ser", "speaker": null}, {"start": 547.156, "end": 550.156, "text": "a ver ya", "speaker": null}, {"start": 550.156, "end": 551.876, "text": "vamos a comer bien barato", "speaker": null}, {"start": 551.876, "end": 553.49603, "text": "que lo hicimos por antes", "speaker": null}, {"start": 553.49603, "end": 558.056, "text": "pásame y platicamos", "speaker": null}, {"start": 558.056, "end": 560.036, "text": "cómo determinas el costo", "speaker": null}, {"start": 560.036, "end": 560.49603, "text": "de comer", "speaker": null}, {"start": 560.49603, "end": 566.636, "text": "Aquí, si necesitas, si no hay alguien.", "speaker": null}, {"start": 568.43604, "end": 569.216, "text": "Aquí está el botón.", "speaker": null}, {"start": 569.916, "end": 570.776, "text": "Si no me quieres.", "speaker": null}, {"start": 590.496, "end": 591.496, "text": "Gracias.", "speaker": null}, {"start": 620.496, "end": 621.496, "text": "Gracias.", "speaker": null}, {"start": 650.496, "end": 671.054, "text": "Gracias por ver el video Gracias", "speaker": null}, {"start": 700.054, "end": 701.054, "text": "Gracias.", "speaker": null}, {"start": 730.054, "end": 731.054, "text": "Gracias.", "speaker": null}, {"start": 760.054, "end": 766.174, "text": "Charlie dice que comienza con el inventario inicial, pero cuando los inventarios iniciales.", "speaker": null}, {"start": 766.174, "end": 768.934, "text": "Charlie, ¿tienes que inventarlos?", "speaker": null}, {"start": 772.19403, "end": 773.174, "text": "No lo sé.", "speaker": null}, {"start": 774.934, "end": 776.51404, "text": "Tengo que consultar.", "speaker": null}, {"start": 779.19403, "end": 779.914, "text": "Introducción.", "speaker": null}, {"start": 781.654, "end": 781.854, "text": "¿Ya?", "speaker": null}, {"start": 782.534, "end": 783.854, "text": "Dale la última chequeada.", "speaker": null}, {"start": 785.334, "end": 788.614, "text": "Te voy a tener que estrenar, Charlie.", "speaker": null}, {"start": 788.614, "end": 791.174, "text": "¿Ya?", "speaker": null}, {"start": 791.174, "end": 791.214, "text": "¿Ya?", "speaker": null}, {"start": 793.01404, "end": 794.714, "text": "Bueno, chaval, a lo mejor", "speaker": null}, {"start": 794.714, "end": 797.854, "text": "me estás dando a pensar", "speaker": null}, {"start": 797.854, "end": 799.474, "text": "que eres medio", "speaker": null}, {"start": 799.474, "end": 800.494, "text": "goloso.", "speaker": null}, {"start": 802.974, "end": 804.474, "text": "Y alguna última chiquita.", "speaker": null}, {"start": 807.07404, "end": 808.334, "text": "A lo que lo checas,", "speaker": null}, {"start": 808.51404, "end": 810.174, "text": "en la actitud de la actitud de los alumnos,", "speaker": null}, {"start": 810.374, "end": 812.454, "text": "entre ellos venían tres informados.", "speaker": null}, {"start": 815.034, "end": 817.474, "text": "Y casualmente platicábamos de eso.", "speaker": null}, {"start": 817.994, "end": 818.314, "text": "Y me decía,", "speaker": null}, {"start": 818.614, "end": 820.534, "text": "No, que no te han tocado.", "speaker": null}, {"start": 822.27405, "end": 824.714, "text": "Colegas, yo creo que es que casi no han de ser.", "speaker": null}, {"start": 825.794, "end": 826.854, "text": "Ahorita tengo dos.", "speaker": null}, {"start": 830.13403, "end": 830.994, "text": "Y nada más.", "speaker": null}, {"start": 831.39404, "end": 832.434, "text": "No, que se quede un servicio.", "speaker": null}, {"start": 833.114, "end": 833.834, "text": "O que es chato.", "speaker": null}, {"start": 836.27405, "end": 838.314, "text": "Sí, creo que es también un deber.", "speaker": null}, {"start": 838.834, "end": 840.614, "text": "Y después, si te asociamos con un grupo,", "speaker": null}, {"start": 840.974, "end": 842.594, "text": "estamos viendo un curso.", "speaker": null}, {"start": 845.19403, "end": 846.77405, "text": "No creo que sea bronca.", "speaker": null}, {"start": 846.77405, "end": 848.834, "text": "y si yo no he trabajado en eso", "speaker": null}, {"start": 848.834, "end": 851.794, "text": "y si me das el imput", "speaker": null}, {"start": 851.794, "end": 853.794, "text": "yo solamente", "speaker": null}, {"start": 853.794, "end": 855.934, "text": "aboco y yo te aliento", "speaker": null}, {"start": 855.934, "end": 856.63403, "text": "cualquier", "speaker": null}, {"start": 856.63403, "end": 858.834, "text": "ojo", "speaker": null}, {"start": 858.834, "end": 860.554, "text": "y manteco", "speaker": null}, {"start": 860.554, "end": 863.454, "text": "y ya le puse el caso", "speaker": null}, {"start": 863.454, "end": 864.454, "text": "que me había recibido", "speaker": null}, {"start": 864.454, "end": 866.914, "text": "en las ventas", "speaker": null}, {"start": 866.914, "end": 871.114, "text": "y los puse a trabajar", "speaker": null}, {"start": 871.114, "end": 872.07404, "text": "en la venta", "speaker": null}, {"start": 872.07404, "end": 875.034, "text": "ustedes son bien tigres", "speaker": null}, {"start": 875.034, "end": 877.174, "text": "las computadoras", "speaker": null}, {"start": 877.174, "end": 881.674, "text": "y me la hizo", "speaker": null}, {"start": 881.674, "end": 882.674, "text": "porque una de ellas", "speaker": null}, {"start": 882.674, "end": 883.874, "text": "fue una mujer", "speaker": null}, {"start": 883.874, "end": 886.314, "text": "bien abusada", "speaker": null}, {"start": 886.314, "end": 886.674, "text": "y me dijo", "speaker": null}, {"start": 886.674, "end": 891.214, "text": "yo le hablo", "speaker": null}, {"start": 891.214, "end": 893.27405, "text": "a mi área de contabilidad", "speaker": null}, {"start": 893.27405, "end": 894.614, "text": "y que me dedica", "speaker": null}, {"start": 894.614, "end": 897.554, "text": "a una de las escuelas", "speaker": null}, {"start": 897.554, "end": 899.714, "text": "y yo", "speaker": null}]