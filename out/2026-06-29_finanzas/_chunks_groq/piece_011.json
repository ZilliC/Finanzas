[{"start": 0.0, "end": 7.4199996, "text": "Pero me dice, la fórmula o la razón me dice que no ocupe las compras totales, ¿qué me dice?", "speaker": null}, {"start": 8.36, "end": 10.54, "text": "Que ocupe las compras netas.", "speaker": null}, {"start": 11.2, "end": 12.759999, "text": "Entonces, ¿qué tengo que hacer?", "speaker": null}, {"start": 13.7, "end": 24.699999, "text": "A mis compras totales a crédito, yo les tendría que quitar nuevamente mis descuentos,", "speaker": null}, {"start": 24.699999, "end": 27.679998, "text": "mis deposiciones", "speaker": null}, {"start": 27.679998, "end": 31.64, "text": "mis rebajas", "speaker": null}, {"start": 31.64, "end": 34.539997, "text": "mis bonificaciones", "speaker": null}, {"start": 34.539997, "end": 36.699997, "text": "¿estamos de acuerdo?", "speaker": null}, {"start": 37.899998, "end": 38.62, "text": "pensemos que", "speaker": null}, {"start": 38.62, "end": 40.32, "text": "le devolvieron entre tu bebé", "speaker": null}, {"start": 40.32, "end": 42.199997, "text": "no sé, 40 mil pesos", "speaker": null}, {"start": 42.199997, "end": 43.399998, "text": "¿puede ser?", "speaker": null}, {"start": 44.059998, "end": 44.379997, "text": "sí", "speaker": null}, {"start": 44.379997, "end": 48.42, "text": "de descuentos", "speaker": null}, {"start": 48.42, "end": 50.699997, "text": "nos hicieron descuentos por 15 mil", "speaker": null}, {"start": 50.699997, "end": 53.0, "text": "¿sabe?", "speaker": null}, {"start": 54.699997, "end": 67.899994, "text": "de rebajas, hicieron rebajas por 10.000, no otros 15.000, pudiera ser, y de modificaciones", "speaker": null}, {"start": 67.899994, "end": 80.7, "text": "10.000, ¿cuánto nos muestra? Son 800, no, aquí serían 80, 800 menos 80, esto sería", "speaker": null}, {"start": 80.7, "end": 82.7, "text": "igual a 720 mil pesos.", "speaker": null}, {"start": 87.7, "end": 89.7, "text": "¿Pudiera ser o no?", "speaker": null}, {"start": 89.7, "end": 105.410995, "text": "Entonces mis compras netas a cr ser de 720 mil pesos Pero ahora tengo que determinar que el promedio de mis cuentas por pagar", "speaker": null}, {"start": 106.410995, "end": 108.351, "text": "ese promedio de dónde lo saco, Maite?", "speaker": null}, {"start": 113.631, "end": 114.951004, "text": "De proveedores.", "speaker": null}, {"start": 115.270996, "end": 119.591, "text": "De proveedores, y yo tendría que hacer lo mismo.", "speaker": null}, {"start": 119.591, "end": 124.211, "text": "el saldo inicial de proveedores", "speaker": null}, {"start": 124.211, "end": 129.051, "text": "pensemos que sea de 100 mil", "speaker": null}, {"start": 129.051, "end": 132.051, "text": "por por ahí mira", "speaker": null}, {"start": 132.051, "end": 134.831, "text": "tendría que buscar ahora que", "speaker": null}, {"start": 134.831, "end": 138.151, "text": "el saldo final de proveedores", "speaker": null}, {"start": 138.151, "end": 140.771, "text": "pensemos que yo también fui pagando a los proveedores", "speaker": null}, {"start": 140.771, "end": 142.051, "text": "cada vez desde Mujeres", "speaker": null}, {"start": 142.051, "end": 147.631, "text": "ok David podría ser", "speaker": null}, {"start": 147.631, "end": 150.611, "text": "ok, que me dice la regla", "speaker": null}, {"start": 150.611, "end": 151.911, "text": "promedio", "speaker": null}, {"start": 151.911, "end": 154.031, "text": "saldo inicial", "speaker": null}, {"start": 154.031, "end": 156.071, "text": "más saldo final", "speaker": null}, {"start": 156.071, "end": 157.89099, "text": "100 más 80", "speaker": null}, {"start": 157.89099, "end": 161.311, "text": "180.000", "speaker": null}, {"start": 161.311, "end": 164.23099, "text": "entre 2", "speaker": null}, {"start": 164.23099, "end": 165.971, "text": "porque voy a determinar un promedio", "speaker": null}, {"start": 165.971, "end": 168.571, "text": "entonces aquí mi promedio", "speaker": null}, {"start": 168.571, "end": 169.45099, "text": "de cuánto va a ser", "speaker": null}, {"start": 169.45099, "end": 171.151, "text": "el 90", "speaker": null}, {"start": 171.151, "end": 176.251, "text": "si yo divido los 720", "speaker": null}, {"start": 176.251, "end": 177.811, "text": "¿Cuánto le da a la ventana?", "speaker": null}, {"start": 178.331, "end": 178.851, "text": "Ocho.", "speaker": null}, {"start": 179.271, "end": 181.41101, "text": "¿Me da a ocho?", "speaker": null}, {"start": 181.631, "end": 183.311, "text": "Ahora, ¿cuál sería la lectura, Carlos?", "speaker": null}, {"start": 186.031, "end": 187.771, "text": "Cada periodo pago", "speaker": null}, {"start": 187.771, "end": 190.47101, "text": "ocho veces a mis proveedores.", "speaker": null}, {"start": 190.491, "end": 192.39099, "text": "Ocho veces le estoy pagando a mis proveedores", "speaker": null}, {"start": 192.39099, "end": 192.95099, "text": "en el año", "speaker": null}, {"start": 192.95099, "end": 195.031, "text": "para que el compre.", "speaker": null}, {"start": 196.331, "end": 204.382, "text": "Habr gente que se me vende y me diga uy los churros que se salgan cabr a qui al vengador", "speaker": null}, {"start": 206.282, "end": 209.04199, "text": "¿Cuál sería la razón de confirmación?", "speaker": null}, {"start": 210.522, "end": 211.862, "text": "La de...", "speaker": null}, {"start": 212.982, "end": 214.942, "text": "...pengue de...", "speaker": null}, {"start": 214.942, "end": 216.582, "text": "...plazo medio de pago.", "speaker": null}, {"start": 216.782, "end": 218.382, "text": "Medio de pago.", "speaker": null}, {"start": 219.062, "end": 224.162, "text": "Y el plazo medio de pago que me dice que tome los números de días de ejercicio", "speaker": null}, {"start": 224.162, "end": 230.162, "text": "sobre la razón de rotación de cuentas por pagar a proveedores.", "speaker": null}, {"start": 231.862, "end": 238.182, "text": "Sustituyo, tengo los 360 días sobre la razón que fue de 8.", "speaker": null}, {"start": 241.002, "end": 242.002, "text": "¿Esto cuánto nos sale?", "speaker": null}, {"start": 242.282, "end": 243.262, "text": "¿Cuánto?", "speaker": null}, {"start": 243.422, "end": 243.982, "text": "45.", "speaker": null}, {"start": 244.662, "end": 247.722, "text": "45 días.", "speaker": null}, {"start": 249.32199, "end": 250.202, "text": "Traducido, Mike.", "speaker": null}, {"start": 250.202, "end": 265.262, "text": "Yo en promedio le estoy pagando a mis proveedores cada 45 días.", "speaker": null}, {"start": 268.262, "end": 270.822, "text": "Ahora la pregunta, señores informáticos,", "speaker": null}, {"start": 271.902, "end": 277.062, "text": "¿de acuerdo a las cifras mi empresa está bien o está mal y por qué?", "speaker": null}, {"start": 280.202, "end": 281.202, "text": "7.000 pesos.", "speaker": null}, {"start": 281.84198, "end": 284.362, "text": "La empresa está bien o mal?", "speaker": null}, {"start": 284.602, "end": 285.40198, "text": "La veo bien.", "speaker": null}, {"start": 286.422, "end": 287.542, "text": "¿Quién la ve bien? ¿Carlos?", "speaker": null}, {"start": 288.722, "end": 288.862, "text": "¿Sí?", "speaker": null}, {"start": 290.562, "end": 292.182, "text": "Cada vez debes menos dinero", "speaker": null}, {"start": 292.182, "end": 293.802, "text": "y si te están pagando algo la tengo.", "speaker": null}, {"start": 294.90198, "end": 304.573, "text": "Vamos a ver mis Tengo 60 tengo 45 c la ves la ves bien", "speaker": null}, {"start": 306.573, "end": 308.193, "text": "yo corrí a", "speaker": null}, {"start": 308.193, "end": 309.493, "text": "a Chávez", "speaker": null}, {"start": 309.493, "end": 311.173, "text": "pero en dos pasadas", "speaker": null}, {"start": 311.173, "end": 313.593, "text": "¿por qué?", "speaker": null}, {"start": 314.913, "end": 316.453, "text": "porque yo estoy pagando", "speaker": null}, {"start": 316.453, "end": 318.673, "text": "cada 45 días a mis proveedores", "speaker": null}, {"start": 318.673, "end": 320.353, "text": "y yo estoy", "speaker": null}, {"start": 320.353, "end": 321.953, "text": "cobrando cada 60", "speaker": null}, {"start": 321.953, "end": 324.593, "text": "tengo 15 días que no tengo", "speaker": null}, {"start": 324.593, "end": 327.633, "text": "lana, ¿con qué demonios les voy a pagar a los proveedores, carajo?", "speaker": null}, {"start": 330.353, "end": 334.353, "text": "Dice Charlie, si un préstamo al banco, si ya te había explicado que si pides dinero", "speaker": null}, {"start": 334.353, "end": 335.613, "text": "al banco te van a exaltar.", "speaker": null}, {"start": 338.653, "end": 343.733, "text": "Ah, bueno, ya si Charlie va a pagar con cuerpo mágico, pues está del otro lado.", "speaker": null}, {"start": 346.733, "end": 347.833, "text": "Se observan o se observan.", "speaker": null}, {"start": 349.353, "end": 351.233, "text": "¿Qué problema tiene este Charlie Barber?", "speaker": null}, {"start": 354.593, "end": 355.313, "text": "Papi, taca.", "speaker": null}, {"start": 358.113, "end": 359.573, "text": "¿Cómo vamos a estar aquí, señores?", "speaker": null}, {"start": 362.49298, "end": 363.953, "text": "Para mañana, mis niños,", "speaker": null}, {"start": 364.513, "end": 365.653, "text": "me valgo el callejuego,", "speaker": null}, {"start": 366.693, "end": 367.873, "text": "porque no nos llevan el día,", "speaker": null}, {"start": 368.233, "end": 368.813, "text": "otra vez,", "speaker": null}, {"start": 369.673, "end": 370.853, "text": "lo van a ver hasta en la tarde.", "speaker": null}, {"start": 372.333, "end": 374.313, "text": "Para mañana, voy a empezar a preguntar", "speaker": null}, {"start": 374.313, "end": 375.93298, "text": "el sistema de la nación.", "speaker": null}, {"start": 378.293, "end": 378.733, "text": "¿Sí?", "speaker": null}, {"start": 380.053, "end": 381.49298, "text": "Aunque se me estudie, porque mañana", "speaker": null}, {"start": 381.49298, "end": 382.573, "text": "les voy a preguntar dos veces.", "speaker": null}, {"start": 382.573, "end": 384.713, "text": "¿Sale?", "speaker": null}, {"start": 385.873, "end": 386.773, "text": "Bien muchachos", "speaker": null}, {"start": 386.773, "end": 388.313, "text": "Si no hay otra cosa que hacer", "speaker": null}, {"start": 388.313, "end": 389.553, "text": "Vamos a dejarlo aquí", "speaker": null}, {"start": 389.553, "end": 391.093, "text": "Y nos va a dar cuatro, cinco", "speaker": null}, {"start": 391.093, "end": 395.49298, "text": "Y no quiero ir a la puerta", "speaker": null}, {"start": 395.49298, "end": 398.153, "text": "¿Ya me puedes?", "speaker": null}, {"start": 400.153, "end": 400.633, "text": "¿Seguros?", "speaker": null}]