[{"start": 0.0, "end": 3.6399999, "text": "¿Qué crees? ¿Que estás hablando de un detective o un placer para el área de la economía?", "speaker": null}, {"start": 6.3599997, "end": 10.0, "text": "Pues tú vas a ser el que me pasa, tendré que determinar de dónde me vas a arrastrar.", "speaker": null}, {"start": 12.5199995, "end": 13.559999, "text": "Y ya no sé qué...", "speaker": null}, {"start": 13.559999, "end": 14.719999, "text": "¿Se ha creado un equipo?", "speaker": null}, {"start": 18.74, "end": 21.82, "text": "Y si no, mejor me cargo de empresa, no me hagan mucho daño.", "speaker": null}, {"start": 22.4, "end": 24.3, "text": "¿Qué te va a quedar con un daño?", "speaker": null}, {"start": 24.3, "end": 24.42, "text": "¿Qué te va a quedar con un daño?", "speaker": null}, {"start": 24.42, "end": 25.42, "text": "Gracias.", "speaker": null}, {"start": 54.42, "end": 61.42, "text": "Eso se me ocurre porque es un formulario. Eso es un material de séptimo.", "speaker": null}, {"start": 61.42, "end": 68.42, "text": "Y para hallar fórmulas, las fórmulas de la matemática, la matemática es una estructura de fórmulas.", "speaker": null}, {"start": 68.42, "end": 71.42, "text": "Pues siempre podemos hallar una fórmula.", "speaker": null}, {"start": 74.42, "end": 79.42, "text": "Pero necesitarías tener, obviamente, un diálogo.", "speaker": null}, {"start": 79.42, "end": 82.42, "text": "cualquiera", "speaker": null}, {"start": 109.42, "end": 111.9, "text": "No hay ninguna duda.", "speaker": null}, {"start": 112.14, "end": 113.159996, "text": "No hay ninguna duda.", "speaker": null}, {"start": 114.78, "end": 115.9, "text": "La atención es que hay que hacer.", "speaker": null}, {"start": 115.9, "end": 139.9, "text": "¿Ya?", "speaker": null}, {"start": 139.9, "end": 139.95999, "text": "¿Ya?", "speaker": null}, {"start": 141.42, "end": 141.93999, "text": "¿Seguro?", "speaker": null}, {"start": 142.36, "end": 142.59999, "text": "No.", "speaker": null}, {"start": 142.59999, "end": 172.57999, "text": "Yo digo que sí.", "speaker": null}, {"start": 172.59999, "end": 174.09999, "text": "en el proceso vas hasta acá abajo", "speaker": null}, {"start": 174.09999, "end": 175.34, "text": "todavía no llegas hasta ahí", "speaker": null}, {"start": 175.34, "end": 178.27998, "text": "¿cómo inicias con el proceso", "speaker": null}, {"start": 178.27998, "end": 179.81999, "text": "si todavía ni siquiera le metes?", "speaker": null}, {"start": 180.35999, "end": 182.7, "text": "¿te acuerdas que hablábamos de los elementos del costo?", "speaker": null}, {"start": 183.01999, "end": 184.31999, "text": "materia prima, mano de obra", "speaker": null}, {"start": 184.31999, "end": 186.57999, "text": "y gastos directos de producción", "speaker": null}, {"start": 186.57999, "end": 188.73999, "text": "y hablábamos", "speaker": null}, {"start": 188.73999, "end": 189.71999, "text": "de que debes de tener", "speaker": null}, {"start": 189.71999, "end": 192.43999, "text": "dentro de la materia prima tus insumos", "speaker": null}, {"start": 192.43999, "end": 195.07999, "text": "y todavía no tienes los insumos", "speaker": null}, {"start": 195.07999, "end": 196.41998, "text": "¿qué es lo que vas a transformar?", "speaker": null}, {"start": 197.31999, "end": 198.07999, "text": "no puedes", "speaker": null}, {"start": 198.07999, "end": 199.43999, "text": "entonces ya les ha dicho", "speaker": null}, {"start": 199.44, "end": 203.6, "text": "nos dice que eso le suma las compras netas", "speaker": null}, {"start": 203.6, "end": 205.32, "text": "que son las compras totales de los descuentos", "speaker": null}, {"start": 205.32, "end": 206.16, "text": "de las rebajas", "speaker": null}, {"start": 206.16, "end": 209.48, "text": "rebajas, devoluciones", "speaker": null}, {"start": 209.48, "end": 211.56, "text": "ok, y la bonificación", "speaker": null}, {"start": 211.56, "end": 214.06, "text": "eso te daría", "speaker": null}, {"start": 214.06, "end": 216.22, "text": "tu inventario", "speaker": null}, {"start": 216.22, "end": 217.52, "text": "disponible", "speaker": null}, {"start": 217.52, "end": 233.698, "text": "me temo que no tendr que es la materia prima disponible Bueno si es inventario final aqu s es inventario final", "speaker": null}, {"start": 233.89801, "end": 236.45801, "text": "pero normalmente fue de los tres inventarios.", "speaker": null}, {"start": 237.438, "end": 239.218, "text": "Creo que hay que hacer el de materia prima.", "speaker": null}, {"start": 241.67801, "end": 244.018, "text": "Esto nos da inventario utilizado.", "speaker": null}, {"start": 244.018, "end": 246.018, "text": "¡Gracias!", "speaker": null}, {"start": 274.018, "end": 280.878, "text": "a ver Mike,", "speaker": null}, {"start": 280.978, "end": 281.758, "text": "no te leo,", "speaker": null}, {"start": 285.09802, "end": 286.798, "text": "MS igual", "speaker": null}, {"start": 286.798, "end": 293.21802, "text": "a 1.80", "speaker": null}, {"start": 293.21802, "end": 299.638, "text": "ya te ahorramos todo el trabajo,", "speaker": null}, {"start": 299.638, "end": 301.758, "text": "tenemos que calcular todo,", "speaker": null}, {"start": 301.758, "end": 308.518, "text": "Ahora necesitamos que nos des la lectura negativa de Sanos.", "speaker": null}, {"start": 309.65802, "end": 311.578, "text": "¿Qué significa ese 1.8?", "speaker": null}, {"start": 319.118, "end": 325.258, "text": "Después de pagar todas mis deudas, tengo el 1.8.", "speaker": null}, {"start": 326.758, "end": 328.558, "text": "¿1.8 a qué?", "speaker": null}, {"start": 328.558, "end": 329.698, "text": "Por ciento.", "speaker": null}, {"start": 330.878, "end": 331.15802, "text": "¿No?", "speaker": null}, {"start": 331.758, "end": 332.758, "text": "Gracias.", "speaker": null}, {"start": 361.758, "end": 362.758, "text": "Gracias.", "speaker": null}, {"start": 391.758, "end": 392.758, "text": "Gracias.", "speaker": null}, {"start": 421.758, "end": 422.758, "text": "Gracias.", "speaker": null}, {"start": 451.758, "end": 475.01602, "text": "Gracias Bienvenidos a la sesi de hoy", "speaker": null}, {"start": 475.036, "end": 476.036, "text": "Gracias.", "speaker": null}, {"start": 505.036, "end": 513.796, "text": "Tengo 1.80 pesos para pagar.", "speaker": null}, {"start": 513.796, "end": 515.476, "text": "Tengo 1.80 pesos.", "speaker": null}, {"start": 517.076, "end": 518.916, "text": "No, pero está a 80 pesos.", "speaker": null}, {"start": 522.216, "end": 523.796, "text": "No, está a...", "speaker": null}, {"start": 524.516, "end": 527.196, "text": "Tengo 1.80 pesos.", "speaker": null}, {"start": 528.536, "end": 529.416, "text": "¿Es suave todo o no?", "speaker": null}, {"start": 535.036, "end": 537.036, "text": "Amén.", "speaker": null}, {"start": 565.036, "end": 595.016, "text": "¿Qué es la historia?", "speaker": null}, {"start": 595.036, "end": 596.036, "text": "Gracias.", "speaker": null}, {"start": 625.036, "end": 629.916, "text": "Después de pagar mi deuda, tengo 1.80 de colchón.", "speaker": null}, {"start": 631.096, "end": 631.616, "text": "¿Después qué?", "speaker": null}, {"start": 632.19604, "end": 642.856, "text": "Después de pagar el activo, en el paseo a corto plazo, tengo 1.80 de colchón.", "speaker": null}, {"start": 644.43604, "end": 648.536, "text": "1.80, pues, ahorita tengo el deuda de un año.", "speaker": null}, {"start": 650.876, "end": 652.016, "text": "Gracias, Juan.", "speaker": null}, {"start": 652.016, "end": 653.016, "text": "Gracias.", "speaker": null}, {"start": 655.036, "end": 656.49603, "text": "No, no, no, yo cuando quedé aquí, yo no.", "speaker": null}, {"start": 659.176, "end": 660.616, "text": "No, no, no, no.", "speaker": null}, {"start": 663.616, "end": 664.81604, "text": "No, mi buen, no.", "speaker": null}, {"start": 665.31604, "end": 668.336, "text": "No, yo les tenía, bueno, un punto ochenta pesos.", "speaker": null}, {"start": 669.43604, "end": 681.534, "text": "O me doles que porcentaje se hab mostrado O me doles en pesos pero yo no puedo tener 1 pesos en el mejor de los casos", "speaker": null}, {"start": 681.534, "end": 682.174, "text": "la moneda", "speaker": null}, {"start": 682.174, "end": 685.214, "text": "que mejor se acercaría sería la de los pesos", "speaker": null}, {"start": 685.214, "end": 687.094, "text": "es correcto", "speaker": null}, {"start": 687.094, "end": 689.07404, "text": "tú no puedes tener", "speaker": null}, {"start": 689.07404, "end": 690.274, "text": "1.80 pesos", "speaker": null}, {"start": 690.274, "end": 691.83405, "text": "¿qué es lo que pasa?", "speaker": null}, {"start": 692.19403, "end": 694.45404, "text": "lo que te está diciendo es que efectivamente", "speaker": null}, {"start": 694.45404, "end": 697.094, "text": "tu empresa es capaz de pagar", "speaker": null}, {"start": 697.094, "end": 699.374, "text": "la totalidad de sus deudas", "speaker": null}, {"start": 699.374, "end": 707.034, "text": "y después de eso todavía cuenta con un peso con 80 centavos de excedente.", "speaker": null}, {"start": 709.414, "end": 713.69403, "text": "El punto 80 se refiere a centavos, no a pesos.", "speaker": null}, {"start": 714.594, "end": 716.234, "text": "Tú no puedes tener fracciones de pesos.", "speaker": null}, {"start": 718.13403, "end": 719.214, "text": "¿Sí? ¿Eso me explicó?", "speaker": null}, {"start": 720.094, "end": 721.114, "text": "¿Qué pasó?", "speaker": null}, {"start": 722.57404, "end": 724.114, "text": "¿Qué problema tienes?", "speaker": null}, {"start": 725.45404, "end": 726.794, "text": "No se acordó.", "speaker": null}, {"start": 729.374, "end": 732.294, "text": "tenemos que tener muy presente", "speaker": null}, {"start": 732.294, "end": 735.174, "text": "los recursos anualizados", "speaker": null}, {"start": 735.174, "end": 737.754, "text": "o sea, lamentablemente", "speaker": null}, {"start": 737.754, "end": 740.934, "text": "digo, eso no se lo vamos a decir a ustedes", "speaker": null}, {"start": 740.934, "end": 741.834, "text": "pero a ustedes no", "speaker": null}, {"start": 741.834, "end": 744.474, "text": "realmente eso no lo van a hacer", "speaker": null}, {"start": 744.474, "end": 746.114, "text": "lo hacen los contadores", "speaker": null}, {"start": 746.114, "end": 750.714, "text": "pero si yo te platico que nosotros los contadores", "speaker": null}, {"start": 750.714, "end": 755.414, "text": "no nos podemos equivocar ni por sentados", "speaker": null}, {"start": 755.414, "end": 758.19403, "text": "no sé si tengas por ahí algún colegio", "speaker": null}, {"start": 758.19403, "end": 759.95404, "text": "que te estoy enseñando aquí con la tarta.", "speaker": null}, {"start": 761.034, "end": 765.534, "text": "Te habrán dicho que si no les cuadra, ellos utilizan mucho sus términos.", "speaker": null}, {"start": 765.974, "end": 767.974, "text": "No me chico, no me cuadro.", "speaker": null}, {"start": 768.45404, "end": 769.254, "text": "¿Por qué no te cuadro?", "speaker": null}, {"start": 769.854, "end": 771.434, "text": "Porque no te sentamos.", "speaker": null}, {"start": 772.334, "end": 776.354, "text": "Por eso sentamos, tienes que estar toda la noche hasta que nos encuentren.", "speaker": null}, {"start": 778.01404, "end": 778.614, "text": "¿Por qué?", "speaker": null}, {"start": 778.614, "end": 782.214, "text": "Porque desafortunadamente la técnica así lo exige.", "speaker": null}, {"start": 783.334, "end": 786.754, "text": "Debe de cuadrar con peso y sentado.", "speaker": null}, {"start": 786.754, "end": 788.614, "text": "entonces", "speaker": null}, {"start": 788.614, "end": 790.794, "text": "si mañana cuando tú le digas a alguien", "speaker": null}, {"start": 790.794, "end": 792.374, "text": "que tiene un número de 80 pesos", "speaker": null}, {"start": 792.374, "end": 793.714, "text": "pues te va a decir", "speaker": null}, {"start": 793.714, "end": 796.07404, "text": "que me motiva", "speaker": null}, {"start": 796.07404, "end": 799.374, "text": "no está mal", "speaker": null}, {"start": 799.374, "end": 801.01404, "text": "en el género", "speaker": null}, {"start": 801.01404, "end": 804.51404, "text": "como decirlo", "speaker": null}, {"start": 804.51404, "end": 807.034, "text": "si lo hubieras encajonado por", "speaker": null}, {"start": 807.034, "end": 807.554, "text": "la fracción", "speaker": null}, {"start": 807.554, "end": 810.034, "text": "hubiera sido más", "speaker": null}, {"start": 810.034, "end": 812.294, "text": "evidente la fracción", "speaker": null}, {"start": 812.294, "end": 815.27405, "text": "pero como lo hiciste con los pesos", "speaker": null}, {"start": 815.27405, "end": 817.13403, "text": "alguien puede ser", "speaker": null}, {"start": 817.13403, "end": 818.874, "text": "sin espíritu", "speaker": null}, {"start": 818.874, "end": 821.414, "text": "por eso es que tenemos la posibilidad", "speaker": null}, {"start": 821.414, "end": 824.034, "text": "de que las razones geométricas", "speaker": null}, {"start": 824.034, "end": 825.914, "text": "se vean emocionales", "speaker": null}, {"start": 826.814, "end": 827.414, "text": "para evitar", "speaker": null}, {"start": 827.414, "end": 829.494, "text": "problemas, te facilitan las cosas", "speaker": null}, {"start": 829.494, "end": 831.454, "text": "pero te complican otras, la terminó", "speaker": null}, {"start": 831.454, "end": 835.594, "text": "vamos a iniciar", "speaker": null}, {"start": 835.594, "end": 837.334, "text": "no sin antes verificar", "speaker": null}, {"start": 837.334, "end": 839.934, "text": "si hay alguna duda", "speaker": null}, {"start": 839.934, "end": 841.234, "text": "comentario", "speaker": null}, {"start": 841.234, "end": 842.934, "text": "aclaración", "speaker": null}, {"start": 842.934, "end": 844.494, "text": "corrección", "speaker": null}, {"start": 844.494, "end": 846.474, "text": "lo que sea", "speaker": null}, {"start": 846.474, "end": 847.434, "text": "lo que nos dice", "speaker": null}, {"start": 847.434, "end": 853.814, "text": "que hay que checar", "speaker": null}, {"start": 853.814, "end": 855.454, "text": "sus sueños bibliográficos", "speaker": null}, {"start": 855.454, "end": 857.494, "text": "notas, libros", "speaker": null}, {"start": 857.494, "end": 860.19403, "text": "no sé, documentos fuentes", "speaker": null}, {"start": 860.19403, "end": 862.354, "text": "que me digan, no me diches esto está mal", "speaker": null}, {"start": 862.354, "end": 864.334, "text": "usted lo está legando", "speaker": null}, {"start": 864.334, "end": 866.51404, "text": "no creo que", "speaker": null}, {"start": 866.51404, "end": 868.19403, "text": "se dé ese caso pero", "speaker": null}, {"start": 868.19403, "end": 870.63403, "text": "no está por demás checado", "speaker": null}, {"start": 870.63403, "end": 873.834, "text": "dudas", "speaker": null}, {"start": 873.834, "end": 875.794, "text": "las que se ven", "speaker": null}, {"start": 875.794, "end": 892.57404, "text": "no, no las voy a comprar", "speaker": null}, {"start": 892.57404, "end": 894.854, "text": "¿seguro?", "speaker": null}, {"start": 895.414, "end": 896.77405, "text": "no, no las voy a comprar", "speaker": null}, {"start": 896.77405, "end": 897.734, "text": "todas en general", "speaker": null}, {"start": 897.734, "end": 899.294, "text": "excelente", "speaker": null}]