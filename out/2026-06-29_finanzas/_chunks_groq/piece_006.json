[{"start": 0.26, "end": 2.04, "text": "Así de sencillo es esto.", "speaker": null}, {"start": 4.46, "end": 4.98, "text": "¿Dudas?", "speaker": null}, {"start": 5.2799997, "end": 9.36, "text": "Ese índice nacional de precios de los millóns, ¿cuáles son las cifras que se manejan?", "speaker": null}, {"start": 9.98, "end": 14.66, "text": "Las que te conviene el Banco de México dentro de los primeros 10 días de cada mes.", "speaker": null}, {"start": 15.2, "end": 21.76, "text": "Pero son así chiquitas, o ese, ¿cómo se sabe?", "speaker": null}, {"start": 22.66, "end": 24.98, "text": "O sea, es ponderado de los precios.", "speaker": null}, {"start": 25.599998, "end": 28.279999, "text": "Ajá, o sea, en este caso, el INE,", "speaker": null}, {"start": 28.279999, "end": 32.879997, "text": "va a hacer los cálculos a través de ponderadores.", "speaker": null}, {"start": 33.76, "end": 34.219997, "text": "¿Correcto?", "speaker": null}, {"start": 34.3, "end": 38.68, "text": "Esos ponderadores los va a aplicar a la fórmula de Pulse Piles", "speaker": null}, {"start": 38.68, "end": 41.8, "text": "y te va a dar un índice.", "speaker": null}, {"start": 41.94, "end": 43.579998, "text": "Esos índices normalmente vienen,", "speaker": null}, {"start": 44.18, "end": 45.899998, "text": "por eso dije, la ley me marca,", "speaker": null}, {"start": 47.44, "end": 51.359997, "text": "que debes de tomarlos o considerarlos hasta diez milésimos.", "speaker": null}, {"start": 52.199997, "end": 53.44, "text": "Métete a tu Super Google", "speaker": null}, {"start": 53.44, "end": 61.6, "text": "y ponle, búscame la tabla de índices nacionales de precios al consumidor.", "speaker": null}, {"start": 63.14, "end": 68.28, "text": "Normalmente en esa tabla te van a aparecer todos los índices,", "speaker": null}, {"start": 68.939995, "end": 72.439995, "text": "ordenados por reglones y por columna.", "speaker": null}, {"start": 73.939995, "end": 79.34, "text": "En esta tabla tú vas a buscar el mes y el año que requieres.", "speaker": null}, {"start": 80.58, "end": 82.28, "text": "Y vienen por fracciones.", "speaker": null}, {"start": 83.439995, "end": 85.92, "text": "si tú verificas", "speaker": null}, {"start": 85.92, "end": 87.759995, "text": "lo único que tienes que hacer es", "speaker": null}, {"start": 87.759995, "end": 90.67999, "text": "ejemplo, buscar el índice nacional", "speaker": null}, {"start": 90.67999, "end": 91.71999, "text": "de precios al consumidor", "speaker": null}, {"start": 91.71999, "end": 94.27999, "text": "se me ocurre pensar de este año", "speaker": null}, {"start": 94.27999, "end": 94.899994, "text": "cuál sería", "speaker": null}, {"start": 94.899994, "end": 98.2, "text": "si nosotros estamos en junio", "speaker": null}, {"start": 98.2, "end": 102.27999, "text": "nosotros no vas a encontrar el índice nacional", "speaker": null}, {"start": 102.27999, "end": 103.53999, "text": "de precios al consumidor de junio", "speaker": null}, {"start": 103.53999, "end": 106.439995, "text": "¿por qué charla? porque se va a publicar", "speaker": null}, {"start": 106.439995, "end": 107.299995, "text": "hasta julio", "speaker": null}, {"start": 107.299995, "end": 110.2, "text": "el más reciente que vas a encontrar", "speaker": null}, {"start": 110.2, "end": 111.759995, "text": "va a ser el de mayo", "speaker": null}, {"start": 111.759995, "end": 113.59999, "text": "A ver, chécalo.", "speaker": null}, {"start": 114.03999, "end": 117.079994, "text": "145.527.", "speaker": null}, {"start": 118.2, "end": 127.7, "text": "A ver, supóngase como ejemplo que en este caso el índice nacional de precios del consumidor", "speaker": null}, {"start": 127.7, "end": 135.12, "text": "se en mayo del 26, ¿cuánto es?", "speaker": null}, {"start": 135.98, "end": 140.92, "text": "145.527.", "speaker": null}, {"start": 140.92, "end": 142.76, "text": "punto 527", "speaker": null}, {"start": 142.76, "end": 143.78, "text": "¿así nada más?", "speaker": null}, {"start": 144.74, "end": 146.08, "text": "¿no trae más dígitos?", "speaker": null}, {"start": 146.5, "end": 147.18, "text": "¿debe traer más?", "speaker": null}, {"start": 149.44, "end": 150.52, "text": "bueno, no importa", "speaker": null}, {"start": 150.52, "end": 152.48, "text": "¿cuál es la diferencia?", "speaker": null}, {"start": 152.92, "end": 154.59999, "text": "que la ley te dice que tienes que tomar", "speaker": null}, {"start": 154.59999, "end": 157.5, "text": "después del punto hasta diez milésimos", "speaker": null}, {"start": 157.5, "end": 157.95999, "text": "¿de acuerdo?", "speaker": null}, {"start": 158.86, "end": 160.42, "text": "y vamos a actualizar un bien", "speaker": null}, {"start": 160.42, "end": 162.58, "text": "que pongamos como ejemplo", "speaker": null}, {"start": 162.58, "end": 163.54, "text": "lo compramos", "speaker": null}, {"start": 163.54, "end": 165.31999, "text": "no lo sé", "speaker": null}, {"start": 165.31999, "end": 168.58, "text": "en noviembre", "speaker": null}, {"start": 168.58, "end": 169.56, "text": "búscalo por favor", "speaker": null}, {"start": 169.56, "end": 176.18, "text": "en noviembre del 2020.", "speaker": null}, {"start": 185.18, "end": 186.9, "text": "108.", "speaker": null}, {"start": 187.34, "end": 188.2, "text": "¿Cuánto es?", "speaker": null}, {"start": 188.54, "end": 191.06, "text": "108.856.", "speaker": null}, {"start": 191.37999, "end": 191.94, "text": "108.", "speaker": null}, {"start": 192.5, "end": 194.44, "text": "856.", "speaker": null}, {"start": 194.78, "end": 196.45999, "text": "856.", "speaker": null}, {"start": 196.45999, "end": 199.73999, "text": "aquí tendríamos nosotros", "speaker": null}, {"start": 199.73999, "end": 201.9, "text": "un ejemplo de índices", "speaker": null}, {"start": 201.9, "end": 202.85999, "text": "reales", "speaker": null}, {"start": 202.85999, "end": 205.62, "text": "para medir cuál fue el impacto", "speaker": null}, {"start": 205.62, "end": 207.81999, "text": "inflacionario desde noviembre", "speaker": null}, {"start": 207.81999, "end": 208.79999, "text": "del 2020", "speaker": null}, {"start": 208.79999, "end": 212.01999, "text": "hasta mayo del 2026", "speaker": null}, {"start": 212.01999, "end": 214.13998, "text": "¿qué haríamos ahora?", "speaker": null}, {"start": 214.35999, "end": 215.43999, "text": "sustituirlos", "speaker": null}, {"start": 215.43999, "end": 216.68, "text": "y tendríamos", "speaker": null}, {"start": 216.68, "end": 219.7, "text": "145.527", "speaker": null}, {"start": 221.23999, "end": 234.31801, "text": "sobre 108 por muchos sustituimos va a ser el en este caso", "speaker": null}, {"start": 236.198, "end": 237.89801, "text": "O sea, el factor de actualización.", "speaker": null}, {"start": 238.418, "end": 239.89801, "text": "1.33.", "speaker": null}, {"start": 240.798, "end": 242.61801, "text": "1.33.", "speaker": null}, {"start": 243.998, "end": 248.45801, "text": "Luego entonces, hemos tenido el factor del 33%.", "speaker": null}, {"start": 248.45801, "end": 251.138, "text": "de incremento general", "speaker": null}, {"start": 251.138, "end": 253.098, "text": "de esta fecha", "speaker": null}, {"start": 253.098, "end": 254.218, "text": "a esta fecha", "speaker": null}, {"start": 254.218, "end": 256.958, "text": "esto sería como un ejemplo", "speaker": null}, {"start": 256.958, "end": 261.118, "text": "con la tabla de I", "speaker": null}, {"start": 261.118, "end": 272.138, "text": "si se observa", "speaker": null}, {"start": 272.138, "end": 274.258, "text": "así es", "speaker": null}, {"start": 274.258, "end": 276.978, "text": "ahora repito", "speaker": null}, {"start": 276.978, "end": 282.618, "text": "Si tú buscas ahorita el de junio, te garantizo que no lo vas a encontrar en ninguna.", "speaker": null}, {"start": 283.398, "end": 285.998, "text": "Porque todavía no lo publican. ¿Cuándo lo van a publicar?", "speaker": null}, {"start": 286.418, "end": 291.978, "text": "Hasta los primeros 10 días del mes de julio.", "speaker": null}, {"start": 292.818, "end": 299.678, "text": "El de julio, hasta los primeros 10 días del mes de agosto y así sucesivamente.", "speaker": null}, {"start": 299.678, "end": 319.178, "text": "Entonces los estados, todo lo que es capital, bueno que no sea monetario, se tiene que modificar.", "speaker": null}, {"start": 319.178, "end": 321.358, "text": "todos, todos", "speaker": null}, {"start": 321.358, "end": 323.898, "text": "cuando tú tengas que reexpresar", "speaker": null}, {"start": 323.898, "end": 324.358, "text": "Charly", "speaker": null}, {"start": 324.358, "end": 327.598, "text": "aquí se tiene mucho cuidado", "speaker": null}, {"start": 327.598, "end": 330.078, "text": "el boletín de 10", "speaker": null}, {"start": 330.078, "end": 331.498, "text": "que es quien norma esto", "speaker": null}, {"start": 331.498, "end": 333.338, "text": "dentro de las NICS", "speaker": null}, {"start": 333.338, "end": 335.978, "text": "ustedes no saben mucho de esto", "speaker": null}, {"start": 335.978, "end": 337.778, "text": "pero nosotros los contadores nos basamos", "speaker": null}, {"start": 337.778, "end": 339.538, "text": "en algo que se llama las NICS", "speaker": null}, {"start": 339.538, "end": 342.158, "text": "que son las normas de información", "speaker": null}, {"start": 342.158, "end": 342.818, "text": "financiera", "speaker": null}, {"start": 342.818, "end": 345.878, "text": "que nos marca las reglas que debemos", "speaker": null}, {"start": 345.878, "end": 347.518, "text": "nosotros utilizar para poder", "speaker": null}, {"start": 347.518, "end": 348.758, "text": "manejar", "speaker": null}, {"start": 348.758, "end": 350.798, "text": "pues básicamente", "speaker": null}, {"start": 350.798, "end": 353.418, "text": "la información financiera", "speaker": null}, {"start": 353.418, "end": 355.618, "text": "entonces el boletín", "speaker": null}, {"start": 355.618, "end": 357.678, "text": "nos dice que nosotros tengamos que aplicar", "speaker": null}, {"start": 357.678, "end": 359.018, "text": "el boletín B10", "speaker": null}, {"start": 359.018, "end": 361.59802, "text": "y el boletín B10", "speaker": null}, {"start": 361.59802, "end": 363.578, "text": "nos marca que dos métodos", "speaker": null}, {"start": 363.578, "end": 364.518, "text": "de reexpresión", "speaker": null}, {"start": 364.518, "end": 367.018, "text": "el de cambio", "speaker": null}, {"start": 367.018, "end": 369.21802, "text": "en el nivel general de precios", "speaker": null}, {"start": 369.21802, "end": 370.958, "text": "y el de reexpresión", "speaker": null}, {"start": 370.958, "end": 374.078, "text": "este es el de cambio en el nivel general de precios", "speaker": null}, {"start": 374.078, "end": 375.418, "text": "entonces", "speaker": null}, {"start": 375.418, "end": 377.878, "text": "cuando tú reexpresas", "speaker": null}, {"start": 377.878, "end": 380.038, "text": "información financiera, el B10", "speaker": null}, {"start": 380.038, "end": 382.17798, "text": "te marca que lo que", "speaker": null}, {"start": 382.17798, "end": 383.878, "text": "nosotros vamos a reexpresar", "speaker": null}, {"start": 383.878, "end": 386.398, "text": "van a ser las partidas", "speaker": null}, {"start": 386.398, "end": 388.018, "text": "no monetarias.", "speaker": null}, {"start": 388.918, "end": 390.198, "text": "Es decir, te van a", "speaker": null}, {"start": 390.198, "end": 391.898, "text": "hablar de lo que son partidas", "speaker": null}, {"start": 391.898, "end": 394.598, "text": "monetarias y partidas", "speaker": null}, {"start": 394.598, "end": 396.21802, "text": "no monetarias.", "speaker": null}, {"start": 397.05798, "end": 398.138, "text": "¿Cuáles son las partidas", "speaker": null}, {"start": 398.138, "end": 399.278, "text": "monetarias? El dinero.", "speaker": null}, {"start": 400.15802, "end": 401.018, "text": "O sea, el billete.", "speaker": null}, {"start": 402.098, "end": 403.298, "text": "Yo aquí tenía un billete,", "speaker": null}, {"start": 403.298, "end": 407.018, "text": "¿Ese billete yo lo tendría que reexpresar?", "speaker": null}, {"start": 407.618, "end": 410.418, "text": "No, no lo puedo reexpresar", "speaker": null}, {"start": 410.418, "end": 413.678, "text": "Porque tiene un valor dominante circulante", "speaker": null}, {"start": 413.678, "end": 415.438, "text": "¿Correcto?", "speaker": null}, {"start": 416.698, "end": 419.698, "text": "¿Pero qué sí tengo que reexpresar?", "speaker": null}, {"start": 420.21802, "end": 422.818, "text": "Las partidas no monetarias", "speaker": null}, {"start": 422.818, "end": 425.078, "text": "¿Cuál sería una partida no monetaria?", "speaker": null}, {"start": 425.078, "end": 427.298, "text": "Por ejemplo, un coche", "speaker": null}, {"start": 427.298, "end": 431.078, "text": "Por ejemplo, un escritorio", "speaker": null}, {"start": 431.078, "end": 436.078, "text": "Por ejemplo, un activo fijo, el que tú quieras.", "speaker": null}, {"start": 436.078, "end": 439.078, "text": "¿Y las que son como inversiones como de certezas o…?", "speaker": null}, {"start": 439.078, "end": 443.078, "text": "No, no las puedes pesar porque es monetario. O sea…", "speaker": null}, {"start": 443.078, "end": 444.078, "text": "¿Igual acciones?", "speaker": null}, {"start": 444.078, "end": 457.23602, "text": "Tampoco tampoco porque se reflejan en dinero Todo lo que es monetario no lo puedes expresar Lo que vas a expresar son precisamente las partidas no monetarias", "speaker": null}, {"start": 457.476, "end": 472.876, "text": "O sea, estaríamos hablando de que tenemos partidas monetarias y partidas no monetarias.", "speaker": null}, {"start": 472.876, "end": 478.376, "text": "las que vamos a respetar son las partidas no monetarias", "speaker": null}, {"start": 478.376, "end": 481.11603, "text": "¿está bien?", "speaker": null}, {"start": 482.596, "end": 483.67603, "text": "¿vuelve bien o no regresa?", "speaker": null}, {"start": 485.17603, "end": 486.776, "text": "si, y nada más es multiplicar", "speaker": null}, {"start": 486.776, "end": 488.456, "text": "por el...", "speaker": null}, {"start": 488.456, "end": 490.556, "text": "si, en este caso", "speaker": null}, {"start": 490.556, "end": 492.79602, "text": "como informático si te lo llegan a pedir", "speaker": null}, {"start": 492.79602, "end": 495.436, "text": "ahí si no tienes ningún problema", "speaker": null}, {"start": 495.436, "end": 497.396, "text": "porque bajas tu tabla", "speaker": null}, {"start": 497.396, "end": 499.61603, "text": "y nada más le pides que se esté actualizando", "speaker": null}, {"start": 499.61603, "end": 501.396, "text": "constantemente en función del internet", "speaker": null}, {"start": 501.396, "end": 503.63602, "text": "no sé cómo lo vayas a hacer, pero lo haces", "speaker": null}, {"start": 503.63602, "end": 505.776, "text": "te lo digo porque eso sí lo hacen", "speaker": null}, {"start": 505.776, "end": 506.816, "text": "los informáticos", "speaker": null}, {"start": 506.816, "end": 510.036, "text": "ellos cuando le necesitamos que nos lo expresen", "speaker": null}, {"start": 510.036, "end": 511.29602, "text": "ya nos", "speaker": null}, {"start": 511.29602, "end": 513.43604, "text": "dan una pantalla al usuario", "speaker": null}, {"start": 513.43604, "end": 515.296, "text": "en donde nada más ponemos la cantidad", "speaker": null}, {"start": 515.296, "end": 517.676, "text": "y chingan el saldo", "speaker": null}, {"start": 517.676, "end": 519.43604, "text": "porque ustedes ya", "speaker": null}, {"start": 519.43604, "end": 521.136, "text": "lo que hacen es que toman como", "speaker": null}, {"start": 521.136, "end": 523.776, "text": "no sé, como base de datos la tabla", "speaker": null}, {"start": 523.776, "end": 525.276, "text": "por poner un ejemplo", "speaker": null}, {"start": 525.276, "end": 528.056, "text": "en otra celda", "speaker": null}, {"start": 528.056, "end": 529.99603, "text": "en otra celda", "speaker": null}, {"start": 529.99603, "end": 533.476, "text": "meten la opción para mí como usuario", "speaker": null}, {"start": 533.476, "end": 535.676, "text": "de variar la cifra base", "speaker": null}, {"start": 535.676, "end": 537.276, "text": "correcto", "speaker": null}, {"start": 537.276, "end": 539.636, "text": "y este factor", "speaker": null}, {"start": 539.636, "end": 542.596, "text": "ustedes lo vinculan", "speaker": null}, {"start": 542.596, "end": 545.036, "text": "no sé si sea el término correcto", "speaker": null}, {"start": 545.036, "end": 546.43604, "text": "con la tabla", "speaker": null}, {"start": 546.43604, "end": 548.076, "text": "va, lo busca", "speaker": null}, {"start": 548.076, "end": 549.756, "text": "y ahí en automático", "speaker": null}, {"start": 549.756, "end": 552.596, "text": "me aparece la cifra actualizada", "speaker": null}, {"start": 552.596, "end": 558.716, "text": "repito, eso no se conglomerará en ustedes", "speaker": null}, {"start": 558.716, "end": 559.956, "text": "tengo idea", "speaker": null}, {"start": 559.956, "end": 561.796, "text": "porque no lo hago yo", "speaker": null}, {"start": 561.796, "end": 564.656, "text": "o sea yo le hablo a mis técnicos", "speaker": null}, {"start": 564.656, "end": 565.93604, "text": "en informática y acabo", "speaker": null}, {"start": 565.93604, "end": 568.796, "text": "necesitamos reexpresar", "speaker": null}, {"start": 568.796, "end": 570.656, "text": "ay una madre yo no sé cómo se hace", "speaker": null}, {"start": 570.656, "end": 572.19604, "text": "no sé pero tienes que hacer", "speaker": null}, {"start": 572.19604, "end": 574.856, "text": "lógicamente si no saben", "speaker": null}, {"start": 574.856, "end": 576.476, "text": "de esto pues", "speaker": null}, {"start": 576.476, "end": 578.276, "text": "se les caen los calzones", "speaker": null}, {"start": 578.276, "end": 580.556, "text": "les tenemos que explicar", "speaker": null}, {"start": 580.556, "end": 582.776, "text": "entonces necesito", "speaker": null}, {"start": 582.776, "end": 584.716, "text": "que tú en tu sistema", "speaker": null}, {"start": 584.716, "end": 586.93604, "text": "me generes una base", "speaker": null}, {"start": 586.93604, "end": 588.756, "text": "de datos para que", "speaker": null}, {"start": 588.756, "end": 590.756, "text": "cuando yo le inserte la cifra base", "speaker": null}, {"start": 590.756, "end": 593.276, "text": "el algoritmo", "speaker": null}, {"start": 593.276, "end": 595.516, "text": "que tú diseñes", "speaker": null}, {"start": 595.516, "end": 597.296, "text": "vaya, busque", "speaker": null}, {"start": 597.296, "end": 598.376, "text": "el índice", "speaker": null}, {"start": 598.376, "end": 601.43604, "text": "lo jale, vaya, busque el otro", "speaker": null}, {"start": 601.43604, "end": 603.236, "text": "lo jale y haga", "speaker": null}, {"start": 603.236, "end": 605.216, "text": "esta ecuación y a mí me aparece", "speaker": null}, {"start": 605.216, "end": 606.716, "text": "en automático esta cifra", "speaker": null}, {"start": 606.716, "end": 609.43604, "text": "cuando le dices eso, en dos patadas", "speaker": null}, {"start": 609.43604, "end": 609.876, "text": "lo hace", "speaker": null}, {"start": 609.876, "end": 611.93604, "text": "ellos sabrán", "speaker": null}, {"start": 611.93604, "end": 614.076, "text": "como demonios lo jalan", "speaker": null}, {"start": 614.076, "end": 616.216, "text": "así no te puedo decir", "speaker": null}, {"start": 616.216, "end": 618.376, "text": "porque no soy informático", "speaker": null}, {"start": 618.376, "end": 620.916, "text": "pero él está resolviendo", "speaker": null}, {"start": 620.916, "end": 623.456, "text": "el tema en dos patadas", "speaker": null}, {"start": 623.456, "end": 625.396, "text": "pero ¿qué tuvo que hacer él?", "speaker": null}, {"start": 625.796, "end": 627.096, "text": "pues primero le pide explicar", "speaker": null}, {"start": 627.096, "end": 628.376, "text": "qué es lo que él quiere", "speaker": null}, {"start": 628.376, "end": 631.016, "text": "para que él lo adapte a su mente", "speaker": null}, {"start": 631.016, "end": 633.596, "text": "es exactamente", "speaker": null}, {"start": 633.596, "end": 635.31604, "text": "lo mismo que vamos a hacer en todo", "speaker": null}, {"start": 635.31604, "end": 637.076, "text": "por eso es que ustedes", "speaker": null}, {"start": 637.076, "end": 638.596, "text": "los tenemos ahorita aquí", "speaker": null}, {"start": 638.596, "end": 641.556, "text": "si, vamos a entenderlo", "speaker": null}, {"start": 641.556, "end": 643.596, "text": "como verán", "speaker": null}, {"start": 643.596, "end": 644.296, "text": "pues esto sí", "speaker": null}, {"start": 644.296, "end": 647.31604, "text": "y aquí a diferencia de otros procesos", "speaker": null}, {"start": 647.31604, "end": 650.116, "text": "Pues aquí una simple fórmula lo resuelves.", "speaker": null}, {"start": 651.476, "end": 651.956, "text": "¿Estás de acuerdo?", "speaker": null}, {"start": 652.656, "end": 655.836, "text": "El informático no tiene más que desarrollar la fórmula", "speaker": null}, {"start": 655.836, "end": 660.376, "text": "con los elementos procesados y con eso resolver el problema.", "speaker": null}, {"start": 661.376, "end": 663.636, "text": "Lo que no sucede con los demás métodos.", "speaker": null}, {"start": 666.576, "end": 667.69604, "text": "¿Sí? ¿Sí me explico?", "speaker": null}, {"start": 668.516, "end": 680.274, "text": "Y aunque sucediera si no sabe cu es el procedimiento no lo puede vaciar en la m Muy bien hombre regreso", "speaker": null}, {"start": 682.814, "end": 683.254, "text": "¿Seguros?", "speaker": null}, {"start": 684.274, "end": 684.714, "text": "¿Dudas?", "speaker": null}, {"start": 685.494, "end": 686.814, "text": "Te veo pensativo, Mike.", "speaker": null}, {"start": 687.13403, "end": 689.914, "text": "Sí, ¿qué sería, bueno, un poquito más en un día,", "speaker": null}, {"start": 689.974, "end": 692.114, "text": "cómo sería la parte de la...", "speaker": null}, {"start": 692.114, "end": 694.494, "text": "¿Cómo?", "speaker": null}, {"start": 694.494, "end": 694.554, "text": "¿Cómo?", "speaker": null}, {"start": 694.554, "end": 696.854, "text": "¿Cómo? ¿Cómo? ¿Cómo?", "speaker": null}, {"start": 697.854, "end": 699.19403, "text": "La partida de los monetarios.", "speaker": null}, {"start": 699.494, "end": 700.89404, "text": "¿La partida de los monetarios?", "speaker": null}, {"start": 701.234, "end": 702.534, "text": "Ya lo mencioné.", "speaker": null}, {"start": 703.034, "end": 705.354, "text": "Son todos aquellos bienes", "speaker": null}, {"start": 705.354, "end": 707.754, "text": "que no están", "speaker": null}, {"start": 707.754, "end": 708.374, "text": "en dinero.", "speaker": null}, {"start": 710.114, "end": 710.534, "text": "Repito,", "speaker": null}, {"start": 710.714, "end": 712.734, "text": "¿qué tipo de partidas", "speaker": null}, {"start": 712.734, "end": 714.214, "text": "o qué tipo de bienes tengo que no?", "speaker": null}, {"start": 714.434, "end": 715.674, "text": "Que no son en dinero.", "speaker": null}, {"start": 716.434, "end": 717.89404, "text": "No sé, una computadora.", "speaker": null}, {"start": 718.814, "end": 720.334, "text": "No lo sé, un auto.", "speaker": null}, {"start": 721.234, "end": 722.95404, "text": "No lo sé, un escritorio.", "speaker": null}, {"start": 723.07404, "end": 723.554, "text": "Está difícil.", "speaker": null}, {"start": 724.554, "end": 729.474, "text": "un bien, el inventario, la mercancía,", "speaker": null}, {"start": 730.69403, "end": 732.01404, "text": "¿sí? Porque no es monetario.", "speaker": null}, {"start": 732.914, "end": 735.534, "text": "Todo eso lo tengo que respetar, porque cambió su valor.", "speaker": null}, {"start": 736.874, "end": 739.614, "text": "Sencillamente, con el puro transcurso del tiempo, cambió su valor.", "speaker": null}, {"start": 740.154, "end": 742.334, "text": "Y no necesariamente es por el transcurso del tiempo,", "speaker": null}, {"start": 742.334, "end": 743.934, "text": "es el punto mínimo.", "speaker": null}, {"start": 745.07404, "end": 747.054, "text": "Si se va a cambiar el valor, ¿por qué?", "speaker": null}, {"start": 748.13403, "end": 751.674, "text": "Por los diversos elementos que se consagran", "speaker": null}, {"start": 751.674, "end": 754.434, "text": "en el sentido de variación de valor.", "speaker": null}, {"start": 754.554, "end": 757.174, "text": "¿cuáles serían esos?", "speaker": null}, {"start": 758.174, "end": 759.974, "text": "el exceso de circular", "speaker": null}, {"start": 759.974, "end": 760.834, "text": "en el país", "speaker": null}, {"start": 760.834, "end": 762.834, "text": "por eso es que si te das cuenta", "speaker": null}, {"start": 762.834, "end": 765.854, "text": "el Banco de México", "speaker": null}, {"start": 765.854, "end": 767.254, "text": "en su momento vamos a hablar", "speaker": null}, {"start": 767.254, "end": 768.614, "text": "de quién es el Banco de México", "speaker": null}, {"start": 768.614, "end": 772.114, "text": "es el encargado de regular", "speaker": null}, {"start": 772.114, "end": 774.674, "text": "la emisión y la circulación", "speaker": null}, {"start": 774.674, "end": 776.034, "text": "del dinero", "speaker": null}, {"start": 776.034, "end": 779.214, "text": "si nada más fuera", "speaker": null}, {"start": 779.214, "end": 781.214, "text": "emitir billetes", "speaker": null}, {"start": 781.214, "end": 782.57404, "text": "y monedas", "speaker": null}, {"start": 782.57404, "end": 784.234, "text": "eso sería muy fácil", "speaker": null}, {"start": 784.234, "end": 786.69403, "text": "¿por qué crees que no lo hacen?", "speaker": null}, {"start": 788.494, "end": 790.414, "text": "porque el exceso de circulación", "speaker": null}, {"start": 790.414, "end": 791.354, "text": "por lo que pasa", "speaker": null}, {"start": 791.354, "end": 793.89404, "text": "ellos no pueden estar", "speaker": null}, {"start": 793.89404, "end": 794.934, "text": "alentando billetes", "speaker": null}, {"start": 794.934, "end": 798.414, "text": "hay parámetros", "speaker": null}, {"start": 798.414, "end": 800.69403, "text": "económicos financieros", "speaker": null}, {"start": 800.69403, "end": 802.594, "text": "que no les permiten", "speaker": null}, {"start": 802.594, "end": 803.51404, "text": "emitir dinero", "speaker": null}, {"start": 803.51404, "end": 805.69403, "text": "hasta cierto nivel", "speaker": null}, {"start": 805.69403, "end": 807.314, "text": "y eso que", "speaker": null}, {"start": 807.314, "end": 809.934, "text": "ahí se nos es, ustedes lo vean", "speaker": null}, {"start": 809.934, "end": 811.854, "text": "nosotros los contadores y lo vemos", "speaker": null}, {"start": 811.854, "end": 814.374, "text": "no sé si a ustedes les dan", "speaker": null}, {"start": 814.374, "end": 817.89404, "text": "materias de economía", "speaker": null}, {"start": 817.89404, "end": 822.254, "text": "en teoría ustedes deberían de llevar", "speaker": null}, {"start": 822.254, "end": 823.614, "text": "bueno no, no ustedes", "speaker": null}, {"start": 823.614, "end": 825.794, "text": "repito no lo sé si deberían de ustedes", "speaker": null}, {"start": 825.794, "end": 828.054, "text": "pero por ejemplo nosotros llevamos", "speaker": null}, {"start": 828.054, "end": 830.254, "text": "economía, macroeconomía", "speaker": null}, {"start": 830.994, "end": 832.254, "text": "y microeconomía", "speaker": null}, {"start": 833.01404, "end": 835.994, "text": "porque ahí nosotros analizamos", "speaker": null}, {"start": 835.994, "end": 837.434, "text": "lo que se conoce como", "speaker": null}, {"start": 837.434, "end": 839.354, "text": "agregados monetarios", "speaker": null}, {"start": 839.354, "end": 844.63403, "text": "que es el M1, el M2, el M3", "speaker": null}, {"start": 844.63403, "end": 849.174, "text": "para poder establecer cómo se encuentra el país", "speaker": null}, {"start": 849.174, "end": 852.554, "text": "y en un agregado monetario", "speaker": null}, {"start": 852.554, "end": 856.734, "text": "por ejemplo, evaluamos no nada más el dinero de circulación", "speaker": null}, {"start": 856.734, "end": 860.554, "text": "sino el dinero documentado", "speaker": null}, {"start": 861.114, "end": 863.714, "text": "por ejemplo, los cheques", "speaker": null}, {"start": 863.714, "end": 871.094, "text": "de hecho", "speaker": null}, {"start": 871.094, "end": 874.114, "text": "pica de ahí", "speaker": null}, {"start": 874.114, "end": 878.274, "text": "y pica de ahí", "speaker": null}, {"start": 878.274, "end": 880.454, "text": "y pone agregados inventarios", "speaker": null}, {"start": 880.454, "end": 882.974, "text": "y te va a dar como resultado", "speaker": null}, {"start": 882.974, "end": 884.214, "text": "el elemento que me dio", "speaker": null}, {"start": 884.214, "end": 884.954, "text": "73", "speaker": null}, {"start": 884.954, "end": 886.794, "text": "aquí viene", "speaker": null}, {"start": 886.794, "end": 890.254, "text": "no sé si está marcado", "speaker": null}, {"start": 890.254, "end": 891.214, "text": "aquí dice el M0", "speaker": null}, {"start": 891.214, "end": 893.214, "text": "¿Sí?", "speaker": null}]