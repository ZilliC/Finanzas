[{"start": 0.0, "end": 17.3, "text": "Hoy vamos a tener un pequeño y muy sencillo, una pequeña y muy sencilla demarca.", "speaker": null}, {"start": 18.359999, "end": 24.3, "text": "Yo sé que no hay en la mano, yo les diría ahorita, saquen su ley, esa es la expresión", "speaker": null}, {"start": 24.3, "end": 28.779999, "text": "de nosotros los contadores. A ver jóvenes, saquen su ley, vamos a checar.", "speaker": null}, {"start": 30.0, "end": 32.6, "text": "Yo sé que si les digo eso, que sonita me traba la menta.", "speaker": null}, {"start": 36.1, "end": 37.88, "text": "No, pero ustedes son informáticos.", "speaker": null}, {"start": 39.3, "end": 40.88, "text": "Es más, pregúntale a Super Google.", "speaker": null}, {"start": 41.46, "end": 43.32, "text": "Tengo la chance de que sea que se tuve para qué.", "speaker": null}, {"start": 45.7, "end": 47.72, "text": "El rey de los informáticos.", "speaker": null}, {"start": 49.92, "end": 51.239998, "text": "Pregúntale a Super Google.", "speaker": null}, {"start": 51.86, "end": 53.96, "text": "Y antes de que Super Google te conteste,", "speaker": null}, {"start": 54.54, "end": 58.02, "text": "yo te aseguro que tiene que hablar de lo que es", "speaker": null}, {"start": 58.02, "end": 61.14, "text": "la fórmula de las paires.", "speaker": null}, {"start": 63.28, "end": 64.74, "text": "Yo estoy seguro que Super Google", "speaker": null}, {"start": 64.74, "end": 66.74, "text": "te tiene que decir", "speaker": null}, {"start": 66.74, "end": 68.94, "text": "que se ocupan con llegadores.", "speaker": null}, {"start": 70.46, "end": 72.64, "text": "Yo sé que Super Google te tiene que decir", "speaker": null}, {"start": 72.64, "end": 74.64, "text": "que tienes que tomar agustreos", "speaker": null}, {"start": 74.64, "end": 76.76, "text": "en zonas con cuando menos", "speaker": null}, {"start": 76.76, "end": 78.28, "text": "de mil habitantes.", "speaker": null}, {"start": 79.74, "end": 80.76, "text": "Yo sé que Super Google", "speaker": null}, {"start": 80.76, "end": 83.18, "text": "te va a decir que cuando menos", "speaker": null}, {"start": 83.18, "end": 83.92, "text": "tienes que tomar", "speaker": null}, {"start": 83.92, "end": 86.56, "text": "mil prometos", "speaker": null}, {"start": 86.56, "end": 89.1, "text": "cuando menos entre bienes y sentimientos", "speaker": null}, {"start": 89.1, "end": 91.399994, "text": "yo sé que", "speaker": null}, {"start": 91.399994, "end": 93.619995, "text": "el perú te tiene que contestar", "speaker": null}, {"start": 93.619995, "end": 94.939995, "text": "que cuando menos lo vas a hacer", "speaker": null}, {"start": 94.939995, "end": 96.079994, "text": "tres veces al mes", "speaker": null}, {"start": 96.079994, "end": 99.119995, "text": "yo sé que cuando menos te tiene que decir", "speaker": null}, {"start": 99.119995, "end": 100.579994, "text": "que tienes que separar cuando menos", "speaker": null}, {"start": 100.579994, "end": 103.21999, "text": "si puedes de consumo", "speaker": null}, {"start": 103.21999, "end": 105.38, "text": "yo sé muchas otras cosas", "speaker": null}, {"start": 105.38, "end": 105.88, "text": "más", "speaker": null}, {"start": 105.88, "end": 109.18, "text": "pregúntale a su perú", "speaker": null}, {"start": 109.18, "end": 110.14, "text": "¿qué es la fecha?", "speaker": null}, {"start": 114.64, "end": 116.0, "text": "¿está pensando en la idea?", "speaker": null}, {"start": 116.56, "end": 121.36, "text": "Parece que ya es al gas de los grupos, ahorita mejora los gastos.", "speaker": null}, {"start": 123.18, "end": 124.92, "text": "¿Qué nos dice la IA?", "speaker": null}, {"start": 127.36, "end": 132.22, "text": "Dice, como señala la canasta de bienes y servicios,", "speaker": null}, {"start": 133.92, "end": 138.42, "text": "necesita saber con precisión en qué gastan los mexicanos.", "speaker": null}, {"start": 139.14, "end": 141.92, "text": "¿Se hace la encuesta nacional de ingresos y gastos de hogares?", "speaker": null}, {"start": 141.92, "end": 171.9, "text": "¿Qué es lo que dice?", "speaker": null}, {"start": 171.92, "end": 177.92, "text": "ustedes son muy aceptos con la creencia y la identidad, nosotros no.", "speaker": null}, {"start": 177.92, "end": 187.92, "text": "Ahora cámbiate de página, regresa con tu Super Google en el buscador que tú quieras.", "speaker": null}, {"start": 187.92, "end": 191.92, "text": "¿Cuál es el de los buscadores Chrome? ¿Qué otro?", "speaker": null}, {"start": 191.92, "end": 193.92, "text": "No, esos son navegadores.", "speaker": null}, {"start": 193.92, "end": 195.92, "text": "Ah, navegadores, perdón.", "speaker": null}, {"start": 195.92, "end": 197.92, "text": "Los buscadores Chrome. Chrome es...", "speaker": null}, {"start": 197.92, "end": 198.92, "text": "¿Estás ahorita?", "speaker": null}, {"start": 198.92, "end": 199.92, "text": "Safari y Firefox.", "speaker": null}, {"start": 199.92, "end": 202.22, "text": "o el chorrito, o la gorrita, no sé cuál cosa.", "speaker": null}, {"start": 203.62, "end": 204.2, "text": "¿Hecho?", "speaker": null}, {"start": 204.28, "end": 205.7, "text": "O el coñac, también hay hecho.", "speaker": null}, {"start": 206.8, "end": 207.81999, "text": "El que quiera.", "speaker": null}, {"start": 209.68, "end": 211.74, "text": "Y ahora vamos a cambiar las cosas.", "speaker": null}, {"start": 211.9, "end": 212.5, "text": "Vamos a ver", "speaker": null}, {"start": 212.5, "end": 216.26, "text": "que si en vez de ocupar la inteligencia artificial", "speaker": null}, {"start": 216.26, "end": 218.12, "text": "ocupo la inteligencia natural,", "speaker": null}, {"start": 218.45999, "end": 230.098, "text": "puedo tener mejor certeza de las cosas Por favor p ah y b el c fiscal de la Federaci", "speaker": null}, {"start": 242.278, "end": 245.25801, "text": "A ver si lo encuentran, a ver si lo reconocen.", "speaker": null}, {"start": 245.25801, "end": 251.83801, "text": "al estar en el diario oficial de la delegación", "speaker": null}, {"start": 251.83801, "end": 253.11801, "text": "¿eso qué nos dice Carlos?", "speaker": null}, {"start": 255.11801, "end": 256.15802, "text": "Carlos, lo oficial", "speaker": null}, {"start": 256.15802, "end": 263.458, "text": "es lo que todos los mexicanos estamos obligados a cumplir", "speaker": null}, {"start": 263.458, "end": 266.478, "text": "quieras o no, te pregunten o no", "speaker": null}, {"start": 266.478, "end": 267.978, "text": "¿estamos de acuerdo?", "speaker": null}, {"start": 268.938, "end": 272.118, "text": "bueno, antes de esto", "speaker": null}, {"start": 272.118, "end": 281.418, "text": "jóvenes. Nadie de ustedes me lo ríe. Lo entiendo, acaban de decir que no lo ríen,", "speaker": null}, {"start": 282.418, "end": 288.15802, "text": "pero quien se los... Yo les he enseñado, les digo que para calcular la inflación lo", "speaker": null}, {"start": 288.15802, "end": 295.818, "text": "hacemos a través de lo que se llama Índice Nacional de Precios al Consumidor. Y el Índice", "speaker": null}, {"start": 295.818, "end": 297.358, "text": "Nacional de Precios al Consumidor", "speaker": null}, {"start": 297.358, "end": 300.298, "text": "lo va a calcular", "speaker": null}, {"start": 300.298, "end": 300.798, "text": "quién?", "speaker": null}, {"start": 301.698, "end": 303.338, "text": "El Instituto Nacional", "speaker": null}, {"start": 303.338, "end": 305.238, "text": "de Geografía,", "speaker": null}, {"start": 305.838, "end": 307.038, "text": "correcto, que es lo que ahora", "speaker": null}, {"start": 307.038, "end": 308.258, "text": "se titula el INEGI.", "speaker": null}, {"start": 309.138, "end": 310.478, "text": "Antes era quien formaba.", "speaker": null}, {"start": 312.118, "end": 313.298, "text": "Ellos lo van a calcular", "speaker": null}, {"start": 313.298, "end": 314.738, "text": "y lo van a publicar a un público.", "speaker": null}, {"start": 315.518, "end": 317.198, "text": "¿Cuándo lo van a publicar? Dentro de los", "speaker": null}, {"start": 317.198, "end": 318.698, "text": "primeros 10 días de carnes.", "speaker": null}, {"start": 320.05798, "end": 320.618, "text": "Correcto.", "speaker": null}, {"start": 321.078, "end": 321.858, "text": "Bueno, eso digo yo.", "speaker": null}, {"start": 323.298, "end": 325.05798, "text": "¿Pero qué les parece si lo verificamos?", "speaker": null}, {"start": 325.818, "end": 332.418, "text": "¿En dónde buscaríamos de todo ese documento, Charly? ¿Dónde queréis que venga la información necesaria?", "speaker": null}, {"start": 333.278, "end": 337.078, "text": "Ahí ya tienes la fuente. ¿A dónde nos traen?", "speaker": null}, {"start": 338.418, "end": 344.838, "text": "Pues te vas a tener que reventar artículo por artículo, fracción por fracción, inciso por inciso, cuadro por cuadro.", "speaker": null}, {"start": 345.498, "end": 349.878, "text": "¿O no? ¿Qué es lo que hacemos nosotros los contadores?", "speaker": null}, {"start": 349.878, "end": 353.05798, "text": "Tú me vas a contestar", "speaker": null}, {"start": 353.05798, "end": 354.21802, "text": "Sí, soy contador", "speaker": null}, {"start": 354.21802, "end": 355.778, "text": "Por eso no soy contador", "speaker": null}, {"start": 355.778, "end": 359.018, "text": "Te voy a ayudar un poco conmigo", "speaker": null}, {"start": 359.018, "end": 362.998, "text": "Ya que estás en el código", "speaker": null}, {"start": 362.998, "end": 364.858, "text": "Ya te han dado cuenta", "speaker": null}, {"start": 364.858, "end": 366.71802, "text": "Que el código se maneja por artículos", "speaker": null}, {"start": 366.71802, "end": 368.418, "text": "¿Es correcto?", "speaker": null}, {"start": 369.618, "end": 370.258, "text": "¿Tú qué haces?", "speaker": null}, {"start": 370.618, "end": 371.738, "text": "Lo hice", "speaker": null}, {"start": 371.738, "end": 374.97803, "text": "Vete al artículo 20 bis", "speaker": null}, {"start": 374.97803, "end": 376.378, "text": "Ahí lo encontraste", "speaker": null}, {"start": 376.378, "end": 377.778, "text": "Ya lo encontraste", "speaker": null}, {"start": 377.778, "end": 394.078, "text": "Ahora dale lectura fuerte y clara. ¿Se acuerdan lo que yo les mencioné hace un momento? Yo te voy a parar. Vamos a ir despacio. Aquí nos van a hablar hasta de los famosos polos de desarrollo. Venga, dale.", "speaker": null}, {"start": 394.378, "end": 403.17798, "text": "El índice nacional de precios al consumidor, a que se refiere el segundo párrafo del artículo 20 de este código, que calcula el Instituto Nacional de Estadística y Geografía.", "speaker": null}, {"start": 403.61798, "end": 405.518, "text": "¿Hasta en un segundo? Creo que lo acabo de decir.", "speaker": null}, {"start": 407.778, "end": 409.738, "text": "¿Eso es INEGI?", "speaker": null}, {"start": 410.538, "end": 411.578, "text": "INEGI.", "speaker": null}, {"start": 412.198, "end": 413.738, "text": "Dije, antes era INEGI.", "speaker": null}, {"start": 414.018, "end": 415.698, "text": "Ah, lo cambiaron.", "speaker": null}, {"start": 417.498, "end": 422.798, "text": "Ahora es Instituto Nacional de Estadística y Geografía.", "speaker": null}, {"start": 423.17798, "end": 424.538, "text": "Antes era INEGI.", "speaker": null}, {"start": 425.67798, "end": 430.098, "text": "Era Instituto Nacional de Estadística, Geografía e Informática.", "speaker": null}, {"start": 430.738, "end": 432.578, "text": "Lamentablemente, pues, se los excluye.", "speaker": null}, {"start": 432.578, "end": 436.038, "text": "Yo no lo hice en mi buen chat,", "speaker": null}, {"start": 436.038, "end": 438.398, "text": "Por eso no quise entrar mucho en eso, pero bueno.", "speaker": null}, {"start": 438.998, "end": 440.258, "text": "Se lo pierden ahí.", "speaker": null}, {"start": 440.778, "end": 442.258, "text": "Sí, pues. ¿Qué más?", "speaker": null}, {"start": 442.438, "end": 443.878, "text": "Se sujeta a lo siguiente.", "speaker": null}, {"start": 444.778, "end": 457.91602, "text": "Se cotizar cuando menos los precios en 30 ciudades las cuales estar ubicadas en por lo menos 20 entidades federativas Las ciudades seleccionadas deber en todo caso tener una poblaci de 20 o m habitantes", "speaker": null}, {"start": 458.51602, "end": 462.876, "text": "y siempre habrán de incluirse las 10 zonas conurbadas o ciudades más pobladas de la República.", "speaker": null}, {"start": 464.256, "end": 468.216, "text": "Deberán cotizarse los precios correspondientes a cuando menos 1.000 productos y servicios,", "speaker": null}, {"start": 468.216, "end": 471.13602, "text": "¿Y cuantos más? ¿Qué más?", "speaker": null}, {"start": 471.13602, "end": 475.596, "text": "y servicios específicos agrupados en 250 conceptos de consumo,", "speaker": null}, {"start": 476.176, "end": 484.396, "text": "los cuales abarcarán al menos 35 ramas de los sectores agrícola, ganadero, industrial y de servicios,", "speaker": null}, {"start": 485.056, "end": 489.79602, "text": "conforme al catálogo de actividades económicas elaborado por el Instituto Nacional de Estadística y Geografía.", "speaker": null}, {"start": 491.256, "end": 496.07602, "text": "Tratándose de alimentos, las cotizaciones de precios se harán como mínimo tres veces durante cada mes.", "speaker": null}, {"start": 496.07602, "end": 497.67603, "text": "¿Se acuerdan cuáles son los precios del día?", "speaker": null}, {"start": 497.67603, "end": 502.79602, "text": "El resto de las cotizaciones se obtendrá una o más veces mensuales.", "speaker": null}, {"start": 503.256, "end": 512.596, "text": "Las cotizaciones de precios con las que se calcule el índice nacional de precios al consumidor de cada mes deberán corresponder al periodo de que se trata.", "speaker": null}, {"start": 514.116, "end": 520.076, "text": "El índice nacional de precios al consumidor de cada mes se calculará utilizando la fórmula de las paredes.", "speaker": null}, {"start": 521.616, "end": 526.636, "text": "Se aplicarán ponderadores para cada rango del consumo familiar considerando los consejos siguientes.", "speaker": null}, {"start": 527.676, "end": 535.296, "text": "Alimentos, bebidas y tabaco", "speaker": null}, {"start": 535.296, "end": 535.916, "text": "Perdón", "speaker": null}, {"start": 535.916, "end": 538.976, "text": "Me lo ponía en la peli", "speaker": null}, {"start": 538.976, "end": 540.976, "text": "Alimentos, bebidas y tabaco", "speaker": null}, {"start": 540.976, "end": 543.416, "text": "Gracias, mi Charlie, gracias", "speaker": null}, {"start": 543.416, "end": 546.276, "text": "Son animales", "speaker": null}, {"start": 546.276, "end": 549.256, "text": "No hay que meterlo porque ya vino", "speaker": null}, {"start": 549.256, "end": 550.456, "text": "No, que no", "speaker": null}, {"start": 550.456, "end": 554.096, "text": "Yo volví", "speaker": null}, {"start": 554.096, "end": 555.99603, "text": "Mire", "speaker": null}, {"start": 555.99603, "end": 559.376, "text": "se lo dije a un tío que me decía", "speaker": null}, {"start": 559.376, "end": 561.81604, "text": "y estoy dentro de la casa.", "speaker": null}, {"start": 563.99603, "end": 564.856, "text": "Y ahora,", "speaker": null}, {"start": 566.016, "end": 568.136, "text": "gracias,", "speaker": null}, {"start": 568.376, "end": 570.056, "text": "muy amable,", "speaker": null}, {"start": 570.336, "end": 571.656, "text": "pudiera no ser, pero", "speaker": null}, {"start": 571.656, "end": 573.656, "text": "como un gran joven,", "speaker": null}, {"start": 573.856, "end": 576.276, "text": "así le tengo mucho amor.", "speaker": null}, {"start": 577.276, "end": 577.896, "text": "Ahora,", "speaker": null}, {"start": 578.976, "end": 580.276, "text": "¿cuál es uno de los temas", "speaker": null}, {"start": 580.276, "end": 582.296, "text": "importantes que nos llevó a tener", "speaker": null}, {"start": 582.296, "end": 583.656, "text": "que tocar lo que le hemos hecho?", "speaker": null}, {"start": 585.996, "end": 590.756, "text": "que la inflación la subimos por el consumo.", "speaker": null}, {"start": 592.11597, "end": 594.856, "text": "Y si consideramos lo que Charlie nos dijo hace un rato,", "speaker": null}, {"start": 595.016, "end": 598.43604, "text": "que era la pérdida del poder adquisitivo del dinero, eso es muy cierto.", "speaker": null}, {"start": 599.656, "end": 602.656, "text": "Luego entonces, si yo no me protejo ante la inflación,", "speaker": null}, {"start": 603.056, "end": 605.396, "text": "mi dinero va a perder poder adquisitivo.", "speaker": null}, {"start": 606.396, "end": 608.816, "text": "Ustedes ya saben, pero...", "speaker": null}, {"start": 608.816, "end": 614.876, "text": "Y si yo no me muevo, no te preocupes, de todos modos estás correcto.", "speaker": null}, {"start": 614.876, "end": 624.116, "text": "porque la pérdida del poder adquisitivo del dinero será incluso, sin temoras, por el simple transcurso de tiempo.", "speaker": null}, {"start": 626.336, "end": 630.456, "text": "Y yo te puedo tratar de explicar esto de una manera más sencilla.", "speaker": null}, {"start": 631.556, "end": 637.716, "text": "Mike, imagínate que el día de hoy traes un billete, ¿qué quieres?", "speaker": null}, {"start": 637.716, "end": 638.996, "text": "entonces", "speaker": null}, {"start": 638.996, "end": 640.856, "text": "voy a", "speaker": null}, {"start": 640.856, "end": 642.896, "text": "ver si hay algo por ahí", "speaker": null}, {"start": 642.896, "end": 644.716, "text": "alguno", "speaker": null}, {"start": 644.716, "end": 649.496, "text": "de la denominación", "speaker": null}, {"start": 649.496, "end": 650.516, "text": "que tú quieras", "speaker": null}, {"start": 650.516, "end": 653.156, "text": "o la cantidad que tú quieras", "speaker": null}, {"start": 653.156, "end": 654.676, "text": "y se puede", "speaker": null}, {"start": 654.676, "end": 655.896, "text": "compartir con algunos", "speaker": null}, {"start": 655.896, "end": 658.396, "text": "y puedo tomar el que sea", "speaker": null}, {"start": 658.396, "end": 659.416, "text": "uno", "speaker": null}, {"start": 659.416, "end": 662.596, "text": "si yo saco ahorita", "speaker": null}, {"start": 662.596, "end": 664.556, "text": "este billete", "speaker": null}, {"start": 664.556, "end": 667.916, "text": "yo te voy a dar chance", "speaker": null}, {"start": 667.916, "end": 680.174, "text": "de que lo tomes con apoyo de que creas que es una mujer de tu espalda de que anotes su seguido de que", "speaker": null}, {"start": 680.174, "end": 687.294, "text": "es más, te doy un chance, te juego el mismo día, a que si te lo dejo para que lo metas", "speaker": null}, {"start": 687.294, "end": 700.01404, "text": "de una caja fuera. Y lo guardas. Y lo sacamos que te gustan. Tres, cuatro, seis meses, diez", "speaker": null}, {"start": 700.01404, "end": 709.994, "text": "meses. El tiempo que tú quieras. Para que veas que no, no hay duda. Va a llegar. A lo", "speaker": null}, {"start": 709.994, "end": 715.51404, "text": "mejor hoy, con este billete, vamos a poner una exageración. Ah, dijimos que era el mismo", "speaker": null}, {"start": 715.51404, "end": 723.774, "text": "billete, yo te lo puedo dejar ahí, ese o cualquier otro. Y si hoy te invito a que vayamos", "speaker": null}, {"start": 723.774, "end": 733.874, "text": "con el proveedor que tú quieres, el que sea, a lo mejor el de Gis, vamos a ponerle una", "speaker": null}, {"start": 733.874, "end": 740.77405, "text": "cantidad, no quiero decir que así sea, pensemos que hoy puedo comprar 500 Gis con ese billete,", "speaker": null}, {"start": 740.77405, "end": 743.13403, "text": "Pensemos que hoy me cuesta un peso cada vez.", "speaker": null}, {"start": 745.01404, "end": 749.554, "text": "Mi poder adquisitivo está reflejado de acuerdo a su valor nominal.", "speaker": null}, {"start": 751.314, "end": 752.734, "text": "Esto se llama valor nominal.", "speaker": null}, {"start": 758.174, "end": 759.39404, "text": "Dice que vale 15.", "speaker": null}, {"start": 760.63403, "end": 761.45404, "text": "¿Están de acuerdo?", "speaker": null}, {"start": 762.63403, "end": 767.234, "text": "Yo tengo en una lana a que si después del tiempo que me digas", "speaker": null}, {"start": 767.234, "end": 771.254, "text": "sacamos el billete de la caja de puerta", "speaker": null}, {"start": 771.254, "end": 774.314, "text": "o sacas tu fotografía", "speaker": null}, {"start": 774.314, "end": 777.294, "text": "o la copia fotostática", "speaker": null}, {"start": 777.294, "end": 778.434, "text": "o lo que quieras", "speaker": null}, {"start": 778.434, "end": 781.874, "text": "y dentro de seis meses vamos otra vez", "speaker": null}, {"start": 781.874, "end": 785.654, "text": "a comprar más Gizas", "speaker": null}, {"start": 785.654, "end": 789.07404, "text": "te juego una gana que ya no vas a poder comprar", "speaker": null}, {"start": 789.07404, "end": 791.07404, "text": "500 Gizas", "speaker": null}, {"start": 791.07404, "end": 795.054, "text": "a lo mejor te va a alcanzar para 480", "speaker": null}, {"start": 795.054, "end": 798.51404, "text": "a lo mejor te va a alcanzar para 470", "speaker": null}, {"start": 798.51404, "end": 801.714, "text": "a lo mejor te va a alcanzar para 450", "speaker": null}, {"start": 801.714, "end": 807.234, "text": "no lo sé", "speaker": null}, {"start": 807.234, "end": 809.454, "text": "tú decís, a chingar, ¿qué pasó?", "speaker": null}, {"start": 810.674, "end": 811.89404, "text": "pues si es el mismo billete", "speaker": null}, {"start": 811.89404, "end": 815.174, "text": "y es el mismo producto", "speaker": null}, {"start": 815.174, "end": 817.914, "text": "¿sabes qué pasó?", "speaker": null}, {"start": 819.454, "end": 822.554, "text": "que tu dinero perdió poder adquisitivo", "speaker": null}, {"start": 822.554, "end": 826.094, "text": "el billete nominalmente", "speaker": null}, {"start": 826.094, "end": 827.334, "text": "siguió costando lo mismo", "speaker": null}, {"start": 827.334, "end": 830.214, "text": "pero su poder adquisitivo", "speaker": null}, {"start": 830.214, "end": 832.114, "text": "se vio afectado", "speaker": null}, {"start": 832.114, "end": 833.454, "text": "disminuyó", "speaker": null}, {"start": 833.454, "end": 836.214, "text": "ese es el efecto", "speaker": null}, {"start": 836.214, "end": 837.814, "text": "de la inflación", "speaker": null}, {"start": 837.814, "end": 840.614, "text": "quiere decir entonces", "speaker": null}, {"start": 840.614, "end": 842.094, "text": "que si tu guardas tu dinero", "speaker": null}, {"start": 842.094, "end": 843.994, "text": "por el simple transcurso del tiempo", "speaker": null}, {"start": 843.994, "end": 845.874, "text": "vas a perder", "speaker": null}, {"start": 845.874, "end": 848.494, "text": "porque vivimos en una economía", "speaker": null}, {"start": 848.494, "end": 850.054, "text": "altamente", "speaker": null}, {"start": 850.054, "end": 851.454, "text": "inflacionaria", "speaker": null}, {"start": 851.454, "end": 853.974, "text": "por eso es que tú vas a escuchar", "speaker": null}, {"start": 853.974, "end": 855.794, "text": "por ejemplo", "speaker": null}, {"start": 855.794, "end": 857.794, "text": "que la mejor administradora que hay", "speaker": null}, {"start": 857.794, "end": 858.674, "text": "que es mamá", "speaker": null}, {"start": 858.674, "end": 861.354, "text": "todo el tiempo se deja", "speaker": null}, {"start": 861.354, "end": 864.01404, "text": "es que ya subió el tomate", "speaker": null}, {"start": 864.01404, "end": 866.034, "text": "es que ya subió", "speaker": null}, {"start": 866.034, "end": 867.19403, "text": "el tomate", "speaker": null}, {"start": 867.19403, "end": 870.054, "text": "es que ya subió la cebolla", "speaker": null}, {"start": 870.054, "end": 872.534, "text": "es que ya subió la carne", "speaker": null}, {"start": 872.534, "end": 874.574, "text": "es que ya subió", "speaker": null}, {"start": 874.574, "end": 875.754, "text": "el huevo", "speaker": null}, {"start": 875.754, "end": 878.034, "text": "y tú vas a escuchar a mamá", "speaker": null}, {"start": 881.454, "end": 899.69403, "text": "que a pesar de que vivimos en un estirado internacional, y acabo de decir, mamá es la mejor administradora del crimen, yo admiro a las señoras, yo a veces me toca platicar con los clientes, con los clientes, me toca.", "speaker": null}]