[{"start": 2.0, "end": 6.9, "text": "Pero me dice, la fórmula o la razón me dice que no ocupe las compras totales.", "speaker": "speaker_1"}, {"start": 6.9, "end": 7.6, "text": "¿Qué me dice?", "speaker": "speaker_1"}, {"start": 8.9, "end": 10.6, "text": "Que ocupe las compras netas.", "speaker": "speaker_1"}, {"start": 11.6, "end": 12.8, "text": "Entonces, ¿qué tengo que hacer?", "speaker": "speaker_1"}, {"start": 13.8, "end": 19.2, "text": "A mis compras totales a crédito.", "speaker": "speaker_1"}, {"start": 19.9, "end": 22.0, "text": "Yo les tendría que quitar...", "speaker": "speaker_1"}, {"start": 23.0, "end": 24.8, "text": "No va a meter en mis descuentos.", "speaker": "speaker_1"}, {"start": 26.6, "end": 28.1, "text": "Si me seposiciones.", "speaker": "speaker_1"}, {"start": 30.4, "end": 34.6, "text": "Mis rebajas, mis bonificaciones.", "speaker": "speaker_1"}, {"start": 36.1, "end": 36.9, "text": "¿Estamos de acuerdo?", "speaker": "speaker_1"}, {"start": 38.1, "end": 42.3, "text": "Pensemos que le devolvemos el cubé, no sé, 40 mil pesos.", "speaker": "speaker_1"}, {"start": 42.9, "end": 43.6, "text": "¿Puede ser?", "speaker": "speaker_1"}, {"start": 44.2, "end": 44.5, "text": "Sí.", "speaker": "speaker_1"}, {"start": 47.584, "end": 50.684, "text": "De descuentos, pues me hicieron descuentos por 15.", "speaker": "speaker_1"}, {"start": 52.784, "end": 53.184, "text": "¿Vale?", "speaker": "speaker_1"}, {"start": 55.184, "end": 59.784, "text": "De rebajas, me hicieron rebajas por 10.000.", "speaker": "speaker_1"}, {"start": 62.084, "end": 62.984, "text": "No, otros 100.", "speaker": "speaker_1"}, {"start": 64.884, "end": 65.584, "text": "Pudiera ser.", "speaker": "speaker_1"}, {"start": 66.784, "end": 68.684, "text": "Y de bonificaciones, ¿y es bien?", "speaker": "speaker_1"}, {"start": 69.384, "end": 70.384, "text": "¿Cuánto nos muestra?", "speaker": "speaker_1"}, {"start": 71.584, "end": 72.184, "text": "120.", "speaker": "speaker_2"}, {"start": 72.984, "end": 74.384, "text": "Son 800.", "speaker": "speaker_1"}, {"start": 74.384, "end": 75.684, "text": "No, aquí serían 80.", "speaker": "speaker_1"}, {"start": 77.084, "end": 79.384, "text": "800 menos 80.", "speaker": "speaker_1"}, {"start": 80.284, "end": 82.584, "text": "Esto sería igual a 720.", "speaker": "speaker_1"}, {"start": 87.896, "end": 88.796, "text": "Utilice o no.", "speaker": "speaker_1"}, {"start": 90.696, "end": 94.696, "text": "Entonces, los compras netos a crédito serían de 700.", "speaker": "speaker_1"}, {"start": 96.696, "end": 97.896, "text": "20.000 pesos.", "speaker": "speaker_1"}, {"start": 98.696, "end": 108.496, "text": "Pero ahora tengo que determinar que el promedio de mis cuentas por pagar, ese promedio de donde los hago, maica.", "speaker": "speaker_1"}, {"start": 114.096, "end": 115.096, "text": "¿De proveedores?", "speaker": "speaker_2"}, {"start": 115.696, "end": 116.796, "text": "De proveedores.", "speaker": "speaker_1"}, {"start": 117.696, "end": 119.796, "text": "Y yo tendría que hacer lo mismo.", "speaker": "speaker_1"}, {"start": 122.276, "end": 124.276, "text": "Pensar en iniciar de proveedores.", "speaker": "speaker_1"}, {"start": 127.676, "end": 129.076, "text": "Pensemos que sea de sí mismo.", "speaker": "speaker_1"}, {"start": 131.376, "end": 132.176, "text": "Por por ahí.", "speaker": "speaker_1"}, {"start": 133.576, "end": 134.876, "text": "Tendré que buscar ahora qué.", "speaker": "speaker_1"}, {"start": 135.476, "end": 136.276, "text": "El saldo final.", "speaker": "speaker_2"}, {"start": 136.476, "end": 138.276, "text": "El saldo final de los proveedores.", "speaker": "speaker_1"}, {"start": 138.276, "end": 140.876, "text": "Pensemos que yo también fui pagando a los proveedores.", "speaker": "speaker_1"}, {"start": 140.976, "end": 142.176, "text": "Cada vez desde momentos.", "speaker": "speaker_1"}, {"start": 146.576, "end": 147.676, "text": "Oye, David, ¿podría ser?", "speaker": "speaker_1"}, {"start": 149.176, "end": 150.676, "text": "Ok, ¿qué me dice la regla?", "speaker": "speaker_1"}, {"start": 151.276, "end": 151.976, "text": "Promedio.", "speaker": "speaker_1"}, {"start": 153.176, "end": 156.176, "text": "Saldo inicial más saldo final.", "speaker": "speaker_1"}, {"start": 156.976, "end": 158.076, "text": "100 más 80.", "speaker": "speaker_1"}, {"start": 160.476, "end": 161.476, "text": "5, 8, 7.", "speaker": "speaker_1"}, {"start": 163.276, "end": 165.976, "text": "Entre 2, porque voy a determinar un promedio.", "speaker": "speaker_1"}, {"start": 166.476, "end": 166.976, "text": "90.", "speaker": "speaker_1"}, {"start": 167.276, "end": 169.576, "text": "Entonces, aquí mi promedio de cuánto va a ser?", "speaker": "speaker_1"}, {"start": 170.976, "end": 171.476, "text": "90.", "speaker": "speaker_1"}, {"start": 174.376, "end": 181.376, "text": "Si yo divido los 720 entre 90 y 8, me da 8.", "speaker": "speaker_1"}, {"start": 181.776, "end": 183.476, "text": "Ahora, ¿cuál sería la lectura, Carlos?", "speaker": "speaker_1"}, {"start": 186.376, "end": 190.576, "text": "Cada periodo pago 8 veces a mis proveedores.", "speaker": "speaker_2"}, {"start": 190.776, "end": 192.476, "text": "8 veces te estoy pagando a mis proveedores.", "speaker": "speaker_1"}, {"start": 196.732, "end": 200.732, "text": "Habrá gente que se me vende y diga, ¿qué son ocho meses hablando?", "speaker": "speaker_1"}, {"start": 203.032, "end": 204.732, "text": "Sacamos a quien al vengador, ¿no?", "speaker": "speaker_1"}, {"start": 206.732, "end": 209.232, "text": "¿Cuál sería la razón de confirmación?", "speaker": "speaker_1"}, {"start": 215.432, "end": 218.432, "text": "Plazo medio de pago.", "speaker": "speaker_1"}, {"start": 219.332, "end": 221.232, "text": "Y el plazo medio de pago, ¿qué me dice?", "speaker": "speaker_1"}, {"start": 221.432, "end": 230.132, "text": "Que tome los números de días de ejercicio sobre la razón de rotación de cuentas por pagar a proveedores.", "speaker": "speaker_1"}, {"start": 232.032, "end": 238.432, "text": "Sustituyo en los 360 días sobre la razón de fue de 8.", "speaker": "speaker_1"}, {"start": 241.332, "end": 243.332, "text": "¿Cuánto?", "speaker": "speaker_1"}, {"start": 243.532, "end": 244.232, "text": "45.", "speaker": "speaker_1"}, {"start": 245.232, "end": 246.432, "text": "45.", "speaker": "speaker_1"}, {"start": 247.532, "end": 248.032, "text": "10.", "speaker": "speaker_1"}, {"start": 249.432, "end": 250.332, "text": "Traducido más.", "speaker": "speaker_1"}, {"start": 260.704, "end": 265.404, "text": "Yo en promedio le estoy pagando a mis proveedores cada 45 días.", "speaker": "speaker_3"}, {"start": 268.704, "end": 271.104, "text": "Ahora la pregunta, señores informáticos.", "speaker": "speaker_3"}, {"start": 273.704, "end": 277.204, "text": "De acuerdo a las cifras, ¿mi empresa está bien o está mal y por qué?", "speaker": "speaker_3"}, {"start": 283.304, "end": 284.404, "text": "La empresa está bien o mal.", "speaker": "speaker_3"}, {"start": 284.404, "end": 285.504, "text": "¿Quién la ve bien?", "speaker": "speaker_3"}, {"start": 286.504, "end": 287.204, "text": "¿Quién la ve bien?", "speaker": "speaker_3"}, {"start": 287.204, "end": 287.604, "text": "¿Carlos?", "speaker": "speaker_3"}, {"start": 288.704, "end": 289.004, "text": "¿Sí?", "speaker": "speaker_3"}, {"start": 289.504, "end": 293.404, "text": "Pues cada vez debes menos dinero y si te están pagando.", "speaker": "speaker_4"}, {"start": 295.192, "end": 296.592, "text": "Vamos a ver mis índices.", "speaker": "speaker_1"}, {"start": 298.092, "end": 300.992, "text": "Tengo 60, tengo 45.", "speaker": "speaker_1"}, {"start": 301.192, "end": 302.092, "text": "¿Tú cómo la ves?", "speaker": "speaker_1"}, {"start": 302.492, "end": 302.792, "text": "Mal.", "speaker": "speaker_1"}, {"start": 304.092, "end": 304.892, "text": "¿También la ves bien?", "speaker": "speaker_1"}, {"start": 305.092, "end": 307.292, "text": "Bueno, es así a largo plazo, es más sostenible.", "speaker": "speaker_5"}, {"start": 307.592, "end": 312.492, "text": "Yo corrí al chat, pero en dos pasadas no me hice el cabrón.", "speaker": "speaker_1"}, {"start": 313.492, "end": 313.992, "text": "¿Por qué?", "speaker": "speaker_1"}, {"start": 315.592, "end": 318.992, "text": "Porque yo les estoy pagando cada 45 días a mis proveedores.", "speaker": "speaker_1"}, {"start": 320.192, "end": 322.392, "text": "Y yo les estoy cobrando cada 60.", "speaker": "speaker_1"}, {"start": 323.392, "end": 325.192, "text": "Tengo 15 días que no tengo lana.", "speaker": "speaker_1"}, {"start": 325.292, "end": 327.992, "text": "¿Con qué demonios les voy a pagar a mis proveedores, cabrón?", "speaker": "speaker_1"}, {"start": 330.972, "end": 335.872, "text": "Y se echa el super, está muy mal, si ya te habías escuchado, que si pides dinero, hermano, te van a ensalpar.", "speaker": "speaker_1"}, {"start": 339.172, "end": 344.172, "text": "Ah, bueno, ya se echa, le va a pagar con cuerpo mágico, pues está del otro lado.", "speaker": "speaker_1"}, {"start": 347.072, "end": 348.172, "text": "Se observan o no se observan.", "speaker": "speaker_1"}, {"start": 349.672, "end": 351.572, "text": "¿Qué problema tiene este chaval?", "speaker": "speaker_1"}, {"start": 354.872, "end": 355.672, "text": "Papita.", "speaker": "speaker_1"}, {"start": 358.772, "end": 359.972, "text": "¿Cómo vamos a hacer aquí, señores?", "speaker": "speaker_1"}, {"start": 363.112, "end": 366.012, "text": "Para mañana, mis niños, me vale oro que haya juego.", "speaker": "speaker_1"}, {"start": 367.112, "end": 369.212, "text": "Porque no nos llevan el día, otra vez.", "speaker": "speaker_1"}, {"start": 370.012, "end": 371.312, "text": "Lo van a dar hasta matarme.", "speaker": "speaker_1"}, {"start": 372.612, "end": 376.312, "text": "Para mañana voy a empezar a preguntar, ¿el sistema financiero?", "speaker": "speaker_1"}, {"start": 378.812, "end": 379.112, "text": "¿Sí?", "speaker": "speaker_1"}, {"start": 380.712, "end": 383.012, "text": "Aunque se me estuviera, mañana es por preguntar dos veces.", "speaker": "speaker_1"}, {"start": 384.712, "end": 385.112, "text": "¿Sale?", "speaker": "speaker_1"}, {"start": 386.312, "end": 387.112, "text": "Bien, muchachos.", "speaker": "speaker_1"}, {"start": 387.312, "end": 389.912, "text": "Si no hay otra cosa que atender, vamos a dejarlo aquí.", "speaker": "speaker_1"}, {"start": 390.012, "end": 390.612, "text": "¿Cuánto va a dar?", "speaker": "speaker_1"}, {"start": 390.612, "end": 391.012, "text": "¿Cuatro?", "speaker": "speaker_1"}, {"start": 391.112, "end": 391.812, "text": "¿Cinco minutos?", "speaker": "speaker_1"}, {"start": 397.864, "end": 398.564, "text": "¿Ya me gustas?", "speaker": "speaker_1"}, {"start": 400.464, "end": 401.064, "text": "¿Seguro?", "speaker": "speaker_1"}]