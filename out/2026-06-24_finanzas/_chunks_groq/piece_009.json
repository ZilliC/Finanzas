[{"start": 0.0, "end": 6.5, "text": "Están obligadas a ir en riesgos, pero no todas están obligadas a hacer esto.", "speaker": null}, {"start": 7.5, "end": 14.059999, "text": "Por ejemplo, si tú eres la empresa Charly S.A., yo te voy a decir, preséntame tu consolidado.", "speaker": null}, {"start": 15.139999, "end": 17.34, "text": "No, no hay que consolidar, no, no sé.", "speaker": null}, {"start": 18.119999, "end": 24.08, "text": "¿Dónde están tus sucursales? ¿Dónde están tus filiales? ¿Dónde está tu planta? ¿Dónde están tus almacenes? ¿Dónde están tus sedes?", "speaker": null}, {"start": 24.08, "end": 26.14, "text": "pues oiga, no maneras", "speaker": null}, {"start": 26.14, "end": 27.5, "text": "yo no consolido", "speaker": null}, {"start": 27.5, "end": 30.38, "text": "yo soy empresa única", "speaker": null}, {"start": 30.38, "end": 31.42, "text": "a ver", "speaker": null}, {"start": 31.42, "end": 33.06, "text": "eres única pero a Chale", "speaker": null}, {"start": 33.06, "end": 35.34, "text": "tienes que tener un estado de asistencia", "speaker": null}, {"start": 35.34, "end": 37.12, "text": "y a Chale", "speaker": null}, {"start": 37.12, "end": 39.16, "text": "tienes que entregar nuestros resultados", "speaker": null}, {"start": 39.16, "end": 41.579998, "text": "¿me entiendo?", "speaker": null}, {"start": 43.02, "end": 43.5, "text": "¿vamos bien?", "speaker": null}, {"start": 43.62, "end": 44.06, "text": "¿me regresas?", "speaker": null}, {"start": 45.14, "end": 45.86, "text": "¿seguro?", "speaker": null}, {"start": 47.52, "end": 48.66, "text": "ahora vamos", "speaker": null}, {"start": 48.66, "end": 50.8, "text": "¿estamos bien?", "speaker": null}, {"start": 51.94, "end": 52.98, "text": "estoy corriendo", "speaker": null}, {"start": 52.98, "end": 54.04, "text": "Corto y corrido.", "speaker": null}, {"start": 63.239998, "end": 64.24, "text": "Corto y corrido.", "speaker": null}, {"start": 65.42, "end": 69.14, "text": "Quiere decir entonces que yo ya terminé mi proceso productivo.", "speaker": null}, {"start": 70.46, "end": 71.979996, "text": "Ya las donitas ya están hechas.", "speaker": null}, {"start": 73.32, "end": 74.74, "text": "Las mantecadas ya están hechas.", "speaker": null}, {"start": 75.1, "end": 76.32, "text": "Los momiolitos ya están hechos.", "speaker": null}, {"start": 77.159996, "end": 77.7, "text": "Entonces, ¿qué hago?", "speaker": null}, {"start": 77.7, "end": 79.94, "text": "Los dejo en el horno todo el tiempo.", "speaker": null}, {"start": 79.94, "end": 83.899994, "text": "no, ahora me voy al siguiente almacén.", "speaker": null}, {"start": 85.13999, "end": 86.35999, "text": "El siguiente almacén.", "speaker": null}, {"start": 87.56, "end": 95.81999, "text": "A ustedes en cuenta les enseñamos que hay una cuenta de almacén con venta,", "speaker": null}, {"start": 96.259995, "end": 99.979996, "text": "pero por lo general manejan una sola cuenta.", "speaker": null}, {"start": 101.399994, "end": 101.59999, "text": "¿Sale?", "speaker": null}, {"start": 102.259995, "end": 105.02, "text": "Eso es para las empresas comercializadoras.", "speaker": null}, {"start": 106.079994, "end": 108.799995, "text": "Aquí tenemos que distinguir que hay diferentes tipos de empresas", "speaker": null}, {"start": 108.799995, "end": 110.85999, "text": "con diferentes giros.", "speaker": null}, {"start": 111.81999, "end": 116.38, "text": "Bueno, en una comercializadora únicamente se maneja un inventario.", "speaker": null}, {"start": 117.479996, "end": 118.979996, "text": "¿Cuál es una comercializadora?", "speaker": null}, {"start": 120.42, "end": 122.53999, "text": "Una empresa comercializadora.", "speaker": null}, {"start": 124.67999, "end": 126.92, "text": "¿Una que se busca comprar un inventario?", "speaker": null}, {"start": 127.49999, "end": 127.85999, "text": "Walmart.", "speaker": null}, {"start": 128.06, "end": 128.94, "text": "Walmart.", "speaker": null}, {"start": 130.04, "end": 136.34, "text": "Walmart compra y ese producto lo exhibe y así como llega, lo vende.", "speaker": null}, {"start": 136.34, "end": 144.95999, "text": "No le cambia nada, no le cambia el contenido, el empaque, el envase, nada, así como llega el producto.", "speaker": null}, {"start": 146.66, "end": 151.08, "text": "OX, así como llega el producto, lo vende.", "speaker": null}, {"start": 152.44, "end": 156.3, "text": "La cómica, así como llega el producto, lo vende.", "speaker": null}, {"start": 157.37999, "end": 161.08, "text": "La soliana, así como llega el producto, lo vende.", "speaker": null}, {"start": 161.08, "end": 165.3, "text": "la miscelánea de la esquina de la casa", "speaker": null}, {"start": 165.3, "end": 167.82, "text": "así como compra", "speaker": null}, {"start": 167.82, "end": 168.8, "text": "lo vende", "speaker": null}, {"start": 168.8, "end": 170.66, "text": "esa es una comercializadora", "speaker": null}, {"start": 170.66, "end": 172.78, "text": "esa tiene un solo inventario", "speaker": null}, {"start": 172.78, "end": 175.1, "text": "en este caso", "speaker": null}, {"start": 175.1, "end": 177.42, "text": "vamos a una bebida transformadora", "speaker": null}, {"start": 177.42, "end": 179.54001, "text": "esta si produce", "speaker": null}, {"start": 179.54001, "end": 181.08, "text": "esa si transforma", "speaker": null}, {"start": 182.12, "end": 183.52, "text": "¿por qué estamos transformando?", "speaker": null}, {"start": 183.66, "end": 184.96, "text": "porque nosotros", "speaker": null}, {"start": 184.96, "end": 186.46, "text": "utilizamos harina y azúcar", "speaker": null}, {"start": 186.46, "end": 188.26, "text": "pero no vendimos harina y azúcar", "speaker": null}, {"start": 188.26, "end": 190.12, "text": "lo transformamos en un pan", "speaker": null}, {"start": 190.12, "end": 192.98, "text": "HP", "speaker": null}, {"start": 192.98, "end": 195.28, "text": "es una transformadora", "speaker": null}, {"start": 195.28, "end": 198.06, "text": "ellos compran las tabletas", "speaker": null}, {"start": 198.06, "end": 199.04, "text": "compran los chips", "speaker": null}, {"start": 199.04, "end": 201.84, "text": "todos los componentes electrónicos", "speaker": null}, {"start": 201.84, "end": 203.56, "text": "y me venden", "speaker": null}, {"start": 203.56, "end": 205.92, "text": "una tableta", "speaker": null}, {"start": 205.92, "end": 206.93999, "text": "o me venden una laptop", "speaker": null}, {"start": 206.93999, "end": 209.01999, "text": "me venden un producto diferente", "speaker": null}, {"start": 209.01999, "end": 212.01999, "text": "¿o qué? ¿yo tengo que estar conectando los chips ahí?", "speaker": null}, {"start": 212.01999, "end": 212.12, "text": "¿no?", "speaker": null}, {"start": 214.95999, "end": 216.23999, "text": "yo nada más", "speaker": null}, {"start": 216.23999, "end": 218.01999, "text": "ocupo la tableta", "speaker": null}, {"start": 218.54, "end": 219.7, "text": "ocupo la computadora", "speaker": null}, {"start": 219.7, "end": 230.47801, "text": "Motorola Samsung lo mismo A m me vende el m ya hecho lo transformo", "speaker": null}, {"start": 231.438, "end": 235.598, "text": "A mí para que de uno me sirva un puro display, le picoteo y no va a ser nada.", "speaker": null}, {"start": 236.598, "end": 237.978, "text": "Si el display no está en su, ¿qué?", "speaker": null}, {"start": 243.778, "end": 246.478, "text": "Y no tiene sus componentes, no sirve de nada.", "speaker": null}, {"start": 247.778, "end": 248.81801, "text": "Es una transformadora.", "speaker": null}, {"start": 250.018, "end": 258.438, "text": "Digo, yo les puse un ejemplo sencillo para que lo vean con bimbo, pero lo mismo pasa con Samsung, con Apple, están transformando.", "speaker": null}, {"start": 261.078, "end": 264.518, "text": "Nissan mexicana, están transformando.", "speaker": null}, {"start": 266.258, "end": 273.258, "text": "Yo no me compro las llantas, las llantas se las compro a Euskadi, las llantas se las compro a Firestone, las llantas se las compro a Toyo.", "speaker": null}, {"start": 273.258, "end": 275.578, "text": "yo compré un carro", "speaker": null}, {"start": 275.578, "end": 278.098, "text": "tengo un carro", "speaker": null}, {"start": 278.098, "end": 280.118, "text": "trae bujías", "speaker": null}, {"start": 280.118, "end": 282.258, "text": "trae llantas, trae rines", "speaker": null}, {"start": 282.258, "end": 283.798, "text": "trae zapatas", "speaker": null}, {"start": 283.798, "end": 285.71802, "text": "trae bufes", "speaker": null}, {"start": 285.71802, "end": 287.078, "text": "¿qué más trae?", "speaker": null}, {"start": 288.418, "end": 289.978, "text": "computadoras, módulos", "speaker": null}, {"start": 289.978, "end": 292.698, "text": "yo compré el carro", "speaker": null}, {"start": 292.698, "end": 293.918, "text": "ya he hecho", "speaker": null}, {"start": 293.918, "end": 296.538, "text": "y a ellos se encargaron de juntar", "speaker": null}, {"start": 296.538, "end": 298.498, "text": "un montón de componentes que se llaman", "speaker": null}, {"start": 298.498, "end": 299.15802, "text": "insumos", "speaker": null}, {"start": 299.15802, "end": 300.858, "text": "y me entregaron el carro", "speaker": null}, {"start": 300.858, "end": 303.678, "text": "ellos hacen esto", "speaker": null}, {"start": 303.678, "end": 306.118, "text": "claro ellos se manejan por línea de producción", "speaker": null}, {"start": 306.118, "end": 307.65802, "text": "pero es lo mismo", "speaker": null}, {"start": 307.65802, "end": 309.678, "text": "si no nos vamos", "speaker": null}, {"start": 309.678, "end": 310.858, "text": "vamos a ir a pelear", "speaker": null}, {"start": 310.858, "end": 313.118, "text": "continuamos", "speaker": null}, {"start": 313.118, "end": 316.098, "text": "una vez que ya salieron de los", "speaker": null}, {"start": 316.098, "end": 317.938, "text": "buenos panes, me los llevo al siguiente", "speaker": null}, {"start": 317.938, "end": 319.938, "text": "almacén y ahí los meto", "speaker": null}, {"start": 319.938, "end": 321.878, "text": "¿vale? ¿pero qué crees?", "speaker": null}, {"start": 324.078, "end": 325.098, "text": "en el almacén", "speaker": null}, {"start": 325.098, "end": 327.238, "text": "ya había más productos", "speaker": null}, {"start": 327.238, "end": 330.71802, "text": "¿y por qué había más productos?", "speaker": null}, {"start": 330.858, "end": 332.638, "text": "lo que se quedó del mes pasado", "speaker": null}, {"start": 332.638, "end": 334.618, "text": "¿o no?", "speaker": null}, {"start": 336.118, "end": 337.198, "text": "entonces ¿qué hago?", "speaker": null}, {"start": 338.338, "end": 339.818, "text": "le sumo el inventario inicial", "speaker": null}, {"start": 339.818, "end": 341.298, "text": "de producción y proceso", "speaker": null}, {"start": 341.298, "end": 344.398, "text": "y le ofrece el inventario final", "speaker": null}, {"start": 344.398, "end": 345.938, "text": "de producción y proceso", "speaker": null}, {"start": 345.938, "end": 347.598, "text": "¿por qué le dice?", "speaker": null}, {"start": 347.898, "end": 349.398, "text": "le estamos diciendo que es un", "speaker": null}, {"start": 349.398, "end": 351.55798, "text": "producto en proceso", "speaker": null}, {"start": 351.55798, "end": 354.298, "text": "Carlos ya transitarció la cara", "speaker": null}, {"start": 354.298, "end": 356.05798, "text": "y me queda caro", "speaker": null}, {"start": 356.05798, "end": 357.55798, "text": "porque es un proceso", "speaker": null}, {"start": 357.55798, "end": 359.17798, "text": "que ya estaba terminado", "speaker": null}, {"start": 359.178, "end": 361.078, "text": "a ver maestro", "speaker": null}, {"start": 361.078, "end": 364.898, "text": "dijimos que el pan ya estaba terminado", "speaker": null}, {"start": 364.898, "end": 368.99802, "text": "exacto", "speaker": null}, {"start": 368.99802, "end": 369.938, "text": "voy para allá", "speaker": null}, {"start": 369.938, "end": 373.018, "text": "que resultado me arroja", "speaker": null}, {"start": 373.018, "end": 375.198, "text": "costo de la producción", "speaker": null}, {"start": 375.198, "end": 377.138, "text": "terminada", "speaker": null}, {"start": 377.138, "end": 380.198, "text": "porque ya está terminada", "speaker": null}, {"start": 380.198, "end": 383.238, "text": "todavía está en proceso", "speaker": null}, {"start": 383.238, "end": 385.998, "text": "pero me faltó que", "speaker": null}, {"start": 385.998, "end": 387.578, "text": "empacar", "speaker": null}, {"start": 387.578, "end": 390.958, "text": "meterlo a sus bolsitas, a sus charlitas", "speaker": null}, {"start": 390.958, "end": 392.738, "text": "a sus cajitas", "speaker": null}, {"start": 392.738, "end": 393.818, "text": "etc", "speaker": null}, {"start": 393.818, "end": 396.938, "text": "entonces ¿qué es lo que hago?", "speaker": null}, {"start": 398.318, "end": 398.838, "text": "le subo", "speaker": null}, {"start": 398.838, "end": 400.978, "text": "el inventario final de producción", "speaker": null}, {"start": 400.978, "end": 402.178, "text": "¿qué?", "speaker": null}, {"start": 403.078, "end": 404.238, "text": "de artículos terminados", "speaker": null}, {"start": 404.238, "end": 406.55798, "text": "o producción terminada", "speaker": null}, {"start": 406.55798, "end": 408.21802, "text": "y le hago este inventario final", "speaker": null}, {"start": 408.21802, "end": 409.55798, "text": "de artículos terminados", "speaker": null}, {"start": 409.55798, "end": 413.05798, "text": "y como consecuencia", "speaker": null}, {"start": 413.05798, "end": 414.138, "text": "¿qué resultado me da?", "speaker": null}, {"start": 415.358, "end": 417.09802, "text": "si yo hago terminado", "speaker": null}, {"start": 417.09802, "end": 424.958, "text": "lo que ya empaqué, lo que ya metí en bolsas, lo que ya pesé, lo metí en el almacén de artículos terminados,", "speaker": null}, {"start": 425.078, "end": 432.47803, "text": "le sumo lo que estaba del mes pasado y le resto el final, lo que ya se fue del almacén.", "speaker": null}, {"start": 433.858, "end": 435.938, "text": "Si ya no está en el almacén, ¿en dónde está, Carlos?", "speaker": null}, {"start": 436.818, "end": 437.938, "text": "¿En los ERIs?", "speaker": null}, {"start": 438.578, "end": 441.798, "text": "No, señor, en la panza del MAIT.", "speaker": null}, {"start": 443.018, "end": 443.678, "text": "¿Por qué?", "speaker": null}, {"start": 443.678, "end": 455.29602, "text": "Porque ya es el costo de la producci ya no est mis almacenes de art terminados Ya no est mis almacenes Y si ya no est en mi empresa quiero decir", "speaker": null}, {"start": 455.616, "end": 456.13602, "text": "Ya se vendió.", "speaker": null}, {"start": 456.256, "end": 457.036, "text": "Pues quiero hablarles.", "speaker": null}, {"start": 458.116, "end": 460.716, "text": "Pero como estamos hablando de toda la producción,", "speaker": null}, {"start": 461.07602, "end": 464.776, "text": "de todos los 500 sacos de esto,", "speaker": null}, {"start": 464.95602, "end": 466.63602, "text": "más los 1.000 sacos del otro,", "speaker": null}, {"start": 467.216, "end": 470.436, "text": "más los 10 litros de leche,", "speaker": null}, {"start": 470.756, "end": 471.756, "text": "más todo eso.", "speaker": null}, {"start": 471.756, "end": 476.256, "text": "lo divido entre el número de unidades producidas.", "speaker": null}, {"start": 477.596, "end": 479.836, "text": "Y si lo divido entre el número de unidades producidas,", "speaker": null}, {"start": 479.996, "end": 480.876, "text": "¿qué me da como resultado?", "speaker": null}, {"start": 481.536, "end": 483.956, "text": "El costo de venta.", "speaker": null}, {"start": 484.196, "end": 487.036, "text": "Lo que me costó cada guis,", "speaker": null}, {"start": 489.376, "end": 490.936, "text": "lo que me costó cada coca,", "speaker": null}, {"start": 492.29602, "end": 495.836, "text": "lo que me costó cada móvil, etc.", "speaker": null}, {"start": 496.17603, "end": 497.63602, "text": "Ese es mi costo de venta.", "speaker": null}, {"start": 498.73602, "end": 500.436, "text": "Ese costo de venta", "speaker": null}, {"start": 500.436, "end": 504.73602, "text": "es el que yo paso al Estado de resultados.", "speaker": null}, {"start": 506.85602, "end": 508.656, "text": "¿Para qué me sirve el Estado de resultados", "speaker": null}, {"start": 508.656, "end": 510.276, "text": "para saber si ganó o perdonó?", "speaker": null}, {"start": 511.67603, "end": 514.056, "text": "¿Y para qué me sirve saber si ganó o perdonó", "speaker": null}, {"start": 514.056, "end": 515.93604, "text": "para presentarlo en el Estado de posiciones?", "speaker": null}, {"start": 517.696, "end": 519.256, "text": "Así de sencillo.", "speaker": null}, {"start": 520.576, "end": 521.656, "text": "Así de fácil.", "speaker": null}, {"start": 523.93604, "end": 525.356, "text": "¿Qué problema tiene esto?", "speaker": null}, {"start": 525.356, "end": 530.516, "text": "bueno después del costo incurrido", "speaker": null}, {"start": 530.516, "end": 531.656, "text": "era", "speaker": null}, {"start": 531.656, "end": 534.796, "text": "inventario inicial", "speaker": null}, {"start": 534.796, "end": 536.796, "text": "de producción de proceso", "speaker": null}, {"start": 536.796, "end": 538.49603, "text": "pero los dos son", "speaker": null}, {"start": 538.49603, "end": 540.176, "text": "inventario inicial", "speaker": null}, {"start": 540.176, "end": 542.736, "text": "este es más inventario inicial", "speaker": null}, {"start": 542.736, "end": 544.896, "text": "de producción de proceso", "speaker": null}, {"start": 544.896, "end": 546.676, "text": "menos", "speaker": null}, {"start": 546.676, "end": 555.276, "text": "el inventario final", "speaker": null}, {"start": 555.276, "end": 560.016, "text": "de producción y proceso.", "speaker": null}, {"start": 574.176, "end": 578.176, "text": "Después es más el inventario inicial de artículos terminados.", "speaker": null}, {"start": 585.276, "end": 597.636, "text": "más, perdón, era al revés, más el inventario inicial de artículos terminados menos el inventario final.", "speaker": null}, {"start": 604.356, "end": 609.916, "text": "Ahora, ¿por qué es importante que ustedes entiendan esto?", "speaker": null}, {"start": 609.916, "end": 623.796, "text": "Porque cuando ustedes les enseñaron costos, a ustedes les dijeron que los elementos del costo son tres.", "speaker": null}, {"start": 623.796, "end": 633.61597, "text": "La materia prima, la mano de obra directa y los gastos en el producto.", "speaker": null}, {"start": 633.616, "end": 642.456, "text": "Esto funciona para las empresas transformadoras y agroempresarias, porque la comercializadora", "speaker": null}, {"start": 642.456, "end": 648.856, "text": "únicamente compra y vende, pero las comercializadoras tenemos que nada más tienen una almacena.", "speaker": null}, {"start": 650.31604, "end": 656.07605, "text": "Las transformadoras mínimo, mínimo, van a tener tres almacenas.", "speaker": null}, {"start": 656.07605, "end": 670.016, "text": "En materia de inventarios van a tener que el inventario de materia prima, el inventario", "speaker": null}, {"start": 670.016, "end": 680.714, "text": "de producci y proceso y el inventario de algoritmos terminados y esos tres inventarios van a convertir en seis", "speaker": null}, {"start": 680.714, "end": 683.094, "text": "¿por qué?", "speaker": null}, {"start": 683.414, "end": 684.374, "text": "porque van a tener", "speaker": null}, {"start": 684.374, "end": 686.554, "text": "un inventario inicial", "speaker": null}, {"start": 686.554, "end": 688.374, "text": "y van a tener", "speaker": null}, {"start": 688.374, "end": 690.234, "text": "un inventario final", "speaker": null}, {"start": 690.234, "end": 692.494, "text": "van a tener", "speaker": null}, {"start": 692.494, "end": 695.054, "text": "un inventario inicial", "speaker": null}, {"start": 695.054, "end": 696.63403, "text": "y van a tener", "speaker": null}, {"start": 696.63403, "end": 698.674, "text": "un inventario final", "speaker": null}, {"start": 698.674, "end": 706.714, "text": "Lo mismo este, un inventario iniciado y un inventario final.", "speaker": null}, {"start": 715.374, "end": 720.314, "text": "Estos inventarios de donde salen, nuevamente repito, salen de aquí.", "speaker": null}, {"start": 720.314, "end": 730.174, "text": "en cada mes, o sea, en cada periodo contable.", "speaker": null}, {"start": 731.51404, "end": 736.69403, "text": "Puede ser mensual, puede ser trimestral, puede ser trimestral, cuatrimestral, etc.", "speaker": null}, {"start": 741.57404, "end": 742.294, "text": "¿Sí o no?", "speaker": null}, {"start": 743.914, "end": 745.95404, "text": "Entonces, si te das cuenta, Carlos,", "speaker": null}, {"start": 747.13403, "end": 749.734, "text": "lo único que estamos haciendo con el documento", "speaker": null}, {"start": 749.734, "end": 751.854, "text": "es que", "speaker": null}, {"start": 751.854, "end": 754.234, "text": "vaciar la información", "speaker": null}, {"start": 754.234, "end": 755.874, "text": "que nosotros ya tenemos", "speaker": null}, {"start": 755.874, "end": 758.154, "text": "ojo, me dicen que parto", "speaker": null}, {"start": 758.154, "end": 759.874, "text": "del inventario final de materia prima", "speaker": null}, {"start": 759.874, "end": 762.174, "text": "entonces ya me hice inventario", "speaker": null}, {"start": 762.174, "end": 763.334, "text": "aquí", "speaker": null}, {"start": 763.334, "end": 766.07404, "text": "inventario inicial", "speaker": null}, {"start": 766.07404, "end": 766.994, "text": "de materia prima", "speaker": null}, {"start": 766.994, "end": 769.89404, "text": "ya lo vacío", "speaker": null}, {"start": 769.89404, "end": 772.07404, "text": "más las compras negras", "speaker": null}, {"start": 772.07404, "end": 773.734, "text": "ya las terminé", "speaker": null}, {"start": 773.734, "end": 775.57404, "text": "y tuve que aplicar los cuentos de bajas", "speaker": null}, {"start": 775.57404, "end": 777.374, "text": "de producción y subcomunicaciones sobre el hogar", "speaker": null}, {"start": 777.374, "end": 779.77405, "text": "me dan el material primo disponible", "speaker": null}, {"start": 779.77405, "end": 781.054, "text": "pero después me dice", "speaker": null}, {"start": 781.054, "end": 783.994, "text": "aplícale el inventario final de material primo", "speaker": null}, {"start": 783.994, "end": 787.95404, "text": "sal, ya lo compré", "speaker": null}, {"start": 787.95404, "end": 791.51404, "text": "esto me da el material primo utilizado", "speaker": null}, {"start": 791.51404, "end": 793.77405, "text": "más mi mano de obra directa", "speaker": null}, {"start": 795.45404, "end": 798.77405, "text": "mano de obra directa", "speaker": null}, {"start": 798.77405, "end": 802.01404, "text": "esto me da el costo primo", "speaker": null}, {"start": 802.01404, "end": 806.314, "text": "más mis gastos indirectos de producción", "speaker": null}, {"start": 806.314, "end": 810.914, "text": "me da mi corte cubrido", "speaker": null}, {"start": 810.914, "end": 815.314, "text": "más que inventar y iniciar la producción en proceso", "speaker": null}, {"start": 815.314, "end": 818.374, "text": "inventar y iniciar la producción en proceso", "speaker": null}, {"start": 818.374, "end": 822.954, "text": "menos inventar y finalizar la producción en proceso", "speaker": null}, {"start": 822.954, "end": 827.51404, "text": "esto me da mi corte de producción terminada", "speaker": null}, {"start": 827.51404, "end": 829.114, "text": "ah no, pero espérame", "speaker": null}, {"start": 829.114, "end": 831.994, "text": "me faltó la mano derecha", "speaker": null}, {"start": 831.994, "end": 836.814, "text": "mando a la directa", "speaker": null}, {"start": 836.814, "end": 841.834, "text": "entonces estábamos con el inventario inicial", "speaker": null}, {"start": 841.834, "end": 843.51404, "text": "de artículos terminados", "speaker": null}, {"start": 843.51404, "end": 846.374, "text": "y el inventario final de artículos terminados", "speaker": null}, {"start": 846.374, "end": 852.094, "text": "como ves, lo único que estoy haciendo es", "speaker": null}, {"start": 852.094, "end": 855.89404, "text": "acomodar el saldo de mis cuentas", "speaker": null}, {"start": 855.89404, "end": 859.19403, "text": "y ordenarlo en el argumento", "speaker": null}, {"start": 859.19403, "end": 861.414, "text": "¿para qué? para poder determinar", "speaker": null}, {"start": 861.414, "end": 864.174, "text": "es lo mismo que ahora", "speaker": null}, {"start": 864.174, "end": 866.714, "text": "cuando hablo de ventas", "speaker": null}, {"start": 866.714, "end": 869.674, "text": "no hablo de las ventas que le hice al Mike", "speaker": null}, {"start": 869.674, "end": 871.714, "text": "hablo de las ventas", "speaker": null}, {"start": 871.714, "end": 873.57404, "text": "que hice en el periodo", "speaker": null}, {"start": 873.57404, "end": 875.334, "text": "a los 500, a los 800", "speaker": null}, {"start": 875.334, "end": 877.554, "text": "a los 1000, ¿cuántos clientes", "speaker": null}, {"start": 877.554, "end": 879.114, "text": "y cuántas ventas que hace bien?", "speaker": null}, {"start": 880.374, "end": 881.434, "text": "puta madre", "speaker": null}, {"start": 881.434, "end": 883.65405, "text": "infinidad de ventas", "speaker": null}, {"start": 883.65405, "end": 885.57404, "text": "pues no voy a poner aquí", "speaker": null}, {"start": 885.57404, "end": 887.89404, "text": "venta por venta", "speaker": null}, {"start": 887.89404, "end": 889.57404, "text": "con gorra, ventas totales", "speaker": null}, {"start": 889.57404, "end": 893.154, "text": "únicamente arrastró salvos", "speaker": null}, {"start": 893.154, "end": 895.714, "text": "es lo que ustedes enseñan como arrastrar salvos", "speaker": null}, {"start": 895.714, "end": 897.51404, "text": "en contabilidad", "speaker": null}]