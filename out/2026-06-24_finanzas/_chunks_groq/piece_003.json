[{"start": 0.0, "end": 2.72, "text": "¿O hacemos un curso?", "speaker": null}, {"start": 3.72, "end": 4.92, "text": "¿Habla con los estudiantes?", "speaker": null}, {"start": 5.24, "end": 5.7799997, "text": "¿O tiene cierre?", "speaker": null}, {"start": 8.059999, "end": 9.58, "text": "Si no cierran los libros,", "speaker": null}, {"start": 9.66, "end": 12.2, "text": "no aparecería como que la reclaman.", "speaker": null}, {"start": 13.58, "end": 14.62, "text": "¿Tiene chance de pagar", "speaker": null}, {"start": 14.62, "end": 16.5, "text": "con otro maestro?", "speaker": null}, {"start": 17.119999, "end": 19.5, "text": "¿O en el escolar es algo?", "speaker": null}, {"start": 20.56, "end": 21.48, "text": "A lo mejor es un libro", "speaker": null}, {"start": 21.48, "end": 22.48, "text": "más con carita.", "speaker": null}, {"start": 25.619999, "end": 27.08, "text": "Lamentablemente yo prefiero hasta", "speaker": null}, {"start": 27.08, "end": 27.92, "text": "hacer pruebas.", "speaker": null}, {"start": 27.92, "end": 41.16, "text": "pero sí aprender, porque creo que en contabilidad no, incluso sale terriblemente, o sea, casi que aunque aprendiera lo que era de ese curso, pero sí, y que salga.", "speaker": null}, {"start": 42.92, "end": 57.42, "text": "Yo sé, y la nota, idealmente, sí, ver todo lo que pienso, incluso lo de Vir, lo de Tirto, y yo sé, yo la nota, tengo otra intención,", "speaker": null}, {"start": 57.42, "end": 60.8, "text": "es más sencillo, casi que no me haces llegar a la clase.", "speaker": null}, {"start": 61.78, "end": 64.32, "text": "Entonces, pues, yo siempre hablaba de que lo podía dedicar a las demás.", "speaker": null}, {"start": 66.36, "end": 71.119995, "text": "Y principalmente ahorita que es casi que reponer lo que no sabemos,", "speaker": null}, {"start": 71.659996, "end": 79.439995, "text": "pues sí, yo sí nos dice así puntualmente como que cosas estudiar y investigar.", "speaker": null}, {"start": 79.439995, "end": 84.159996, "text": "Yo, en la década de la noche, no sé si es más blanca para mí,", "speaker": null}, {"start": 84.84, "end": 87.0, "text": "pero lo único que son motitos no tengo boca.", "speaker": null}, {"start": 87.42, "end": 90.42, "text": "y la intención es ayudar a que el cuerpo esté en su dirección.", "speaker": null}, {"start": 91.56, "end": 94.28, "text": "O les impide, se van a tener que apretar.", "speaker": null}, {"start": 95.5, "end": 97.759995, "text": "O mejor, algo muy muy muy práctico.", "speaker": null}, {"start": 99.82, "end": 104.52, "text": "La ventaja es que cuando un hombre de esa falla se desvanece de esa falta.", "speaker": null}, {"start": 105.88, "end": 106.46, "text": "¿Me explico?", "speaker": null}, {"start": 107.119995, "end": 108.7, "text": "No aparece un clave probable.", "speaker": null}, {"start": 109.52, "end": 111.14, "text": "Sencillamente es como si no hubiera existido.", "speaker": null}, {"start": 111.72, "end": 113.2, "text": "Y ya después la paga.", "speaker": null}, {"start": 113.2, "end": 114.2, "text": "¿Me explico?", "speaker": null}, {"start": 114.2, "end": 117.56, "text": "La mitad ahora tendrá que viajar, ¿no?", "speaker": null}, {"start": 118.2, "end": 125.579994, "text": "Digo, la mitad va a tener que viajar en otro momento, es que a lo mejor lo van a llevar en más tiempo, en un semestre, con el noviaje.", "speaker": null}, {"start": 127.03999, "end": 133.8, "text": "Esa podría ser la mitad, pero sí, al final la deuda, al final la van a tener que pagar hoy o mañana.", "speaker": null}, {"start": 136.56, "end": 137.86, "text": "¿Qué les conviene más?", "speaker": null}, {"start": 137.86, "end": 145.08, "text": "¿Tú crees y estás de acuerdo con mi mano?", "speaker": null}, {"start": 147.5, "end": 147.66, "text": "¿Tú?", "speaker": null}, {"start": 148.12, "end": 148.94, "text": "¿Con mi parte también?", "speaker": null}, {"start": 149.62, "end": 151.02, "text": "¿Con mi parte también?", "speaker": null}, {"start": 151.02, "end": 151.18001, "text": "¿Con mi parte también?", "speaker": null}, {"start": 151.5, "end": 154.82, "text": "¿Qué me pasa cuando me acompañan a la estación de contraria?", "speaker": null}, {"start": 155.06, "end": 155.54, "text": "¿Cómo se hace?", "speaker": null}, {"start": 156.48, "end": 158.34, "text": "¿Se hace muy fácil?", "speaker": null}, {"start": 159.76, "end": 162.02, "text": "Por ejemplo, de...", "speaker": null}, {"start": 162.64, "end": 163.44, "text": "¿Con mi parte también?", "speaker": null}, {"start": 163.74, "end": 164.22, "text": "¿Con mi parte también?", "speaker": null}, {"start": 164.22, "end": 169.74, "text": "¿Qué es lo que nos dio con este pequeño catálogo de cuentas?", "speaker": null}, {"start": 170.14, "end": 171.06, "text": "Bueno, es un catálogo.", "speaker": null}, {"start": 172.9, "end": 181.96, "text": "Se explicó un poquito del activo, del activo, un poco de lo que se llama, pero muy, casi nada.", "speaker": null}, {"start": 182.94, "end": 187.04, "text": "Y esto de financieros fue lo último que vimos, pero ni siquiera lo decimos también.", "speaker": null}, {"start": 188.36, "end": 192.0, "text": "Mira, yo no sé qué vamos a hacer, no sé qué vamos a hacer con la cuenta.", "speaker": null}, {"start": 192.0, "end": 193.9, "text": "porque aquí no vamos a tener contabilidad.", "speaker": null}, {"start": 195.28, "end": 198.18, "text": "Aquí el problema fue más o menos un escenario", "speaker": null}, {"start": 198.18, "end": 201.36, "text": "de por qué llegamos hasta la contabilidad.", "speaker": null}, {"start": 202.26, "end": 205.24, "text": "Si se acuerdan, yo te diría que lo importante es", "speaker": null}, {"start": 205.24, "end": 207.44, "text": "que los estados tienen siempre para adelante.", "speaker": null}, {"start": 208.24, "end": 209.78, "text": "De la contabilidad hay que preguntarse.", "speaker": null}, {"start": 209.96, "end": 211.18, "text": "Aquí no vamos a tener contabilidad,", "speaker": null}, {"start": 211.28, "end": 212.78, "text": "ni en el mundo, ni en la contabilidad.", "speaker": null}, {"start": 213.12, "end": 214.72, "text": "Me interesa que lo que hemos encontrado", "speaker": null}, {"start": 214.72, "end": 216.68, "text": "porque si a mí me tocara,", "speaker": null}, {"start": 216.68, "end": 231.47801, "text": "yo la parte contable ser la contable Pero mi madre dec as si requiere si requiero que tenga idea de la contabilidad pero no ni les voy a preguntar", "speaker": null}, {"start": 231.47801, "end": 232.418, "text": "ni les voy a exigir", "speaker": null}, {"start": 232.418, "end": 234.358, "text": "sería de ahí para adelante", "speaker": null}, {"start": 234.358, "end": 236.83801, "text": "por eso me llamo", "speaker": null}, {"start": 236.83801, "end": 239.878, "text": "pero si cuando tienes una idea", "speaker": null}, {"start": 239.878, "end": 240.778, "text": "de lo que te enseñaron", "speaker": null}, {"start": 240.778, "end": 241.938, "text": "lo que te enseñaron", "speaker": null}, {"start": 241.938, "end": 243.978, "text": "igual ahí", "speaker": null}, {"start": 243.978, "end": 246.018, "text": "que no a la monta de la contabilidad", "speaker": null}, {"start": 246.658, "end": 247.67801, "text": "yo tengo cuantos", "speaker": null}, {"start": 247.67801, "end": 253.998, "text": "de la contaminación de la tierra, de hecho se ha encontrado en el punto de vista de los", "speaker": null}, {"start": 253.998, "end": 260.178, "text": "centros para que no se contenga esto y este contaminante.", "speaker": null}, {"start": 262.918, "end": 270.418, "text": "Pero digo, trataríamos de ver lo necesario de contaminación para que puedan entender,", "speaker": null}, {"start": 270.418, "end": 275.118, "text": "pero tenemos que enfocarnos en nuestra área, en el país de los niños,", "speaker": null}, {"start": 275.118, "end": 284.398, "text": "Imagínense, cuando vamos a tomar todas las baterías que vienen atrás, vamos a ir tratando de escuchar lo más importante.", "speaker": null}, {"start": 286.138, "end": 286.438, "text": "Ok.", "speaker": null}, {"start": 289.398, "end": 296.538, "text": "Falta el pancho, pero pues, este va a ganar por 10, pues ya sabe que le tiene que pagar.", "speaker": null}, {"start": 297.99802, "end": 301.538, "text": "Y, pues, qué modo, si se escribió, porque la tiene que pagar.", "speaker": null}, {"start": 301.538, "end": 305.258, "text": "¿Tú votando en tu parte también?", "speaker": null}, {"start": 305.858, "end": 306.538, "text": "¿Esta es la última?", "speaker": null}, {"start": 307.978, "end": 308.198, "text": "¿No?", "speaker": null}, {"start": 308.958, "end": 309.59802, "text": "¿Tú en los tres?", "speaker": null}, {"start": 310.578, "end": 311.458, "text": "¿Representando a Pache?", "speaker": null}, {"start": 312.258, "end": 313.358, "text": "Entonces, fíjate.", "speaker": null}, {"start": 314.258, "end": 315.21802, "text": "Se queda en la ancha.", "speaker": null}, {"start": 316.278, "end": 318.398, "text": "Si es que no, sale bien y se va de caja.", "speaker": null}, {"start": 319.618, "end": 320.058, "text": "¿No?", "speaker": null}, {"start": 320.298, "end": 321.458, "text": "Que también puede ser que no.", "speaker": null}, {"start": 321.458, "end": 321.618, "text": "¿Sí?", "speaker": null}, {"start": 322.318, "end": 323.038, "text": "¿Qué no lo es?", "speaker": null}, {"start": 324.458, "end": 325.09802, "text": "¿Quién sabe?", "speaker": null}, {"start": 327.398, "end": 328.65802, "text": "Ok, ¿cómo lo hago?", "speaker": null}, {"start": 328.778, "end": 329.538, "text": "¿A su lado qué quiero?", "speaker": null}, {"start": 331.538, "end": 333.898, "text": "Vamos a tener que regresar a los impregnados.", "speaker": null}, {"start": 334.678, "end": 336.878, "text": "Pero estos vamos incluso, es más, vamos a pagar.", "speaker": null}, {"start": 338.298, "end": 340.09802, "text": "Vamos a tener que ampliar la dinámica.", "speaker": null}, {"start": 341.758, "end": 342.778, "text": "Vamos a tener que ampliar.", "speaker": null}, {"start": 344.538, "end": 346.738, "text": "Y con eso contigo, de alguna manera, de verdad.", "speaker": null}, {"start": 347.65802, "end": 350.358, "text": "Vamos a tener que ampliar a lo que de ella sabe.", "speaker": null}, {"start": 351.578, "end": 352.21802, "text": "¿Sí me explico?", "speaker": null}, {"start": 352.958, "end": 355.09802, "text": "O sea, no te lo haríamos a los que nos compliquemos.", "speaker": null}, {"start": 356.09802, "end": 360.55798, "text": "Si nos lo vas a tener que ampliar para tocar temas que deberían saber parte de esto.", "speaker": null}, {"start": 361.53802, "end": 391.518, "text": "No sé si estoy dando la idea.", "speaker": null}, {"start": 391.53802, "end": 396.778, "text": "ustedes, porque ustedes no van a tener que conformarnos. Probablemente lo que yo les", "speaker": null}, {"start": 396.778, "end": 402.298, "text": "platicaba antes de entrar a la Nación para elaborar Pax y que lleguen a ser", "speaker": null}, {"start": 402.298, "end": 407.09802, "text": "estados financieros y después eso es lo que va a tener que contaminar. Y que", "speaker": null}, {"start": 407.09802, "end": 411.618, "text": "nada, porque las empresas han dado el ejemplo que es contaminante. Y hay un", "speaker": null}, {"start": 411.618, "end": 415.918, "text": "otro año, porque no tienes finanzas. Y hay un otro año que se llama contra", "speaker": null}, {"start": 415.918, "end": 417.818, "text": "cada año", "speaker": null}, {"start": 417.818, "end": 420.65802, "text": "entonces yo", "speaker": null}, {"start": 420.65802, "end": 422.938, "text": "mis creyentes", "speaker": null}, {"start": 422.938, "end": 423.898, "text": "yo igual me alegro", "speaker": null}, {"start": 423.898, "end": 427.438, "text": "de los que me arme en el área de contabilidad", "speaker": null}, {"start": 427.438, "end": 429.118, "text": "yo necesito contabilidad", "speaker": null}, {"start": 429.118, "end": 429.878, "text": "mientras que no", "speaker": null}, {"start": 429.878, "end": 432.798, "text": "me los acabo por un ejemplo", "speaker": null}, {"start": 432.798, "end": 434.258, "text": "mis creyentes", "speaker": null}, {"start": 434.258, "end": 435.758, "text": "me dicen que no lo voy a hacer", "speaker": null}, {"start": 435.758, "end": 437.47803, "text": "no voy a hacer los contadores", "speaker": null}, {"start": 437.47803, "end": 438.55798, "text": "oye pero si tú", "speaker": null}, {"start": 438.55798, "end": 440.15802, "text": "sigo contabilidad", "speaker": null}, {"start": 440.15802, "end": 442.638, "text": "se los acabo de explicar", "speaker": null}, {"start": 442.638, "end": 443.418, "text": "si yo no me arrepiento", "speaker": null}, {"start": 443.418, "end": 455.996, "text": "muy sencillo de la vida les aclaro yo no los voy a llevar a la vida no chavos yo no me voy a estar quedando en la pizarra es que ahorita se nos dijo vamos a estar viendo un consejo de todo lo que vamos a ver aqu all afuera", "speaker": null}, {"start": 456.096, "end": 462.776, "text": "a mirar, porque si no nos falta todo ese tiempo, para que se queden de notas, no se que eso,", "speaker": null}, {"start": 463.496, "end": 468.396, "text": "ustedes necesitan un pequeño programa de ciencia allá afuera, ¿están de acuerdo?", "speaker": null}, {"start": 468.396, "end": 471.956, "text": "¿Qué pasa?", "speaker": null}, {"start": 472.436, "end": 473.536, "text": "Hola, soy el Santador", "speaker": null}, {"start": 473.536, "end": 474.876, "text": "Son mis colegas", "speaker": null}, {"start": 474.876, "end": 476.51602, "text": "Pero por la pena", "speaker": null}, {"start": 476.51602, "end": 478.13602, "text": "No puedo mantener tanto", "speaker": null}, {"start": 478.13602, "end": 480.036, "text": "Mi cliente se tiene pago", "speaker": null}, {"start": 480.036, "end": 483.13602, "text": "Y mi cliente me está exigiendo que minimice los costos", "speaker": null}, {"start": 483.13602, "end": 484.85602, "text": "Que disfruta de la empresa", "speaker": null}, {"start": 484.85602, "end": 486.996, "text": "Creo que es fenomenal", "speaker": null}, {"start": 486.996, "end": 488.816, "text": "Justísimo", "speaker": null}, {"start": 488.816, "end": 491.116, "text": "Sustituimos al área notable", "speaker": null}, {"start": 491.116, "end": 492.996, "text": "Por el área de sistemas", "speaker": null}, {"start": 492.996, "end": 495.876, "text": "Yo no deseamos", "speaker": null}, {"start": 495.876, "end": 496.936, "text": "Hermanitos de la calidad", "speaker": null}, {"start": 496.936, "end": 501.73602, "text": "¿Por qué no lo hicimos por cuestiones financieras?", "speaker": null}, {"start": 502.316, "end": 504.516, "text": "Es algo más barato, ¿verdad?", "speaker": null}, {"start": 504.696, "end": 507.876, "text": "De la más eficiencia, de la más rapidez.", "speaker": null}, {"start": 508.57602, "end": 512.196, "text": "No es lo mismo lo que tarda en ir haciendo la mano que lo que tarda en la máquina y se", "speaker": null}, {"start": 512.196, "end": 512.976, "text": "comienza a resolver.", "speaker": null}, {"start": 513.896, "end": 514.81604, "text": "Sí, sí, es muy importante.", "speaker": null}, {"start": 515.376, "end": 519.456, "text": "Tenemos que ver la relación de costo-beneficio e importancia de ustedes.", "speaker": null}, {"start": 520.356, "end": 525.836, "text": "Para mí, personal, a lo mejor en la vida práctica, ustedes son una clave importantísima", "speaker": null}, {"start": 525.836, "end": 526.296, "text": "para mí.", "speaker": null}, {"start": 526.93604, "end": 532.93604, "text": "Yo necesito tener a mi área de informática, a mi área de sistemas, a mi área de soporte,", "speaker": null}, {"start": 532.93604, "end": 533.93604, "text": "que ustedes me llamen.", "speaker": null}, {"start": 533.93604, "end": 536.93604, "text": "Necesito obtenerla como hoja de cocina.", "speaker": null}, {"start": 537.93604, "end": 539.93604, "text": "Porque eso depende del resultado de mi trabajo.", "speaker": null}, {"start": 540.93604, "end": 546.93604, "text": "Si nosotros vamos en el mundo, ok, entonces, con la tecla y con la música,", "speaker": null}, {"start": 546.93604, "end": 548.93604, "text": "es el campo donde tienes la vida real.", "speaker": null}, {"start": 549.93604, "end": 550.93604, "text": "¿Vale?", "speaker": null}, {"start": 551.93604, "end": 555.93604, "text": "A lo mejor no hay una mañana que va a lograr una industria que no cuide la cocina.", "speaker": null}, {"start": 556.93604, "end": 565.176, "text": "Ok, chavos, nos vamos a tener que regresar hasta Lugaza, acá, a la hora de ver.", "speaker": null}, {"start": 568.256, "end": 569.776, "text": "Ahí les vamos a ir, chavos.", "speaker": null}, {"start": 572.43604, "end": 578.376, "text": "Tenemos personas físicas y morales que se registran.", "speaker": null}, {"start": 578.376, "end": 580.376, "text": "¿Qué es lo que se registra?", "speaker": null}, {"start": 580.376, "end": 610.356, "text": "¿Y qué es?", "speaker": null}, {"start": 610.376, "end": 612.376, "text": "Gracias.", "speaker": null}, {"start": 640.376, "end": 659.296, "text": "Ok.", "speaker": null}, {"start": 659.296, "end": 659.376, "text": "Ok.", "speaker": null}, {"start": 660.596, "end": 666.916, "text": "El día de ayer, nosotros hacíamos a modo de síntesis.", "speaker": null}, {"start": 668.276, "end": 669.156, "text": "Partimos del propietario.", "speaker": null}, {"start": 670.376, "end": 671.054, "text": "Gracias Gracias", "speaker": null}, {"start": 700.054, "end": 702.13403, "text": "allá afuera. ¿Por qué?", "speaker": null}, {"start": 702.254, "end": 704.034, "text": "Porque estos cuates van a tener obligaciones", "speaker": null}, {"start": 704.034, "end": 706.314, "text": "y quien va a estar sobre ellos", "speaker": null}, {"start": 706.314, "end": 708.494, "text": "y se habrán dado cuenta, escuchen las noticias,", "speaker": null}, {"start": 708.494, "end": 710.834, "text": "a las famosas mañaneras de esta mujer", "speaker": null}, {"start": 710.834, "end": 712.494, "text": "están más que...", "speaker": null}, {"start": 713.254, "end": 714.834, "text": "No voy a hablar de eso, señor.", "speaker": null}, {"start": 715.414, "end": 716.494, "text": "Señora Presidente,", "speaker": null}, {"start": 717.69403, "end": 718.77405, "text": "me extraña que se agrese", "speaker": null}, {"start": 718.77405, "end": 720.054, "text": "a la UNAM y que se atarde.", "speaker": null}, {"start": 721.674, "end": 721.994, "text": "Eso.", "speaker": null}, {"start": 723.034, "end": 724.89404, "text": "Que hasta habla de presidenta,", "speaker": null}, {"start": 724.994, "end": 726.174, "text": "de valió gordo, ¿verdad?", "speaker": null}, {"start": 727.874, "end": 728.654, "text": "Ella dice", "speaker": null}, {"start": 728.654, "end": 730.07404, "text": "que existen las presidencias", "speaker": null}, {"start": 730.07404, "end": 731.874, "text": "yo creo que no he hablado de primaria", "speaker": null}, {"start": 731.874, "end": 733.854, "text": "porque sepa que señora presidente", "speaker": null}, {"start": 733.854, "end": 735.51404, "text": "no prescinda", "speaker": null}, {"start": 735.51404, "end": 737.434, "text": "¿estamos de acuerdo?", "speaker": null}, {"start": 738.354, "end": 740.614, "text": "bueno, hasta ahí me he estado diciendo", "speaker": null}, {"start": 740.614, "end": 742.63403, "text": "no diario", "speaker": null}, {"start": 742.63403, "end": 743.814, "text": "pero tiro por diario", "speaker": null}, {"start": 743.814, "end": 745.294, "text": "¿a quién nos quiere alentar?", "speaker": null}, {"start": 746.094, "end": 746.714, "text": "al SAT", "speaker": null}, {"start": 746.714, "end": 749.45404, "text": "se ha dado cuenta que hoy para todos", "speaker": null}, {"start": 749.45404, "end": 750.754, "text": "está presente el SAT", "speaker": null}, {"start": 750.754, "end": 754.554, "text": "el SAT ya revolcó a Densa, ya revolcó a Bimbo", "speaker": null}, {"start": 754.554, "end": 757.354, "text": "ya revolcó a", "speaker": null}, {"start": 757.354, "end": 760.334, "text": "con quien trae una bronca casada", "speaker": null}, {"start": 760.334, "end": 761.434, "text": "es con este cuate", "speaker": null}, {"start": 761.434, "end": 763.034, "text": "con el tío", "speaker": null}, {"start": 763.034, "end": 764.254, "text": "¿verdad?", "speaker": null}, {"start": 765.054, "end": 766.734, "text": "Ricardo Salinas", "speaker": null}, {"start": 766.734, "end": 770.154, "text": "ya le sacó más de 60 mil millones", "speaker": null}, {"start": 770.154, "end": 770.89404, "text": "de pesos", "speaker": null}, {"start": 770.89404, "end": 773.69403, "text": "ya lo hizo que vendiera", "speaker": null}, {"start": 773.69403, "end": 774.69403, "text": "en fila de empresas", "speaker": null}, {"start": 774.69403, "end": 777.13403, "text": "y no se conforme", "speaker": null}, {"start": 777.13403, "end": 779.874, "text": "y todo acá a la rata está amenazando", "speaker": null}, {"start": 779.874, "end": 781.63403, "text": "con que el saldo", "speaker": null}, {"start": 781.63403, "end": 782.39404, "text": "está revisado", "speaker": null}, {"start": 782.39404, "end": 784.13403, "text": "se tiene que regularizar", "speaker": null}, {"start": 784.13403, "end": 785.774, "text": "acá", "speaker": null}, {"start": 785.77405, "end": 790.334, "text": "Acá, si no se han dado, han hecho muchísimas cosas para recabar dinero.", "speaker": null}, {"start": 791.494, "end": 797.974, "text": "Y si les interesa, y no se atienden, hasta para allá nos vamos a meter, para que entiendan cómo funciona todo esto.", "speaker": null}, {"start": 800.114, "end": 807.034, "text": "Digo, me va a decir algo que me han ido diciendo mal, pero yo lo repito, van a aprender todo esto.", "speaker": null}, {"start": 807.814, "end": 812.754, "text": "A veces es de compromiso, discúlpenme, pero con la pena.", "speaker": null}, {"start": 812.754, "end": 815.19403, "text": "entonces", "speaker": null}, {"start": 815.19403, "end": 816.854, "text": "¿cuáles van a", "speaker": null}, {"start": 816.854, "end": 818.834, "text": "hacer en síntesis?", "speaker": null}, {"start": 819.07404, "end": 820.734, "text": "¿van a realizar operaciones?", "speaker": null}, {"start": 821.63403, "end": 822.114, "text": "¿correcto?", "speaker": null}, {"start": 823.57404, "end": 825.094, "text": "van a ser infinidad de operaciones", "speaker": null}, {"start": 825.094, "end": 826.614, "text": "pero no hablamos de cirugías", "speaker": null}, {"start": 826.614, "end": 829.474, "text": "aquí casualmente", "speaker": null}, {"start": 829.474, "end": 830.974, "text": "vamos a hablar de operaciones", "speaker": null}, {"start": 830.974, "end": 832.874, "text": "que le vamos a conocer como", "speaker": null}, {"start": 832.874, "end": 833.834, "text": "económico", "speaker": null}, {"start": 833.834, "end": 836.254, "text": "financiero, ¿por qué?", "speaker": null}, {"start": 837.054, "end": 839.214, "text": "porque se realizan", "speaker": null}, {"start": 839.214, "end": 841.674, "text": "se trafican, se manejan", "speaker": null}, {"start": 841.674, "end": 842.934, "text": "con dinero.", "speaker": null}, {"start": 843.734, "end": 845.754, "text": "Esas operaciones se tienen que realizar con dinero.", "speaker": null}, {"start": 847.114, "end": 848.234, "text": "Y todo lo que nos lleva", "speaker": null}, {"start": 848.234, "end": 850.414, "text": "a dinero, ¿qué dijimos que generaba?", "speaker": null}, {"start": 855.714, "end": 857.234, "text": "Eso, que no se puede registrar.", "speaker": null}, {"start": 857.854, "end": 859.674, "text": "Teníamos la necesidad de registrar.", "speaker": null}, {"start": 860.114, "end": 861.77405, "text": "Repito, hoy en día,", "speaker": null}, {"start": 861.954, "end": 863.114, "text": "¿qué está diciendo el santo?", "speaker": null}, {"start": 863.474, "end": 865.19403, "text": "Que nos va a revisar.", "speaker": null}, {"start": 866.114, "end": 867.374, "text": "¿Y cómo nos va a revisar?", "speaker": null}, {"start": 867.51404, "end": 868.414, "text": "Con registro.", "speaker": null}, {"start": 868.974, "end": 871.574, "text": "Si tú no tienes registrado, no puedes comprobar", "speaker": null}, {"start": 871.574, "end": 873.574, "text": "¿Qué crees? Pagas.", "speaker": null}, {"start": 873.574, "end": 875.574, "text": "Oye, pero es que yo sí pagué.", "speaker": null}, {"start": 875.574, "end": 877.574, "text": "¿Cuándo y cómo y dónde?", "speaker": null}, {"start": 877.574, "end": 879.574, "text": "¿Por qué pagaste y por qué no pagaste?", "speaker": null}, {"start": 879.574, "end": 881.574, "text": "Es que no me acuerdo.", "speaker": null}, {"start": 881.574, "end": 883.574, "text": "Lo peor es que no pagas.", "speaker": null}, {"start": 883.574, "end": 885.574, "text": "¿Qué tengo que hacer?", "speaker": null}, {"start": 885.574, "end": 887.574, "text": "A ver, a ver, a ver, a ver.", "speaker": null}, {"start": 887.574, "end": 889.574, "text": "¿Cómo que me quieres comprar acá?", "speaker": null}, {"start": 889.574, "end": 891.574, "text": "Aquí están mis registros.", "speaker": null}, {"start": 891.574, "end": 893.574, "text": "Con base en esto, yo ya pagué.", "speaker": null}, {"start": 893.574, "end": 895.574, "text": "O no pagué por esto.", "speaker": null}, {"start": 895.574, "end": 897.574, "text": "¿Por qué? Porque no tenía obligación.", "speaker": null}, {"start": 897.574, "end": 899.734, "text": "¿Sí me explico?", "speaker": null}]