[{"start": 0.0, "end": 3.0, "text": "A nosotros nos están queriendo vender.", "speaker": null}, {"start": 5.46, "end": 8.46, "text": "Y ya tengo bien desde cuando compré a su música,", "speaker": null}, {"start": 8.8, "end": 9.96, "text": "me contratan a su cabrón,", "speaker": null}, {"start": 10.92, "end": 14.06, "text": "a la profesional de información clasificada.", "speaker": null}, {"start": 17.76, "end": 19.22, "text": "Y tú le dirías, ¿por qué no lo haces?", "speaker": null}, {"start": 19.42, "end": 20.16, "text": "¿Cuál es el sistema?", "speaker": null}, {"start": 20.3, "end": 21.3, "text": "¿Por qué no lo compres?", "speaker": null}, {"start": 22.32, "end": 23.56, "text": "Así te contestan.", "speaker": null}, {"start": 23.84, "end": 25.08, "text": "Así te contestan.", "speaker": null}, {"start": 26.0, "end": 26.94, "text": "Entonces, ¿por qué no lo compres?", "speaker": null}, {"start": 26.94, "end": 30.26, "text": "Los pendejos, algunas pecas pueden con la operación de la empresa,", "speaker": null}, {"start": 30.44, "end": 31.7, "text": "¿cómo la van a proteger?", "speaker": null}, {"start": 31.88, "end": 34.28, "text": "¿Cómo va a tener un despacho de ciberseguridad?", "speaker": null}, {"start": 35.58, "end": 36.68, "text": "¿Cómo son las tigres?", "speaker": null}, {"start": 40.62, "end": 41.54, "text": "¿Sí me explico?", "speaker": null}, {"start": 41.54, "end": 45.22, "text": "Vamos, entre más sepan las funciones,", "speaker": null}, {"start": 45.5, "end": 48.58, "text": "tengan mejores posibilidades de éxito para la tienda.", "speaker": null}, {"start": 50.82, "end": 51.74, "text": "¿Me explico?", "speaker": null}, {"start": 54.88, "end": 55.64, "text": "Vámonos.", "speaker": null}, {"start": 56.94, "end": 63.42, "text": "Vamos a llegar a un momento, señores, en los que nosotros, sin hacer todas estas dudas,", "speaker": null}, {"start": 64.42, "end": 70.06, "text": "nada más con ver la estructura de la empresa, yo puedo identificar muchas cosas, muchas.", "speaker": null}, {"start": 71.16, "end": 74.92, "text": "Nada más con ver, esto va a ser con más experiencia, con más conocimiento.", "speaker": null}, {"start": 76.64, "end": 83.08, "text": "Este va a ser un estado de reposición financiera igual a este estado de reposición financiera.", "speaker": null}, {"start": 83.08, "end": 87.52, "text": "los dos tienen", "speaker": null}, {"start": 87.52, "end": 90.2, "text": "no me voy a adelantar", "speaker": null}, {"start": 90.2, "end": 93.54, "text": "ahorita nos vemos", "speaker": null}, {"start": 93.54, "end": 95.44, "text": "muy bueno", "speaker": null}, {"start": 95.44, "end": 98.4, "text": "vamos a partir de otra", "speaker": null}, {"start": 98.4, "end": 104.06, "text": "ya estoy pensando", "speaker": null}, {"start": 104.06, "end": 105.86, "text": "que con la pura escritura no puede leer", "speaker": null}, {"start": 105.86, "end": 107.24, "text": "me leeré", "speaker": null}, {"start": 107.24, "end": 137.22, "text": "No, no, no.", "speaker": null}, {"start": 137.24, "end": 142.34, "text": "que este y este", "speaker": null}, {"start": 142.34, "end": 143.24, "text": "es el mismo", "speaker": null}, {"start": 143.24, "end": 144.94, "text": "¿de acuerdo?", "speaker": null}, {"start": 145.88, "end": 147.86, "text": "esto es una copia fotográfica", "speaker": null}, {"start": 147.86, "end": 150.0, "text": "es otra impresión", "speaker": null}, {"start": 150.0, "end": 151.3, "text": "como quiera", "speaker": null}, {"start": 151.3, "end": 154.58, "text": "si nosotros nos decimos que este es otro estado", "speaker": null}, {"start": 154.58, "end": 155.58, "text": "de la posición", "speaker": null}, {"start": 155.58, "end": 157.46, "text": "pero es el mismo", "speaker": null}, {"start": 157.46, "end": 158.94, "text": "¿ok?", "speaker": null}, {"start": 159.96, "end": 162.48, "text": "vamos a repasar desde lo mismo", "speaker": null}, {"start": 162.48, "end": 163.36, "text": "que debe de saber", "speaker": null}, {"start": 163.36, "end": 165.6, "text": "y a donde vamos a ir", "speaker": null}, {"start": 165.6, "end": 166.7, "text": "¿vale?", "speaker": null}, {"start": 167.24, "end": 179.66, "text": "El documento de la misma empresa, nada más que uno lo vamos a ver desde el punto de vista contable y otro lo vamos a ver desde el punto de vista financiero.", "speaker": null}, {"start": 180.84, "end": 192.089, "text": "Es el mismo documento claro las mismas cuentas las mismas cifras la misma empresa pero la forma en que la vamos a analizar es diferente a cuando vemos contadores normales", "speaker": null}, {"start": 193.18901, "end": 196.369, "text": "a cuando vemos los sujetos del punto de vista financiero.", "speaker": null}, {"start": 197.149, "end": 202.489, "text": "Aquí yo ya no necesito ser contador, puedo ser ingeniero, puedo ser actual,", "speaker": null}, {"start": 203.569, "end": 208.529, "text": "puedo ser contador, puedo ser administrador, puedo ser informático,", "speaker": null}, {"start": 208.529, "end": 210.589, "text": "puedo ser la profesión que sea", "speaker": null}, {"start": 210.589, "end": 213.509, "text": "si yo sé manejar la información financiera", "speaker": null}, {"start": 213.509, "end": 215.089, "text": "ok", "speaker": null}, {"start": 215.089, "end": 216.32901, "text": "bueno", "speaker": null}, {"start": 216.32901, "end": 218.789, "text": "quiero pensar que a ustedes", "speaker": null}, {"start": 218.789, "end": 220.369, "text": "desde sus inicios", "speaker": null}, {"start": 220.369, "end": 222.969, "text": "les empezaron a enseñar la contabilidad", "speaker": null}, {"start": 222.969, "end": 225.10901, "text": "de los estados financieros más o menos así", "speaker": null}, {"start": 225.10901, "end": 226.789, "text": "a ver mi", "speaker": null}, {"start": 226.789, "end": 228.969, "text": "este es un estado", "speaker": null}, {"start": 228.969, "end": 230.969, "text": "de la profesión financiera", "speaker": null}, {"start": 230.969, "end": 232.589, "text": "que dice la maestra", "speaker": null}, {"start": 232.589, "end": 234.669, "text": "haz de cuenta que es una foto", "speaker": null}, {"start": 234.669, "end": 235.309, "text": "de un hombre", "speaker": null}, {"start": 235.309, "end": 248.869, "text": "Aquí vamos a ver que en el documento se va a componer de activos, pasivos y capital contable.", "speaker": null}, {"start": 250.289, "end": 260.789, "text": "El activo lo vamos a dividir en activo circulante, activo tipo, activo diferido, pasivo a corto y pasivo a largo.", "speaker": null}, {"start": 260.789, "end": 265.609, "text": "y empieza la maestra", "speaker": null}, {"start": 265.609, "end": 266.36902, "text": "a ver", "speaker": null}, {"start": 266.36902, "end": 278.169, "text": "para que entienda mejor esto", "speaker": null}, {"start": 278.169, "end": 281.049, "text": "los activos", "speaker": null}, {"start": 281.049, "end": 282.889, "text": "nos van a representar", "speaker": null}, {"start": 282.889, "end": 285.029, "text": "bienes y derechos", "speaker": null}, {"start": 285.029, "end": 287.149, "text": "pero casi se los explica", "speaker": null}, {"start": 287.149, "end": 287.829, "text": "en las leyes", "speaker": null}, {"start": 287.829, "end": 292.849, "text": "los básicos a diferencia de los activos", "speaker": null}, {"start": 292.849, "end": 294.629, "text": "me van a representar", "speaker": null}, {"start": 294.629, "end": 297.909, "text": "las tendas y obligaciones", "speaker": null}, {"start": 297.909, "end": 301.189, "text": "ahora lo vamos a permitir", "speaker": null}, {"start": 301.189, "end": 302.829, "text": "a sufrir el circulante", "speaker": null}, {"start": 302.829, "end": 304.389, "text": "por un periodo", "speaker": null}, {"start": 304.389, "end": 305.889, "text": "¿por qué?", "speaker": null}, {"start": 306.949, "end": 308.849, "text": "porque en el activo circulante", "speaker": null}, {"start": 308.849, "end": 311.849, "text": "vamos a mandar todas las cuentas", "speaker": null}, {"start": 311.849, "end": 313.849, "text": "que me representan", "speaker": null}, {"start": 313.849, "end": 315.76898, "text": "bienes y derechos", "speaker": null}, {"start": 315.76898, "end": 319.129, "text": "pero las vamos a ordenar", "speaker": null}, {"start": 319.129, "end": 320.649, "text": "las cuentas", "speaker": null}, {"start": 320.649, "end": 322.82898, "text": "en función de su", "speaker": null}, {"start": 322.82898, "end": 324.789, "text": "grado de disponibilidad", "speaker": null}, {"start": 324.789, "end": 328.789, "text": "y ese grado de disponibilidad", "speaker": null}, {"start": 328.789, "end": 330.94897, "text": "va a ser aquellas", "speaker": null}, {"start": 330.94897, "end": 332.669, "text": "que sean menores o", "speaker": null}, {"start": 332.669, "end": 335.169, "text": "iguales a un", "speaker": null}, {"start": 335.169, "end": 336.009, "text": "año", "speaker": null}, {"start": 336.009, "end": 338.76898, "text": "de ahí", "speaker": null}, {"start": 338.76898, "end": 341.009, "text": "que cuando ustedes enseñaron a ordenar", "speaker": null}, {"start": 341.009, "end": 342.44897, "text": "este documento", "speaker": null}, {"start": 342.44897, "end": 345.169, "text": "la primera cuenta que siempre van a encontrar", "speaker": null}, {"start": 345.169, "end": 348.569, "text": "después vienen", "speaker": null}, {"start": 348.569, "end": 349.989, "text": "bancos", "speaker": null}, {"start": 349.989, "end": 352.80902, "text": "después inversiones", "speaker": null}, {"start": 352.80902, "end": 354.68903, "text": "de inmediata realización", "speaker": null}, {"start": 354.68903, "end": 359.18903, "text": "después clientes", "speaker": null}, {"start": 359.18903, "end": 360.42902, "text": "y así", "speaker": null}, {"start": 360.42902, "end": 363.009, "text": "se la van llevando hasta llegar a inventar", "speaker": null}, {"start": 363.009, "end": 365.009, "text": "que es la", "speaker": null}, {"start": 365.009, "end": 366.169, "text": "última cuenta", "speaker": null}, {"start": 366.169, "end": 377.358, "text": "del circulante quiero que se lo ponga m o menos eso es ense Ahora qu hablamos de grado de disponibilidad", "speaker": null}, {"start": 378.818, "end": 381.538, "text": "El grado de disponibilidad se refiere a qué?", "speaker": null}, {"start": 382.538, "end": 388.858, "text": "A la rapidez en que lo conviertes en efectivo, en dinero líquido.", "speaker": null}, {"start": 390.638, "end": 393.118, "text": "Entonces, de ahí, de la cuenta de caja.", "speaker": null}, {"start": 393.118, "end": 398.178, "text": "yo no tengo roca porque no tengo más que abrir el cajón del escritorio", "speaker": null}, {"start": 398.178, "end": 399.71802, "text": "y ahí están los clientes", "speaker": null}, {"start": 399.71802, "end": 403.138, "text": "así de sencillo", "speaker": null}, {"start": 403.138, "end": 407.21802, "text": "por eso hablamos de disponibilidad", "speaker": null}, {"start": 407.21802, "end": 410.93802, "text": "sin encargo de las deudas y obligaciones", "speaker": null}, {"start": 410.93802, "end": 415.15802, "text": "las vamos a registrar en función a su grado", "speaker": null}, {"start": 415.15802, "end": 417.418, "text": "de exigibilidad", "speaker": null}, {"start": 417.418, "end": 420.478, "text": "que tan exigible es", "speaker": null}, {"start": 420.478, "end": 424.618, "text": "y este también tendrá que ser", "speaker": null}, {"start": 424.618, "end": 427.058, "text": "menor o igual", "speaker": null}, {"start": 427.058, "end": 428.898, "text": "a una", "speaker": null}, {"start": 428.898, "end": 431.59802, "text": "por eso tienen ambos lados", "speaker": null}, {"start": 431.59802, "end": 433.258, "text": "correcto", "speaker": null}, {"start": 433.258, "end": 434.298, "text": "y dará la equidad", "speaker": null}, {"start": 434.298, "end": 437.09802, "text": "hasta ahí lo veo", "speaker": null}, {"start": 437.09802, "end": 438.738, "text": "bueno", "speaker": null}, {"start": 438.738, "end": 441.03802, "text": "si ya tenemos que caer", "speaker": null}, {"start": 441.03802, "end": 442.65802, "text": "yo dejo más tarde el cajón", "speaker": null}, {"start": 442.65802, "end": 444.15802, "text": "sacar el billete", "speaker": null}, {"start": 444.15802, "end": 446.018, "text": "que cuenta en ese guión", "speaker": null}, {"start": 446.018, "end": 447.458, "text": "son bancos", "speaker": null}, {"start": 447.458, "end": 450.618, "text": "porque yo, ejemplo, en mi cuenta de cheques", "speaker": null}, {"start": 450.618, "end": 455.118, "text": "yo no tengo más que elaborar un título de crédito", "speaker": null}, {"start": 455.118, "end": 456.21802, "text": "denominado cheque", "speaker": null}, {"start": 456.21802, "end": 460.318, "text": "y un cheque no es más que una orden incondicional de pago", "speaker": null}, {"start": 460.318, "end": 464.418, "text": "que podrá ser que al portador o nominativo", "speaker": null}, {"start": 464.418, "end": 466.858, "text": "en donde yo extiendo el cheque", "speaker": null}, {"start": 466.858, "end": 468.438, "text": "se lo doy al IBM", "speaker": null}, {"start": 468.438, "end": 470.758, "text": "y lo mando a la esquina", "speaker": null}, {"start": 470.758, "end": 471.198, "text": "¿sabes qué?", "speaker": null}, {"start": 471.198, "end": 475.838, "text": "¿qué va a ser mi IBM, mi esclavo?", "speaker": null}, {"start": 475.838, "end": 479.118, "text": "como chiflido se va a la ventanilla", "speaker": null}, {"start": 479.118, "end": 481.118, "text": "lo van a acreditar", "speaker": null}, {"start": 481.118, "end": 482.378, "text": "que sea un charro", "speaker": null}, {"start": 482.378, "end": 483.898, "text": "ah si, un charro", "speaker": null}, {"start": 483.898, "end": 485.198, "text": "si, si hay sal", "speaker": null}, {"start": 485.198, "end": 488.938, "text": "y en friega me trae", "speaker": null}, {"start": 488.938, "end": 489.438, "text": "la barra", "speaker": null}, {"start": 489.438, "end": 492.358, "text": "quiere decir que esa cuenta es", "speaker": null}, {"start": 492.358, "end": 495.078, "text": "mediatamente disponible", "speaker": null}, {"start": 495.078, "end": 497.258, "text": "no es inmediatamente", "speaker": null}, {"start": 497.258, "end": 498.53802, "text": "porque no lo tengo a la mano", "speaker": null}, {"start": 498.53802, "end": 499.59802, "text": "pero es inmediato", "speaker": null}, {"start": 499.59802, "end": 502.838, "text": "no tengo más que mandar por dinero y me lo trae", "speaker": null}, {"start": 502.838, "end": 504.878, "text": "y el dinero está garantizado", "speaker": null}, {"start": 504.878, "end": 506.618, "text": "está asegurado", "speaker": null}, {"start": 506.618, "end": 508.21802, "text": "porque está en mi cuenta de bancos", "speaker": null}, {"start": 508.21802, "end": 510.018, "text": "quien la controla soy yo", "speaker": null}, {"start": 510.018, "end": 511.71802, "text": "quien sabe cuánto hay yo, soy yo", "speaker": null}, {"start": 511.71802, "end": 514.018, "text": "quien lo saca soy yo, quien lo gasta soy yo", "speaker": null}, {"start": 514.018, "end": 515.85803, "text": "quien lo mete soy yo", "speaker": null}, {"start": 515.85803, "end": 517.23804, "text": "¿estamos de acuerdo?", "speaker": null}, {"start": 518.458, "end": 519.838, "text": "¿qué cuenta le seguiría?", "speaker": null}, {"start": 522.698, "end": 524.218, "text": "inversiones de inmediata", "speaker": null}, {"start": 524.218, "end": 525.158, "text": "reacciones", "speaker": null}, {"start": 525.158, "end": 528.138, "text": "¿cuál es la inversión? que en vez de que el dinero", "speaker": null}, {"start": 528.138, "end": 529.758, "text": "esté en mi cuenta de cheques", "speaker": null}, {"start": 529.758, "end": 531.678, "text": "en el mismo banco", "speaker": null}, {"start": 531.678, "end": 534.23804, "text": "yo abro un contrato que puede ser un pagaré", "speaker": null}, {"start": 534.23804, "end": 536.398, "text": "con rendimiento liquidario y capital más intereses,", "speaker": null}, {"start": 536.898, "end": 538.41797, "text": "que es lo que ustedes vulgarmente conocen", "speaker": null}, {"start": 538.41797, "end": 540.198, "text": "con el nombre de inversiones a plazo,", "speaker": null}, {"start": 541.298, "end": 542.298, "text": "en donde el banco", "speaker": null}, {"start": 542.298, "end": 544.338, "text": "me quita el dinero temporalmente", "speaker": null}, {"start": 544.338, "end": 546.23804, "text": "a un plazo,", "speaker": null}, {"start": 546.35803, "end": 548.578, "text": "por ejemplo, de 28 días, pero al término del plazo", "speaker": null}, {"start": 548.578, "end": 549.41797, "text": "me la devuelve,", "speaker": null}, {"start": 550.498, "end": 561.927, "text": "pero me lo devuelve m intereses Quiere decir que mi lana est generando Pero si yo quiero cancelo la inversi y me regresa mi lana Entonces es", "speaker": null}, {"start": 561.927, "end": 564.08704, "text": "también inmediatamente disponible.", "speaker": null}, {"start": 565.02704, "end": 565.747, "text": "De eso", "speaker": null}, {"start": 565.747, "end": 568.067, "text": "hay unas situaciones que son", "speaker": null}, {"start": 568.067, "end": 570.14703, "text": "como de que de plano no lo puedes", "speaker": null}, {"start": 570.14703, "end": 571.64703, "text": "sacar hasta que termine el emplazo.", "speaker": null}, {"start": 571.807, "end": 573.627, "text": "Vamos a, si quieres, una vez lo tocamos.", "speaker": null}, {"start": 574.14703, "end": 575.84705, "text": "Eso no sería de inmediato.", "speaker": null}, {"start": 576.02704, "end": 577.927, "text": "Sí, también no tiene de regresión.", "speaker": null}, {"start": 578.60706, "end": 580.08704, "text": "¿Por qué? Porque hay inversiones", "speaker": null}, {"start": 580.08704, "end": 582.367, "text": "que son las 28 días, o sea, menos de un mes", "speaker": null}, {"start": 582.367, "end": 584.067, "text": "como te pagaré", "speaker": null}, {"start": 584.067, "end": 586.20703, "text": "pero si tú quieres ser más", "speaker": null}, {"start": 586.20703, "end": 588.20703, "text": "tigre, si quieres ser", "speaker": null}, {"start": 588.20703, "end": 590.34705, "text": "más financiero, yo me venía", "speaker": null}, {"start": 590.34705, "end": 591.867, "text": "a esto porque vamos a pasar por más", "speaker": null}, {"start": 591.867, "end": 593.60706, "text": "pero ya que", "speaker": null}, {"start": 593.60706, "end": 596.067, "text": "si te recargas de la plata baja", "speaker": null}, {"start": 596.067, "end": 597.60706, "text": "al primer piso, no pasa nada", "speaker": null}, {"start": 597.60706, "end": 598.84705, "text": "mientras te dejo", "speaker": null}, {"start": 598.84705, "end": 601.267, "text": "en vez de que", "speaker": null}, {"start": 601.267, "end": 603.72705, "text": "contrates un pagaré", "speaker": null}, {"start": 603.72705, "end": 606.007, "text": "con rendimiento de un cuidado de los intereses", "speaker": null}, {"start": 606.007, "end": 607.067, "text": "que pasó a 28 días", "speaker": null}, {"start": 607.067, "end": 609.84705, "text": "yo te recomendaría que te quites de tan", "speaker": null}, {"start": 609.84705, "end": 619.127, "text": "y mejor no viajes en CETES. ¿Por qué? Porque CETES, aunque también trabaja 28 días, ¿pero qué sucede?", "speaker": null}, {"start": 620.10706, "end": 628.22705, "text": "Trabaja a plazo, digo, a tasa de descuento. Eso te lo deberían haber enseñado en matemáticas financieras.", "speaker": null}, {"start": 629.247, "end": 634.10706, "text": "El papel, al ser a plazo, por supuesto, te tienes que esperar a que terminen los 28 días.", "speaker": null}, {"start": 634.867, "end": 639.547, "text": "Si no terminan los 28 días, aunque tú vayas y le dices a cualquier banco, no te va a regresar nunca.", "speaker": null}, {"start": 639.84705, "end": 645.427, "text": "porque tú firmaste y te comprometiste a dejarse los 28 días para que ellos no trabajen.", "speaker": null}, {"start": 646.48706, "end": 647.64703, "text": "Pero en los CETES no.", "speaker": null}, {"start": 648.427, "end": 648.767, "text": "¿Por qué?", "speaker": null}, {"start": 648.98706, "end": 653.48706, "text": "Porque los CETES es un certificado de la tesorería de la federación", "speaker": null}, {"start": 653.48706, "end": 656.127, "text": "que trabaja a tasa de descuento.", "speaker": null}, {"start": 656.127, "end": 656.98706, "text": "¿Qué quiere decir?", "speaker": null}, {"start": 657.547, "end": 660.58704, "text": "Que si tú invertiste a los 28 días,", "speaker": null}, {"start": 661.307, "end": 662.64703, "text": "pero por poner un ejemplo,", "speaker": null}, {"start": 664.40704, "end": 667.367, "text": "a los 15 días se te olvidó que no completaste la nómina", "speaker": null}, {"start": 667.367, "end": 673.127, "text": "y necesitas dinero, revientas el cete y en 24 horas tienes tu dama.", "speaker": null}, {"start": 675.007, "end": 678.66705, "text": "Si a la semana necesitas dinero porque te quieres ir al mundial,", "speaker": null}, {"start": 680.247, "end": 683.627, "text": "revientas tu cete y a los 8 horas tienes tu dama.", "speaker": null}, {"start": 684.667, "end": 687.567, "text": "¿Qué es lo que va a pasar? Va a ser con sacrificio de la casa,", "speaker": null}, {"start": 687.567, "end": 689.547, "text": "porque va a ser a descuento.", "speaker": null}, {"start": 690.28705, "end": 692.72705, "text": "¿Qué quiere decir esto? Que te van a pagar menos intereses,", "speaker": null}, {"start": 692.887, "end": 694.267, "text": "pero tienes disponibilidad.", "speaker": null}, {"start": 694.267, "end": 697.28705, "text": "Así de fácil.", "speaker": null}, {"start": 699.20703, "end": 700.447, "text": "Hoy viene una regresa.", "speaker": null}, {"start": 703.02704, "end": 703.887, "text": "Por ti.", "speaker": null}, {"start": 704.767, "end": 706.46704, "text": "Ya son las 10.", "speaker": null}, {"start": 706.64703, "end": 707.72705, "text": "No me digas.", "speaker": null}, {"start": 708.887, "end": 709.20703, "text": "¿10?", "speaker": null}, {"start": 709.58704, "end": 709.807, "text": "Sí.", "speaker": null}, {"start": 709.96704, "end": 711.007, "text": "Vamos, le damos la clase.", "speaker": null}, {"start": 711.72705, "end": 712.267, "text": "Muy bien.", "speaker": null}, {"start": 712.96704, "end": 713.34705, "text": "Gracias.", "speaker": null}, {"start": 713.667, "end": 713.887, "text": "Gracias.", "speaker": null}, {"start": 714.827, "end": 717.02704, "text": "Vamos a dejar las de aquí por hoy.", "speaker": null}, {"start": 717.887, "end": 720.52704, "text": "Mañana te pregunto, ¿qué voy a preguntar?", "speaker": null}, {"start": 720.52704, "end": 722.447, "text": "básicamente esto", "speaker": null}, {"start": 722.447, "end": 725.02704, "text": "para que ustedes empiecen vamos a comenzar", "speaker": null}, {"start": 725.02704, "end": 726.34705, "text": "con los métodos", "speaker": null}, {"start": 726.34705, "end": 728.767, "text": "y el primer método va a ser el método de los hombres", "speaker": null}, {"start": 728.767, "end": 731.08704, "text": "para que yo le vaya a mi nieto", "speaker": null}, {"start": 731.08704, "end": 731.947, "text": "al agua de los tronos", "speaker": null}, {"start": 731.947, "end": 733.90704, "text": "¿sale y vale?", "speaker": null}, {"start": 736.187, "end": 737.287, "text": "¿cómo vamos hasta aquí?", "speaker": null}, {"start": 740.427, "end": 740.867, "text": "¿bien?", "speaker": null}]