[{"start": 0.0, "end": 6.46, "text": "Y por estar ahí con tus sacos, yo perdí dinero, Charly.", "speaker": null}, {"start": 8.34, "end": 10.219999, "text": "¿Qué te parece si me haces una bonificación?", "speaker": null}, {"start": 16.52, "end": 20.439999, "text": "Con la pena, vamos a pensar que la bonificación", "speaker": null}, {"start": 20.439999, "end": 23.279999, "text": "sea el equivalente de dinero o de piezas.", "speaker": null}, {"start": 25.859999, "end": 27.64, "text": "¿Cuántos sacos se te ha dado la vez más?", "speaker": null}, {"start": 30.0, "end": 41.0, "text": "Oye, Charly, pero qué crees, que ya lo pensé y tú me ibas a dar un crédito a 90 días.", "speaker": null}, {"start": 42.6, "end": 49.04, "text": "Pero, pues como este mes me ha ido bien, ¿y si te pago por adelantar?", "speaker": null}, {"start": 53.239998, "end": 53.8, "text": "Está bien.", "speaker": null}, {"start": 54.98, "end": 55.96, "text": "¿Te parece o no te parece?", "speaker": null}, {"start": 57.34, "end": 58.899998, "text": "Yo te tengo que pagar 90 días.", "speaker": null}, {"start": 58.899998, "end": 61.14, "text": "pero si te pago hoy, ¿qué hacemos?", "speaker": null}, {"start": 66.92, "end": 68.2, "text": "el equivalente", "speaker": null}, {"start": 68.2, "end": 69.64, "text": "yo te lo diría siempre", "speaker": null}, {"start": 69.64, "end": 72.32, "text": "que pueda o no se puede", "speaker": null}, {"start": 72.32, "end": 75.46, "text": "y así podemos poner las hipótesis", "speaker": null}, {"start": 75.46, "end": 77.659996, "text": "que tú quieras, que funcionen en la vida real", "speaker": null}, {"start": 77.659996, "end": 79.42, "text": "acuérdate que estamos negociando", "speaker": null}, {"start": 79.42, "end": 83.04, "text": "yo lo que necesito obviamente", "speaker": null}, {"start": 83.04, "end": 84.78, "text": "es que", "speaker": null}, {"start": 84.78, "end": 87.2, "text": "minimizar mi costo", "speaker": null}, {"start": 87.2, "end": 89.34, "text": "es como si yo te puedo decir", "speaker": null}, {"start": 89.34, "end": 92.36, "text": "yo te pude haber comprado 20 sacos", "speaker": null}, {"start": 92.36, "end": 96.03999, "text": "pero te compré 600", "speaker": null}, {"start": 96.03999, "end": 98.0, "text": "y si son 600", "speaker": null}, {"start": 98.0, "end": 98.92, "text": "¿qué me merezco?", "speaker": null}, {"start": 100.21999, "end": 101.24, "text": "un precio de mayoría", "speaker": null}, {"start": 101.24, "end": 102.6, "text": "un precio de mayoría", "speaker": null}, {"start": 102.6, "end": 104.71999, "text": "no puede ser lo mismo", "speaker": null}, {"start": 104.71999, "end": 105.96, "text": "nos vamos entendiendo", "speaker": null}, {"start": 105.96, "end": 108.1, "text": "entonces vamos a hacer", "speaker": null}, {"start": 108.1, "end": 110.259995, "text": "a las compras totales", "speaker": null}, {"start": 110.259995, "end": 112.24, "text": "le vamos a restar", "speaker": null}, {"start": 112.24, "end": 114.299995, "text": "los descuentos, las rebajas, las devoluciones", "speaker": null}, {"start": 114.299995, "end": 115.21999, "text": "y las publicaciones", "speaker": null}, {"start": 115.21999, "end": 116.399994, "text": "sobre compra", "speaker": null}, {"start": 116.399994, "end": 118.81999, "text": "el resultado de esto", "speaker": null}, {"start": 118.81999, "end": 121.27999, "text": "realmente", "speaker": null}, {"start": 121.27999, "end": 122.63999, "text": "¿cuántos sacos", "speaker": null}, {"start": 122.63999, "end": 123.95999, "text": "comprar al almacén?", "speaker": null}, {"start": 124.77999, "end": 125.53999, "text": "500", "speaker": null}, {"start": 125.53999, "end": 129.04, "text": "inventar", "speaker": null}, {"start": 129.04, "end": 130.71999, "text": "y utilizar de materia 500 sacos", "speaker": null}, {"start": 130.71999, "end": 133.09999, "text": "más", "speaker": null}, {"start": 133.09999, "end": 134.23999, "text": "compras netas", "speaker": null}, {"start": 134.23999, "end": 136.34, "text": "500 sacos", "speaker": null}, {"start": 136.34, "end": 138.43999, "text": "¿qué me da como resultado?", "speaker": null}, {"start": 139.07999, "end": 139.4, "text": "1000", "speaker": null}, {"start": 139.4, "end": 141.81999, "text": "1000", "speaker": null}, {"start": 141.81999, "end": 143.0, "text": "¿y eso cómo se llama?", "speaker": null}, {"start": 143.0, "end": 147.02, "text": "materia prima disponible", "speaker": null}, {"start": 147.02, "end": 148.84, "text": "quiere decir que ahorita", "speaker": null}, {"start": 148.84, "end": 151.1, "text": "en este animacín, en esta bodega", "speaker": null}, {"start": 151.1, "end": 154.56, "text": "tengo mil sacos", "speaker": null}, {"start": 154.56, "end": 156.58, "text": "disponibles, si o no", "speaker": null}, {"start": 156.58, "end": 159.08, "text": "son estas sillas que están aquí", "speaker": null}, {"start": 159.08, "end": 161.22, "text": "marcas que entraron ahora", "speaker": null}, {"start": 161.22, "end": 163.22, "text": "¿cuántos tengo disponibles?", "speaker": null}, {"start": 163.84, "end": 164.96, "text": "mil sacos", "speaker": null}, {"start": 164.96, "end": 166.96, "text": "obviamente no lo vamos a vender en sacos", "speaker": null}, {"start": 166.96, "end": 168.02, "text": "lo vamos a vender en dinero", "speaker": null}, {"start": 168.02, "end": 170.86, "text": "digo, se lo estoy poniendo así para que lo vayan entendiendo", "speaker": null}, {"start": 170.86, "end": 175.24, "text": "entonces", "speaker": null}, {"start": 175.24, "end": 177.48, "text": "¿cuánto tengo de materia prima disponible?", "speaker": null}, {"start": 177.76, "end": 179.48, "text": "mil sangres", "speaker": null}, {"start": 179.48, "end": 181.32, "text": "ahora", "speaker": null}, {"start": 181.32, "end": 184.02, "text": "la norma me dice", "speaker": null}, {"start": 184.02, "end": 185.66, "text": "que le reste", "speaker": null}, {"start": 185.66, "end": 187.94, "text": "el inventario final de materia prima", "speaker": null}, {"start": 187.94, "end": 189.82, "text": "¿cuál va a ser", "speaker": null}, {"start": 189.82, "end": 191.26, "text": "el inventario final de materia prima?", "speaker": null}, {"start": 191.72, "end": 193.54, "text": "este, al cierre del mes", "speaker": null}, {"start": 193.54, "end": 195.56, "text": "ya pasó todo el mes", "speaker": null}, {"start": 195.56, "end": 197.8, "text": "todo el mes ya pasó y vuelvo a contar", "speaker": null}, {"start": 197.8, "end": 198.38, "text": "los años", "speaker": null}, {"start": 198.38, "end": 201.09999, "text": "yo conté los", "speaker": null}, {"start": 201.09999, "end": 202.57999, "text": "los arcos en el inicio", "speaker": null}, {"start": 202.57999, "end": 204.9, "text": "me vi en 1, 2, 3, 4, 5", "speaker": null}, {"start": 204.9, "end": 205.77998, "text": "eran 500", "speaker": null}, {"start": 205.77998, "end": 209.51999, "text": "pero cuando terminó el mes volví a contar", "speaker": null}, {"start": 209.51999, "end": 211.2, "text": "¿sabe?", "speaker": null}, {"start": 212.54, "end": 213.79999, "text": "al cierre de mes", "speaker": null}, {"start": 213.79999, "end": 215.09999, "text": "¿qué crees?", "speaker": null}, {"start": 215.65999, "end": 217.84, "text": "que nada más me quedan 300 arcos", "speaker": null}, {"start": 217.84, "end": 230.518, "text": "entonces va a pasar materia prima disponible menos el inventario final de materia prima 300 que me va a pasar Materia prima disponible Menos el inventario final de materia prima 300 me va a dar como resultado", "speaker": null}, {"start": 231.058, "end": 231.598, "text": "100.", "speaker": null}, {"start": 232.598, "end": 233.098, "text": "¿300?", "speaker": null}, {"start": 234.53801, "end": 235.17801, "text": "No.", "speaker": null}, {"start": 235.47801, "end": 236.078, "text": "No es el 100.", "speaker": null}, {"start": 237.078, "end": 237.81801, "text": "Sí, es el 100.", "speaker": null}, {"start": 238.95801, "end": 240.218, "text": "¿A eso cómo le llamamos?", "speaker": null}, {"start": 244.298, "end": 245.738, "text": "Materia prima utilizada.", "speaker": null}, {"start": 245.83801, "end": 247.238, "text": "Materia prima utilizada.", "speaker": null}, {"start": 247.238, "end": 249.218, "text": "¿Por qué? Yo tenía 1000.", "speaker": null}, {"start": 250.018, "end": 252.75801, "text": "y quedaron 300 quiere decir que me faltan 700.", "speaker": null}, {"start": 254.53801, "end": 257.038, "text": "Y si me faltan 700, ¿a dónde demonios están?", "speaker": null}, {"start": 257.898, "end": 259.258, "text": "Que ahí les salieron pajitas.", "speaker": null}, {"start": 259.258, "end": 262.298, "text": "Ya se lo comieron a los clientes.", "speaker": null}, {"start": 264.878, "end": 269.09802, "text": "Esa azúcar, esa harina, ese rollo, ya no está en el almacén.", "speaker": null}, {"start": 270.198, "end": 271.858, "text": "Y si no está en el almacén, ¿por qué no está?", "speaker": null}, {"start": 272.258, "end": 273.818, "text": "Porque ya la utilicé.", "speaker": null}, {"start": 275.118, "end": 276.578, "text": "Ya me la quité del almacén.", "speaker": null}, {"start": 276.578, "end": 278.838, "text": "entonces, insisto", "speaker": null}, {"start": 278.838, "end": 280.298, "text": "inventar el material de materia prima", "speaker": null}, {"start": 280.298, "end": 282.918, "text": "las compras netas, materia prima disponible", "speaker": null}, {"start": 282.918, "end": 284.338, "text": "materia prima disponible", "speaker": null}, {"start": 284.338, "end": 286.298, "text": "inventar el material de materia prima que le da", "speaker": null}, {"start": 286.298, "end": 287.438, "text": "materia prima utiliza", "speaker": null}, {"start": 287.438, "end": 290.578, "text": "quiere decir que esos 700", "speaker": null}, {"start": 290.578, "end": 292.798, "text": "que están ahí, porque los utilicé", "speaker": null}, {"start": 292.798, "end": 295.618, "text": "oye, pero si los utilicé", "speaker": null}, {"start": 295.618, "end": 297.09802, "text": "vuelvo a hacer la pregunta", "speaker": null}, {"start": 297.09802, "end": 298.518, "text": "yo les chiflé", "speaker": null}, {"start": 298.518, "end": 301.09802, "text": "a ver esos 700", "speaker": null}, {"start": 301.09802, "end": 302.478, "text": "que están ahí, es como los alumnos", "speaker": null}, {"start": 302.478, "end": 304.058, "text": "a ver esos alumnos de la fila de atrás", "speaker": null}, {"start": 304.058, "end": 306.038, "text": "pásense al otro salón", "speaker": null}, {"start": 306.038, "end": 306.918, "text": "así lo hacemos", "speaker": null}, {"start": 306.918, "end": 310.178, "text": "le vamos a decir a los sacos", "speaker": null}, {"start": 310.178, "end": 312.338, "text": "ahí van los sacos", "speaker": null}, {"start": 312.338, "end": 313.558, "text": "¿sí?", "speaker": null}, {"start": 314.818, "end": 315.298, "text": "no, no", "speaker": null}, {"start": 315.298, "end": 317.758, "text": "esos sacos", "speaker": null}, {"start": 317.758, "end": 318.558, "text": "si yo los utilicé", "speaker": null}, {"start": 318.558, "end": 319.738, "text": "a donde de uno de los únicos", "speaker": null}, {"start": 319.738, "end": 322.418, "text": "o sea, a lo mejor fue para echarlos", "speaker": null}, {"start": 322.418, "end": 324.49802, "text": "a los contenedores", "speaker": null}, {"start": 324.49802, "end": 326.038, "text": "a donde se va a mezclar", "speaker": null}, {"start": 326.038, "end": 326.918, "text": "con el azúcar", "speaker": null}, {"start": 326.918, "end": 328.618, "text": "con la leche", "speaker": null}, {"start": 328.618, "end": 330.178, "text": "con los huevos", "speaker": null}, {"start": 330.178, "end": 331.878, "text": "para empezar su proceso", "speaker": null}, {"start": 331.878, "end": 344.358, "text": "y repito, corrieron los saquitos, alguien lo debió haber hecho. Ese alguien lo conocemos", "speaker": null}, {"start": 344.358, "end": 358.578, "text": "como mano de obra. Materia bien utilizada más mano de obra directa. ¿Qué me da como", "speaker": null}, {"start": 358.578, "end": 362.418, "text": "costado mi costo primo.", "speaker": null}, {"start": 364.418, "end": 365.178, "text": "Ok.", "speaker": null}, {"start": 366.358, "end": 367.71802, "text": "La máquina para que lo ocupé,", "speaker": null}, {"start": 367.798, "end": 372.238, "text": "para sacar los actos, para vaciarlos", "speaker": null}, {"start": 372.238, "end": 375.678, "text": "en el molde, pues para prender la máquina", "speaker": null}, {"start": 375.678, "end": 379.438, "text": "y la máquina funcionar para todo.", "speaker": null}, {"start": 379.438, "end": 380.418, "text": "¿Estamos de acuerdo?", "speaker": null}, {"start": 381.198, "end": 382.398, "text": "Eso me da mi costo primo.", "speaker": null}, {"start": 382.398, "end": 385.498, "text": "más", "speaker": null}, {"start": 385.498, "end": 388.618, "text": "los gastos indirectos de producción", "speaker": null}, {"start": 388.618, "end": 390.15802, "text": "¿cuáles son los gastos indirectos de producción?", "speaker": null}, {"start": 390.65802, "end": 392.238, "text": "si dijimos que la mano de obra era la que", "speaker": null}, {"start": 392.238, "end": 394.438, "text": "desde que se acababa la cosa con rebordía", "speaker": null}, {"start": 394.438, "end": 395.398, "text": "hacía los moldes", "speaker": null}, {"start": 395.398, "end": 397.738, "text": "ya acabó la chamba ahí del cuate este", "speaker": null}, {"start": 397.738, "end": 399.178, "text": "a la mejor, pero no", "speaker": null}, {"start": 399.178, "end": 402.578, "text": "faltó meter la loma", "speaker": null}, {"start": 402.578, "end": 407.138, "text": "¿y qué faltó?", "speaker": null}, {"start": 407.138, "end": 413.438, "text": "prenderle al gas", "speaker": null}, {"start": 413.438, "end": 417.59802, "text": "y el gas se va a consumir", "speaker": null}, {"start": 417.59802, "end": 418.818, "text": "durante cierto tiempo", "speaker": null}, {"start": 418.818, "end": 420.898, "text": "¿eso qué es?", "speaker": null}, {"start": 422.47803, "end": 423.59802, "text": "un gas", "speaker": null}, {"start": 423.59802, "end": 425.21802, "text": "muy directo de producción", "speaker": null}, {"start": 425.21802, "end": 432.958, "text": "¿qué me da como resultado eso?", "speaker": null}, {"start": 432.958, "end": 439.198, "text": "mi costo incurrido", "speaker": null}, {"start": 439.198, "end": 465.876, "text": "hasta ah volvieron al regreso bueno tengo duda en la mano de obra directa Es igual a otro c relacionado al tiempo que se utiliza en este espec", "speaker": null}, {"start": 465.876, "end": 469.396, "text": "y se relaciona con la nómina de la persona que está...", "speaker": null}, {"start": 469.396, "end": 471.01602, "text": "¿Con las personas? ¿Con las?", "speaker": null}, {"start": 471.01602, "end": 473.036, "text": "Sí, es otro cálculo.", "speaker": null}, {"start": 473.336, "end": 473.79602, "text": "¿Aparte?", "speaker": null}, {"start": 473.79602, "end": 476.67603, "text": "no, no, no, se lleva el tiempo de todo", "speaker": null}, {"start": 476.67603, "end": 478.976, "text": "por eso es la mano de obra directa", "speaker": null}, {"start": 478.976, "end": 479.896, "text": "a ver, vamos a ver", "speaker": null}, {"start": 479.896, "end": 481.976, "text": "la mano de obra directa, Charlie", "speaker": null}, {"start": 481.976, "end": 484.73602, "text": "es la mano de obra del personal", "speaker": null}, {"start": 484.73602, "end": 487.096, "text": "o de la gente", "speaker": null}, {"start": 487.096, "end": 488.456, "text": "que estuvo involucrada", "speaker": null}, {"start": 488.456, "end": 490.756, "text": "directamente en ese proceso", "speaker": null}, {"start": 490.756, "end": 491.51602, "text": "productivo", "speaker": null}, {"start": 491.51602, "end": 493.51602, "text": "por un ejemplo", "speaker": null}, {"start": 493.51602, "end": 495.896, "text": "estamos hablando de los obreros", "speaker": null}, {"start": 495.896, "end": 498.73602, "text": "¿sabe? porque tú vas a decir", "speaker": null}, {"start": 498.73602, "end": 500.376, "text": "y quiero entender lo que estás diciendo", "speaker": null}, {"start": 500.376, "end": 501.79602, "text": "oye, pero por ejemplo", "speaker": null}, {"start": 501.79602, "end": 503.91602, "text": "y el sueldo de las secretarias", "speaker": null}, {"start": 503.91602, "end": 506.896, "text": "y el sueldo de los vendedores", "speaker": null}, {"start": 506.896, "end": 509.156, "text": "es esa parte", "speaker": null}, {"start": 509.156, "end": 511.57602, "text": "que es a la mano de obra", "speaker": null}, {"start": 511.57602, "end": 514.296, "text": "pero no está relacionada", "speaker": null}, {"start": 514.296, "end": 515.276, "text": "con el sueldo", "speaker": null}, {"start": 515.276, "end": 517.43604, "text": "si es tan seguro", "speaker": null}, {"start": 517.43604, "end": 519.536, "text": "que está más cerca de la mina", "speaker": null}, {"start": 519.536, "end": 521.876, "text": "aquí está en un lugar", "speaker": null}, {"start": 521.876, "end": 523.676, "text": "que está relacionado", "speaker": null}, {"start": 523.676, "end": 525.536, "text": "al proceso productivo", "speaker": null}, {"start": 525.536, "end": 527.99603, "text": "es un poco el caso del producto", "speaker": null}, {"start": 527.99603, "end": 529.31604, "text": "el agro y el gas", "speaker": null}, {"start": 529.31604, "end": 530.016, "text": "nada más", "speaker": null}, {"start": 530.016, "end": 534.976, "text": "los vendedores, la secretaria, la limpieza", "speaker": null}, {"start": 534.976, "end": 536.296, "text": "todos sus camaradas", "speaker": null}, {"start": 536.296, "end": 538.81604, "text": "los apagamos de empresa", "speaker": null}, {"start": 538.81604, "end": 544.236, "text": "por eso tú te das cuenta que todas las empresas", "speaker": null}, {"start": 544.236, "end": 545.276, "text": "sobre todo las grandes", "speaker": null}, {"start": 545.276, "end": 547.716, "text": "están separadas de sus oficinas", "speaker": null}, {"start": 547.716, "end": 551.31604, "text": "de las plantas o de los fábricas", "speaker": null}, {"start": 551.31604, "end": 552.916, "text": "¿sí?", "speaker": null}, {"start": 552.916, "end": 552.996, "text": "¿sí?", "speaker": null}, {"start": 553.956, "end": 555.776, "text": "porque una cosa es la producción", "speaker": null}, {"start": 555.776, "end": 558.296, "text": "y otra es la parte administrativa o operativa", "speaker": null}, {"start": 558.296, "end": 566.536, "text": "por distribución, lo que quiera que puedan estar disponibles. Hasta ahí nada más es la parte de la producción.", "speaker": null}, {"start": 568.536, "end": 579.496, "text": "Y entonces, en esa parte de monodero directa sería toda la nómina completa de todas las personas involucradas de ese mes.", "speaker": null}, {"start": 580.016, "end": 587.036, "text": "Es porque, que estén en esa área, que estén en ese todo el tiempo. Porque, por ejemplo, yo vivo, no va a pasar nada.", "speaker": null}, {"start": 587.036, "end": 589.49603, "text": "tengo la planta de Vallejo", "speaker": null}, {"start": 589.49603, "end": 592.676, "text": "pero puedo tener plantas en otras partes de la República", "speaker": null}, {"start": 592.676, "end": 593.896, "text": "tengo la de", "speaker": null}, {"start": 593.896, "end": 595.756, "text": "la de la Cuarta", "speaker": null}, {"start": 595.756, "end": 597.956, "text": "tengo la de la Etapa", "speaker": null}, {"start": 597.956, "end": 599.536, "text": "tengo en distintos lados", "speaker": null}, {"start": 599.536, "end": 602.516, "text": "aunque son también productivas", "speaker": null}, {"start": 602.516, "end": 604.396, "text": "pero cada plano", "speaker": null}, {"start": 604.396, "end": 605.31604, "text": "es un otro", "speaker": null}, {"start": 605.31604, "end": 608.43604, "text": "a ver, qué bueno que salió este", "speaker": null}, {"start": 608.43604, "end": 608.93604, "text": "ojo", "speaker": null}, {"start": 614.93604, "end": 616.076, "text": "¿te acuerdas que te dije", "speaker": null}, {"start": 616.076, "end": 618.036, "text": "que había estados financieros secundarios.", "speaker": null}, {"start": 620.636, "end": 624.416, "text": "Bingo, en la realidad, se llama Grupo Bingo.", "speaker": null}, {"start": 625.896, "end": 633.976, "text": "Y acabo de señalar que yo voy a tener diferentes empresas o representaciones.", "speaker": null}, {"start": 635.756, "end": 640.656, "text": "Tengo plantas en CDMX y tengo plantas en diferentes partes de la región.", "speaker": null}, {"start": 640.656, "end": 643.076, "text": "pero aparte de tener plantas", "speaker": null}, {"start": 643.076, "end": 643.956, "text": "ejemplo", "speaker": null}, {"start": 643.956, "end": 646.536, "text": "tengo algo que se llama CEDIS", "speaker": null}, {"start": 646.536, "end": 648.696, "text": "¿qué es un CEDIS?", "speaker": null}, {"start": 648.896, "end": 651.396, "text": "un centro de distribución", "speaker": null}, {"start": 651.396, "end": 652.836, "text": "es el ocupo", "speaker": null}, {"start": 652.836, "end": 654.416, "text": "para distribuir mi producto", "speaker": null}, {"start": 654.416, "end": 656.856, "text": "son otros almacenes que nada tienen que ver", "speaker": null}, {"start": 656.856, "end": 657.576, "text": "con la producción", "speaker": null}, {"start": 657.576, "end": 660.836, "text": "pero son míos", "speaker": null}, {"start": 660.836, "end": 662.456, "text": "también tengo", "speaker": null}, {"start": 662.456, "end": 664.116, "text": "puntos de venta", "speaker": null}, {"start": 664.116, "end": 666.756, "text": "y tengo en toda la república", "speaker": null}, {"start": 666.756, "end": 668.216, "text": "entonces ¿qué va a pasar?", "speaker": null}, {"start": 668.416, "end": 681.57404, "text": "si cada uno de esos lugares en el mundo no tenemos elementos que van a cuatro que van a derretir que van bajada de la TN cada uno lleva su propio control y su propia contabilidad va a pasar", "speaker": null}, {"start": 681.57404, "end": 685.494, "text": "Pues que va a ser un desastre de contabilidades.", "speaker": null}, {"start": 686.934, "end": 692.294, "text": "Todos van a ser estados de yacimiento por separado, así tiene que ser.", "speaker": null}, {"start": 692.294, "end": 695.07404, "text": "entonces yo", "speaker": null}, {"start": 695.07404, "end": 696.174, "text": "¿verdad?", "speaker": null}, {"start": 697.89404, "end": 699.214, "text": "estando en la dirección", "speaker": null}, {"start": 699.214, "end": 701.19403, "text": "yo soy", "speaker": null}, {"start": 701.19403, "end": 704.19403, "text": "uno de los dueños", "speaker": null}, {"start": 704.19403, "end": 706.39404, "text": "a mi no me interesa que me digas", "speaker": null}, {"start": 706.39404, "end": 708.094, "text": "cuantos están manejando", "speaker": null}, {"start": 708.094, "end": 710.39404, "text": "en Querétaro, cuantos están manejando", "speaker": null}, {"start": 710.39404, "end": 711.874, "text": "en Veracruz, cuantos están", "speaker": null}, {"start": 711.874, "end": 713.69403, "text": "manejando en Saltillo", "speaker": null}, {"start": 713.69403, "end": 715.45404, "text": "yo quiero ver hoy", "speaker": null}, {"start": 715.45404, "end": 717.39404, "text": "si estoy ganando o estoy perdiendo", "speaker": null}, {"start": 717.39404, "end": 722.594, "text": "te vas a traer a los", "speaker": null}, {"start": 722.594, "end": 724.474, "text": "L contadores", "speaker": null}, {"start": 724.474, "end": 726.174, "text": "N administradores", "speaker": null}, {"start": 726.174, "end": 728.714, "text": "N esclavos", "speaker": null}, {"start": 728.714, "end": 729.414, "text": "de cada empresa", "speaker": null}, {"start": 729.414, "end": 734.39404, "text": "¿qué voy a hacer?", "speaker": null}, {"start": 735.254, "end": 736.654, "text": "voy a citar a reunión", "speaker": null}, {"start": 736.654, "end": 738.094, "text": "en el corporativo", "speaker": null}, {"start": 738.094, "end": 740.414, "text": "han oído hablar que hay empresas corporativas", "speaker": null}, {"start": 740.414, "end": 742.094, "text": "¿qué?", "speaker": null}, {"start": 742.874, "end": 744.874, "text": "es donde yo me manejo en el corporativo", "speaker": null}, {"start": 744.874, "end": 746.554, "text": "y ahí voy a ver la situación", "speaker": null}, {"start": 746.554, "end": 748.094, "text": "de todas mis empresas.", "speaker": null}, {"start": 750.154, "end": 751.094, "text": "Entonces me van a traer", "speaker": null}, {"start": 751.094, "end": 752.654, "text": "50 estados financieros.", "speaker": null}, {"start": 753.534, "end": 755.054, "text": "¿Tú crees que yo como dueño", "speaker": null}, {"start": 755.054, "end": 756.754, "text": "de mi gobierno voy a solicitar", "speaker": null}, {"start": 756.754, "end": 758.854, "text": "50 estados financieros?", "speaker": null}, {"start": 760.994, "end": 762.494, "text": "¿Qué voy a solicitar?", "speaker": null}, {"start": 764.594, "end": 766.234, "text": "¿Estados financieros qué?", "speaker": null}, {"start": 769.27405, "end": 769.95404, "text": "Consolidados.", "speaker": null}, {"start": 770.95404, "end": 772.434, "text": "Ahí viene el resultado", "speaker": null}, {"start": 772.434, "end": 774.95404, "text": "de todas las", "speaker": null}, {"start": 774.95404, "end": 775.994, "text": "empresas de mi grupo.", "speaker": null}, {"start": 776.554, "end": 781.154, "text": "ya vamos de ello porque estos son básicos", "speaker": null}, {"start": 781.154, "end": 783.534, "text": "y estos son secundarios", "speaker": null}, {"start": 783.534, "end": 786.534, "text": "estos son de apoyo a los básicos", "speaker": null}, {"start": 786.534, "end": 789.314, "text": "hoy mismo me regreso", "speaker": null}, {"start": 789.314, "end": 792.674, "text": "si para seguir", "speaker": null}, {"start": 792.674, "end": 803.714, "text": "bueno había entendido un poco que", "speaker": null}, {"start": 803.714, "end": 805.934, "text": "por ejemplo este de costa de producción", "speaker": null}, {"start": 805.934, "end": 811.39404, "text": "es como un precursor del estado de resultados.", "speaker": null}, {"start": 811.51404, "end": 812.13403, "text": "Así es.", "speaker": null}, {"start": 812.13403, "end": 819.13403, "text": "Pero entonces también el...", "speaker": null}, {"start": 820.174, "end": 831.214, "text": "Bueno, pero el consolidado es como la consolidación", "speaker": null}, {"start": 831.214, "end": 835.39404, "text": "de muchos estados de resultados o de situación.", "speaker": null}, {"start": 835.934, "end": 839.614, "text": "Entonces, como que la relación sí va de los dos lados.", "speaker": null}, {"start": 840.39404, "end": 843.814, "text": "Los secundarios pueden tener de los básicos y los básicos de los secundarios.", "speaker": null}, {"start": 843.814, "end": 847.874, "text": "Depende de cada uno. Por eso es que son diferentes argumentos.", "speaker": null}, {"start": 848.874, "end": 856.154, "text": "Hay uno que a lo mejor es dependiente de eso, o de eso, o de estos.", "speaker": null}, {"start": 857.354, "end": 861.234, "text": "Y a lo mejor alguno de estos es dependiente de estos.", "speaker": null}, {"start": 861.234, "end": 863.334, "text": "como en este caso", "speaker": null}, {"start": 863.334, "end": 866.19403, "text": "el estado de resultados es dependiente", "speaker": null}, {"start": 866.19403, "end": 867.13403, "text": "del secundario", "speaker": null}, {"start": 867.13403, "end": 869.614, "text": "caso inverso", "speaker": null}, {"start": 869.614, "end": 870.874, "text": "la subordinación", "speaker": null}, {"start": 870.874, "end": 872.934, "text": "yo explico", "speaker": null}, {"start": 872.934, "end": 873.854, "text": "porque sin eso", "speaker": null}, {"start": 873.854, "end": 875.754, "text": "no nace este", "speaker": null}, {"start": 875.754, "end": 877.474, "text": "si o no", "speaker": null}, {"start": 877.474, "end": 877.614, "text": "si", "speaker": null}, {"start": 877.614, "end": 882.294, "text": "yo pensé que entonces la definición", "speaker": null}, {"start": 882.294, "end": 884.674, "text": "pensé originalmente que la definición era", "speaker": null}, {"start": 884.674, "end": 886.914, "text": "que los básicos siempre dependían", "speaker": null}, {"start": 886.914, "end": 888.13403, "text": "de los secundarios pero no es así", "speaker": null}, {"start": 888.13403, "end": 889.334, "text": "entonces cuál sería", "speaker": null}, {"start": 889.334, "end": 890.63403, "text": "como la...", "speaker": null}, {"start": 890.63403, "end": 892.234, "text": "Son secundarios porque", "speaker": null}, {"start": 892.234, "end": 895.63403, "text": "no todas las empresas están obligadas", "speaker": null}, {"start": 895.63403, "end": 896.254, "text": "a serlo.", "speaker": null}, {"start": 897.474, "end": 898.19403, "text": "Sí.", "speaker": null}]