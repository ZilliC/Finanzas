[{"start": 0.0, "end": 2.0, "text": "...", "speaker": null}, {"start": 30.0, "end": 33.44, "text": "Yo lo estoy esperando como 20 minutos al metro.", "speaker": null}, {"start": 34.72, "end": 35.06, "text": "¿Un poco?", "speaker": null}, {"start": 36.26, "end": 37.14, "text": "Y en cada...", "speaker": null}, {"start": 37.14, "end": 37.48, "text": "Así va.", "speaker": null}, {"start": 45.48, "end": 46.38, "text": "Muchas gracias.", "speaker": null}, {"start": 60.0, "end": 71.14, "text": "Sí, hay bloqueos, digamos, más bien ya están armando los bloqueos, porque todavía no hay.", "speaker": null}, {"start": 73.14, "end": 81.8, "text": "Bueno, se cierre, pero todavía hay bastante movilidad, no tanto como parecía.", "speaker": null}, {"start": 82.42, "end": 83.22, "text": "Sí, no.", "speaker": null}, {"start": 83.22, "end": 84.22, "text": "Sí, sí, sí.", "speaker": null}, {"start": 86.22, "end": 89.52, "text": "Pero sí, sí se montan, que van a ser los que van a ir.", "speaker": null}, {"start": 90.0, "end": 98.4, "text": "¿Usted por dónde llega?", "speaker": null}, {"start": 120.0, "end": 128.0, "text": "el tráfico del metro, y a veces se complica mucho, a veces se lleva a tardar hasta 40", "speaker": null}, {"start": 128.0, "end": 138.1, "text": "minutos para dar esa vuelta, entonces a veces te pido dar toda la vuelta a C1, a veces por", "speaker": null}, {"start": 138.1, "end": 144.3, "text": "la mano, de plano, a la mano, a la mano, a la mano, a la mano, a la mano, a la mano,", "speaker": null}, {"start": 144.3, "end": 174.28, "text": "¿Qué pasa?", "speaker": null}, {"start": 174.3, "end": 191.36, "text": "pero bueno", "speaker": null}, {"start": 204.3, "end": 206.72, "text": "Entonces, ya no veo lo que se diga.", "speaker": null}, {"start": 207.2, "end": 207.7, "text": "No está bien.", "speaker": null}, {"start": 210.42, "end": 212.7, "text": "Lo único que hay problemas es con los hielos.", "speaker": null}, {"start": 214.08, "end": 216.26001, "text": "Lo que les he dicho es que los hielos están frágil.", "speaker": null}, {"start": 216.42, "end": 218.74, "text": "En cambio, los hielos están a la noche.", "speaker": null}, {"start": 220.36, "end": 230.39801, "text": "No estoy muy contento Pero si voy a ir a un sitio y voy a poner con la sedici ese es mi problema No hay eres un buen es el estilo de tu cuerpo de comercio es tu problema qu no te escoges el pechito bien con la vida", "speaker": null}, {"start": 230.918, "end": 232.498, "text": "¿Qué te va a decir el hombre que sabe menos?", "speaker": null}, {"start": 232.95801, "end": 233.47801, "text": "¿Lo mismo?", "speaker": null}, {"start": 234.83801, "end": 235.998, "text": "¿Cuál es tu problema?", "speaker": null}, {"start": 236.778, "end": 239.018, "text": "¿Quieres ir a preguntar a nadie?", "speaker": null}, {"start": 239.938, "end": 241.158, "text": "¿Qué no vas a decir a la gente?", "speaker": null}, {"start": 242.11801, "end": 243.238, "text": "¿Es hasta la noche?", "speaker": null}, {"start": 244.098, "end": 245.078, "text": "¿Por qué se enoja?", "speaker": null}, {"start": 246.298, "end": 247.418, "text": "¿Por qué no entiendo a la gente?", "speaker": null}, {"start": 247.418, "end": 248.17801, "text": "¿Por qué no te acuerdas de la gente?", "speaker": null}, {"start": 248.17801, "end": 248.53801, "text": "¿Por qué no te acuerdas de la gente?", "speaker": null}, {"start": 250.018, "end": 254.698, "text": "Y tengo amigos que son franceses, de Ft. Ward.", "speaker": null}, {"start": 255.858, "end": 258.478, "text": "Y me han dado, porque no tengo saber,", "speaker": null}, {"start": 259.938, "end": 260.818, "text": "no sabía explicar.", "speaker": null}, {"start": 262.258, "end": 263.538, "text": "Y yo, y yo, y yo.", "speaker": null}, {"start": 264.638, "end": 265.838, "text": "No me he hecho de chico,", "speaker": null}, {"start": 266.738, "end": 268.358, "text": "no me he hecho de ganado,", "speaker": null}, {"start": 268.958, "end": 270.438, "text": "no me he hecho de ganado.", "speaker": null}, {"start": 271.71802, "end": 272.838, "text": "Supongo que se quitan,", "speaker": null}, {"start": 273.49802, "end": 275.738, "text": "que llevan el chico, no es de ese tipo.", "speaker": null}, {"start": 277.078, "end": 278.258, "text": "Pero bien yo, bien.", "speaker": null}, {"start": 280.018, "end": 282.878, "text": "No, no sé tú, pero yo no me lo hago.", "speaker": null}, {"start": 283.358, "end": 285.058, "text": "¿Por qué no te voy a trabajar y me lo hago?", "speaker": null}, {"start": 286.438, "end": 289.15802, "text": "Ahora te pregunto a ti, ¿qué vas a hacer?", "speaker": null}, {"start": 290.678, "end": 292.318, "text": "Pues que me lo hagas el chico.", "speaker": null}, {"start": 292.698, "end": 293.898, "text": "Pues sí, me lo hagas el chico.", "speaker": null}, {"start": 294.638, "end": 295.738, "text": "¿Y qué harás tú?", "speaker": null}, {"start": 296.918, "end": 297.958, "text": "Pues que no voy a trabajar.", "speaker": null}, {"start": 299.238, "end": 300.818, "text": "Usted es un regalado, maestro.", "speaker": null}, {"start": 301.938, "end": 303.678, "text": "O no te necesitan en tu trabajo.", "speaker": null}, {"start": 304.798, "end": 306.698, "text": "O a lo mejor en tu servicio con sus queridos.", "speaker": null}, {"start": 306.698, "end": 309.698, "text": "Que no lo pude, pero por qué no acá?", "speaker": null}, {"start": 310.018, "end": 324.018, "text": "y que por fin, la voz con voz incluso de los maestros nos va a iniciar la pelea.", "speaker": null}, {"start": 324.018, "end": 331.018, "text": "Entonces, ¿qué? Traemos un impresionante equipo de los que, con suerte, seguimos ganando.", "speaker": null}, {"start": 331.018, "end": 337.018, "text": "Y yo vuelvo a verlo de nuevo. Voz de ellos. Traemos un impresionante equipo.", "speaker": null}, {"start": 337.018, "end": 344.958, "text": "Estaba escuchando que en el primer partido les tocó con los negritos, porque dijo que no jugaban.", "speaker": null}, {"start": 345.178, "end": 349.178, "text": "Y luego que tuvieron que jugar con los negros, no sé cuántos se venden siempre.", "speaker": null}, {"start": 350.21802, "end": 351.318, "text": "Y nada más que jugó con los negros.", "speaker": null}, {"start": 352.09802, "end": 353.458, "text": "Y no entendieron que jugaban menos.", "speaker": null}, {"start": 355.258, "end": 356.55798, "text": "Si no hubiera sido por eso, no habría.", "speaker": null}, {"start": 357.278, "end": 358.878, "text": "Y se leen.", "speaker": null}, {"start": 358.878, "end": 362.178, "text": "y de", "speaker": null}, {"start": 362.178, "end": 364.078, "text": "Guadalajara", "speaker": null}, {"start": 364.078, "end": 364.97803, "text": "comentando", "speaker": null}, {"start": 364.97803, "end": 366.838, "text": "quien fue por el gobierno", "speaker": null}, {"start": 366.838, "end": 369.998, "text": "el gobierno", "speaker": null}, {"start": 369.998, "end": 370.578, "text": "fue el gobierno", "speaker": null}, {"start": 370.578, "end": 373.03802, "text": "y lo que decimos", "speaker": null}, {"start": 373.03802, "end": 375.198, "text": "no lo dirán a nadie", "speaker": null}, {"start": 375.198, "end": 376.53802, "text": "entonces", "speaker": null}, {"start": 376.53802, "end": 378.898, "text": "¿cuánto importante es hacer eso?", "speaker": null}, {"start": 380.15802, "end": 380.738, "text": "piensa", "speaker": null}, {"start": 380.738, "end": 383.938, "text": "son puntos de vista", "speaker": null}, {"start": 383.938, "end": 385.298, "text": "de la gente que conoce", "speaker": null}, {"start": 385.298, "end": 386.238, "text": "yo no conozco", "speaker": null}, {"start": 386.238, "end": 387.238, "text": "Gracias.", "speaker": null}, {"start": 416.238, "end": 427.838, "text": "El comunicado oficial, en donde hay la actividad pública, es el de matar, matar los seres, es cantar las facilidades.", "speaker": null}, {"start": 429.378, "end": 433.378, "text": "Esto es lo que estoy diciendo, lo que estoy diciendo, lo que estoy diciendo, lo que estoy diciendo.", "speaker": null}, {"start": 433.378, "end": 434.378, "text": "Gracias.", "speaker": null}, {"start": 475.036, "end": 505.01602, "text": "Vamos a ver qué tal viene.", "speaker": null}, {"start": 505.036, "end": 506.036, "text": "Gracias.", "speaker": null}, {"start": 535.036, "end": 537.776, "text": "viene nada más un modo", "speaker": null}, {"start": 537.776, "end": 538.796, "text": "de cuidar los seres", "speaker": null}, {"start": 538.796, "end": 541.536, "text": "pero", "speaker": null}, {"start": 541.536, "end": 545.216, "text": "hay varios", "speaker": null}, {"start": 545.216, "end": 546.456, "text": "temas", "speaker": null}, {"start": 546.456, "end": 548.376, "text": "que siempre van a haber", "speaker": null}, {"start": 548.376, "end": 551.456, "text": "de buenas bases", "speaker": null}, {"start": 551.456, "end": 554.296, "text": "igual la actitud", "speaker": null}, {"start": 554.296, "end": 559.876, "text": "para hacer todo lo que", "speaker": null}, {"start": 559.876, "end": 561.216, "text": "tenga con los niños", "speaker": null}, {"start": 561.216, "end": 562.176, "text": "en el caso de que hayan", "speaker": null}, {"start": 562.176, "end": 569.296, "text": "La unidad de labor es la introducción de las finanzas. Es una base de la unidad.", "speaker": null}, {"start": 569.93604, "end": 570.456, "text": "¿A que es el primero?", "speaker": null}, {"start": 571.31604, "end": 572.556, "text": "Creo que sí es el primero.", "speaker": null}, {"start": 572.856, "end": 573.976, "text": "A ver, ¿qué es el primero?", "speaker": null}, {"start": 575.616, "end": 579.81604, "text": "El segundo es el modelo de análisis financiero sistemático integral.", "speaker": null}, {"start": 580.676, "end": 583.176, "text": "El tercero es planeación financiera empresarial.", "speaker": null}, {"start": 584.636, "end": 588.176, "text": "El cuarto es estado de flujo de efectivo, método directo.", "speaker": null}, {"start": 588.176, "end": 594.856, "text": "Y el quinto, métodos de evaluación, valor presente en esto y tasa interna de retorno.", "speaker": null}, {"start": 595.31604, "end": 599.396, "text": "Exacto. Pero si te vas a análisis de sistemas, por favor.", "speaker": null}, {"start": 602.256, "end": 603.376, "text": "Análisis sistemático.", "speaker": null}, {"start": 604.416, "end": 606.736, "text": "Sí, aparte de la hipoteca y el sistema básico.", "speaker": null}, {"start": 607.736, "end": 614.19604, "text": "Dice, herramientas para el análisis de la situación financiera y de la rentabilidad de la empresa.", "speaker": null}, {"start": 614.19604, "end": 616.896, "text": "los estados financieros", "speaker": null}, {"start": 616.896, "end": 618.736, "text": "los métodos de análisis", "speaker": null}, {"start": 618.736, "end": 620.93604, "text": "de interpretación de estados financieros", "speaker": null}, {"start": 620.93604, "end": 622.896, "text": "clasificación de las técnicas", "speaker": null}, {"start": 622.896, "end": 624.656, "text": "de análisis de los estados financieros", "speaker": null}, {"start": 624.656, "end": 626.016, "text": "así es", "speaker": null}, {"start": 626.016, "end": 627.416, "text": "este tema", "speaker": null}, {"start": 627.416, "end": 632.536, "text": "es un tema", "speaker": null}, {"start": 632.536, "end": 633.69604, "text": "que es convencional", "speaker": null}, {"start": 633.69604, "end": 635.456, "text": "y que es un método de análisis", "speaker": null}, {"start": 635.456, "end": 636.576, "text": "y ahí", "speaker": null}, {"start": 636.576, "end": 637.836, "text": "es un método", "speaker": null}, {"start": 637.836, "end": 639.256, "text": "de análisis", "speaker": null}, {"start": 639.256, "end": 642.396, "text": "analizar", "speaker": null}, {"start": 642.396, "end": 643.896, "text": "o revisar", "speaker": null}, {"start": 643.896, "end": 671.054, "text": "se encuentran las mesas Les voy a hacer un escudo No no lo voy a hacer No lo voy a hacer Gracias", "speaker": null}, {"start": 700.054, "end": 702.45404, "text": "la mente debe contar con usted", "speaker": null}, {"start": 702.45404, "end": 705.13403, "text": "que hace un espacio", "speaker": null}, {"start": 705.13403, "end": 707.334, "text": "que nos está moviendo", "speaker": null}, {"start": 707.334, "end": 707.814, "text": "de mano", "speaker": null}, {"start": 707.814, "end": 710.034, "text": "cuando yo les da", "speaker": null}, {"start": 710.034, "end": 711.414, "text": "más ansiosos", "speaker": null}, {"start": 711.414, "end": 713.314, "text": "más ansiosos", "speaker": null}, {"start": 713.314, "end": 715.494, "text": "la luz", "speaker": null}, {"start": 715.494, "end": 717.734, "text": "no se entiende", "speaker": null}, {"start": 717.734, "end": 720.234, "text": "yo no quiero que", "speaker": null}, {"start": 720.234, "end": 721.854, "text": "muchas personas", "speaker": null}, {"start": 721.854, "end": 723.01404, "text": "lleguen a mi trabajo", "speaker": null}, {"start": 723.01404, "end": 726.174, "text": "y no les pongan días ansiosos", "speaker": null}, {"start": 726.174, "end": 727.254, "text": "y ustedes no pueden", "speaker": null}, {"start": 727.254, "end": 729.934, "text": "entonces aquí si", "speaker": null}, {"start": 729.934, "end": 732.13403, "text": "Sí, también tu enseñanza.", "speaker": null}, {"start": 734.294, "end": 744.594, "text": "Pero obviamente, voy a ver la manera de explicar la forma más relajada posible, la forma más sencilla posible.", "speaker": null}, {"start": 745.454, "end": 746.454, "text": "Pero sí, vamos a ver.", "speaker": null}, {"start": 749.174, "end": 754.39404, "text": "Evidentemente, esto me va a presentar probablemente a la mejor.", "speaker": null}, {"start": 754.39404, "end": 760.934, "text": "el dedicarle más tiempo", "speaker": null}, {"start": 760.934, "end": 761.69403, "text": "a la mejor", "speaker": null}, {"start": 761.69403, "end": 764.554, "text": "el tener que apoyar", "speaker": null}, {"start": 764.554, "end": 765.914, "text": "los pasos", "speaker": null}, {"start": 765.914, "end": 770.854, "text": "de la disposición", "speaker": null}, {"start": 770.854, "end": 771.794, "text": "y del espíritu", "speaker": null}, {"start": 771.794, "end": 774.274, "text": "porque al final llegamos a ese acuerdo", "speaker": null}, {"start": 774.274, "end": 776.254, "text": "y eso es lo que nos hace", "speaker": null}, {"start": 776.254, "end": 777.294, "text": "que no es un plan", "speaker": null}, {"start": 777.294, "end": 779.794, "text": "yo siento que la autoridad es muy importante", "speaker": null}, {"start": 779.794, "end": 781.39404, "text": "en esta versión", "speaker": null}, {"start": 781.39404, "end": 783.19403, "text": "que debe ser", "speaker": null}, {"start": 783.19403, "end": 784.19403, "text": "Gracias.", "speaker": null}, {"start": 813.19403, "end": 814.27405, "text": "Y ahí vemos.", "speaker": null}, {"start": 816.594, "end": 819.794, "text": "Entonces, si quieres darle la respuesta, si quieres.", "speaker": null}, {"start": 821.294, "end": 827.63403, "text": "Dice, planeación financiera empresarial, punto de equilibrio contable, planeación operativa,", "speaker": null}, {"start": 828.15405, "end": 831.834, "text": "planeación estratégica, presupuesto de efectivo, costo de capital,", "speaker": null}, {"start": 832.614, "end": 835.034, "text": "proceso de cuantificación de las fuentes de financiamiento.", "speaker": null}, {"start": 835.034, "end": 837.554, "text": "Y ahí, claro, las fuentes de financiamiento.", "speaker": null}, {"start": 838.13403, "end": 843.034, "text": "Si yo les pregunto, porque aquí hablan de la financiación y cuantificación financiera,", "speaker": null}, {"start": 843.19403, "end": 869.01404, "text": "¿Qué es el coste de capital?", "speaker": null}, {"start": 873.19403, "end": 874.89404, "text": "¿Qué más?", "speaker": null}, {"start": 875.414, "end": 878.734, "text": "El costo del capital promedio comparado, WACC.", "speaker": null}, {"start": 879.01404, "end": 879.63403, "text": "¿Y el capital?", "speaker": null}, {"start": 881.434, "end": 887.57404, "text": "El modelo de evaluación de los activos del capital, el capital, y el resumen y concluyentes.", "speaker": null}, {"start": 887.814, "end": 888.534, "text": "Es correcto.", "speaker": null}, {"start": 889.534, "end": 892.854, "text": "Luego viene básicamente el estado de WACC.", "speaker": null}, {"start": 894.174, "end": 896.01404, "text": "Básicamente es para el contrabando.", "speaker": null}, {"start": 898.254, "end": 899.69403, "text": "Finalmente, viene otra.", "speaker": null}]