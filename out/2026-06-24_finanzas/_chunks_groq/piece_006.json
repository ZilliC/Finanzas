[{"start": 0.0, "end": 2.6799998, "text": "Vamos a ver qué es todo, pero a ver si funciona.", "speaker": null}, {"start": 4.56, "end": 7.94, "text": "Ok, ¿a qué demonio se dedica Bimbo?", "speaker": null}, {"start": 8.8, "end": 9.12, "text": "¿A qué?", "speaker": null}, {"start": 10.96, "end": 11.44, "text": "Rápido.", "speaker": null}, {"start": 11.679999, "end": 12.12, "text": "¿Qué pasa?", "speaker": null}, {"start": 12.62, "end": 13.24, "text": "A la braca.", "speaker": null}, {"start": 14.12, "end": 14.94, "text": "¿A la braca?", "speaker": null}, {"start": 15.98, "end": 16.859999, "text": "Así de sencillo.", "speaker": null}, {"start": 17.96, "end": 18.88, "text": "¿Qué tipo de pan hace?", "speaker": null}, {"start": 19.859999, "end": 21.9, "text": "No vayan a pensar como nosotros sabemos.", "speaker": null}, {"start": 23.16, "end": 24.279999, "text": "Pan Bimbo.", "speaker": null}, {"start": 25.42, "end": 28.46, "text": "Yo sé qué es pan y qué es Bimbo.", "speaker": null}, {"start": 28.46, "end": 30.019999, "text": "hace", "speaker": null}, {"start": 30.019999, "end": 33.239998, "text": "¿cómo se llama ese pan largo que vende?", "speaker": null}, {"start": 34.46, "end": 35.6, "text": "pan de caja", "speaker": null}, {"start": 35.6, "end": 39.36, "text": "ya todo el mundo lo conoce como pan bingo", "speaker": null}, {"start": 39.36, "end": 41.3, "text": "no señor, se llama pan de caja", "speaker": null}, {"start": 41.3, "end": 42.719997, "text": "con el suceso", "speaker": null}, {"start": 42.719997, "end": 43.96, "text": "grupo bingo", "speaker": null}, {"start": 43.96, "end": 46.859997, "text": "y no nada más hace pan de caja", "speaker": null}, {"start": 46.859997, "end": 49.0, "text": "hace bolitas", "speaker": null}, {"start": 49.0, "end": 51.039997, "text": "hace mermelos", "speaker": null}, {"start": 51.039997, "end": 52.739998, "text": "hace panquecitos", "speaker": null}, {"start": 52.739998, "end": 53.699997, "text": "hace", "speaker": null}, {"start": 53.699997, "end": 55.76, "text": "mantecada", "speaker": null}, {"start": 55.76, "end": 57.6, "text": "un montón de cordilleras", "speaker": null}, {"start": 57.6, "end": 58.48, "text": "¿Estamos de acuerdo?", "speaker": null}, {"start": 60.739998, "end": 64.26, "text": "Ok, si es ese negocio maravilloso,", "speaker": null}, {"start": 65.159996, "end": 68.58, "text": "ese negocio que ha hecho crecer a lo que es hoy en día,", "speaker": null}, {"start": 70.6, "end": 74.78, "text": "pues debe de haber alguna manera de elaborar ese pan.", "speaker": null}, {"start": 76.0, "end": 79.979996, "text": "Porque ellos lo elaboran, no lo compran hecho y lo revenden.", "speaker": null}, {"start": 81.299995, "end": 81.799995, "text": "¿Estamos de acuerdo?", "speaker": null}, {"start": 82.6, "end": 84.299995, "text": "Ellos no son comercializadores.", "speaker": null}, {"start": 86.759995, "end": 87.28, "text": "¿Sí?", "speaker": null}, {"start": 87.6, "end": 90.68, "text": "¿Ellos qué hacen? Ellos lo producen.", "speaker": null}, {"start": 93.0, "end": 93.82, "text": "Volviendo a la relación.", "speaker": null}, {"start": 96.54, "end": 98.759995, "text": "Aquí no hay mujeres que nos ayuden, ni modo.", "speaker": null}, {"start": 99.9, "end": 104.64, "text": "A veces las mujeres son necesarias pero no indispensables.", "speaker": null}, {"start": 107.34, "end": 109.72, "text": "¿Cómo se imaginan ustedes que se disfrutan?", "speaker": null}, {"start": 109.72, "end": 112.439995, "text": "¿Tienen idea?", "speaker": null}, {"start": 112.439995, "end": 117.159996, "text": "lo primero que vamos a necesitar", "speaker": null}, {"start": 117.159996, "end": 118.7, "text": "va a ser materia prima", "speaker": null}, {"start": 118.7, "end": 120.56, "text": "¿estamos de acuerdo?", "speaker": null}, {"start": 121.17999, "end": 121.45999, "text": "¿o no?", "speaker": null}, {"start": 122.35999, "end": 123.88, "text": "la materia prima ¿cuál pudiera ser?", "speaker": null}, {"start": 124.079994, "end": 125.03999, "text": "lo que acabas de decir", "speaker": null}, {"start": 125.03999, "end": 127.77999, "text": "harina, leche", "speaker": null}, {"start": 127.77999, "end": 130.36, "text": "a lo mejor que hay saborizantes", "speaker": null}, {"start": 130.36, "end": 132.18, "text": "a lo mejor roya", "speaker": null}, {"start": 132.18, "end": 134.42, "text": "a lo mejor colorantes", "speaker": null}, {"start": 134.42, "end": 136.28, "text": "aunque no sean artificiales", "speaker": null}, {"start": 136.28, "end": 137.28, "text": "pero colorantes", "speaker": null}, {"start": 137.28, "end": 140.34, "text": "aunque no sea azúcar pero fructuosa", "speaker": null}, {"start": 140.34, "end": 141.43999, "text": "¿verdad?", "speaker": null}, {"start": 141.44, "end": 142.72, "text": "y así sucesivamente", "speaker": null}, {"start": 142.72, "end": 145.48, "text": "va a requerir algo que nosotros", "speaker": null}, {"start": 145.48, "end": 148.18001, "text": "vamos a conocer en la vida real como insumos", "speaker": null}, {"start": 148.18001, "end": 152.04001, "text": "váyanse familiarizando con los conceptos", "speaker": null}, {"start": 152.04001, "end": 153.40001, "text": "contables y financieros", "speaker": null}, {"start": 153.40001, "end": 154.34, "text": "que es necesario", "speaker": null}, {"start": 154.34, "end": 156.76, "text": "echando de nuevo y dando de nuevo", "speaker": null}, {"start": 156.76, "end": 158.28, "text": "poco a poquito", "speaker": null}, {"start": 158.28, "end": 160.68001, "text": "a ser", "speaker": null}, {"start": 160.68001, "end": 162.76, "text": "determinados", "speaker": null}, {"start": 162.76, "end": 165.02, "text": "que se tienen ustedes que ir familiarizando", "speaker": null}, {"start": 165.02, "end": 165.58, "text": "ok", "speaker": null}, {"start": 165.58, "end": 169.72, "text": "entonces esos insumos van a ser las materias primas", "speaker": null}, {"start": 169.72, "end": 170.64, "text": "entonces", "speaker": null}, {"start": 170.64, "end": 171.56, "text": "a durar por días.", "speaker": null}, {"start": 172.72, "end": 174.26, "text": "¿Qué tal cosa vamos a necesitar", "speaker": null}, {"start": 174.26, "end": 175.28, "text": "para la hora de la tarde?", "speaker": null}, {"start": 177.46, "end": 178.36, "text": "Bueno, en el caso de", "speaker": null}, {"start": 178.36, "end": 179.56, "text": "vivos y de marinarios,", "speaker": null}, {"start": 180.1, "end": 181.46, "text": "si lo hacemos desde el nivel", "speaker": null}, {"start": 181.46, "end": 184.86, "text": "personal, a nivel doméstico,", "speaker": null}, {"start": 185.28, "end": 186.64, "text": "pues a lo mejor", "speaker": null}, {"start": 186.64, "end": 187.92, "text": "los recipientes,", "speaker": null}, {"start": 187.92, "end": 189.44, "text": "¿estamos de acuerdo?", "speaker": null}, {"start": 190.04, "end": 191.66, "text": "Porque tenemos la harina,", "speaker": null}, {"start": 192.68, "end": 194.1, "text": "tenemos, no sé,", "speaker": null}, {"start": 194.16, "end": 195.84, "text": "el azúcar, tenemos", "speaker": null}, {"start": 195.84, "end": 197.42, "text": "la leche, ¿qué hacemos con la leche?", "speaker": null}, {"start": 198.34, "end": 199.7, "text": "¿Revolvemos las manos, los huevos,", "speaker": null}, {"start": 199.78, "end": 200.31999, "text": "con la leche?", "speaker": null}, {"start": 200.64, "end": 202.31999, "text": "¿Cómo le hacemos?", "speaker": null}, {"start": 203.54, "end": 204.42, "text": "No, no, no.", "speaker": null}, {"start": 204.8, "end": 206.78, "text": "Tenemos un recipiente adecuado.", "speaker": null}, {"start": 208.2, "end": 209.58, "text": "En ese recipiente, ¿qué vamos a hacer?", "speaker": null}, {"start": 209.68, "end": 211.6, "text": "Vamos a echar la leche, correcto.", "speaker": null}, {"start": 212.34, "end": 214.04, "text": "Después le vamos a echar la harina,", "speaker": null}, {"start": 214.6, "end": 215.58, "text": "le vamos a echar los huevos,", "speaker": null}, {"start": 215.7, "end": 216.7, "text": "le vamos a echar el roya,", "speaker": null}, {"start": 216.8, "end": 219.28, "text": "le vamos a hacer todo un revuelto y cuaín.", "speaker": null}, {"start": 220.2, "end": 228.97801, "text": "Y regularmente hace tu mujer o qu hace mam Lo revuelve Digo ah se que lo hace la madre", "speaker": null}, {"start": 230.078, "end": 232.198, "text": "Hoy en día, las señoras más modernas", "speaker": null}, {"start": 232.198, "end": 234.25801, "text": "ocupan algo que se llama batidor.", "speaker": null}, {"start": 234.938, "end": 236.95801, "text": "No sé si en su cocina tendrán algo por ahí,", "speaker": null}, {"start": 237.11801, "end": 239.858, "text": "pero son unos aparatos que tienen unas aspas.", "speaker": null}, {"start": 241.018, "end": 242.358, "text": "Mamá llega a lo metir,", "speaker": null}, {"start": 242.578, "end": 246.05801, "text": "dos patadas y ya está la porquería esa.", "speaker": null}, {"start": 247.17801, "end": 248.11801, "text": "Hoy viene una revisa.", "speaker": null}, {"start": 248.11801, "end": 251.238, "text": "¿qué más requeriríamos para hacer el pan?", "speaker": null}, {"start": 251.298, "end": 253.858, "text": "¿ya lo comemos así de la mezcla?", "speaker": null}, {"start": 254.858, "end": 256.278, "text": "no, hermano", "speaker": null}, {"start": 256.278, "end": 257.898, "text": "necesitamos", "speaker": null}, {"start": 257.898, "end": 258.938, "text": "activos", "speaker": null}, {"start": 258.938, "end": 260.338, "text": "¿sí?", "speaker": null}, {"start": 260.338, "end": 260.938, "text": "¿qué más?", "speaker": null}, {"start": 260.938, "end": 261.178, "text": "¿qué más?", "speaker": null}, {"start": 261.578, "end": 262.418, "text": "¿cómo va?", "speaker": null}, {"start": 263.038, "end": 264.258, "text": "¿cómo acabas de decir?", "speaker": null}, {"start": 264.818, "end": 265.698, "text": "un horno", "speaker": null}, {"start": 265.698, "end": 268.538, "text": "¿estamos de acuerdo o no?", "speaker": null}, {"start": 269.71802, "end": 270.858, "text": "en donde ese horno", "speaker": null}, {"start": 270.858, "end": 273.738, "text": "para que se lleve a cabo", "speaker": null}, {"start": 273.738, "end": 275.458, "text": "un proceso de cocción", "speaker": null}, {"start": 275.458, "end": 277.038, "text": "es decir", "speaker": null}, {"start": 277.038, "end": 287.398, "text": "se va a cocinar. ¿Para qué? Para que cambie su estructura y de ser una masa pase a ser", "speaker": null}, {"start": 287.398, "end": 294.078, "text": "un pan con la textura de cada tipo de pan, no es la textura de una mantecada, una donita,", "speaker": null}, {"start": 294.078, "end": 303.698, "text": "un buñuel. Vamos a ver, con diferentes tiempos, diferentes insumos, diferentes moldes, todos", "speaker": null}, {"start": 303.698, "end": 309.618, "text": "diferente, obviamente, pues, depende de lo que va a hacer mamá, tiene los muebles para", "speaker": null}, {"start": 309.618, "end": 317.838, "text": "cada, pues, cada pan, que tú le pidas, ¿qué te dice mamá? Hoy te voy a conseguir, dicen", "speaker": null}, {"start": 317.838, "end": 327.118, "text": "tus muñecos, a lo grande, hoy te voy a dar para que te lleves a la escuela tus panecitos,", "speaker": null}, {"start": 327.118, "end": 328.058, "text": "manteca.", "speaker": null}, {"start": 329.21802, "end": 330.738, "text": "Esa es la que va a llevar una mano de sopa.", "speaker": null}, {"start": 331.518, "end": 333.258, "text": "No, no va a ser", "speaker": null}, {"start": 333.258, "end": 333.918, "text": "para todos.", "speaker": null}, {"start": 335.49802, "end": 336.99802, "text": "Estamos viendo a nivel de casa", "speaker": null}, {"start": 336.99802, "end": 338.918, "text": "lo mismo que en el", "speaker": null}, {"start": 338.918, "end": 340.49802, "text": "obviamente aquí es", "speaker": null}, {"start": 340.49802, "end": 342.578, "text": "a nivel", "speaker": null}, {"start": 342.578, "end": 344.638, "text": "industrial.", "speaker": null}, {"start": 345.758, "end": 346.458, "text": "Pero en casa", "speaker": null}, {"start": 346.458, "end": 346.938, "text": "no va a ser.", "speaker": null}, {"start": 348.638, "end": 350.53802, "text": "Metemos en su molde", "speaker": null}, {"start": 350.53802, "end": 352.438, "text": "esa mezcla", "speaker": null}, {"start": 352.438, "end": 354.458, "text": "anormo, le damos un tiempo", "speaker": null}, {"start": 354.998, "end": 356.798, "text": "y una temperatura.", "speaker": null}, {"start": 357.118, "end": 361.918, "text": "para que se lleve a cabo el proceso de boxeo", "speaker": null}, {"start": 361.918, "end": 364.03802, "text": "pero para eso necesitamos el activo", "speaker": null}, {"start": 364.03802, "end": 365.238, "text": "o sea el oro", "speaker": null}, {"start": 365.238, "end": 367.418, "text": "pero ahora tiene", "speaker": null}, {"start": 367.418, "end": 371.078, "text": "y eso planos", "speaker": null}, {"start": 371.078, "end": 372.47803, "text": "ok", "speaker": null}, {"start": 372.47803, "end": 375.638, "text": "entonces necesitaríamos", "speaker": null}, {"start": 375.638, "end": 377.018, "text": "el activo de las manos", "speaker": null}, {"start": 377.018, "end": 379.698, "text": "puede ser eléctrico", "speaker": null}, {"start": 379.698, "end": 382.298, "text": "puede ser de gas", "speaker": null}, {"start": 382.298, "end": 385.118, "text": "puede ser de bici", "speaker": null}, {"start": 385.118, "end": 387.71802, "text": "hay diferentes que", "speaker": null}, {"start": 387.71802, "end": 391.178, "text": "oro", "speaker": null}, {"start": 391.178, "end": 394.698, "text": "y eso solo puede tener también diferentes", "speaker": null}, {"start": 394.698, "end": 396.998, "text": "que fuentes de energía", "speaker": null}, {"start": 396.998, "end": 398.858, "text": "¿estamos de acuerdo?", "speaker": null}, {"start": 399.53802, "end": 402.838, "text": "pero que en este caso estamos hablando", "speaker": null}, {"start": 402.838, "end": 406.498, "text": "de un gasto", "speaker": null}, {"start": 406.498, "end": 407.438, "text": "invierto", "speaker": null}, {"start": 407.438, "end": 409.698, "text": "¿por qué?", "speaker": null}, {"start": 410.518, "end": 413.198, "text": "porque el gas se consume", "speaker": null}, {"start": 413.198, "end": 415.97803, "text": "de diferentes cosas", "speaker": null}, {"start": 415.97803, "end": 418.03802, "text": "en función a qué", "speaker": null}, {"start": 418.03802, "end": 420.398, "text": "a qué punto ocupas", "speaker": null}, {"start": 420.398, "end": 422.798, "text": "no es como la renta", "speaker": null}, {"start": 422.798, "end": 424.018, "text": "en la renta la pagas", "speaker": null}, {"start": 424.018, "end": 425.818, "text": "y se considera un gasto fijo", "speaker": null}, {"start": 425.818, "end": 428.618, "text": "porque si yo rento", "speaker": null}, {"start": 428.618, "end": 429.618, "text": "un local", "speaker": null}, {"start": 429.618, "end": 432.198, "text": "yo rento un edificio", "speaker": null}, {"start": 432.198, "end": 434.078, "text": "yo rento un departamento", "speaker": null}, {"start": 434.078, "end": 436.018, "text": "yo rento", "speaker": null}, {"start": 436.018, "end": 436.938, "text": "porque tú rentas", "speaker": null}, {"start": 436.938, "end": 440.21802, "text": "el dueño te dice a mí me pagas", "speaker": null}, {"start": 440.21802, "end": 442.818, "text": "20 mil pesos de renta", "speaker": null}, {"start": 442.818, "end": 455.35602, "text": "por ese tratamiento entonces oye pero que crees que yo no m lo voy a ocupar en las noches A chingar qu me est dando a entender", "speaker": null}, {"start": 456.556, "end": 460.976, "text": "¿Que te cobren nada más la noche y el día gratis?", "speaker": null}, {"start": 461.936, "end": 464.696, "text": "¿Sí? El que renta las casas te dice eso.", "speaker": null}, {"start": 465.616, "end": 466.896, "text": "Pues eso no vale nada.", "speaker": null}, {"start": 467.976, "end": 471.936, "text": "Oye, ¿pero qué crees que yo nada más voy a estar los fines de semana", "speaker": null}, {"start": 471.936, "end": 473.756, "text": "porque entre semana trabajo", "speaker": null}, {"start": 473.756, "end": 477.996, "text": "es una de las", "speaker": null}, {"start": 477.996, "end": 479.716, "text": "mínimas cosas que me manda", "speaker": null}, {"start": 479.716, "end": 481.91602, "text": "es más si no llegas", "speaker": null}, {"start": 481.91602, "end": 482.976, "text": "para mí no es bota", "speaker": null}, {"start": 482.976, "end": 485.096, "text": "pero de todo es la reina de las madres", "speaker": null}, {"start": 485.096, "end": 486.456, "text": "o no", "speaker": null}, {"start": 486.456, "end": 488.196, "text": "es un gasto fijo", "speaker": null}, {"start": 488.196, "end": 491.956, "text": "nos vamos más o menos entendiendo", "speaker": null}, {"start": 491.956, "end": 493.35602, "text": "o no nos vamos entendiendo", "speaker": null}, {"start": 493.35602, "end": 495.816, "text": "ya que sacamos", "speaker": null}, {"start": 495.816, "end": 496.976, "text": "del horno al palísimo", "speaker": null}, {"start": 496.976, "end": 500.13602, "text": "que hizo mamá para que te lo traigas", "speaker": null}, {"start": 500.13602, "end": 501.17603, "text": "a la escuela", "speaker": null}, {"start": 501.17603, "end": 509.35602, "text": "que lo puedas comer en un brunch, en una bolsita, a lo mejor en una bolsita, en un hotel, no sé,", "speaker": null}, {"start": 509.456, "end": 516.796, "text": "nomás en la Zanjica, ¿estamos de acuerdo? Lo mismo va a ser en la casa, lo mismo va a ser en la casa.", "speaker": null}, {"start": 518.43604, "end": 526.476, "text": "Hasta aquí nos vamos a vender, ahora vamos a ordenar todo eso y vamos a ver cómo funciona.", "speaker": null}, {"start": 526.476, "end": 530.096, "text": "y van a ver que esto es una verdadera basura.", "speaker": null}, {"start": 532.576, "end": 533.916, "text": "Imaginemos por un momento", "speaker": null}, {"start": 533.916, "end": 537.216, "text": "que este edificio,", "speaker": null}, {"start": 537.816, "end": 539.576, "text": "no necesito imaginar el edificio,", "speaker": null}, {"start": 539.676, "end": 540.216, "text": "es más enero,", "speaker": null}, {"start": 541.496, "end": 542.956, "text": "imaginemos por un momento", "speaker": null}, {"start": 542.956, "end": 544.956, "text": "que en este edificio", "speaker": null}, {"start": 544.956, "end": 547.876, "text": "está la planta de Pino.", "speaker": null}, {"start": 549.176, "end": 549.536, "text": "¿De acuerdo?", "speaker": null}, {"start": 550.676, "end": 551.476, "text": "¿De acuerdo?", "speaker": null}, {"start": 552.876, "end": 554.036, "text": "Tenemos la jaula", "speaker": null}, {"start": 554.036, "end": 564.336, "text": "¿Qué es esta? De 107, ¿correcto? 106, 105 y así.", "speaker": null}, {"start": 564.476, "end": 571.556, "text": "Pensemos que esta es la 1, para no meternos en bronca, pero está separado por alas.", "speaker": null}, {"start": 572.216, "end": 574.796, "text": "Si la dio uno, la dio dos, la dio tres, y así.", "speaker": null}, {"start": 578.216, "end": 581.376, "text": "Ojo, ¿qué me dice el documento?", "speaker": null}, {"start": 581.376, "end": 582.496, "text": "Avisados aquí.", "speaker": null}, {"start": 583.756, "end": 588.556, "text": "El documento me dice, inicia con tu mental inicial A.", "speaker": null}, {"start": 589.896, "end": 590.796, "text": "Antes de eso.", "speaker": null}, {"start": 597.896, "end": 602.736, "text": "Ustedes desde el Kinder les enseñaron a utilizar la granita.", "speaker": null}, {"start": 604.81604, "end": 609.776, "text": "Para establecer qué magnitudes de tiempo.", "speaker": null}, {"start": 609.776, "end": 612.416, "text": "es correcto", "speaker": null}, {"start": 612.416, "end": 614.93604, "text": "nosotros vamos a seguir utilizando la herramienta", "speaker": null}, {"start": 619.856, "end": 620.976, "text": "para establecer", "speaker": null}, {"start": 620.976, "end": 622.856, "text": "magnitud del", "speaker": null}, {"start": 622.856, "end": 623.476, "text": "movimiento", "speaker": null}, {"start": 623.476, "end": 626.596, "text": "pensemos que en esta herramienta", "speaker": null}, {"start": 626.596, "end": 628.356, "text": "que se conoce como reponente", "speaker": null}, {"start": 628.356, "end": 630.716, "text": "lo vamos a ocupar para", "speaker": null}, {"start": 630.716, "end": 632.93604, "text": "representar", "speaker": null}, {"start": 632.93604, "end": 635.416, "text": "un ejercicio", "speaker": null}, {"start": 635.416, "end": 637.036, "text": "si saben lo que es un ejercicio", "speaker": null}, {"start": 637.036, "end": 650.336, "text": "Un ejercicio es un periodo contable", "speaker": null}, {"start": 650.336, "end": 654.516, "text": "Y ese periodo contable cuando hablamos de ejercicios", "speaker": null}, {"start": 654.516, "end": 655.896, "text": "Es un año", "speaker": null}, {"start": 655.896, "end": 659.916, "text": "Puede haber ejercicios año calendario", "speaker": null}, {"start": 659.916, "end": 661.636, "text": "¿Sabe?", "speaker": null}, {"start": 662.376, "end": 666.036, "text": "Entonces un ejercicio año calendario es el que tiene 12 meses", "speaker": null}, {"start": 666.036, "end": 668.096, "text": "parte desde el primero de enero", "speaker": null}, {"start": 668.096, "end": 673.95404, "text": "hasta el 31 de diciembre eso se conoce como ejercicio mental", "speaker": null}, {"start": 686.714, "end": 688.89404, "text": "Ese ejercicio es parte de mí.", "speaker": null}, {"start": 690.69403, "end": 692.114, "text": "El nuevo primero", "speaker": null}, {"start": 692.114, "end": 697.554, "text": "pasa", "speaker": null}, {"start": 697.554, "end": 701.214, "text": "y siempre en el mismo año", "speaker": null}, {"start": 701.214, "end": 702.57404, "text": "de acuerdo", "speaker": null}, {"start": 702.57404, "end": 704.874, "text": "ok", "speaker": null}, {"start": 704.874, "end": 706.45404, "text": "si eso es cierto", "speaker": null}, {"start": 706.45404, "end": 708.734, "text": "aquí vamos a tener", "speaker": null}, {"start": 708.734, "end": 710.01404, "text": "primero", "speaker": null}, {"start": 710.01404, "end": 713.794, "text": "aquí vamos a empezar", "speaker": null}, {"start": 713.794, "end": 716.89404, "text": "febrero", "speaker": null}, {"start": 716.89404, "end": 718.994, "text": "marzo", "speaker": null}, {"start": 718.994, "end": 720.374, "text": "abril", "speaker": null}, {"start": 720.374, "end": 722.07404, "text": "marzo", "speaker": null}, {"start": 722.07404, "end": 725.254, "text": "hasta el día de hoy", "speaker": null}, {"start": 725.254, "end": 726.974, "text": "volviendo", "speaker": null}, {"start": 726.974, "end": 729.354, "text": "regreso", "speaker": null}, {"start": 729.354, "end": 731.254, "text": "ok", "speaker": null}, {"start": 731.254, "end": 733.314, "text": "contablemente", "speaker": null}, {"start": 733.314, "end": 735.114, "text": "eso se lo debieron haber enseñado", "speaker": null}, {"start": 735.114, "end": 737.01404, "text": "contablemente", "speaker": null}, {"start": 737.01404, "end": 741.034, "text": "aquí en las cuentas de balance", "speaker": null}, {"start": 741.034, "end": 743.874, "text": "hay una cuenta que se llama", "speaker": null}, {"start": 743.874, "end": 746.834, "text": "inventario", "speaker": null}, {"start": 746.834, "end": 749.07404, "text": "o almacén", "speaker": null}, {"start": 749.07404, "end": 750.794, "text": "no sé cómo se las enseña", "speaker": null}, {"start": 750.794, "end": 754.314, "text": "es una cuenta de balance", "speaker": null}, {"start": 754.314, "end": 756.27405, "text": "y es de naturaleza deudora", "speaker": null}, {"start": 756.27405, "end": 761.674, "text": "¿Para qué de nuevo nos sirve el inventario de la iglesia?", "speaker": null}, {"start": 763.534, "end": 766.034, "text": "Para controlar nuestras mercancías", "speaker": null}, {"start": 766.034, "end": 768.13403, "text": "¿Sí?", "speaker": null}, {"start": 768.854, "end": 769.434, "text": "Ejemplo", "speaker": null}, {"start": 769.434, "end": 772.07404, "text": "En el caso que nos atan", "speaker": null}, {"start": 772.07404, "end": 774.414, "text": "Que traemos como ejemplo", "speaker": null}, {"start": 774.414, "end": 775.474, "text": "A vino", "speaker": null}, {"start": 775.474, "end": 778.794, "text": "¿Qué tendría que tener en el inventario?", "speaker": null}, {"start": 780.794, "end": 781.814, "text": "La harina", "speaker": null}, {"start": 781.814, "end": 783.914, "text": "El azúcar", "speaker": null}, {"start": 783.914, "end": 796.39404, "text": "el royal, el saborizante, el endulzante, el colorante, todo eso lo va a tener en el almacén", "speaker": null}, {"start": 796.39404, "end": 799.114, "text": "y se controla en el inventario.", "speaker": null}, {"start": 801.114, "end": 806.934, "text": "Cada periodo contable, hace un rato hablé del ejercicio contable,", "speaker": null}, {"start": 806.934, "end": 810.234, "text": "existe algo que se llama", "speaker": null}, {"start": 810.234, "end": 812.294, "text": "pedido contable", "speaker": null}, {"start": 812.294, "end": 820.874, "text": "este es un ejercicio", "speaker": null}, {"start": 820.874, "end": 821.954, "text": "contable", "speaker": null}, {"start": 821.954, "end": 827.454, "text": "pero un ejercicio contable", "speaker": null}, {"start": 827.454, "end": 831.114, "text": "es un desalto", "speaker": null}, {"start": 831.114, "end": 834.334, "text": "de sus pedidos contables", "speaker": null}, {"start": 834.334, "end": 836.094, "text": "quiere decir que", "speaker": null}, {"start": 836.094, "end": 845.69403, "text": "el periodo de enero es un periodo mensual, pero puedo tener periodos bimestrales, que", "speaker": null}, {"start": 845.69403, "end": 854.054, "text": "serían dos meses, bi habla de dos, o puedo tener periodos trimestrales, tri me habla", "speaker": null}, {"start": 854.054, "end": 857.01404, "text": "de tres, uno, dos y tres.", "speaker": null}, {"start": 858.314, "end": 859.834, "text": "Háganme hablar de los empresarios de ese año.", "speaker": null}, {"start": 860.434, "end": 862.214, "text": "Entrégame el reporte trimestral.", "speaker": null}, {"start": 862.214, "end": 866.614, "text": "quiero hacer un cierre", "speaker": null}, {"start": 866.614, "end": 868.074, "text": "cuatrimestral", "speaker": null}, {"start": 868.074, "end": 871.474, "text": "quiero hacer una evaluación", "speaker": null}, {"start": 871.474, "end": 872.874, "text": "semestral", "speaker": null}, {"start": 872.874, "end": 876.754, "text": "me hablan de un periodo semestral", "speaker": null}, {"start": 876.754, "end": 879.01404, "text": "semestral son seis periodos", "speaker": null}, {"start": 879.01404, "end": 880.274, "text": "semestrales", "speaker": null}, {"start": 880.274, "end": 887.054, "text": "todos los periodos", "speaker": null}, {"start": 887.054, "end": 887.654, "text": "contables", "speaker": null}, {"start": 887.654, "end": 889.774, "text": "en", "speaker": null}, {"start": 889.774, "end": 892.574, "text": "salvo inicial", "speaker": null}, {"start": 892.574, "end": 895.39404, "text": "y salvo final", "speaker": null}, {"start": 895.39404, "end": 897.51404, "text": "¿correcto?", "speaker": null}, {"start": 898.474, "end": 899.494, "text": "¿está iniciado?", "speaker": null}]