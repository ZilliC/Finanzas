[{"start": 1.0, "end": 7.0, "text": "Entonces, realizaremos operaciones que nos motivan a una ubicación o necesidad de registro.", "speaker": null}, {"start": 8.24, "end": 13.12, "text": "Esos registros, a través de quién lo vamos a hacer, del mal necesario, aunque no queramos,", "speaker": null}, {"start": 14.48, "end": 15.78, "text": "de la famosa contabilidad.", "speaker": null}, {"start": 16.82, "end": 20.66, "text": "Y la contabilidad, después de haber hecho toda su técnica, porque al final les enseñaron,", "speaker": null}, {"start": 20.74, "end": 24.019999, "text": "no les lo iban a enseñar, porque la contabilidad no es la técnica de registro,", "speaker": null}, {"start": 24.98, "end": 26.14, "text": "va a arrojar presionistados.", "speaker": null}, {"start": 26.98, "end": 29.06, "text": "Como resultado, ¿qué demonios va a arrojar?", "speaker": null}, {"start": 30.0, "end": 34.579998, "text": "estados financieros", "speaker": null}, {"start": 34.579998, "end": 36.24, "text": "correcto", "speaker": null}, {"start": 36.24, "end": 38.34, "text": "ahora, esos estados financieros", "speaker": null}, {"start": 38.34, "end": 40.62, "text": "para que nosotros empecemos a entender", "speaker": null}, {"start": 40.62, "end": 42.12, "text": "el mundo financiero", "speaker": null}, {"start": 42.12, "end": 45.1, "text": "los vamos a tener que clasificar", "speaker": null}, {"start": 45.1, "end": 47.26, "text": "y se van a clasificar", "speaker": null}, {"start": 47.26, "end": 49.78, "text": "en dos grandes grupos", "speaker": null}, {"start": 49.78, "end": 52.88, "text": "de acuerdo a las 10", "speaker": null}, {"start": 52.88, "end": 54.6, "text": "si sabemos las 10", "speaker": null}, {"start": 54.6, "end": 56.22, "text": "de acuerdo a la educación financiera", "speaker": null}, {"start": 56.22, "end": 59.66, "text": "los vamos a clasificar en dos grandes grupos", "speaker": null}, {"start": 59.66, "end": 70.02, "text": "en lo que se conocen como básicos y en lo que se conocen como estados financieros secundarios.", "speaker": null}, {"start": 71.64, "end": 81.26, "text": "Los famosos estados financieros básicos van a ser cuatro, que ya se los tuvieron aprendido.", "speaker": null}, {"start": 82.52, "end": 87.32, "text": "Esos estados financieros van a ser de más dinero, lo que van a conocer con el nombre", "speaker": null}, {"start": 87.32, "end": 88.82, "text": "de balance general", "speaker": null}, {"start": 88.82, "end": 89.56, "text": "o", "speaker": null}, {"start": 89.56, "end": 93.08, "text": "estado de posición", "speaker": null}, {"start": 93.08, "end": 94.84, "text": "financiera o", "speaker": null}, {"start": 94.84, "end": 97.52, "text": "estado de situación", "speaker": null}, {"start": 97.52, "end": 98.58, "text": "financiera", "speaker": null}, {"start": 98.58, "end": 100.68, "text": "como cualquiera de esos nombres", "speaker": null}, {"start": 100.68, "end": 103.14, "text": "los van a conocer, ¿correcto?", "speaker": null}, {"start": 103.72, "end": 104.84, "text": "es la misma gata", "speaker": null}, {"start": 104.84, "end": 106.3, "text": "nada más que preocupada", "speaker": null}, {"start": 106.3, "end": 109.32, "text": "habrá autores, libros, textos", "speaker": null}, {"start": 109.32, "end": 110.7, "text": "empresas que te digan", "speaker": null}, {"start": 110.7, "end": 113.0, "text": "oye necesito que me generes informático", "speaker": null}, {"start": 113.0, "end": 115.4, "text": "necesito que me generes", "speaker": null}, {"start": 115.4, "end": 117.14, "text": "el balance general", "speaker": null}, {"start": 117.14, "end": 120.18, "text": "ah, ya sé que es un balance", "speaker": null}, {"start": 120.18, "end": 122.4, "text": "pero puede haber un compadre", "speaker": null}, {"start": 122.4, "end": 123.42, "text": "que te diga, ¿sabes qué?", "speaker": null}, {"start": 124.44, "end": 126.84, "text": "mandame el estado de posición financiera", "speaker": null}, {"start": 126.84, "end": 128.2, "text": "así, a mí me piensa que es", "speaker": null}, {"start": 128.2, "end": 130.34, "text": "ese es el balance, ese es el banco", "speaker": null}, {"start": 130.34, "end": 131.14, "text": "ese es el mismo", "speaker": null}, {"start": 131.14, "end": 134.44, "text": "y va a haber quien te diga, mandame el estado de posición financiera", "speaker": null}, {"start": 134.44, "end": 135.45999, "text": "¿ese quién es?", "speaker": null}, {"start": 135.7, "end": 136.52, "text": "es el mismo", "speaker": null}, {"start": 136.52, "end": 139.12, "text": "se conoce con cualquiera de esos nombres", "speaker": null}, {"start": 139.12, "end": 140.06, "text": "hablamos del mismo", "speaker": null}, {"start": 140.06, "end": 142.48, "text": "¿sabe? ¿vale?", "speaker": null}, {"start": 143.62, "end": 144.68, "text": "¿cuál sería el siguiente?", "speaker": null}, {"start": 147.14, "end": 151.64, "text": "En algunos lugares le hablan como estado de perdilación.", "speaker": null}, {"start": 152.54, "end": 153.26, "text": "Galaxia.", "speaker": null}, {"start": 153.56, "end": 157.86, "text": "El mejor conocido por el nombre de estado de resultados.", "speaker": null}, {"start": 159.0, "end": 161.94, "text": "Y hoy le ponen el apellido de integral.", "speaker": null}, {"start": 163.54, "end": 164.22, "text": "¿Es correcto?", "speaker": null}, {"start": 166.22, "end": 168.24, "text": "Es el mismo documento.", "speaker": null}, {"start": 170.0, "end": 172.8, "text": "Después tenemos, ¿cuál es el tercer documento?", "speaker": null}, {"start": 172.8, "end": 177.44, "text": "el estado", "speaker": null}, {"start": 177.44, "end": 178.84, "text": "de qué", "speaker": null}, {"start": 178.84, "end": 180.52, "text": "de grupo", "speaker": null}, {"start": 180.52, "end": 181.68001, "text": "de efectivo", "speaker": null}, {"start": 181.68001, "end": 184.66, "text": "o por qué", "speaker": null}, {"start": 184.66, "end": 186.02, "text": "lo podríamos conocer", "speaker": null}, {"start": 186.02, "end": 190.78, "text": "como estado de situación", "speaker": null}, {"start": 190.78, "end": 192.64, "text": "financiera con base efectiva", "speaker": null}, {"start": 192.64, "end": 194.40001, "text": "es lo mismo", "speaker": null}, {"start": 194.40001, "end": 195.88, "text": "¿correcto?", "speaker": null}, {"start": 197.16, "end": 198.12, "text": "y finalmente", "speaker": null}, {"start": 198.12, "end": 200.14, "text": "el estado", "speaker": null}, {"start": 200.14, "end": 202.7, "text": "de variaciones en las cuentas de capital", "speaker": null}, {"start": 202.7, "end": 206.8, "text": "o estado de capital contable.", "speaker": null}, {"start": 208.8, "end": 209.2, "text": "¿Correcto?", "speaker": null}, {"start": 210.06, "end": 212.2, "text": "Ahora, pasemos a los secundarios.", "speaker": null}, {"start": 212.86, "end": 215.54, "text": "¿Cuáles serían los estados financieros secundarios?", "speaker": null}, {"start": 219.54, "end": 229.938, "text": "Bueno pues aqu tenemos muchos bastantes Vamos a se algunos de los m comunes de los m usados de los m socorridos", "speaker": null}, {"start": 231.89801, "end": 236.33801, "text": "Aquí, aunque ustedes no sean contadores, pero sí tienen necesidad de saber que existen, ¿verdad?", "speaker": null}, {"start": 236.518, "end": 238.25801, "text": "Y para qué demonios se usan.", "speaker": null}, {"start": 238.878, "end": 239.31801, "text": "¿Sale, vale?", "speaker": null}, {"start": 240.45801, "end": 246.018, "text": "Entonces, dentro de los estados financieros fecundarios,", "speaker": null}, {"start": 246.018, "end": 263.078, "text": "Tenemos, por ejemplo, el estado de costo de producción y costo de producción de la línea.", "speaker": null}, {"start": 264.65802, "end": 266.118, "text": "¿Qué otro podríamos encontrar aquí?", "speaker": null}, {"start": 267.198, "end": 271.578, "text": "Los estados financieros reexpresados.", "speaker": null}, {"start": 271.578, "end": 276.638, "text": "¿Qué otros podríamos tener aquí?", "speaker": null}, {"start": 278.398, "end": 281.698, "text": "Los estados financieros que", "speaker": null}, {"start": 281.698, "end": 286.298, "text": "¿Los escucho señores?", "speaker": null}, {"start": 289.058, "end": 290.338, "text": "Aquí pongo el micrófono", "speaker": null}, {"start": 290.338, "end": 293.118, "text": "Para que vean bien", "speaker": null}, {"start": 293.118, "end": 294.618, "text": "Esos financieros que están", "speaker": null}, {"start": 294.618, "end": 298.278, "text": "¿Qué otros estados financieros?", "speaker": null}, {"start": 298.278, "end": 301.078, "text": "los estados financieros", "speaker": null}, {"start": 301.078, "end": 302.278, "text": "consolidados", "speaker": null}, {"start": 302.278, "end": 306.978, "text": "¿qué otros?", "speaker": null}, {"start": 308.59802, "end": 311.318, "text": "los estados financieros", "speaker": null}, {"start": 311.318, "end": 313.338, "text": "comparativos", "speaker": null}, {"start": 313.338, "end": 315.978, "text": "¿qué otro?", "speaker": null}, {"start": 315.978, "end": 316.038, "text": "¿qué otro?", "speaker": null}, {"start": 320.778, "end": 324.15802, "text": "los estados financieros", "speaker": null}, {"start": 324.15802, "end": 326.978, "text": "presupuestados", "speaker": null}, {"start": 326.978, "end": 352.53802, "text": "¿Qué otro? A ver, piénsale. Los estados financieros proporman. ¿Qué otro? Los estados financieros analíticos.", "speaker": null}, {"start": 352.53802, "end": 353.958, "text": "¿Qué otro?", "speaker": null}, {"start": 354.818, "end": 356.458, "text": "Hay N", "speaker": null}, {"start": 356.458, "end": 358.59802, "text": "N estados de atención", "speaker": null}, {"start": 358.59802, "end": 361.09802, "text": "Hay muchos estados de atención", "speaker": null}, {"start": 361.09802, "end": 363.438, "text": "Dependiendo de mis necesidades", "speaker": null}, {"start": 363.438, "end": 364.21802, "text": "Y de lo que les decía", "speaker": null}, {"start": 364.21802, "end": 365.378, "text": "Porque son informáticos", "speaker": null}, {"start": 365.378, "end": 367.678, "text": "Yo se los voy a pedir", "speaker": null}, {"start": 367.678, "end": 370.318, "text": "Ustedes no tienen que tener idea", "speaker": null}, {"start": 370.318, "end": 372.878, "text": "Ustedes tienen que tener idea", "speaker": null}, {"start": 372.878, "end": 374.418, "text": "De qué demonios estamos hablando", "speaker": null}, {"start": 374.418, "end": 375.97803, "text": "¿Correcto?", "speaker": null}, {"start": 376.638, "end": 377.578, "text": "Por poner un ejemplo", "speaker": null}, {"start": 377.578, "end": 379.59802, "text": "Empezamos con cualquiera", "speaker": null}, {"start": 379.59802, "end": 382.318, "text": "Ustedes quieran, vamos a empezar en el estado de costo", "speaker": null}, {"start": 382.318, "end": 383.918, "text": "de pronto yo y mi padre", "speaker": null}, {"start": 383.918, "end": 384.838, "text": "me lo debieron", "speaker": null}, {"start": 384.838, "end": 387.618, "text": "ese maldito documento para que nos va a servir", "speaker": null}, {"start": 387.618, "end": 389.918, "text": "me va a servir para determinar", "speaker": null}, {"start": 389.918, "end": 392.118, "text": "el costo de venta", "speaker": null}, {"start": 392.118, "end": 394.798, "text": "el costo de venta", "speaker": null}, {"start": 394.798, "end": 396.21802, "text": "¿por qué razón?", "speaker": null}, {"start": 396.838, "end": 398.358, "text": "para que me vayan entendiendo", "speaker": null}, {"start": 398.358, "end": 399.998, "text": "y que vean que esto en la vida real", "speaker": null}, {"start": 399.998, "end": 400.778, "text": "se ocupa", "speaker": null}, {"start": 400.778, "end": 403.698, "text": "ustedes debieron haber pasado a tu pancha", "speaker": null}, {"start": 403.698, "end": 404.698, "text": "rico por conta", "speaker": null}, {"start": 404.698, "end": 408.05798, "text": "ya me dijeron que me les enseñaron mucho", "speaker": null}, {"start": 408.05798, "end": 409.53802, "text": "que algunas penas", "speaker": null}, {"start": 409.53802, "end": 411.698, "text": "les enseñaron a lo mejor dos o tres", "speaker": null}, {"start": 411.698, "end": 417.418, "text": "estados financieros, les dijeron cómo lo van a registrar y cómo van a vaciar las tesitas", "speaker": null}, {"start": 417.418, "end": 423.938, "text": "o el diario, cómo lo van a vaciar para llenar los documentos, ¿es correcto? Y para ello", "speaker": null}, {"start": 423.938, "end": 432.498, "text": "quiero pensar que mínimo, que les debí de haber enseñado, que existe ejemplo, este,", "speaker": null}, {"start": 432.498, "end": 439.438, "text": "¿Qué sería el estado de su financiamiento?", "speaker": null}, {"start": 439.958, "end": 442.078, "text": "Pues como su balance, ¿se acuerdan de eso?", "speaker": null}, {"start": 444.578, "end": 456.95602, "text": "Cuando ustedes ense el balance es el balance El balance se integra en tres grandes grupos El activo el vac y las fuentes de capital o tapa", "speaker": null}, {"start": 458.85602, "end": 459.63602, "text": "Bueno, ya no me regreso.", "speaker": null}, {"start": 460.836, "end": 464.996, "text": "El activo se lo clasificaron como activo circulante,", "speaker": null}, {"start": 466.096, "end": 469.156, "text": "activo vivo, activo libre.", "speaker": null}, {"start": 470.07602, "end": 472.896, "text": "El vacío se lo clasificaron como acorto,", "speaker": null}, {"start": 472.896, "end": 474.616, "text": "el fascismo a la democracia.", "speaker": null}, {"start": 475.57602, "end": 477.196, "text": "Y aquí tenemos las cuentas", "speaker": null}, {"start": 477.196, "end": 477.776, "text": "de capital.", "speaker": null}, {"start": 479.85602, "end": 480.536, "text": "Correcto.", "speaker": null}, {"start": 481.216, "end": 483.156, "text": "En las cuentas de capital, lo primero", "speaker": null}, {"start": 483.156, "end": 484.91602, "text": "que deben entender es de dónde", "speaker": null}, {"start": 484.91602, "end": 486.57602, "text": "nace el capital", "speaker": null}, {"start": 486.57602, "end": 487.656, "text": "social.", "speaker": null}, {"start": 489.976, "end": 490.956, "text": "¿Se acuerdan que", "speaker": null}, {"start": 490.956, "end": 492.156, "text": "ayer hablábamos", "speaker": null}, {"start": 492.156, "end": 494.716, "text": "de que las personas", "speaker": null}, {"start": 494.716, "end": 495.696, "text": "morales,", "speaker": null}, {"start": 496.35602, "end": 498.17603, "text": "las personas morales,", "speaker": null}, {"start": 498.57602, "end": 502.616, "text": "se podían constituir de acuerdo a la ley", "speaker": null}, {"start": 502.616, "end": 513.096, "text": "en las sociedades plantiles, ejemplos como S.A., como S.A., S.D., E.R.E., ¿verdad?,", "speaker": null}, {"start": 513.096, "end": 519.156, "text": "como sociedad normativa simple, como sociedad normativa por acciones, etc., etc.", "speaker": null}, {"start": 520.956, "end": 526.056, "text": "Y que esté la reunión jurídica de dos o más personas físicas o morales para crear", "speaker": null}, {"start": 526.056, "end": 530.236, "text": "una nueva con personalidad jurídica propia y diferente a la de sus creadores.", "speaker": null}, {"start": 530.236, "end": 532.156, "text": "¿de acuerdo o no?", "speaker": null}, {"start": 532.716, "end": 534.036, "text": "vamos a ver que esto es cierto", "speaker": null}, {"start": 534.036, "end": 535.676, "text": "y que eso existe en la realidad", "speaker": null}, {"start": 535.676, "end": 538.016, "text": "también les dije", "speaker": null}, {"start": 538.016, "end": 540.136, "text": "que estos cuartos deben estar", "speaker": null}, {"start": 540.136, "end": 542.256, "text": "debidamente registrados", "speaker": null}, {"start": 542.256, "end": 543.99603, "text": "y protocolizados", "speaker": null}, {"start": 543.99603, "end": 546.356, "text": "y dijimos que se tenían", "speaker": null}, {"start": 546.356, "end": 547.516, "text": "que registrar en orden", "speaker": null}, {"start": 547.516, "end": 549.99603, "text": "en el equipo público de la propiedad", "speaker": null}, {"start": 549.99603, "end": 550.876, "text": "de la provincia", "speaker": null}, {"start": 550.876, "end": 554.116, "text": "para que estén registrados dijimos que", "speaker": null}, {"start": 554.116, "end": 556.216, "text": "estos amigos van a tener", "speaker": null}, {"start": 556.216, "end": 557.416, "text": "que", "speaker": null}, {"start": 557.416, "end": 560.216, "text": "generar un documento", "speaker": null}, {"start": 560.216, "end": 565.956, "text": "que los acredite como tal, que acredite que existen.", "speaker": null}, {"start": 566.69604, "end": 569.476, "text": "De hecho, aquí dijimos que en el mundo de las personas físicas,", "speaker": null}, {"start": 570.276, "end": 571.096, "text": "¿cuáles?", "speaker": null}, {"start": 571.336, "end": 573.876, "text": "La misión a la vez está en el mundo de los seres vivos.", "speaker": null}, {"start": 574.916, "end": 578.616, "text": "Dijimos que para llegar a este parte existe un acta de nacimiento", "speaker": null}, {"start": 578.616, "end": 582.156, "text": "y dijimos que estos padres también iban a tener un acta,", "speaker": null}, {"start": 582.296, "end": 584.616, "text": "pero no es de nacimiento, aunque están naciendo,", "speaker": null}, {"start": 585.616, "end": 589.076, "text": "pero no es como los niños, nacen jurídicamente.", "speaker": null}, {"start": 590.216, "end": 594.276, "text": "¿Y cómo lo van a hacer? A través de un acta constitutiva.", "speaker": null}, {"start": 595.976, "end": 596.536, "text": "¿Correcto?", "speaker": null}, {"start": 596.956, "end": 603.136, "text": "Y esa acta constitutiva va a tener que expresar quiénes son los dueños de la empresa", "speaker": null}, {"start": 603.136, "end": 609.796, "text": "y en qué parte o en qué proporción participaron o son dueños de esa empresa.", "speaker": null}, {"start": 610.796, "end": 612.93604, "text": "¿Eso lo van a hacer a través de qué?", "speaker": null}, {"start": 614.716, "end": 616.176, "text": "De acciones.", "speaker": null}, {"start": 618.496, "end": 619.056, "text": "¿Correcto?", "speaker": null}, {"start": 619.056, "end": 623.056, "text": "Por eso hablamos de que existen los señores accionistas.", "speaker": null}, {"start": 624.056, "end": 627.716, "text": "Un accionista, ¿verdad?, es el dueño de una empresa.", "speaker": null}, {"start": 629.356, "end": 633.636, "text": "¿Cómo lo acreditan? A través de sus títulos de crédito denominados accionistas.", "speaker": null}, {"start": 634.816, "end": 637.396, "text": "¿Ok? Hasta aquí muy bien, no me regreso.", "speaker": null}, {"start": 638.61597, "end": 647.676, "text": "Bueno, entonces, esto va a formar el capital social de esa empresa.", "speaker": null}, {"start": 647.676, "end": 650.156, "text": "esas cuentas", "speaker": null}, {"start": 650.156, "end": 653.036, "text": "correcto", "speaker": null}, {"start": 653.036, "end": 654.916, "text": "en el capital social", "speaker": null}, {"start": 654.916, "end": 657.156, "text": "y en el capital social", "speaker": null}, {"start": 657.156, "end": 658.156, "text": "¿qué más cuentas tenemos?", "speaker": null}, {"start": 659.136, "end": 660.81604, "text": "de acuerdo al artículo 20 de la ley", "speaker": null}, {"start": 660.81604, "end": 662.93604, "text": "de las instituciones mercantiles tenemos la obligación", "speaker": null}, {"start": 662.93604, "end": 666.136, "text": "de la reserva legal", "speaker": null}, {"start": 666.136, "end": 669.056, "text": "¿qué otras cuentas tenemos?", "speaker": null}, {"start": 669.056, "end": 669.93604, "text": "ejemplo", "speaker": null}, {"start": 669.93604, "end": 685.794, "text": "las unidades de las unidades o perdida o no", "speaker": null}, {"start": 685.794, "end": 688.494, "text": "y así pudiéramos hablar", "speaker": null}, {"start": 688.494, "end": 689.614, "text": "de todas las cuentas", "speaker": null}, {"start": 689.614, "end": 691.19403, "text": "que deberían de conocer ustedes", "speaker": null}, {"start": 691.19403, "end": 694.254, "text": "que ocupamos para llenar este mundo", "speaker": null}, {"start": 694.254, "end": 696.494, "text": "voy bien o me regreso", "speaker": null}, {"start": 696.494, "end": 699.594, "text": "seguro", "speaker": null}, {"start": 699.594, "end": 711.594, "text": "Por otro lado, les debieron haber enseñado, y no me puedo negar que se los he enseñado, a Charly, que es el que me ha mencionado, que existe otro documento.", "speaker": null}, {"start": 713.834, "end": 716.974, "text": "Y ese documento es el estado de resultados.", "speaker": null}, {"start": 716.974, "end": 720.654, "text": "en donde en el estado de resultados", "speaker": null}, {"start": 720.654, "end": 722.834, "text": "partimos del ómnibus", "speaker": null}, {"start": 722.834, "end": 724.914, "text": "de las ventas brutales", "speaker": null}, {"start": 724.914, "end": 726.414, "text": "ejemplos", "speaker": null}, {"start": 726.414, "end": 727.794, "text": "menos descuentos", "speaker": null}, {"start": 727.794, "end": 730.294, "text": "de bajas, de colisiones", "speaker": null}, {"start": 730.294, "end": 732.95404, "text": "y bonificaciones sobre ventas", "speaker": null}, {"start": 732.95404, "end": 734.63403, "text": "esto es igual", "speaker": null}, {"start": 734.63403, "end": 737.01404, "text": "a las ventas lentas", "speaker": null}, {"start": 737.01404, "end": 740.614, "text": "menos el costo de ventas", "speaker": null}, {"start": 740.614, "end": 742.314, "text": "esto es igual", "speaker": null}, {"start": 742.314, "end": 743.994, "text": "al resultado de la operación", "speaker": null}, {"start": 743.994, "end": 746.954, "text": "¿qué más?", "speaker": null}, {"start": 748.334, "end": 748.974, "text": "menos", "speaker": null}, {"start": 748.974, "end": 752.294, "text": "los gastos", "speaker": null}, {"start": 752.294, "end": 755.374, "text": "etc, etc, etc", "speaker": null}, {"start": 755.374, "end": 757.854, "text": "hasta llegar a la utilidad", "speaker": null}, {"start": 757.854, "end": 758.814, "text": "o pérdida", "speaker": null}, {"start": 758.814, "end": 761.734, "text": "¿voy bien o me regreso?", "speaker": null}, {"start": 763.734, "end": 765.934, "text": "¿por qué digo que lo tenían que haber", "speaker": null}, {"start": 765.934, "end": 768.01404, "text": "aprendido? creo que se lo tenían que haber", "speaker": null}, {"start": 768.01404, "end": 768.594, "text": "enseñado", "speaker": null}, {"start": 768.594, "end": 770.674, "text": "porque para que ustedes", "speaker": null}, {"start": 770.674, "end": 778.034, "text": "para que ustedes cierren este documento que es el estado de posición financiera,", "speaker": null}, {"start": 779.154, "end": 782.234, "text": "a Chaleco debieron haber hecho primero este.", "speaker": null}, {"start": 783.534, "end": 785.69403, "text": "¿Y por qué digo que debieron haber hecho este?", "speaker": null}, {"start": 786.19403, "end": 791.314, "text": "Porque si no, a mí me la tienen una incógnita, no les va a cuadrar el documento.", "speaker": null}, {"start": 791.874, "end": 794.474, "text": "Y no les va a cuadrar porque les hacen un dato.", "speaker": null}, {"start": 795.594, "end": 798.39404, "text": "¿Ese dato cuál es? La utilidad de comprar.", "speaker": null}, {"start": 798.39404, "end": 801.974, "text": "quiere decir entonces que primero debieron haber hecho", "speaker": null}, {"start": 801.974, "end": 803.054, "text": "estas representaciones", "speaker": null}, {"start": 803.054, "end": 806.13403, "text": "es el que le indica cuál es la utilidad", "speaker": null}, {"start": 806.13403, "end": 808.174, "text": "pérdida para que esta", "speaker": null}, {"start": 808.174, "end": 810.914, "text": "la pasen para acá", "speaker": null}, {"start": 810.914, "end": 813.63403, "text": "y ahora sí puede encuadrar", "speaker": null}, {"start": 813.63403, "end": 816.034, "text": "el segundo documento", "speaker": null}, {"start": 816.034, "end": 818.094, "text": "¡oh sorpresa!", "speaker": null}, {"start": 818.734, "end": 820.314, "text": "pero para hacer este documento", "speaker": null}, {"start": 820.314, "end": 821.974, "text": "este y este son básicos", "speaker": null}, {"start": 821.974, "end": 824.534, "text": "machista", "speaker": null}, {"start": 824.534, "end": 827.054, "text": "estaba en posición financiera", "speaker": null}, {"start": 827.054, "end": 829.19403, "text": "y estaba resultado.", "speaker": null}, {"start": 830.27405, "end": 831.114, "text": "Que aquí repito,", "speaker": null}, {"start": 831.534, "end": 832.734, "text": "hoy por hoy se está mirando", "speaker": null}, {"start": 832.734, "end": 833.814, "text": "de integrar,", "speaker": null}, {"start": 834.814, "end": 836.19403, "text": "pero eso está resultado.", "speaker": null}, {"start": 837.57404, "end": 838.01404, "text": "¿Sí?", "speaker": null}, {"start": 838.854, "end": 839.294, "text": "Ok.", "speaker": null}, {"start": 840.27405, "end": 841.454, "text": "Ahora la pregunta es,", "speaker": null}, {"start": 841.594, "end": 842.77405, "text": "¿ya con esto la hice mortal?", "speaker": null}, {"start": 843.174, "end": 845.294, "text": "¿Ya con esto puedo entrar al mundo financiero?", "speaker": null}, {"start": 845.39404, "end": 846.614, "text": "¿Ya con esto puedo analizar?", "speaker": null}, {"start": 847.094, "end": 847.714, "text": "¿Ya con esto?", "speaker": null}, {"start": 847.874, "end": 849.114, "text": "Olvídense de los métodos,", "speaker": null}, {"start": 849.214, "end": 850.19403, "text": "olvídense de la escuela,", "speaker": null}, {"start": 850.374, "end": 851.474, "text": "olvídense de la materia.", "speaker": null}, {"start": 852.554, "end": 854.214, "text": "En la vida real, en mi empresa,", "speaker": null}, {"start": 854.334, "end": 856.874, "text": "¿ya con eso la hago mortal para tomar decisiones?", "speaker": null}, {"start": 857.054, "end": 865.19403, "text": "Claro, porque me faltaría saber de dónde debo colocar este documento.", "speaker": null}, {"start": 866.15405, "end": 869.65405, "text": "Y este documento se va a tener que apoyar en los secundarios.", "speaker": null}, {"start": 871.69403, "end": 872.234, "text": "Ejemplo.", "speaker": null}, {"start": 878.234, "end": 883.314, "text": "En el estado o punto de costo de reproducción de lo vendido.", "speaker": null}, {"start": 883.314, "end": 887.574, "text": "¿para qué el gobierno recibe ese maldito documento?", "speaker": null}, {"start": 889.154, "end": 891.13403, "text": "bueno, ese documento", "speaker": null}, {"start": 891.13403, "end": 892.094, "text": "me va a servir", "speaker": null}, {"start": 892.094, "end": 894.69403, "text": "porque ahí voy a determinar", "speaker": null}, {"start": 894.69403, "end": 896.334, "text": "qué, vamos a ver", "speaker": null}, {"start": 896.334, "end": 898.374, "text": "cuál es la estructura del Estado conjunto", "speaker": null}, {"start": 898.374, "end": 899.374, "text": "cualquiera de los dos", "speaker": null}]