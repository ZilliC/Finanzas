.61597, "text": "y va a ver que la actividad es simple,", "speaker": null}, {"start": 579.61597, "end": 581.61597, "text": "y al estar a una, sin cualquier capón,", "speaker": null}, {"start": 581.61597, "end": 584.61597, "text": "es que no puede.", "speaker": null}, {"start": 584.61597, "end": 586.61597, "text": "Entonces necesitamos alguien más en presencia.", "speaker": null}, {"start": 586.61597, "end": 588.61597, "text": "Pero ¿qué crees?", "speaker": null}, {"start": 588.616, "end": 591.07605, "text": "necesitamos hacer una oferta más efectiva.", "speaker": null}, {"start": 592.556, "end": 593.016, "text": "¿Para qué?", "speaker": null}, {"start": 593.216, "end": 594.99603, "text": "Para que si hay un cargo por ahí,", "speaker": null}, {"start": 595.716, "end": 596.49603, "text": "pues se alimente.", "speaker": null}, {"start": 598.176, "end": 598.836, "text": "Se alimente.", "speaker": null}, {"start": 600.836, "end": 601.356, "text": "¿Me explico?", "speaker": null}, {"start": 603.016, "end": 604.93604, "text": "Entonces, por eso yo digo que no pasa nada.", "speaker": null}, {"start": 605.396, "end": 606.336, "text": "No pasa nada.", "speaker": null}, {"start": 607.176, "end": 608.93604, "text": "Porque yo sé que ustedes, como yo,", "speaker": null}, {"start": 609.056, "end": 610.176, "text": "lo primero que van a hacer,", "speaker": null}, {"start": 610.296, "end": 611.476, "text": "y eso me lo han hecho,", "speaker": null}, {"start": 611.476, "end": 612.93604, "text": "y eso me lo han hecho.", "speaker": null}, {"start": 613.716, "end": 615.056, "text": "También informática,", "speaker": null}, {"start": 615.49603, "end": 616.596, "text": "también la liberación.", "speaker": null}, {"start": 616.596, "end": 631.416, "text": "¿Qué es lo que está diciendo?", "speaker": null}, {"start": 633.416, "end": 635.336, "text": "¿De verdad sabe qué es lo que está diciendo?", "speaker": null}, {"start": 636.176, "end": 642.896, "text": "Porque usted como informático, usted puede y tiene que aprender a trabajar con contraparte,", "speaker": null}, {"start": 642.896, "end": 644.81604, "text": "con qué?", "speaker": null}, {"start": 645.716, "end": 647.296, "text": "con alquiler", "speaker": null}, {"start": 647.296, "end": 650.356, "text": "con biólogos", "speaker": null}, {"start": 650.356, "end": 654.176, "text": "con químicos", "speaker": null}, {"start": 654.176, "end": 657.336, "text": "entonces", "speaker": null}, {"start": 657.336, "end": 659.136, "text": "como que eso es lo que más", "speaker": null}, {"start": 659.136, "end": 661.43604, "text": "necesito enseñar a todos ustedes", "speaker": null}, {"start": 661.43604, "end": 664.776, "text": "usted lo tiene una mano", "speaker": null}, {"start": 664.776, "end": 666.236, "text": "y dice que debe ser un químico", "speaker": null}, {"start": 666.236, "end": 669.396, "text": "porque usted va a tener", "speaker": null}, {"start": 669.396, "end": 682.094, "text": "la necesidad de sus clientes Amados si ustedes se convicen en un Gates ponga las reglas que no creo que las diga por ah Usted va a tener que entender adem si a un Bill Gates", "speaker": null}, {"start": 682.094, "end": 684.154, "text": "atiende necesidades", "speaker": null}, {"start": 684.154, "end": 685.094, "text": "de los usuarios,", "speaker": null}, {"start": 686.434, "end": 687.154, "text": "o me equivoco,", "speaker": null}, {"start": 687.314, "end": 690.114, "text": "por eso tiene el éxito que tiene.", "speaker": null}, {"start": 691.63403, "end": 692.07404, "text": "Porque", "speaker": null}, {"start": 692.07404, "end": 693.714, "text": "por un que le ofrece", "speaker": null}, {"start": 693.714, "end": 695.494, "text": "la cosa posible,", "speaker": null}, {"start": 697.414, "end": 698.594, "text": "cubre las necesidades", "speaker": null}, {"start": 698.594, "end": 699.434, "text": "de los usuarios.", "speaker": null}, {"start": 700.054, "end": 705.19403, "text": "Por eso es que carne parece un animal y sigue creciendo más.", "speaker": null}, {"start": 706.77405, "end": 709.07404, "text": "¿Tienes un hijo? ¿Cómo lo tienes?", "speaker": null}, {"start": 711.214, "end": 712.614, "text": "¿Hoy viene una revista?", "speaker": null}, {"start": 713.27405, "end": 713.51404, "text": "Sí.", "speaker": null}, {"start": 714.374, "end": 717.854, "text": "Pues con la pena, mi Dios, porque a mí me tachan de malito, con la pena.", "speaker": null}, {"start": 718.154, "end": 718.794, "text": "Todo lo contrario.", "speaker": null}, {"start": 719.434, "end": 722.854, "text": "Pero yo sé lo que dirán, no seré muy malito.", "speaker": null}, {"start": 722.854, "end": 726.13403, "text": "Pero algo se me queda antes.", "speaker": null}, {"start": 727.314, "end": 727.914, "text": "Van a creer.", "speaker": null}, {"start": 727.914, "end": 729.914, "text": "¡Marcha!", "speaker": null}, {"start": 729.914, "end": 734.914, "text": "A lo mejor no vamos a ver con mucha profundidad si ustedes no lo soportan, no hay broma.", "speaker": null}, {"start": 734.914, "end": 737.914, "text": "Pero sí necesito que sepan de lo que estamos hablando.", "speaker": null}, {"start": 737.914, "end": 740.914, "text": "¿Me explico?", "speaker": null}, {"start": 740.914, "end": 743.914, "text": "Hoy vienen muy bien.", "speaker": null}, {"start": 743.914, "end": 745.914, "text": "Con la pena, muchos.", "speaker": null}, {"start": 745.914, "end": 747.914, "text": "Todo lo contrario.", "speaker": null}, {"start": 747.914, "end": 749.914, "text": "Hace buenísimo.", "speaker": null}, {"start": 749.914, "end": 751.914, "text": "¡Sáquenlo!", "speaker": null}, {"start": 751.914, "end": 753.914, "text": "A ver...", "speaker": null}, {"start": 753.914, "end": 761.714, "text": "Hoy voy a hacer un especial con mi lista, pero a partir de mañana, preguntas, hagas preguntas, te las voy a buscar.", "speaker": null}, {"start": 762.63403, "end": 762.834, "text": "¿Vale?", "speaker": null}, {"start": 763.77405, "end": 766.13403, "text": "Te abierto en el escenario, te lo voy a dar.", "speaker": null}, {"start": 767.414, "end": 770.554, "text": "A ver, esta es la cancha donde van a jugar los jugadores.", "speaker": null}, {"start": 771.874, "end": 775.434, "text": "Ahora vamos a ver que también hay jugadores, que también hay mi selección.", "speaker": null}, {"start": 777.234, "end": 781.814, "text": "A ver, Charlie, no quiero que me expliques nada.", "speaker": null}, {"start": 781.814, "end": 783.154, "text": "la", "speaker": null}, {"start": 783.154, "end": 785.714, "text": "de Cuervo Conte Metasomólicas", "speaker": null}, {"start": 785.714, "end": 787.794, "text": "nada más", "speaker": null}, {"start": 787.794, "end": 789.674, "text": "menciona", "speaker": null}, {"start": 789.674, "end": 790.734, "text": "recuerda", "speaker": null}, {"start": 790.734, "end": 792.434, "text": "señala", "speaker": null}, {"start": 792.434, "end": 796.254, "text": "cuando menos", "speaker": null}, {"start": 796.254, "end": 797.954, "text": "seis", "speaker": null}, {"start": 797.954, "end": 800.01404, "text": "métodos de análisis", "speaker": null}, {"start": 800.01404, "end": 801.554, "text": "financiero", "speaker": null}, {"start": 809.554, "end": 810.754, "text": "¿es de razón?", "speaker": null}, {"start": 811.814, "end": 813.814, "text": "vertical", "speaker": null}, {"start": 813.814, "end": 815.814, "text": "y horizontal", "speaker": null}, {"start": 841.814, "end": 855.754, "text": "¿Qué es la orden de las ventas?", "speaker": null}, {"start": 857.434, "end": 859.314, "text": "¿Vas a hacer ventas?", "speaker": null}, {"start": 859.63403, "end": 860.794, "text": "¿Vas a hacer ventas?", "speaker": null}, {"start": 861.574, "end": 862.39404, "text": "¿Vas a hacer ventas?", "speaker": null}, {"start": 862.39404, "end": 863.834, "text": "¿Vas a hacer ventas?", "speaker": null}, {"start": 871.814, "end": 878.814, "text": "Pero fíjate lo que no me va mal, hablamos de lo que realmente es un secreto, no de cuentas contables.", "speaker": null}, {"start": 878.814, "end": 887.814, "text": "Lo que tú me mencionaste son cuentas contables y son cuentas de resultados, que nada tiene que ver con lo que estamos contando.", "speaker": null}, {"start": 887.814, "end": 899.734, "text": "Vamos a encontrar eso en un título humano de ¿Necesito preguntarles a qué necesito saber?", "speaker": null}]