[{"start": 0.0, "end": 1.66, "text": "¿Para qué sirve la maldita contabilidad?", "speaker": null}, {"start": 6.08, "end": 7.68, "text": "¿A ustedes qué les va a tocar hacer?", "speaker": null}, {"start": 9.26, "end": 10.9, "text": "Controlar la venta por cuenta.", "speaker": null}, {"start": 11.62, "end": 15.559999, "text": "Cuando les digan, a ver Charlie, necesito que controlar las ventas de la empresa,", "speaker": null}, {"start": 16.32, "end": 18.38, "text": "los tengo que programar ahí.", "speaker": null}, {"start": 19.3, "end": 23.359999, "text": "Cada factura que haga la empresa, la va a jalar y la va a colocar en esa cuenta.", "speaker": null}, {"start": 24.58, "end": 29.4, "text": "Cada que yo pago, lo va a jalar y lo va a poner en esa cuenta.", "speaker": null}, {"start": 30.0, "end": 34.32, "text": "y aparte va a afectar, por ejemplo, con qué pague, con bancos.", "speaker": null}, {"start": 35.82, "end": 37.68, "text": "Entonces, ¿de dónde voy a sacar el dinero?", "speaker": null}, {"start": 38.12, "end": 41.86, "text": "Le voy a dar una instrucción a la máquina para que saque el dinero de banco", "speaker": null}, {"start": 41.86, "end": 45.06, "text": "y lo meta al inventario, por poner un ejemplo.", "speaker": null}, {"start": 46.079998, "end": 48.92, "text": "¿Por qué? Porque de ahí saque el dinero y en que lo mude.", "speaker": null}, {"start": 50.48, "end": 52.86, "text": "Para que el usuario, cuando le pise Enter,", "speaker": null}, {"start": 52.86, "end": 59.52, "text": "ya nada más le aparezca en su pantalla, banco estando, almacenando, cliente estando.", "speaker": null}, {"start": 59.52, "end": 61.06, "text": "compras tanto", "speaker": null}, {"start": 61.06, "end": 62.14, "text": "¿me explico?", "speaker": null}, {"start": 62.84, "end": 64.72, "text": "para eso ocupan ustedes su base de datos", "speaker": null}, {"start": 64.72, "end": 66.54, "text": "entonces si ponen que tienen clientes", "speaker": null}, {"start": 66.54, "end": 68.78, "text": "en una base de datos", "speaker": null}, {"start": 68.78, "end": 71.12, "text": "en donde no puede estar tecleando", "speaker": null}, {"start": 71.12, "end": 72.46, "text": "operación a operación", "speaker": null}, {"start": 72.46, "end": 74.84, "text": "el pinche usuario que le voy a decir", "speaker": null}, {"start": 74.84, "end": 76.72, "text": "échate un catálogo de cuentas", "speaker": null}, {"start": 76.72, "end": 78.92, "text": "y cuando tú hagas la operación", "speaker": null}, {"start": 78.92, "end": 80.48, "text": "regístrala", "speaker": null}, {"start": 80.48, "end": 81.96, "text": "con su número de cuenta", "speaker": null}, {"start": 81.96, "end": 83.62, "text": "para que la computadora entienda", "speaker": null}, {"start": 83.62, "end": 85.28, "text": "de quién es y a dónde va", "speaker": null}, {"start": 85.28, "end": 88.24, "text": "digo yo, yo no soy informático", "speaker": null}, {"start": 88.24, "end": 91.799995, "text": "¿O me equivoco?", "speaker": null}, {"start": 94.299995, "end": 96.439995, "text": "¿Qué maldito problema tienes?", "speaker": null}, {"start": 102.06, "end": 103.579994, "text": "¿Qué es esta papita?", "speaker": null}, {"start": 107.06, "end": 108.42, "text": "¿Pero qué pasa?", "speaker": null}, {"start": 108.619995, "end": 109.86, "text": "Si mi cuate lo informa,", "speaker": null}, {"start": 110.1, "end": 111.68, "text": "¿dónde existe todo eso?", "speaker": null}, {"start": 112.42, "end": 113.659996, "text": "¿De dónde demonios?", "speaker": null}, {"start": 113.659996, "end": 113.71999, "text": "¿Qué pasa?", "speaker": null}, {"start": 115.5, "end": 116.6, "text": "¿Me van a morir?", "speaker": null}, {"start": 118.24, "end": 126.24, "text": "No quiero que el informático cargue ya un huevo. Quiero que sepa que dónde va a tomar la información.", "speaker": null}, {"start": 130.23999, "end": 132.23999, "text": "¿Se puede o no se puede?", "speaker": null}, {"start": 136.23999, "end": 138.23999, "text": "¿Cómo vamos a seguir?", "speaker": null}, {"start": 140.23999, "end": 142.23999, "text": "Es que hay que llevarlo a otra vez.", "speaker": null}, {"start": 144.23999, "end": 147.23999, "text": "Es para chamacos. Es para los crúplices.", "speaker": null}, {"start": 148.23999, "end": 156.48, "text": "Bien, continuamos. Y así pudiéramos hablar de cada uno.", "speaker": null}, {"start": 159.85999, "end": 163.12, "text": "Chale, me llora mi mente y los reexpresados, ¿qué onda?", "speaker": null}, {"start": 167.18, "end": 169.41998, "text": "Hace un rato hablábamos de la inflación.", "speaker": null}, {"start": 171.27998, "end": 173.59999, "text": "¿Por qué tenemos la obligación de reexpresar?", "speaker": null}, {"start": 174.29999, "end": 177.84, "text": "Para que refleje la realidad del dinero.", "speaker": null}, {"start": 178.23999, "end": 179.9, "text": "ya en su momento procesado", "speaker": null}, {"start": 179.9, "end": 180.73999, "text": "por todos los que quieren", "speaker": null}, {"start": 180.73999, "end": 182.26, "text": "vemos como se reexpresa el dinero", "speaker": null}, {"start": 182.26, "end": 184.51999, "text": "pero existe", "speaker": null}, {"start": 184.51999, "end": 186.63998, "text": "un documento que me refleja", "speaker": null}, {"start": 186.63998, "end": 188.79999, "text": "las cifras reexpresadas", "speaker": null}, {"start": 188.79999, "end": 190.95999, "text": "señala esta opinación reexpresada", "speaker": null}, {"start": 190.95999, "end": 193.21999, "text": "ahora no todas las empresas", "speaker": null}, {"start": 193.21999, "end": 193.99998, "text": "reexpresan", "speaker": null}, {"start": 193.99998, "end": 196.43999, "text": "¿por qué?", "speaker": null}, {"start": 196.81999, "end": 198.63998, "text": "por cinco poderosas razones", "speaker": null}, {"start": 198.63998, "end": 200.43999, "text": "o por una muy importante", "speaker": null}, {"start": 200.43999, "end": 202.95999, "text": "porque son los gratis", "speaker": null}, {"start": 202.95999, "end": 205.21999, "text": "si a mí me dices que yo te reexpreso", "speaker": null}, {"start": 205.21999, "end": 206.73999, "text": "entonces tú al final yo te voy a coger", "speaker": null}, {"start": 206.73999, "end": 213.23999, "text": "Entonces, normalmente quién las represa, las empresas grandes, las que se dictaminan,", "speaker": null}, {"start": 213.23999, "end": 219.98, "text": "porque es un requisito para ellas. Por ejemplo, Bimbo tiene obligación de represa a los 8", "speaker": null}, {"start": 219.98, "end": 235.418, "text": "mecheles Ford Chrysler Volkswagen Nissan Procter Gamble Ernest La Coste tienen obligaci de reexpresar", "speaker": null}, {"start": 237.418, "end": 245.878, "text": "Pero Charlie, ¿crees que va a reexpresar? No va a reexpresar.", "speaker": null}, {"start": 245.878, "end": 258.338, "text": "¿Pero tú crees que Volkswagen se conforma con decir manejo mi lana?", "speaker": null}, {"start": 259.338, "end": 260.418, "text": "Va a decir, no, cabrón.", "speaker": null}, {"start": 261.258, "end": 265.49802, "text": "Una cosa es, ventas México, ¿verdad?", "speaker": null}, {"start": 265.738, "end": 267.978, "text": "Otra cosa es, ventas Europa.", "speaker": null}, {"start": 269.238, "end": 271.018, "text": "Otra cosa es, Asia.", "speaker": null}, {"start": 271.858, "end": 272.71802, "text": "Y así sucesivamente.", "speaker": null}, {"start": 272.71802, "end": 274.898, "text": "porque lo que pasa en México", "speaker": null}, {"start": 274.898, "end": 277.15802, "text": "no pasa en América Latina", "speaker": null}, {"start": 277.15802, "end": 279.738, "text": "y lo que pasa en América Latina", "speaker": null}, {"start": 279.738, "end": 280.678, "text": "no pasa en Europa", "speaker": null}, {"start": 280.678, "end": 285.198, "text": "ni en Estados Unidos", "speaker": null}, {"start": 285.198, "end": 287.778, "text": "¿qué va a pasar?", "speaker": null}, {"start": 288.558, "end": 291.178, "text": "o sea ya la inflación se comporta de manera diferente", "speaker": null}, {"start": 291.178, "end": 294.978, "text": "además a lo mejor hay países", "speaker": null}, {"start": 294.978, "end": 297.618, "text": "en donde ni siquiera se deja la inflación", "speaker": null}, {"start": 297.618, "end": 301.938, "text": "pregunta la Europa", "speaker": null}, {"start": 301.938, "end": 309.258, "text": "¿En Japón se están acercando a desplazión?", "speaker": null}, {"start": 309.958, "end": 311.398, "text": "No, en Japón es más que buena.", "speaker": null}, {"start": 312.838, "end": 313.898, "text": "¿Estás hablando de eso?", "speaker": null}, {"start": 314.418, "end": 315.918, "text": "Imagínate que ya hay un...", "speaker": null}, {"start": 315.918, "end": 316.958, "text": "allá utilizan eso.", "speaker": null}, {"start": 317.058, "end": 318.21802, "text": "Ya hablando de inventarios.", "speaker": null}, {"start": 318.858, "end": 320.318, "text": "Aquí todavía hablamos de inventarios.", "speaker": null}, {"start": 322.938, "end": 324.978, "text": "Hay economías, no voy a hablar de países,", "speaker": null}, {"start": 325.15802, "end": 326.338, "text": "voy a hablar de economías.", "speaker": null}, {"start": 327.518, "end": 328.958, "text": "En donde ya manejan el famoso", "speaker": null}, {"start": 328.958, "end": 329.978, "text": "just-in-time.", "speaker": null}, {"start": 329.978, "end": 332.178, "text": "han ido a hablar de ellos", "speaker": null}, {"start": 332.178, "end": 332.65802, "text": "este año", "speaker": null}, {"start": 332.65802, "end": 335.15802, "text": "es el justo tiempo", "speaker": null}, {"start": 335.15802, "end": 336.838, "text": "y ahí tienes", "speaker": null}, {"start": 336.838, "end": 340.21802, "text": "en lo que nosotros", "speaker": null}, {"start": 340.21802, "end": 341.978, "text": "aquí un ejemplo", "speaker": null}, {"start": 341.978, "end": 343.09802, "text": "en la industria pesquera", "speaker": null}, {"start": 343.09802, "end": 346.398, "text": "en lo que llegas al mueble", "speaker": null}, {"start": 346.398, "end": 347.818, "text": "le das cuerda a tu", "speaker": null}, {"start": 347.818, "end": 350.03802, "text": "barquito, trepas", "speaker": null}, {"start": 350.03802, "end": 352.05798, "text": "a todo ganado", "speaker": null}, {"start": 352.05798, "end": 353.858, "text": "los avientas a remar", "speaker": null}, {"start": 353.858, "end": 355.71802, "text": "porque tienes motocicletas", "speaker": null}, {"start": 355.71802, "end": 356.758, "text": "que tienes mi jala", "speaker": null}, {"start": 356.758, "end": 359.298, "text": "en lo que sacan sus cuerditas", "speaker": null}, {"start": 359.298, "end": 360.498, "text": "redesitas", "speaker": null}, {"start": 360.498, "end": 363.258, "text": "¿qué hacen? llegan los japoneses", "speaker": null}, {"start": 363.258, "end": 365.198, "text": "con su navio", "speaker": null}, {"start": 365.198, "end": 367.418, "text": "vienen, se meten", "speaker": null}, {"start": 367.418, "end": 369.958, "text": "a los litorales marítimos", "speaker": null}, {"start": 369.958, "end": 370.998, "text": "a donde hay peces", "speaker": null}, {"start": 370.998, "end": 373.738, "text": "y en lo que llegan a Japón", "speaker": null}, {"start": 373.738, "end": 375.53802, "text": "en el mismo barco van procesando", "speaker": null}, {"start": 375.53802, "end": 377.838, "text": "y cuando llegan ya tienen", "speaker": null}, {"start": 377.838, "end": 380.09802, "text": "incluso el producto venido", "speaker": null}, {"start": 380.09802, "end": 381.71802, "text": "ya nada más es entregar", "speaker": null}, {"start": 381.71802, "end": 385.118, "text": "de ese tamaño está", "speaker": null}, {"start": 385.118, "end": 387.15802, "text": "pero como verán", "speaker": null}, {"start": 387.15802, "end": 389.638, "text": "dice tu presidenta", "speaker": null}, {"start": 389.638, "end": 392.03802, "text": "que ya estamos por entrar al primer mundo", "speaker": null}, {"start": 392.03802, "end": 395.378, "text": "que a partir de que llegó el peje y ella", "speaker": null}, {"start": 395.378, "end": 397.71802, "text": "México ya cambió", "speaker": null}, {"start": 397.71802, "end": 400.03802, "text": "¿tú le crees?", "speaker": null}, {"start": 403.398, "end": 405.418, "text": "está muy jodida la señora", "speaker": null}, {"start": 405.418, "end": 407.498, "text": "pero bueno", "speaker": null}, {"start": 407.498, "end": 408.758, "text": "habrá quien le cree", "speaker": null}, {"start": 408.758, "end": 411.71802, "text": "la respuesta ya la sabemos", "speaker": null}, {"start": 411.71802, "end": 415.638, "text": "ella igual que su abuelo", "speaker": null}, {"start": 415.638, "end": 417.078, "text": "tiene otros datos", "speaker": null}, {"start": 417.078, "end": 420.05798, "text": "no contestan así ellos", "speaker": null}, {"start": 420.05798, "end": 422.55798, "text": "ellos tienen otros datos", "speaker": null}, {"start": 422.55798, "end": 427.618, "text": "los datos de nosotros son estos", "speaker": null}, {"start": 427.618, "end": 431.298, "text": "hay que usar su destreza en los datos hechos", "speaker": null}, {"start": 431.298, "end": 435.358, "text": "pero la empresa no va a vivir de los datos feos", "speaker": null}, {"start": 435.358, "end": 437.53802, "text": "te lo garantizo", "speaker": null}, {"start": 437.53802, "end": 440.958, "text": "¿cómo vamos a seguir?", "speaker": null}, {"start": 444.498, "end": 445.018, "text": "seguros", "speaker": null}, {"start": 445.018, "end": 462.756, "text": "y vamos a empezar a enterar nuestro mundo financiero hasta aqu vamos bien para que nos vayamos es la contabilidad", "speaker": null}, {"start": 475.036, "end": 476.756, "text": "aplicación de las hijas", "speaker": null}, {"start": 476.756, "end": 478.656, "text": "si sucede, supone", "speaker": null}, {"start": 478.656, "end": 481.336, "text": "que todo eso se los enseñaron", "speaker": null}, {"start": 481.336, "end": 481.67603, "text": "ayer", "speaker": null}, {"start": 481.67603, "end": 484.196, "text": "aquí ya estamos repasando", "speaker": null}, {"start": 484.196, "end": 485.196, "text": "de cuando estaba", "speaker": null}, {"start": 485.196, "end": 487.816, "text": "entonces", "speaker": null}, {"start": 487.816, "end": 488.256, "text": "vamos a subir", "speaker": null}, {"start": 488.256, "end": 494.79602, "text": "vamos a subir", "speaker": null}, {"start": 494.79602, "end": 497.696, "text": "ok, por lo tanto", "speaker": null}, {"start": 497.696, "end": 498.756, "text": "empezaron a entrar a donde", "speaker": null}, {"start": 498.756, "end": 500.85602, "text": "¿qué hora es?", "speaker": null}, {"start": 502.63602, "end": 503.73602, "text": "un cuarenta y cuatro", "speaker": null}, {"start": 503.73602, "end": 505.676, "text": "¿Qué pasa?", "speaker": null}, {"start": 506.676, "end": 508.73602, "text": "Ahorita le echamos un kilogramo.", "speaker": null}, {"start": 518.616, "end": 519.296, "text": "Ok.", "speaker": null}, {"start": 520.99603, "end": 523.476, "text": "Vamos a empezar a entrar en este mundo financiero.", "speaker": null}, {"start": 525.416, "end": 526.656, "text": "¿Cómo empezamos?", "speaker": null}, {"start": 526.776, "end": 527.156, "text": "¿En el 26?", "speaker": null}, {"start": 528.756, "end": 529.93604, "text": "¿Cómo empezamos?", "speaker": null}, {"start": 530.056, "end": 530.49603, "text": "¿En el 26?", "speaker": null}, {"start": 530.49603, "end": 531.49603, "text": "¿Cómo empezamos?", "speaker": null}, {"start": 531.49603, "end": 531.576, "text": "¿Cómo empezamos?", "speaker": null}, {"start": 531.576, "end": 531.876, "text": "¿Cómo empezamos?", "speaker": null}, {"start": 531.876, "end": 531.916, "text": "¿Cómo empezamos?", "speaker": null}, {"start": 531.916, "end": 532.176, "text": "¿Cómo empezamos?", "speaker": null}, {"start": 533.736, "end": 538.556, "text": "hay un término más o menos como el de la oposición", "speaker": null}, {"start": 538.556, "end": 542.036, "text": "imaginemos que ese es el estado de oposición", "speaker": null}, {"start": 542.036, "end": 542.93604, "text": "y no es el estado de la oposición", "speaker": null}, {"start": 542.93604, "end": 558.256, "text": "lo primero que tenemos que entender", "speaker": null}, {"start": 558.256, "end": 561.196, "text": "es que existe", "speaker": null}, {"start": 561.196, "end": 571.056, "text": "diferentes métodos de análisis", "speaker": null}, {"start": 571.056, "end": 574.056, "text": "¿por qué la universidad", "speaker": null}, {"start": 574.056, "end": 575.416, "text": "está interesada en ustedes", "speaker": null}, {"start": 575.416, "end": 577.156, "text": "con los cánticos de análisis?", "speaker": null}, {"start": 577.81604, "end": 578.916, "text": "se nos acabó de leer", "speaker": null}, {"start": 578.916, "end": 580.976, "text": "que tienen que volver a revisar", "speaker": null}, {"start": 580.976, "end": 582.596, "text": "con que hubo", "speaker": null}, {"start": 582.596, "end": 586.516, "text": "presión", "speaker": null}, {"start": 586.516, "end": 616.496, "text": "¿Qué es la vida?", "speaker": null}, {"start": 616.516, "end": 618.616, "text": "adueño, pero bueno, no pasa nada.", "speaker": null}, {"start": 620.696, "end": 621.81604, "text": "¿Qué es lo que les va a decir?", "speaker": null}, {"start": 623.336, "end": 624.496, "text": "Porque yo debo de", "speaker": null}, {"start": 624.496, "end": 626.416, "text": "analizar e interpretar", "speaker": null}, {"start": 626.416, "end": 627.216, "text": "la información.", "speaker": null}, {"start": 629.916, "end": 631.916, "text": "Porque si ustedes logran hacer eso,", "speaker": null}, {"start": 632.296, "end": 634.216, "text": "y al final del día voy a ser", "speaker": null}, {"start": 634.216, "end": 635.856, "text": "un poco más ambicioso.", "speaker": null}, {"start": 636.856, "end": 637.096, "text": "¿Vale?", "speaker": null}, {"start": 637.876, "end": 640.456, "text": "Yo no quiero decir que ustedes lo hagan.", "speaker": null}, {"start": 643.176, "end": 644.736, "text": "Yo les voy a decir lo mismo.", "speaker": null}, {"start": 646.516, "end": 652.036, "text": "que trato de enseñarles a mis alumnos contadores, porque para mí no hay diferencia.", "speaker": null}, {"start": 653.476, "end": 657.93604, "text": "Yo trato de atender de la misma manera a los informáticos que a los contadores,", "speaker": null}, {"start": 659.81604, "end": 660.876, "text": "aunque yo soy contador.", "speaker": null}, {"start": 662.136, "end": 666.836, "text": "Trato de atender de la misma manera a mis alumnos informáticos,", "speaker": null}, {"start": 667.256, "end": 683.794, "text": "administradores de negocios internacionales que a los contadores aunque yo soy contador porque todos son mis alumnos Trato de atender igual a mis alumnos de all que son los abog que son los ingenieros", "speaker": null}, {"start": 686.07404, "end": 691.534, "text": "¿Por qué? Porque también son mis alumnos. Yo no estoy peleando con ninguna carga.", "speaker": null}, {"start": 692.674, "end": 699.294, "text": "Trato de que todos aprendan. ¿Ok? Y les voy a decir lo mismo que les digo a los contadores,", "speaker": null}, {"start": 699.294, "end": 700.674, "text": "porque también son mis amigos.", "speaker": null}, {"start": 701.294, "end": 703.914, "text": "Y dije, voy a ser un poco más ambicioso.", "speaker": null}, {"start": 705.77405, "end": 709.19403, "text": "Por ejemplo, yo a mis contadores los cajeteo y los devuelvo.", "speaker": null}, {"start": 709.594, "end": 710.51404, "text": "Y se los echaré todo.", "speaker": null}, {"start": 711.474, "end": 712.594, "text": "¿Para qué viniste aquí?", "speaker": null}, {"start": 714.07404, "end": 715.374, "text": "Para ser contador.", "speaker": null}, {"start": 716.754, "end": 718.57404, "text": "¿Y para qué quieres ser contador?", "speaker": null}, {"start": 720.174, "end": 725.274, "text": "Ajá, pues porque al final pretendo ser el contador de la empresa.", "speaker": null}, {"start": 725.45404, "end": 727.674, "text": "¿Cuál empresa te puso en la que me contraté?", "speaker": null}, {"start": 729.294, "end": 736.794, "text": "Entonces, sería bueno, desde el punto de vista de mi amigo, llegar a ser el contador de la empresa.", "speaker": null}, {"start": 738.474, "end": 741.534, "text": "Pues si es el contador general, sí, porque es el mandamás de la empresa.", "speaker": null}, {"start": 743.034, "end": 745.914, "text": "¿Estamos de acuerdo? Él va a ser el machucapapas de la empresa.", "speaker": null}, {"start": 748.254, "end": 752.914, "text": "Pero yo le diría, ¿te vas a conformar con ser el contador de la empresa?", "speaker": null}, {"start": 752.914, "end": 758.69403, "text": "¿Y por qué no te pones a pensar que tú pudieras ser el dueño de la empresa?", "speaker": null}, {"start": 759.294, "end": 768.294, "text": "Pues aquí te preparamos para que hagas crecer empresas, para que esas empresas florezcan,", "speaker": null}, {"start": 768.294, "end": 777.294, "text": "produzcan, crezcan. ¿Y por qué no pones tu propia empresa? Si te vamos a dar los conocimientos", "speaker": null}, {"start": 777.294, "end": 783.294, "text": "necesarios para que lo hagas. Es lo mismo que yo les digo a ustedes. A ver Charly, ¿para", "speaker": null}, {"start": 783.294, "end": 785.434, "text": "ser licenciado en informática", "speaker": null}, {"start": 785.434, "end": 787.27405, "text": "y ser el machuca papas", "speaker": null}, {"start": 787.27405, "end": 788.334, "text": "del área de sistemas", "speaker": null}, {"start": 788.334, "end": 791.334, "text": "porque no pones", "speaker": null}, {"start": 791.334, "end": 792.794, "text": "una firma de sistemas", "speaker": null}, {"start": 792.794, "end": 794.13403, "text": "y eres", "speaker": null}, {"start": 794.13403, "end": 796.27405, "text": "dueño de la empresa", "speaker": null}, {"start": 796.27405, "end": 799.974, "text": "no crees poder", "speaker": null}, {"start": 799.974, "end": 804.794, "text": "mientras tengas la capacidad", "speaker": null}, {"start": 804.794, "end": 805.994, "text": "de los conocimientos", "speaker": null}, {"start": 805.994, "end": 808.494, "text": "puedes aspirar a ser algo más", "speaker": null}, {"start": 808.494, "end": 809.69403, "text": "que un pinche diablo", "speaker": null}, {"start": 809.69403, "end": 812.934, "text": "disculpenme pero", "speaker": null}, {"start": 812.934, "end": 814.834, "text": "Yo no soy conformista, señoras.", "speaker": null}, {"start": 817.794, "end": 819.274, "text": "Sí, me voy a ir a vender,", "speaker": null}, {"start": 819.434, "end": 820.114, "text": "pero no me voy a vender.", "speaker": null}, {"start": 821.734, "end": 823.174, "text": "Cuando tú seas el empresario,", "speaker": null}, {"start": 823.814, "end": 826.954, "text": "ya no vas a ser el que va a gastar esto.", "speaker": null}, {"start": 827.714, "end": 829.89404, "text": "Vas a ser el que va a leer esto.", "speaker": null}, {"start": 830.774, "end": 831.63403, "text": "A ver cómo va mi negocio,", "speaker": null}, {"start": 831.754, "end": 832.474, "text": "cuántos clientes tenemos,", "speaker": null}, {"start": 832.614, "end": 833.714, "text": "a quién estamos dando soporte,", "speaker": null}, {"start": 834.214, "end": 835.094, "text": "quién nos necesita,", "speaker": null}, {"start": 835.254, "end": 836.63403, "text": "a dónde nos podemos meter,", "speaker": null}, {"start": 836.854, "end": 838.434, "text": "qué les podemos implementar,", "speaker": null}, {"start": 838.51404, "end": 839.434, "text": "qué les podemos vender.", "speaker": null}, {"start": 842.934, "end": 846.674, "text": "hoy la tendencia es que todo se está", "speaker": null}, {"start": 846.674, "end": 848.154, "text": "sistematizando señores", "speaker": null}, {"start": 848.154, "end": 850.89404, "text": "ustedes se ponen en truchas", "speaker": null}, {"start": 850.89404, "end": 852.534, "text": "¿qué puede pasar?", "speaker": null}, {"start": 854.054, "end": 854.734, "text": "ustedes pueden", "speaker": null}, {"start": 854.734, "end": 855.974, "text": "crear su propia empresa", "speaker": null}, {"start": 855.974, "end": 862.734, "text": "o me equivoco", "speaker": null}, {"start": 862.734, "end": 866.754, "text": "o hay empresas que meten", "speaker": null}, {"start": 866.754, "end": 869.174, "text": "hasta ciberseguridad según ellos", "speaker": null}, {"start": 869.174, "end": 874.054, "text": "¿saben lo que cobran los saraganos?", "speaker": null}, {"start": 875.054, "end": 876.094, "text": "billete de torte", "speaker": null}, {"start": 876.094, "end": 878.294, "text": "porque van a decirle", "speaker": null}, {"start": 878.294, "end": 880.154, "text": "Charly, te pueden secuestrar tu información", "speaker": null}, {"start": 880.154, "end": 884.914, "text": "se puede enterar tu sistema", "speaker": null}, {"start": 884.914, "end": 886.594, "text": "y te lo pueden secuestrar", "speaker": null}, {"start": 886.594, "end": 888.254, "text": "¿sabes cuánto te van a pedir para", "speaker": null}, {"start": 888.254, "end": 889.094, "text": "reclutártelo?", "speaker": null}, {"start": 890.154, "end": 891.69403, "text": "yo te puedo", "speaker": null}, {"start": 891.69403, "end": 893.474, "text": "proteger", "speaker": null}, {"start": 893.474, "end": 895.974, "text": "¿o no?", "speaker": null}, {"start": 899.174, "end": 899.69403, "text": "Gracias.", "speaker": null}]