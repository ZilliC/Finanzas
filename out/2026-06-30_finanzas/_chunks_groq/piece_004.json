[{"start": 0.0, "end": 5.2799997, "text": "Hay gente de seguros, yo lo voy a abatear, yo, porque yo soy conozco a usted.", "speaker": null}, {"start": 6.1, "end": 12.059999, "text": "Entonces me dice, no, oiga, pero que, este, si el día de mañana, si algo le pasa a usted,", "speaker": null}, {"start": 12.34, "end": 17.32, "text": "piense en ese señor, si no lo va a tener en paz, si no se preocupa por él,", "speaker": null}, {"start": 17.56, "end": 20.06, "text": "que no se preocupe por él.", "speaker": null}, {"start": 21.359999, "end": 27.22, "text": "Sí, pero bueno, póngale que sí, pues, bueno, usted enjadiza para su navidad, pues, su señora.", "speaker": null}, {"start": 27.22, "end": 30.22, "text": "y yo por qué me voy a preocupar", "speaker": null}, {"start": 30.22, "end": 31.72, "text": "con mis señoras cabrón", "speaker": null}, {"start": 31.72, "end": 34.079998, "text": "qué tal si yo", "speaker": null}, {"start": 34.079998, "end": 36.6, "text": "les dejo a mis viejas", "speaker": null}, {"start": 36.6, "end": 37.059998, "text": "dinero", "speaker": null}, {"start": 37.059998, "end": 40.6, "text": "y el ganón van a ser los anchos", "speaker": null}, {"start": 40.6, "end": 44.36, "text": "cabrón ya los habéis pagado de hacerse", "speaker": null}, {"start": 44.36, "end": 46.48, "text": "no me das la cara", "speaker": null}, {"start": 46.48, "end": 48.0, "text": "yo conozco esto", "speaker": null}, {"start": 48.0, "end": 50.46, "text": "pero bueno hay gente que se hace la", "speaker": null}, {"start": 50.46, "end": 52.899998, "text": "cartuchana que no es malo", "speaker": null}, {"start": 52.899998, "end": 53.82, "text": "siempre es", "speaker": null}, {"start": 53.82, "end": 56.539997, "text": "conveniente estar asegurado", "speaker": null}, {"start": 56.539997, "end": 63.979996, "text": "Esa es la realidad. Porque ahora vamos a verlo en el sentido no de vida, vamos a verlo en el sentido de salud.", "speaker": null}, {"start": 64.2, "end": 69.24, "text": "Hoy hay seguros para gastos médicos, por ejemplo. Vamos a verlo en el seguro de daños.", "speaker": null}, {"start": 70.24, "end": 77.119995, "text": "Ahorita que está lloviendo no es nada imposible que pueda haber un percance automotriz.", "speaker": null}, {"start": 77.899994, "end": 82.5, "text": "Imagínate, le pagas un coche y ¿con qué demonios pagas? Y en ese momento no tienes lana.", "speaker": null}, {"start": 82.5, "end": 85.5, "text": "y si hoy, que es en determinado momento", "speaker": null}, {"start": 85.5, "end": 86.78, "text": "lo que todo el mundo pensaba", "speaker": null}, {"start": 86.78, "end": 89.52, "text": "o lo decimos a nuestros hijos, por ejemplo", "speaker": null}, {"start": 89.52, "end": 90.64, "text": "cuidado", "speaker": null}, {"start": 90.64, "end": 93.5, "text": "el carro, el tuyo", "speaker": null}, {"start": 93.5, "end": 95.48, "text": "lo desbaratas, pero si", "speaker": null}, {"start": 95.48, "end": 97.62, "text": "le pegas a un BMW", "speaker": null}, {"start": 97.62, "end": 99.58, "text": "si le", "speaker": null}, {"start": 99.58, "end": 101.04, "text": "pegas a un Volvo", "speaker": null}, {"start": 101.04, "end": 103.44, "text": "si le pegas", "speaker": null}, {"start": 103.44, "end": 105.659996, "text": "a un Mercedes, con que demonios", "speaker": null}, {"start": 105.659996, "end": 107.58, "text": "pagas, ni con", "speaker": null}, {"start": 107.58, "end": 108.18, "text": "el carro", "speaker": null}, {"start": 108.18, "end": 111.159996, "text": "no, no se rían, saben lo que va", "speaker": null}, {"start": 111.159996, "end": 112.14, "text": "una porquería de esas", "speaker": null}, {"start": 112.14, "end": 114.92, "text": "a lo mejor yo a unas penas tengo", "speaker": null}, {"start": 114.92, "end": 115.899994, "text": "un irruañerito", "speaker": null}, {"start": 115.899994, "end": 119.299995, "text": "y le llegas a dar", "speaker": null}, {"start": 119.299995, "end": 121.03999, "text": "un carro de esos, ni con el carro", "speaker": null}, {"start": 121.03999, "end": 122.74, "text": "pagas, que lo aseguro", "speaker": null}, {"start": 122.74, "end": 124.71999, "text": "porque esas joyitas", "speaker": null}, {"start": 124.71999, "end": 126.2, "text": "no están nada baratas", "speaker": null}, {"start": 126.2, "end": 129.06, "text": "entonces tenemos que ponernos a pensar", "speaker": null}, {"start": 129.06, "end": 131.08, "text": "qué es lo que puede suceder", "speaker": null}, {"start": 131.08, "end": 132.8, "text": "entonces nosotros", "speaker": null}, {"start": 132.8, "end": 133.45999, "text": "en general", "speaker": null}, {"start": 133.45999, "end": 136.45999, "text": "como ustedes tendríamos que", "speaker": null}, {"start": 136.45999, "end": 137.94, "text": "analizar Cristo", "speaker": null}, {"start": 137.94, "end": 140.92, "text": "como lo estamos haciendo y lo vamos haciendo", "speaker": null}, {"start": 140.92, "end": 148.24, "text": "Vamos a dar un luchazo. Esto el programa de ustedes anterior lo marca.", "speaker": null}, {"start": 149.78, "end": 156.04, "text": "Ahora, la pregunta fue, ¿quieren verlo nada más así o quieren verlo en un mundo de nuestros contadores?", "speaker": null}, {"start": 157.84, "end": 158.73999, "text": "¿Cuál es la diferencia?", "speaker": null}, {"start": 159.78, "end": 161.06, "text": "Hay un mundo de diferencia.", "speaker": null}, {"start": 162.81999, "end": 163.4, "text": "Un mundo.", "speaker": null}, {"start": 164.52, "end": 168.02, "text": "Nosotros esto analizamos previamente.", "speaker": null}, {"start": 168.02, "end": 175.65999, "text": "antes de entrar acá, la primera pregunta que se hace en el mundo de nuestra profesión,", "speaker": null}, {"start": 175.65999, "end": 181.68, "text": "digo nuestra profesión, repito, es el escenario que nosotros analizamos, no es necesariamente", "speaker": null}, {"start": 181.68, "end": 188.04, "text": "dispensable para ustedes. Para nosotros sí, repito, porque nosotros tenemos que atender", "speaker": null}, {"start": 188.04, "end": 193.41998, "text": "a los Estados Unidos como parte de nuestros posibles clientes. Nosotros vamos a tener", "speaker": null}, {"start": 193.42, "end": 203.34, "text": "como los clientes, ingenieros, informáticos, médicos, abogados, arquitectos,", "speaker": null}, {"start": 203.58, "end": 210.44, "text": "empresas de distinto giro, comerciales, transformadoras, de servicios, extractivas,", "speaker": null}, {"start": 210.9, "end": 218.08, "text": "tamaños desde un micronegocio hasta una megaempresa sin estrellas,", "speaker": null}, {"start": 218.08, "end": 230.738, "text": "que son las importadoras y exportadoras son las holdings son las empresas transnacionales Entonces yo con ustedes estoy al rev a ustedes se los voy a escoger", "speaker": null}, {"start": 231.33801, "end": 234.518, "text": "a aquellos se los digo lo mínimo que tienes que saber, cabrón, es esto.", "speaker": null}, {"start": 235.67801, "end": 240.978, "text": "Porque si no, ¿cómo demonios vas a atender al charly cuando te llegue a consultar", "speaker": null}, {"start": 240.978, "end": 242.558, "text": "cómo manejar su negocio?", "speaker": null}, {"start": 243.298, "end": 248.078, "text": "Aquí estamos viendo cositas insignificantes, yo hace un rato lo mencioné,", "speaker": null}, {"start": 248.078, "end": 250.478, "text": "los cabronos de ahí de los", "speaker": null}, {"start": 250.478, "end": 252.918, "text": "de los negocios de los hospitales", "speaker": null}, {"start": 252.918, "end": 253.478, "text": "de celulares", "speaker": null}, {"start": 253.478, "end": 256.318, "text": "todo ese tipo de empresitas que abren", "speaker": null}, {"start": 256.318, "end": 257.698, "text": "esa es una empresita", "speaker": null}, {"start": 257.698, "end": 259.358, "text": "relativa", "speaker": null}, {"start": 259.358, "end": 262.21802, "text": "porque ellos te llega el celular", "speaker": null}, {"start": 262.21802, "end": 263.078, "text": "me corriges", "speaker": null}, {"start": 263.078, "end": 266.678, "text": "tienen proveedores ya locales", "speaker": null}, {"start": 266.678, "end": 268.738, "text": "ya saben que se van a la plaza de la computación", "speaker": null}, {"start": 268.738, "end": 270.338, "text": "y ahí a lo mejor consiguen", "speaker": null}, {"start": 270.338, "end": 271.99802, "text": "y si no tienen a lo mejor", "speaker": null}, {"start": 271.99802, "end": 274.778, "text": "ya hay un proveedor específico para cada tipo", "speaker": null}, {"start": 274.778, "end": 275.878, "text": "de componente", "speaker": null}, {"start": 275.878, "end": 278.538, "text": "y si no, a lo mejor el señor se quita", "speaker": null}, {"start": 278.538, "end": 281.178, "text": "de bronca, se mete a más y lo manda a traer", "speaker": null}, {"start": 281.178, "end": 282.758, "text": "a lo mejor", "speaker": null}, {"start": 282.758, "end": 285.198, "text": "que es lo que actualmente hace todo el mundo", "speaker": null}, {"start": 285.198, "end": 286.71802, "text": "pero que pasa si escalamos", "speaker": null}, {"start": 286.71802, "end": 287.798, "text": "al siguiente nivel", "speaker": null}, {"start": 287.798, "end": 290.738, "text": "y el charly no se conforma con eso", "speaker": null}, {"start": 290.738, "end": 293.538, "text": "dice, ¿por qué demonios me voy a limitar a eso?", "speaker": null}, {"start": 294.258, "end": 294.918, "text": "me quito de", "speaker": null}, {"start": 294.918, "end": 295.838, "text": "pendejadas", "speaker": null}, {"start": 295.838, "end": 299.09802, "text": "y yo lo importo directamente", "speaker": null}, {"start": 299.09802, "end": 300.238, "text": "del origen", "speaker": null}, {"start": 300.238, "end": 302.858, "text": "Japón, China", "speaker": null}, {"start": 302.858, "end": 304.118, "text": "Asia", "speaker": null}, {"start": 304.118, "end": 305.818, "text": "Alemania", "speaker": null}, {"start": 305.818, "end": 308.098, "text": "Estados Unidos, Francia", "speaker": null}, {"start": 308.098, "end": 311.638, "text": "ya estás hablando de una empresa", "speaker": null}, {"start": 311.638, "end": 313.278, "text": "de otro nivel", "speaker": null}, {"start": 313.278, "end": 316.398, "text": "y ya el chable como importador", "speaker": null}, {"start": 316.398, "end": 318.598, "text": "va a tener otros requisitos", "speaker": null}, {"start": 318.598, "end": 319.858, "text": "otras necesidades", "speaker": null}, {"start": 319.858, "end": 321.198, "text": "otro conocimiento", "speaker": null}, {"start": 321.198, "end": 324.618, "text": "y ustedes aquí lo ven tirados en la maca", "speaker": null}, {"start": 324.618, "end": 326.178, "text": "creen que eso no pasa", "speaker": null}, {"start": 326.178, "end": 328.278, "text": "yo se los pongo a mis alumnos", "speaker": null}, {"start": 328.278, "end": 330.458, "text": "de ejemplo y sobre todo a los pinches", "speaker": null}, {"start": 330.458, "end": 332.438, "text": "ingenieros porque ahí ya no somos contadores", "speaker": null}, {"start": 332.438, "end": 334.21802, "text": "somos ingenieros", "speaker": null}, {"start": 334.21802, "end": 335.418, "text": "quien más la está causando", "speaker": null}, {"start": 335.418, "end": 344.818, "text": "¿Por qué? Porque los ingenieros son los que están destinados a la industria, a los procesos, a la innovación, a la tecnología.", "speaker": null}, {"start": 346.018, "end": 349.838, "text": "Ustedes por lo menos están del lado del software.", "speaker": null}, {"start": 350.838, "end": 352.278, "text": "Aquí los informantes.", "speaker": null}, {"start": 353.378, "end": 353.838, "text": "¿Están de acuerdo?", "speaker": null}, {"start": 357.018, "end": 360.73798, "text": "En mi casa, yo doy clases para ingenieros.", "speaker": null}, {"start": 361.73798, "end": 364.458, "text": "Ellos están guiados al hardware.", "speaker": null}, {"start": 365.418, "end": 372.418, "text": "Entonces, ellos constantemente están sobre los avances tecnológicos, ellos constantemente", "speaker": null}, {"start": 372.418, "end": 379.418, "text": "están sobre la innovación, ellos constantemente están, oiga, necesito hacer ahora un teléfono", "speaker": null}, {"start": 379.418, "end": 387.418, "text": "de pantalla curva y en México ¿hay pantallas curvas? Ni dónde, por supuesto que no, es", "speaker": null}, {"start": 387.418, "end": 391.418, "text": "más, ni siquiera las inventaron aquí en México.", "speaker": null}, {"start": 391.418, "end": 400.65802, "text": "Pero en China sí, en Japón sí, y yo lo voy a traer porque yo voy a ser de los pioneros", "speaker": null}, {"start": 400.65802, "end": 410.71802, "text": "aquí en China. Los que ahora se doblan, yo traigo esa bronca con algunos ingenieros,", "speaker": null}, {"start": 410.878, "end": 417.778, "text": "no porque se dediquen a la telefonía, sino porque son proveedores de los gabinetes, bueno,", "speaker": null}, {"start": 417.778, "end": 419.778, "text": "en el gabinete, la armazón.", "speaker": null}, {"start": 420.998, "end": 422.278, "text": "Entonces, ellos tienen que ver", "speaker": null}, {"start": 422.278, "end": 424.05798, "text": "los modelos de flexibilidad,", "speaker": null}, {"start": 424.418, "end": 425.198, "text": "el material,", "speaker": null}, {"start": 425.998, "end": 427.298, "text": "la durabilidad,", "speaker": null}, {"start": 428.138, "end": 430.138, "text": "qué índices son resistentes al agua,", "speaker": null}, {"start": 430.298, "end": 431.758, "text": "qué es irresistente al óxido,", "speaker": null}, {"start": 431.878, "end": 434.55798, "text": "qué es irresistente al sol, qué es irresistente al calor,", "speaker": null}, {"start": 435.298, "end": 436.098, "text": "cosas como eso.", "speaker": null}, {"start": 436.098, "end": 437.638, "text": "Porque son ingeniosos.", "speaker": null}, {"start": 438.458, "end": 439.998, "text": "Se me equivocó. Ellos analizan todo eso.", "speaker": null}, {"start": 441.258, "end": 442.238, "text": "Y ellos de repente me hablan", "speaker": null}, {"start": 442.238, "end": 443.818, "text": "oigan, oigan, oigan, tengo una bronca.", "speaker": null}, {"start": 444.61798, "end": 454.836, "text": "Que acabo de ver que en Suecia est manejando esto probabilidad hay de que lo importemos", "speaker": null}, {"start": 456.056, "end": 459.35602, "text": "¡Uta madre! Esperan, pero ¿de qué en Chicago se suele decir?", "speaker": null}, {"start": 459.536, "end": 461.45602, "text": "No, no podemos decirles eso.", "speaker": null}, {"start": 462.376, "end": 465.45602, "text": "Entonces, que sí se puede, pero ahí se maneja contra el grado de origen.", "speaker": null}, {"start": 465.696, "end": 469.23602, "text": "Necesitamos verificar si tenemos tratados internacionales con ellos,", "speaker": null}, {"start": 469.79602, "end": 472.976, "text": "tenemos que verificar la documentación que se va a requerir,", "speaker": null}, {"start": 472.976, "end": 475.376, "text": "necesitamos ver su clasificación", "speaker": null}, {"start": 475.376, "end": 477.196, "text": "arancelaria, ¿para qué?", "speaker": null}, {"start": 477.256, "end": 479.276, "text": "para que veas si te conviene traerlo", "speaker": null}, {"start": 479.276, "end": 480.91602, "text": "¿por qué? ¿qué pasa?", "speaker": null}, {"start": 481.85602, "end": 483.01602, "text": "te puede salir más caro", "speaker": null}, {"start": 483.01602, "end": 485.316, "text": "el caldo que las albúrquicas", "speaker": null}, {"start": 485.316, "end": 487.496, "text": "hoy en materia de importaciones", "speaker": null}, {"start": 487.496, "end": 489.23602, "text": "y exportaciones, yo te puedo decir que yo", "speaker": null}, {"start": 489.23602, "end": 491.536, "text": "tengo clientes que importan", "speaker": null}, {"start": 491.536, "end": 493.376, "text": "productos y nos sale más caro", "speaker": null}, {"start": 494.116, "end": 495.91602, "text": "traerlo que el producto", "speaker": null}, {"start": 495.91602, "end": 498.536, "text": "sí, claro", "speaker": null}, {"start": 498.536, "end": 500.656, "text": "los gastos banales", "speaker": null}, {"start": 500.656, "end": 504.056, "text": "el tipo de", "speaker": null}, {"start": 504.056, "end": 507.23602, "text": "de medio que ocupas", "speaker": null}, {"start": 507.23602, "end": 510.17603, "text": "no es lo mismo lo que me cuesta traer una cosa por barco", "speaker": null}, {"start": 510.17603, "end": 511.91602, "text": "que me va a llegar en tres meses", "speaker": null}, {"start": 511.91602, "end": 513.556, "text": "para que si la mando por avión", "speaker": null}, {"start": 513.556, "end": 515.956, "text": "me llegue al mismo día", "speaker": null}, {"start": 515.956, "end": 517.876, "text": "pero cuánto me cuesta", "speaker": null}, {"start": 517.876, "end": 520.416, "text": "¿si me explico?", "speaker": null}, {"start": 520.876, "end": 522.836, "text": "todo eso lo evaluamos nosotros", "speaker": null}, {"start": 522.836, "end": 524.976, "text": "pues decía ustedes en ese sentido", "speaker": null}, {"start": 524.976, "end": 527.516, "text": "no requiere meterse tan profundamente", "speaker": null}, {"start": 527.516, "end": 529.576, "text": "pero depende también", "speaker": null}, {"start": 529.576, "end": 530.81604, "text": "cuando hace su segmento.", "speaker": null}, {"start": 531.31604, "end": 533.356, "text": "A lo mejor yo ahora me puedo poner de lado de Carlos", "speaker": null}, {"start": 533.356, "end": 535.81604, "text": "y le puedo decir a Carlos, sería conveniente", "speaker": null}, {"start": 535.81604, "end": 537.416, "text": "que le sepas, claro, porque puedes tener", "speaker": null}, {"start": 537.416, "end": 539.036, "text": "clientes de esto, de esto, de esto.", "speaker": null}, {"start": 539.036, "end": 541.416, "text": "Entonces, informático sí, pero ya sabes", "speaker": null}, {"start": 541.416, "end": 543.336, "text": "específicamente a qué tipo de", "speaker": null}, {"start": 543.336, "end": 545.49603, "text": "equipo, a qué tipo de empresa vas a caer a trabajar.", "speaker": null}, {"start": 546.236, "end": 547.236, "text": "Si no lo sabes,", "speaker": null}, {"start": 547.856, "end": 549.276, "text": "entonces tú tienes que estar abierto porque", "speaker": null}, {"start": 549.276, "end": 551.636, "text": "cualquiera que llegues, te va a exigir", "speaker": null}, {"start": 551.636, "end": 552.216, "text": "diferente.", "speaker": null}, {"start": 553.31604, "end": 555.136, "text": "Entonces, entre más capacidad tengas,", "speaker": null}, {"start": 555.236, "end": 557.296, "text": "más posibilidades tienes de colocarte.", "speaker": null}, {"start": 558.416, "end": 559.256, "text": "¿Sí me explico?", "speaker": null}, {"start": 559.576, "end": 561.19604, "text": "y lo que les puedo decir", "speaker": null}, {"start": 561.19604, "end": 562.156, "text": "yo necesito ahorita", "speaker": null}, {"start": 562.156, "end": 563.93604, "text": "una hipótesis", "speaker": null}, {"start": 563.93604, "end": 564.836, "text": "un hijo", "speaker": null}, {"start": 564.836, "end": 567.916, "text": "que se maneje", "speaker": null}, {"start": 567.916, "end": 574.056, "text": "y lo requiero para su orden", "speaker": null}, {"start": 574.056, "end": 575.796, "text": "no para que te hagan el oráculo", "speaker": null}, {"start": 575.796, "end": 577.49603, "text": "porque el oráculo ya existe", "speaker": null}, {"start": 577.49603, "end": 579.656, "text": "yo te agradezco", "speaker": null}, {"start": 579.656, "end": 580.396, "text": "que muchos de ustedes", "speaker": null}, {"start": 580.396, "end": 581.296, "text": "necesiten el oráculo", "speaker": null}, {"start": 581.296, "end": 584.296, "text": "son parte de los sistemas", "speaker": null}, {"start": 584.296, "end": 585.81604, "text": "más naturales que hay", "speaker": null}, {"start": 585.81604, "end": 587.536, "text": "eso es una tía correal", "speaker": null}, {"start": 587.536, "end": 588.676, "text": "a nivel global", "speaker": null}, {"start": 588.676, "end": 591.216, "text": "y te lo digo porque yo trabajo con ellos", "speaker": null}, {"start": 591.216, "end": 594.036, "text": "y a veces los sistemas", "speaker": null}, {"start": 594.036, "end": 595.516, "text": "están pariendo chayotes", "speaker": null}, {"start": 595.516, "end": 598.276, "text": "donde tienen que verificar la conectividad", "speaker": null}, {"start": 598.276, "end": 600.276, "text": "con Europa, con Asia", "speaker": null}, {"start": 600.276, "end": 601.716, "text": "con Estados Unidos", "speaker": null}, {"start": 601.716, "end": 603.31604, "text": "que es diferente, no es que eran libres", "speaker": null}, {"start": 603.31604, "end": 605.876, "text": "pero también son enchiladas que no tienen que armonizar", "speaker": null}, {"start": 605.876, "end": 606.956, "text": "con ellos", "speaker": null}, {"start": 606.956, "end": 608.356, "text": "no estás tu chamba", "speaker": null}, {"start": 608.356, "end": 611.076, "text": "pero yo lo necesito para mi clima", "speaker": null}, {"start": 611.076, "end": 613.336, "text": "así es de que si no duermes", "speaker": null}, {"start": 613.336, "end": 615.536, "text": "con catuleta y la pasas todo el mes echado", "speaker": null}, {"start": 615.536, "end": 617.516, "text": "y cuando menos una noche que chamezca", "speaker": null}, {"start": 617.516, "end": 622.756, "text": "Si me explico o me equivoco, me voy a echar.", "speaker": null}, {"start": 626.496, "end": 629.116, "text": "Entonces, ¿quieren ver más o menos el mensaje de todo eso o no?", "speaker": null}, {"start": 629.756, "end": 631.176, "text": "Como quieran, a mí me dan un libro.", "speaker": null}, {"start": 631.676, "end": 632.536, "text": "Repito, para ustedes.", "speaker": null}, {"start": 633.956, "end": 635.716, "text": "Y aquí también, esto también.", "speaker": null}, {"start": 638.276, "end": 644.656, "text": "Nada más que tenemos que ver un poquito más de parte de conocimientos.", "speaker": null}, {"start": 644.656, "end": 651.456, "text": "Y no son conocimientos que tengan una grave dificultad.", "speaker": null}, {"start": 653.016, "end": 656.736, "text": "Son conocimientos que estamos obligados, yo se lo digo a mi salud.", "speaker": null}, {"start": 657.396, "end": 659.81604, "text": "Usted ya debería saber esto sin que yo se lo enseñe.", "speaker": null}, {"start": 660.136, "end": 661.876, "text": "Usted vive con eso todos los días.", "speaker": null}, {"start": 668.556, "end": 683.254, "text": "Ok entonces vamos a ver Bueno lo primero en lo que comenzamos a mis alumnos les pido el queique porque muchos de ellos est por all comiendo camote", "speaker": null}, {"start": 683.254, "end": 684.614, "text": "¿Qué es eso?", "speaker": null}, {"start": 684.914, "end": 692.07404, "text": "Y los que normalmente si vienen despiertos, lo primero que te preguntan, oiga, ¿cómo que hay un error?", "speaker": null}, {"start": 693.63403, "end": 695.07404, "text": "A ver, Charlie, ¿por qué hay un error?", "speaker": null}, {"start": 695.07404, "end": 704.234, "text": "Pues sí, porque se supone que esto es el sistema financiero mexicano.", "speaker": null}, {"start": 705.374, "end": 712.874, "text": "Y cuando hablamos del sistema financiero mexicano, yo puedo entender que se manejan recursos financieros y alineo.", "speaker": null}, {"start": 714.474, "end": 722.89404, "text": "Lo primero que preguntan aquellos chavos es, oiga, ¿y qué tiene que ver Hacienda con el sistema financiero?", "speaker": null}, {"start": 722.89404, "end": 725.174, "text": "porque así la", "speaker": null}, {"start": 725.174, "end": 726.63403, "text": "se aboca", "speaker": null}, {"start": 726.63403, "end": 730.054, "text": "al número fiscal", "speaker": null}, {"start": 730.054, "end": 732.934, "text": "o sea, de impuestos", "speaker": null}, {"start": 732.934, "end": 737.754, "text": "y de este lado", "speaker": null}, {"start": 737.754, "end": 739.57404, "text": "en la parte", "speaker": null}, {"start": 739.57404, "end": 742.754, "text": "financiera", "speaker": null}, {"start": 742.754, "end": 745.254, "text": "es como que no me checan", "speaker": null}, {"start": 745.254, "end": 747.934, "text": "que tiene que ver una cosa con otra", "speaker": null}, {"start": 747.934, "end": 749.95404, "text": "a mi chavo", "speaker": null}, {"start": 749.95404, "end": 751.63403, "text": "desde ahorita que está usted", "speaker": null}, {"start": 751.63403, "end": 753.914, "text": "tal como está, usted es un perfecto", "speaker": null}, {"start": 753.914, "end": 754.834, "text": "director ámbito.", "speaker": null}, {"start": 757.19403, "end": 757.994, "text": "¿Por qué?", "speaker": null}, {"start": 759.154, "end": 760.374, "text": "Porque cuando hablamos", "speaker": null}, {"start": 760.374, "end": 762.334, "text": "del mundo fiscal,", "speaker": null}, {"start": 763.354, "end": 764.19403, "text": "vamos a ver que", "speaker": null}, {"start": 764.19403, "end": 766.13403, "text": "Hacienda, efectivamente, es el lugar", "speaker": null}, {"start": 766.13403, "end": 768.214, "text": "donde se puede presentar la función de Hacienda.", "speaker": null}, {"start": 768.77405, "end": 770.51404, "text": "Porque tiene más funciones", "speaker": null}, {"start": 770.51404, "end": 772.63403, "text": "financieras que fiscales.", "speaker": null}, {"start": 773.39404, "end": 774.554, "text": "Que la generalidad", "speaker": null}, {"start": 774.554, "end": 775.234, "text": "de la gente", "speaker": null}, {"start": 775.234, "end": 778.334, "text": "conoce Hacienda por los fiscales", "speaker": null}, {"start": 778.334, "end": 779.89404, "text": "o por los impuestos es diferente.", "speaker": null}, {"start": 779.89404, "end": 790.154, "text": "Pero normalmente aquí no es Hacienda, aquí es el SAD, que es el Sistema de Administración Tributaria.", "speaker": null}, {"start": 791.814, "end": 803.474, "text": "¿Por qué razón? Porque Hacienda pasa a ser una de las dependencias públicas, una de las secretarías de Estado más importantes de este país.", "speaker": null}, {"start": 803.474, "end": 806.094, "text": "aunque ustedes no lo creen", "speaker": null}, {"start": 806.094, "end": 807.63403, "text": "¿por qué razón?", "speaker": null}, {"start": 808.27405, "end": 810.01404, "text": "vamos a verlo rápido", "speaker": null}, {"start": 810.01404, "end": 811.19403, "text": "lo más rápido que se pueda", "speaker": null}, {"start": 811.19403, "end": 814.034, "text": "digo, con la intención de que ustedes tengan", "speaker": null}, {"start": 814.034, "end": 816.594, "text": "una idea más específica", "speaker": null}, {"start": 816.594, "end": 816.994, "text": "de esto", "speaker": null}, {"start": 816.994, "end": 820.294, "text": "si nosotros quisiéramos analizar", "speaker": null}, {"start": 820.294, "end": 822.334, "text": "¿por qué demonios", "speaker": null}, {"start": 822.334, "end": 824.054, "text": "tenemos esta naturaleza", "speaker": null}, {"start": 824.054, "end": 825.474, "text": "que tiene tanto poder?", "speaker": null}, {"start": 826.234, "end": 827.19403, "text": "esto es insuficiente", "speaker": null}, {"start": 827.19403, "end": 829.874, "text": "podríamos tener que empezar a hacerlo", "speaker": null}, {"start": 829.874, "end": 832.314, "text": "de una manera insuficiente", "speaker": null}, {"start": 832.314, "end": 835.174, "text": "sabemos que nosotros aquí", "speaker": null}, {"start": 835.174, "end": 838.874, "text": "en este país", "speaker": null}, {"start": 838.874, "end": 846.01404, "text": "habemos más de", "speaker": null}, {"start": 846.01404, "end": 849.594, "text": "120 millones de cristianos", "speaker": null}, {"start": 849.594, "end": 851.534, "text": "es correcto", "speaker": null}, {"start": 851.534, "end": 855.034, "text": "es decir, en el mundo terrenal", "speaker": null}, {"start": 855.034, "end": 857.594, "text": "hay muchos", "speaker": null}, {"start": 857.594, "end": 859.674, "text": "se acuerdan que", "speaker": null}, {"start": 859.674, "end": 861.374, "text": "platicábamos en el repaso", "speaker": null}, {"start": 861.374, "end": 868.19403, "text": "que no podemos identificar a Carlos, no tenemos necesidad de identificar a Miguel, no tenemos", "speaker": null}, {"start": 868.19403, "end": 875.314, "text": "necesidad de identificar a Pedro, a Chucho, a Lúbio, porque para esto ya tengo la forma", "speaker": null}, {"start": 875.314, "end": 884.454, "text": "de identificación, pero hace el mundo de personas físicas y personas que hacen de", "speaker": null}, {"start": 884.454, "end": 887.214, "text": "Pero estos están en el mismo terreno.", "speaker": null}, {"start": 888.474, "end": 894.234, "text": "Todos estos, obviamente, van a depender y van a tener que coaccionar con alguien.", "speaker": null}, {"start": 895.054, "end": 896.614, "text": "Ese alguien es el que está acá arriba.", "speaker": null}, {"start": 898.074, "end": 899.69403, "text": "Es el gobierno.", "speaker": null}]