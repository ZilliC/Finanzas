[{"start": 0.0, "end": 4.0, "text": "Nuevamente, la gente de hechos.", "speaker": null}, {"start": 4.0, "end": 10.0, "text": "Quiere decir que ahora no se conformaron con poder modificar las leyes,", "speaker": null}, {"start": 10.0, "end": 14.0, "text": "sino que ahora ya tienen a la Suprema Corte de Justicia.", "speaker": null}, {"start": 14.0, "end": 22.0, "text": "Y tan no lograron hacerlo, que ya dentro de los primeros ordenamientos de violación de la Corte", "speaker": null}, {"start": 22.0, "end": 25.96, "text": "que fue avalar la desaparición de quién?", "speaker": null}, {"start": 27.16, "end": 28.68, "text": "Del derecho de amparo.", "speaker": null}, {"start": 29.9, "end": 33.76, "text": "El derecho de amparo era algo que teníamos todos los ciudadanos", "speaker": null}, {"start": 33.76, "end": 40.1, "text": "para protegernos e inconformarnos de actos de las autoridades.", "speaker": null}, {"start": 42.76, "end": 46.96, "text": "Hoy por hoy ya no tienen ustedes ese beneficio,", "speaker": null}, {"start": 46.96, "end": 49.579998, "text": "lo cual indica a Jóvenes", "speaker": null}, {"start": 49.579998, "end": 51.239998, "text": "que así", "speaker": null}, {"start": 51.239998, "end": 53.3, "text": "libre y llanamente", "speaker": null}, {"start": 53.3, "end": 55.28, "text": "su pie es claro", "speaker": null}, {"start": 55.28, "end": 58.32, "text": "no hay quien le amarre las manos", "speaker": null}, {"start": 58.32, "end": 61.76, "text": "por eso está haciendo y deshaciendo", "speaker": null}, {"start": 61.76, "end": 63.5, "text": "lo que se le da su real", "speaker": null}, {"start": 63.5, "end": 64.479996, "text": "y regalará", "speaker": null}, {"start": 64.479996, "end": 67.28, "text": "y dije", "speaker": null}, {"start": 67.28, "end": 69.34, "text": "eso comenzó con una inconformidad", "speaker": null}, {"start": 69.34, "end": 70.36, "text": "personal", "speaker": null}, {"start": 70.36, "end": 72.84, "text": "porque yo sí entiendo lo que está pasando", "speaker": null}, {"start": 72.84, "end": 74.52, "text": "a diferencia de muchos de ustedes", "speaker": null}, {"start": 74.52, "end": 76.68, "text": "pasó", "speaker": null}, {"start": 76.68, "end": 79.840004, "text": "a una inconformidad social.", "speaker": null}, {"start": 80.46, "end": 82.7, "text": "Lo estamos viendo ahorita, ¿verdad?", "speaker": null}, {"start": 83.1, "end": 84.74, "text": "Segmentado, pero lo estamos viendo.", "speaker": null}, {"start": 85.66, "end": 88.5, "text": "¿A través de qué? De las manifestaciones.", "speaker": null}, {"start": 89.64, "end": 91.76, "text": "¿Cómo es posible que el propio Poder Judicial", "speaker": null}, {"start": 91.76, "end": 94.08, "text": "se está manifestando en contra del gobierno", "speaker": null}, {"start": 94.08, "end": 96.26, "text": "y siendo que es parte del gobierno?", "speaker": null}, {"start": 97.36, "end": 100.22, "text": "Porque ya se dieron cuenta que es excesivo el abuso", "speaker": null}, {"start": 100.22, "end": 102.5, "text": "que se está decretando por parte del gobierno.", "speaker": null}, {"start": 102.5, "end": 104.74, "text": "tal es así", "speaker": null}, {"start": 104.74, "end": 107.16, "text": "que el mismo peje se cubrió", "speaker": null}, {"start": 107.16, "end": 110.74, "text": "y desde que el peje entró", "speaker": null}, {"start": 110.74, "end": 113.32, "text": "cambió todas las normas", "speaker": null}, {"start": 113.32, "end": 114.8, "text": "en lo que respecta", "speaker": null}, {"start": 114.8, "end": 116.1, "text": "no nada más al poder ruso", "speaker": null}, {"start": 116.1, "end": 117.48, "text": "y se lo hizo esclavo", "speaker": null}, {"start": 117.48, "end": 119.64, "text": "pero él la brindó", "speaker": null}, {"start": 119.64, "end": 121.5, "text": "porque si no lo sabía", "speaker": null}, {"start": 121.5, "end": 123.18, "text": "¿quién puso a la esclava?", "speaker": null}, {"start": 125.88, "end": 127.18, "text": "dicen la sociedad", "speaker": null}, {"start": 127.18, "end": 127.86, "text": "¿no es cierto?", "speaker": null}, {"start": 128.8, "end": 129.14, "text": "la puso", "speaker": null}, {"start": 129.14, "end": 135.28, "text": "y se blindó él y la blindó ella.", "speaker": null}, {"start": 137.06, "end": 140.78, "text": "Señores, si no se han dado cuenta, desde el sexenio mediante anterior,", "speaker": null}, {"start": 142.22, "end": 147.22, "text": "todas las policías de este país se militarizaron.", "speaker": null}, {"start": 148.8, "end": 149.62, "text": "¿Por qué?", "speaker": null}, {"start": 150.72, "end": 156.0, "text": "Porque de conformidad con el 27 y otros ordenamientos de la Ley Orgánica", "speaker": null}, {"start": 156.0, "end": 157.58, "text": "de la Administración Pública Federal,", "speaker": null}, {"start": 157.58, "end": 159.48, "text": "casualmente", "speaker": null}, {"start": 159.48, "end": 161.84, "text": "quién es el organismo", "speaker": null}, {"start": 161.84, "end": 164.76, "text": "que impone el gobierno", "speaker": null}, {"start": 164.76, "end": 166.64, "text": "para imponer", "speaker": null}, {"start": 166.64, "end": 167.34, "text": "orden", "speaker": null}, {"start": 167.34, "end": 170.38, "text": "las fuerzas militares", "speaker": null}, {"start": 170.38, "end": 173.52, "text": "ni así las policías", "speaker": null}, {"start": 173.52, "end": 176.04001, "text": "pero él cuidadosamente", "speaker": null}, {"start": 176.04001, "end": 177.84, "text": "fue muy cauteloso", "speaker": null}, {"start": 177.84, "end": 180.62, "text": "y desde el sexenio pasado", "speaker": null}, {"start": 180.62, "end": 182.3, "text": "todas las policías", "speaker": null}, {"start": 182.3, "end": 183.34, "text": "comenzaron con", "speaker": null}, {"start": 183.34, "end": 185.74, "text": "no militarizarse completamente", "speaker": null}, {"start": 185.74, "end": 189.31999, "text": "pero les empezaron a cambiar los mandos", "speaker": null}, {"start": 189.31999, "end": 191.56, "text": "desde el sexenio pasado", "speaker": null}, {"start": 191.56, "end": 193.37999, "text": "todos los mandos policiales", "speaker": null}, {"start": 193.37999, "end": 194.45999, "text": "fueron militares", "speaker": null}, {"start": 194.45999, "end": 196.71999, "text": "para este sexenio", "speaker": null}, {"start": 196.71999, "end": 199.68, "text": "todas sin excepción", "speaker": null}, {"start": 199.68, "end": 201.68, "text": "son militares", "speaker": null}, {"start": 201.68, "end": 203.91998, "text": "tan es así que fue la creación", "speaker": null}, {"start": 203.91998, "end": 205.23999, "text": "de la Guardia Nacional", "speaker": null}, {"start": 205.23999, "end": 207.59999, "text": "y si ustedes se dan cuenta", "speaker": null}, {"start": 207.59999, "end": 209.05998, "text": "la Guardia Nacional", "speaker": null}, {"start": 209.05998, "end": 211.62, "text": "¿quién la representa?", "speaker": null}, {"start": 212.45999, "end": 213.05998, "text": "¿el futuro?", "speaker": null}, {"start": 214.27998, "end": 215.27998, "text": "los militares", "speaker": null}, {"start": 215.28, "end": 219.78, "text": "¿Qué tiene de malo que sean militares?", "speaker": null}, {"start": 220.66, "end": 232.998, "text": "Bueno j si ustedes desconocen c funciona el sistema como este y si quieren ahorita hablamos de eso de ustedes tiene alg familiar que sea militar", "speaker": null}, {"start": 234.378, "end": 235.698, "text": "¿Conocen a algún militar?", "speaker": null}, {"start": 237.858, "end": 238.53801, "text": "No.", "speaker": null}, {"start": 239.39801, "end": 242.25801, "text": "Los chavos no están obligados.", "speaker": null}, {"start": 243.518, "end": 245.61801, "text": "¿Saben cómo funciona el sistema militar?", "speaker": null}, {"start": 247.098, "end": 247.738, "text": "Tampoco.", "speaker": null}, {"start": 250.018, "end": 252.438, "text": "Cuando tengan oportunidad, chequeenlo.", "speaker": null}, {"start": 253.778, "end": 256.978, "text": "Pero los militares tienen una educación diferente a nosotros.", "speaker": null}, {"start": 258.118, "end": 262.49802, "text": "¿Cómo se le llama a la educación que tienen los militares?", "speaker": null}, {"start": 266.958, "end": 267.838, "text": "Castrense.", "speaker": null}, {"start": 268.518, "end": 269.778, "text": "¿Han escuchado ese término?", "speaker": null}, {"start": 272.058, "end": 272.898, "text": "No.", "speaker": null}, {"start": 273.778, "end": 275.118, "text": "Entonces olvidenlo.", "speaker": null}, {"start": 275.118, "end": 275.358, "text": "¿Cómo se le llama a los militares?", "speaker": null}, {"start": 275.978, "end": 277.198, "text": "¿Cómo se le llama a los militares?", "speaker": null}, {"start": 277.198, "end": 280.558, "text": "como resumen", "speaker": null}, {"start": 280.558, "end": 281.018, "text": "nada más", "speaker": null}, {"start": 281.018, "end": 283.178, "text": "el único comentario que voy a hacer señores", "speaker": null}, {"start": 283.178, "end": 285.458, "text": "cuando vengan a la comunidad cheque", "speaker": null}, {"start": 285.458, "end": 287.238, "text": "con su hijo, con alguna", "speaker": null}, {"start": 287.238, "end": 289.538, "text": "de sus hijos, con su familia", "speaker": null}, {"start": 289.538, "end": 292.058, "text": "como funciona", "speaker": null}, {"start": 292.058, "end": 293.398, "text": "el sistema militar", "speaker": null}, {"start": 293.398, "end": 295.638, "text": "y el sistema militar", "speaker": null}, {"start": 295.638, "end": 296.178, "text": "jóvenes", "speaker": null}, {"start": 296.178, "end": 298.858, "text": "a estas personas", "speaker": null}, {"start": 298.858, "end": 301.978, "text": "las educan diferente que a nosotros", "speaker": null}, {"start": 301.978, "end": 303.238, "text": "a ellos los educan", "speaker": null}, {"start": 303.238, "end": 305.738, "text": "para recibir órdenes", "speaker": null}, {"start": 305.738, "end": 308.338, "text": "ellos no cuestionan", "speaker": null}, {"start": 308.338, "end": 310.418, "text": "nunca una orden", "speaker": null}, {"start": 310.418, "end": 314.738, "text": "tú si a un militar le dices", "speaker": null}, {"start": 314.738, "end": 316.678, "text": "ven, mata a tu madre, vaya, mata", "speaker": null}, {"start": 316.678, "end": 319.198, "text": "porque está educado", "speaker": null}, {"start": 319.198, "end": 320.398, "text": "para recibir", "speaker": null}, {"start": 320.398, "end": 321.278, "text": "orden", "speaker": null}, {"start": 321.278, "end": 324.398, "text": "tú a un policía", "speaker": null}, {"start": 324.398, "end": 326.198, "text": "ven, manda a tu madre", "speaker": null}, {"start": 326.198, "end": 328.778, "text": "y te va a decir primero que mata a tu madre", "speaker": null}, {"start": 328.778, "end": 330.878, "text": "para mi madre no la toques", "speaker": null}, {"start": 330.878, "end": 333.938, "text": "¿qué es lo que hicieron?", "speaker": null}, {"start": 333.938, "end": 336.038, "text": "ni vitalizarlo ya", "speaker": null}, {"start": 336.038, "end": 337.738, "text": "malpensas", "speaker": null}, {"start": 337.738, "end": 339.698, "text": "¿por qué razón?", "speaker": null}, {"start": 340.938, "end": 342.15802, "text": "porque tienen el control", "speaker": null}, {"start": 342.15802, "end": 343.838, "text": "porque tienen el control", "speaker": null}, {"start": 343.838, "end": 345.538, "text": "y están pidiendo", "speaker": null}, {"start": 345.538, "end": 349.15802, "text": "que la sociedad se pueda levantar", "speaker": null}, {"start": 349.15802, "end": 350.59802, "text": "y si se llega a levantar", "speaker": null}, {"start": 350.59802, "end": 353.238, "text": "¿con quién lo van a aplacar?", "speaker": null}, {"start": 353.778, "end": 356.198, "text": "con las fuerzas militares", "speaker": null}, {"start": 356.198, "end": 358.498, "text": "por eso si se dan cuenta", "speaker": null}, {"start": 358.498, "end": 360.638, "text": "hoy ya no nada más tenemos las policías", "speaker": null}, {"start": 360.638, "end": 363.21802, "text": "hoy tenemos", "speaker": null}, {"start": 363.21802, "end": 371.838, "text": "que los aeropuertos, los centros marinos, las carreteras, etc.", "speaker": null}, {"start": 372.698, "end": 375.778, "text": "Casualmente hace tres semanas a la Guardia Nacional", "speaker": null}, {"start": 375.778, "end": 376.998, "text": "le dieron nuevos atributos.", "speaker": null}, {"start": 378.178, "end": 379.818, "text": "¿Y esos nuevos atributos cuáles fueron?", "speaker": null}, {"start": 379.818, "end": 383.818, "text": "Ya no nada más te van a regular el tráfico carretero.", "speaker": null}, {"start": 384.998, "end": 389.678, "text": "Ahora te pueden sancionar, te pueden revisar.", "speaker": null}, {"start": 389.678, "end": 401.058, "text": "Hoy son hasta peritos y técnicos al grado que está, chécate lo del internet, chécate lo de la ley, chécate lo de las redes sociales.", "speaker": null}, {"start": 402.03802, "end": 411.018, "text": "Hoy ya no les puedes ni siquiera discutir porque tienen facultades para detenerte y presentarte a los amparos.", "speaker": null}, {"start": 411.018, "end": 415.738, "text": "y para acabar la demora", "speaker": null}, {"start": 415.738, "end": 417.458, "text": "no nada más para el nivel general", "speaker": null}, {"start": 417.458, "end": 419.078, "text": "porque la Guardia Nacional", "speaker": null}, {"start": 419.078, "end": 420.018, "text": "es de educación federal", "speaker": null}, {"start": 420.018, "end": 423.838, "text": "tu otra tía", "speaker": null}, {"start": 423.838, "end": 426.298, "text": "¿quién es tu otra tía?", "speaker": null}, {"start": 428.03802, "end": 428.858, "text": "es tu comadre", "speaker": null}, {"start": 428.858, "end": 429.55798, "text": "la abogada", "speaker": null}, {"start": 429.55798, "end": 432.53802, "text": "les acaba de dar facultades", "speaker": null}, {"start": 432.53802, "end": 434.358, "text": "aquí en CDMX", "speaker": null}, {"start": 434.358, "end": 436.618, "text": "hasta la PBI", "speaker": null}, {"start": 436.618, "end": 438.678, "text": "para poder sancionar", "speaker": null}, {"start": 438.678, "end": 443.138, "text": "Fíjate en dónde estamos parados", "speaker": null}, {"start": 443.138, "end": 454.476, "text": "Ya listo estamos en llegar al coto de poder Hasta ahorita los que est poniendo orden son los Estados Unidos", "speaker": null}, {"start": 455.29602, "end": 458.876, "text": "Porque los Estados Unidos ya detectaron que tenemos un arco móvil.", "speaker": null}, {"start": 460.276, "end": 466.996, "text": "Mandó una lista de 10, de los cuales un día aquí, llamando para allá.", "speaker": null}, {"start": 468.336, "end": 468.756, "text": "A ninguna.", "speaker": null}, {"start": 470.616, "end": 473.756, "text": "A excepción de dos que se presentaron por su propia voluntad.", "speaker": null}, {"start": 473.756, "end": 477.436, "text": "¿por qué? porque van como testigos protegidos", "speaker": null}, {"start": 477.436, "end": 480.776, "text": "yo no sé", "speaker": null}, {"start": 480.776, "end": 481.756, "text": "qué espera esta mujer", "speaker": null}, {"start": 481.756, "end": 484.276, "text": "pero hay que ustedes", "speaker": null}, {"start": 484.276, "end": 486.096, "text": "si no se dan cuenta de todo esto", "speaker": null}, {"start": 486.096, "end": 487.656, "text": "jóvenes", "speaker": null}, {"start": 487.656, "end": 490.956, "text": "la sociedad en general", "speaker": null}, {"start": 490.956, "end": 492.35602, "text": "incluyendo a muchos de ustedes", "speaker": null}, {"start": 492.35602, "end": 494.596, "text": "y digo a muchos de ustedes, me refiero a esos gigantes", "speaker": null}, {"start": 494.596, "end": 495.196, "text": "que peñan", "speaker": null}, {"start": 495.196, "end": 498.116, "text": "porque ustedes están en una institución superior", "speaker": null}, {"start": 498.116, "end": 501.056, "text": "y todo esto deberían de empezar a", "speaker": null}, {"start": 501.056, "end": 503.496, "text": "darse cuenta", "speaker": null}, {"start": 503.496, "end": 505.196, "text": "que es lo que está pasando en el país", "speaker": null}, {"start": 505.196, "end": 506.976, "text": "pero no", "speaker": null}, {"start": 506.976, "end": 509.396, "text": "la gente prefiere perderse en el mundial", "speaker": null}, {"start": 509.396, "end": 511.61603, "text": "¿por qué crees que el gobierno", "speaker": null}, {"start": 511.61603, "end": 513.256, "text": "está metiendo tanta lana", "speaker": null}, {"start": 513.256, "end": 513.99603, "text": "al mundial?", "speaker": null}, {"start": 515.976, "end": 516.616, "text": "¿por qué sabe", "speaker": null}, {"start": 516.616, "end": 518.216, "text": "que el pueblo mexicano", "speaker": null}, {"start": 518.216, "end": 519.016, "text": "va en circo", "speaker": null}, {"start": 519.016, "end": 522.596, "text": "mientras ellos asisten a sus madres?", "speaker": null}, {"start": 524.576, "end": 526.43604, "text": "cuando vuelven van a estar más que", "speaker": null}, {"start": 526.43604, "end": 527.176, "text": "charlados", "speaker": null}, {"start": 527.176, "end": 529.976, "text": "y ahorita vamos a ver otra parte", "speaker": null}, {"start": 529.976, "end": 559.956, "text": "¿Cuánto es el precio?", "speaker": null}, {"start": 559.976, "end": 568.116, "text": "Y el gobierno casualmente se va a mover todo lo que haga el gobierno lo va a hacer con dinero.", "speaker": null}, {"start": 568.856, "end": 570.336, "text": "No hay otra manera de hacerlo.", "speaker": null}, {"start": 571.276, "end": 572.496, "text": "El gobierno va a dar dinero.", "speaker": null}, {"start": 573.996, "end": 574.476, "text": "Dinero.", "speaker": null}, {"start": 575.376, "end": 576.556, "text": "Y ahorita voy a explicar por qué.", "speaker": null}, {"start": 577.356, "end": 586.376, "text": "Luego entonces al gobierno le interesa obtener, administrar y aplicar dinero.", "speaker": null}, {"start": 586.376, "end": 590.056, "text": "¿por qué vamos a tener la necesidad", "speaker": null}, {"start": 590.056, "end": 592.096, "text": "de caer al dinero?", "speaker": null}, {"start": 593.176, "end": 593.996, "text": "porque si nosotros", "speaker": null}, {"start": 593.996, "end": 595.69604, "text": "vemos el gobierno tiene", "speaker": null}, {"start": 595.69604, "end": 598.096, "text": "obligaciones que se transmiten en derechos", "speaker": null}, {"start": 598.096, "end": 599.076, "text": "de nosotros", "speaker": null}, {"start": 599.076, "end": 601.396, "text": "vamos a hablar de nuestros derechos", "speaker": null}, {"start": 601.396, "end": 602.696, "text": "yo les decía a ustedes", "speaker": null}, {"start": 602.696, "end": 606.676, "text": "¿qué tipo de derecho tienen?", "speaker": null}, {"start": 607.196, "end": 607.876, "text": "a mí a lo mejor", "speaker": null}, {"start": 607.876, "end": 609.176, "text": "me están mentando la madre", "speaker": null}, {"start": 609.176, "end": 611.496, "text": "yo les dije", "speaker": null}, {"start": 611.496, "end": 613.496, "text": "mienten o las echen pero yo estoy", "speaker": null}, {"start": 613.496, "end": 614.836, "text": "velando por sus derechos", "speaker": null}, {"start": 614.836, "end": 616.416, "text": "¿Qué derechos tienen?", "speaker": null}, {"start": 616.81604, "end": 619.676, "text": "A que yo les dé todas las clases de su curso", "speaker": null}, {"start": 619.676, "end": 623.036, "text": "A que yo les dé sus tres horas de clase", "speaker": null}, {"start": 623.036, "end": 623.976, "text": "Una media hora", "speaker": null}, {"start": 623.976, "end": 625.956, "text": "No cuarenta minutos", "speaker": null}, {"start": 625.956, "end": 627.556, "text": "Tres horas de clase", "speaker": null}, {"start": 627.556, "end": 629.19604, "text": "Es lo que tienen derecho", "speaker": null}, {"start": 629.19604, "end": 630.796, "text": "¿Cuál es mi obligación?", "speaker": null}, {"start": 631.99603, "end": 632.43604, "text": "Trabajar", "speaker": null}, {"start": 632.43604, "end": 635.31604, "text": "¿Ve?", "speaker": null}, {"start": 635.556, "end": 637.19604, "text": "La facultad está vacía", "speaker": null}, {"start": 637.19604, "end": 640.516, "text": "No hacen uso de su derecho", "speaker": null}, {"start": 640.516, "end": 641.416, "text": "Yo estoy hablando de ustedes", "speaker": null}, {"start": 641.416, "end": 644.376, "text": "Yo estoy hablando de sus intereses", "speaker": null}, {"start": 644.376, "end": 645.216, "text": "¿Lo mismo pasa aquí?", "speaker": null}, {"start": 645.736, "end": 646.836, "text": "Lo mismo pasa aquí.", "speaker": null}, {"start": 647.996, "end": 649.616, "text": "¿A qué tenemos derechos, señores?", "speaker": null}, {"start": 649.996, "end": 651.616, "text": "Nosotros como mexicanos,", "speaker": null}, {"start": 651.69604, "end": 654.076, "text": "por el simple hecho de ser mexicanos,", "speaker": null}, {"start": 655.076, "end": 656.576, "text": "a saber de nosotros,", "speaker": null}, {"start": 657.216, "end": 660.076, "text": "tenemos derechos.", "speaker": null}, {"start": 661.176, "end": 663.43604, "text": "¿Derechos como cuáles?", "speaker": null}, {"start": 663.43604, "end": 664.776, "text": "Ejemplo.", "speaker": null}, {"start": 665.976, "end": 668.516, "text": "A la educación.", "speaker": null}, {"start": 670.676, "end": 680.854, "text": "Ejemplo ejemplo Ejemplo a la salud Ejemplo a la seguridad", "speaker": null}, {"start": 682.374, "end": 688.39404, "text": "¿Eché? ¿O me equivoco? ¿Quién tiene la obligación de darnos?", "speaker": null}, {"start": 689.39404, "end": 693.754, "text": "El gobierno, efectivamente. No nos dependen de nadie.", "speaker": null}, {"start": 693.754, "end": 697.534, "text": "ustedes se imaginan", "speaker": null}, {"start": 697.534, "end": 699.034, "text": "a su abuelo Peje", "speaker": null}, {"start": 699.034, "end": 700.814, "text": "dándoles a tu chua a hacer ceres", "speaker": null}, {"start": 700.814, "end": 704.214, "text": "yo no me imagino", "speaker": null}, {"start": 704.214, "end": 708.374, "text": "Peje dándoles", "speaker": null}, {"start": 708.374, "end": 710.854, "text": "y menos", "speaker": null}, {"start": 710.854, "end": 711.754, "text": "a los niños", "speaker": null}, {"start": 711.754, "end": 714.414, "text": "ya lo intentó hacer", "speaker": null}, {"start": 714.414, "end": 716.274, "text": "cambió los libros de texto", "speaker": null}, {"start": 716.274, "end": 720.914, "text": "y empezaron a hacer", "speaker": null}, {"start": 720.914, "end": 723.934, "text": "imagínatelo parado", "speaker": null}, {"start": 723.934, "end": 725.314, "text": "adelante de un salón", "speaker": null}, {"start": 725.314, "end": 729.654, "text": "imagínate a esclaura", "speaker": null}, {"start": 729.654, "end": 730.554, "text": "aquí dando clase", "speaker": null}, {"start": 730.554, "end": 733.414, "text": "cuando se burla irónicamente", "speaker": null}, {"start": 733.414, "end": 735.174, "text": "de los problemas de la sociedad", "speaker": null}, {"start": 735.174, "end": 736.89404, "text": "con su visita sarcástica", "speaker": null}, {"start": 736.89404, "end": 741.094, "text": "yo creo que se va a venir a encontrar", "speaker": null}, {"start": 741.094, "end": 743.234, "text": "la ignorancia de los estudiantes", "speaker": null}, {"start": 743.234, "end": 747.39404, "text": "yo no me lo imagino", "speaker": null}, {"start": 747.39404, "end": 750.254, "text": "te imaginas", "speaker": null}, {"start": 750.254, "end": 752.034, "text": "atendiendo", "speaker": null}, {"start": 752.034, "end": 755.454, "text": "dentro del sector salud", "speaker": null}, {"start": 755.454, "end": 759.094, "text": "va a terminar como si fuera Salinas", "speaker": null}, {"start": 759.094, "end": 761.314, "text": "¿sí saben quién fue Salinas?", "speaker": null}, {"start": 762.034, "end": 763.374, "text": "Salinas prometió algo", "speaker": null}, {"start": 763.374, "end": 765.01404, "text": "cuando fue presidente y lo cumplió", "speaker": null}, {"start": 765.01404, "end": 766.914, "text": "Salinas que dijo", "speaker": null}, {"start": 766.914, "end": 769.794, "text": "en mi sexenio", "speaker": null}, {"start": 769.794, "end": 772.254, "text": "¿qué va a pasar?", "speaker": null}, {"start": 775.314, "end": 777.13403, "text": "a lo largo de mi sexenio", "speaker": null}, {"start": 777.13403, "end": 778.89404, "text": "va a haber cada vez", "speaker": null}, {"start": 778.89404, "end": 781.334, "text": "menos pobres", "speaker": null}, {"start": 781.334, "end": 784.39404, "text": "¿y cumplieron o no cumplieron?", "speaker": null}, {"start": 786.034, "end": 786.714, "text": "¿sí?", "speaker": null}, {"start": 787.274, "end": 788.774, "text": "porque son movidos de ámbrica", "speaker": null}, {"start": 788.774, "end": 790.954, "text": "no, no se venían", "speaker": null}, {"start": 790.954, "end": 793.554, "text": "vean estadísticamente lo que les estoy diciendo", "speaker": null}, {"start": 793.554, "end": 795.114, "text": "y esto", "speaker": null}, {"start": 795.114, "end": 797.57404, "text": "y el mayoritario lo vamos a fundamentar si quiere ser", "speaker": null}, {"start": 797.57404, "end": 800.914, "text": "yo no me lo imagino", "speaker": null}, {"start": 800.914, "end": 802.854, "text": "una inseguridad", "speaker": null}, {"start": 802.854, "end": 804.474, "text": "ustedes lo ven en una", "speaker": null}, {"start": 804.474, "end": 806.094, "text": "super", "speaker": null}, {"start": 806.094, "end": 807.834, "text": "for explorer", "speaker": null}, {"start": 807.834, "end": 810.414, "text": "porque estamos estrenando", "speaker": null}, {"start": 810.414, "end": 811.034, "text": "explorers", "speaker": null}, {"start": 811.034, "end": 814.114, "text": "estamos estrenando", "speaker": null}, {"start": 814.114, "end": 814.77405, "text": "lobos", "speaker": null}, {"start": 814.77405, "end": 817.15405, "text": "super lobos", "speaker": null}, {"start": 817.15405, "end": 819.334, "text": "estamos estrenando", "speaker": null}, {"start": 819.334, "end": 821.07404, "text": "b-wings", "speaker": null}, {"start": 821.07404, "end": 823.734, "text": "yo no me imagino", "speaker": null}, {"start": 823.734, "end": 825.214, "text": "a ninguno de estos personajes", "speaker": null}, {"start": 825.214, "end": 830.054, "text": "rondando y cuidando la seguridad de mi colonia", "speaker": null}, {"start": 830.054, "end": 833.454, "text": "entonces si así estamos como estamos", "speaker": null}, {"start": 833.454, "end": 834.874, "text": "ya estaríamos ahí como", "speaker": null}, {"start": 834.874, "end": 837.094, "text": "chancados en cada esquina", "speaker": null}, {"start": 837.094, "end": 840.654, "text": "no son justos", "speaker": null}, {"start": 840.654, "end": 842.63403, "text": "y eso no puede ser", "speaker": null}, {"start": 842.63403, "end": 844.13403, "text": "¿por qué?", "speaker": null}, {"start": 844.674, "end": 846.13403, "text": "porque el gobierno lo va a resolver", "speaker": null}, {"start": 846.13403, "end": 846.274, "text": "¿por qué?", "speaker": null}, {"start": 851.974, "end": 852.69403, "text": "complicado", "speaker": null}, {"start": 852.69403, "end": 856.094, "text": "de ahí se lo dije, se lo voy a demostrar", "speaker": null}, {"start": 856.094, "end": 857.994, "text": "cuando hablamos de", "speaker": null}, {"start": 857.994, "end": 859.934, "text": "educación, la educación", "speaker": null}, {"start": 859.934, "end": 861.754, "text": "se va a controlar", "speaker": null}, {"start": 861.754, "end": 863.954, "text": "se va a transmitir", "speaker": null}, {"start": 863.954, "end": 865.234, "text": "se va a dar", "speaker": null}, {"start": 865.234, "end": 867.654, "text": "a través de instituciones de gobierno.", "speaker": null}, {"start": 867.994, "end": 872.554, "text": "Esas instituciones de gobierno se llaman secretarías de Estado.", "speaker": null}, {"start": 873.51404, "end": 876.534, "text": "En este caso va a ser la SED.", "speaker": null}, {"start": 877.594, "end": 886.414, "text": "Es decir, el gobierno va a ser llegar recursos a la SED", "speaker": null}, {"start": 886.414, "end": 891.314, "text": "para que la SED de manera regional y después local", "speaker": null}, {"start": 891.314, "end": 899.69403, "text": "y así sucesivamente le paguen a quienes? Al sector educativo.", "speaker": null}]