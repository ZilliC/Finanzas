[{"start": 0.0, "end": 29.98, "text": "Bienvenidos a la sesión de hoy.", "speaker": null}, {"start": 30.0, "end": 31.0, "text": "Gracias.", "speaker": null}, {"start": 60.0, "end": 65.0, "text": "La vez pasada, por accidente, a mi hijo se le cayó.", "speaker": null}, {"start": 65.0, "end": 72.0, "text": "Si uno ve algo tan grave, o sea, se puede ver el pupitre y todo el display se...", "speaker": null}, {"start": 72.0, "end": 76.0, "text": "Y mi otro hijo acaba de tener hace dos semanas la misma bronca.", "speaker": null}, {"start": 76.0, "end": 78.0, "text": "La misma bronca.", "speaker": null}, {"start": 78.0, "end": 84.0, "text": "Entonces, cuando llevamos el... que yo fui a nosotros a hacer mis...", "speaker": null}, {"start": 84.0, "end": 89.64, "text": "Hombre, yo sabía que ha sido la más inevitable, reparar y comprar otro.", "speaker": null}, {"start": 90.28, "end": 92.1, "text": "O sea, bien para mí.", "speaker": null}, {"start": 93.159996, "end": 96.56, "text": "Y ya se los mando, me dijo, el bello de Sancho.", "speaker": null}, {"start": 97.38, "end": 98.86, "text": "Le pasó lo mismo.", "speaker": null}, {"start": 100.3, "end": 105.54, "text": "Le pasó lo mismo, o sea, ese día me dijo, conmigo, me dijo,", "speaker": null}, {"start": 105.82, "end": 109.96, "text": "que no, que para algunos cosas se llama, como era de noche,", "speaker": null}, {"start": 109.96, "end": 113.2, "text": "a mí se hizo fácil poner su luz", "speaker": null}, {"start": 113.2, "end": 115.02, "text": "arriba de la camioneta", "speaker": null}, {"start": 115.02, "end": 118.44, "text": "para limpar", "speaker": null}, {"start": 118.44, "end": 120.02, "text": "lo que estábamos haciendo", "speaker": null}, {"start": 120.02, "end": 123.52, "text": "y no sé cómo", "speaker": null}, {"start": 123.52, "end": 126.6, "text": "yo creo que nos recargamos", "speaker": null}, {"start": 126.6, "end": 128.6, "text": "con una camioneta o algo", "speaker": null}, {"start": 128.6, "end": 130.44, "text"