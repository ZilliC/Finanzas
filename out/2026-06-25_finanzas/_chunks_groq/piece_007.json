[{"start": 0.0, "end": 17.0, "text": "y el arte dicho ahora para mí me va a representar lo que conocemos como fuentes de financiamiento.", "speaker": null}, {"start": 21.0, "end": 21.44, "text": "¿Ok?", "speaker": null}, {"start": 24.02, "end": 28.06, "text": "Entonces, no está aquí ahorita, pero si estuviera el Pancho, el Pancho va a comunicar.", "speaker": null}, {"start": 28.06, "end": 30.94, "text": "cuando yo le dije a mi tiche, le dije a la casita, oh no manches, vida.", "speaker": null}, {"start": 32.62, "end": 33.46, "text": "¿Por qué, macho?", "speaker": null}, {"start": 33.8, "end": 35.54, "text": "Es que yo soy administrador,", "speaker": null}, {"start": 36.78, "end": 39.34, "text": "y los administradores se han dado unos cuentos,", "speaker": null}, {"start": 39.34, "end": 41.4, "text": "¿por qué la casita?", "speaker": null}, {"start": 42.54, "end": 45.7, "text": "Porque usted me está igualando el pasivo con el capital.", "speaker": null}, {"start": 47.08, "end": 47.94, "text": "Y no es lo mismo.", "speaker": null}, {"start": 49.04, "end": 53.36, "text": "Ah, no, no, no, no, no, no, no, no, no, no, no, no, no, no, no, no, no, no.", "speaker": null}, {"start": 54.3, "end": 56.84, "text": "¿Por qué? Porque si viene cierto, lo quiere separar.", "speaker": null}, {"start": 58.06, "end": 59.44, "text": "lo podemos separar.", "speaker": null}, {"start": 61.84, "end": 68.6, "text": "El pasivo entonces se va a convertir en una fuente de financiamiento externo.", "speaker": null}, {"start": 70.16, "end": 73.58, "text": "Y el capital va a seguir siendo una fuente de financiamiento,", "speaker": null}, {"start": 73.58, "end": 78.58, "text": "pero ahora va a ser una fuente de financiamiento interno.", "speaker": null}, {"start": 78.58, "end": 90.62, "text": "¿Dudas?", "speaker": null}, {"start": 90.62, "end": 90.66, "text": "¿Dudas?", "speaker": null}, {"start": 97.0, "end": 97.86, "text": "Incluso desde antes", "speaker": null}, {"start": 97.86, "end": 100.38, "text": "no entiendo bien cómo se maneja la parte", "speaker": null}, {"start": 100.38, "end": 102.54, "text": "del capital contable. O sea, si yo", "speaker": null}, {"start": 102.54, "end": 104.4, "text": "llego como inversionista y digo, no, pues", "speaker": null}, {"start": 104.4, "end": 106.02, "text": "quiero invertirle en mi barco a tal empresa,", "speaker": null}, {"start": 106.02, "end": 108.88, "text": "lo ponen en una cuenta", "speaker": null}, {"start": 108.88, "end": 109.94, "text": "de contacto", "speaker": null}, {"start": 109.94, "end": 110.3, "text": "claro", "speaker": null}, {"start": 110.3, "end": 112.68, "text": "pero", "speaker": null}, {"start": 112.68, "end": 115.34, "text": "entonces", "speaker": null}, {"start": 115.34, "end": 117.3, "text": "de ahí sale", "speaker": null}, {"start": 117.3, "end": 120.06, "text": "y lo usan como financiamiento", "speaker": null}, {"start": 120.06, "end": 122.54, "text": "para comprar cosas", "speaker": null}, {"start": 122.54, "end": 124.82, "text": "o más", "speaker": null}, {"start": 124.82, "end": 126.42, "text": "cuando tú", "speaker": null}, {"start": 126.42, "end": 127.82, "text": "recuerdas lo que hicimos", "speaker": null}, {"start": 127.82, "end": 130.56, "text": "vas a hacer lo mismo, vas a abrir tus tesitas", "speaker": null}, {"start": 130.56, "end": 132.64, "text": "si estamos hablando", "speaker": null}, {"start": 132.64, "end": 134.84, "text": "que tú vas a invertir", "speaker": null}, {"start": 134.84, "end": 138.64, "text": "vas a meter tu dinero", "speaker": null}, {"start": 138.64, "end": 141.2, "text": "en tu empresa", "speaker": null}, {"start": 141.2, "end": 142.58, "text": "porque ya va a ser tu empresa", "speaker": null}, {"start": 142.58, "end": 142.86, "text": "bueno", "speaker": null}, {"start": 142.86, "end": 145.84, "text": "dependiendo del número de acciones", "speaker": null}, {"start": 145.84, "end": 148.02, "text": "puede ser tu empresa o tú vas a ser", "speaker": null}, {"start": 148.02, "end": 149.46, "text": "parte de la empresa", "speaker": null}, {"start": 149.46, "end": 152.34, "text": "porque aquí hablamos de accionistas", "speaker": null}, {"start": 152.34, "end": 154.06, "text": "y hay accionistas", "speaker": null}, {"start": 154.06, "end": 156.42, "text": "mayoritarios y accionistas", "speaker": null}, {"start": 156.42, "end": 157.66, "text": "minoritarios", "speaker": null}, {"start": 157.66, "end": 161.82, "text": "la clase pasada por aquí", "speaker": null}, {"start": 161.82, "end": 163.08, "text": "por eso", "speaker": null}, {"start": 163.08, "end": 167.74, "text": "de lo que atrevía a perder el tema fue el de algo por ahí.", "speaker": null}, {"start": 168.62, "end": 173.16, "text": "Habíamos hablado de entes económicos y había una función que los entes económicos aquí están.", "speaker": null}, {"start": 174.54, "end": 176.86, "text": "Son personas morales, ejemplo una sea.", "speaker": null}, {"start": 177.94, "end": 184.38, "text": "Y dijimos que una sea o una persona moral es una unidad jurídica de dos o más personas físicas morales", "speaker": null}, {"start": 184.38, "end": 190.08, "text": "para crear una diferente que va a tener un nombre, una razón o denominación social,", "speaker": null}, {"start": 190.08, "end": 194.56, "text": "pero que va a tener una personalidad jurídica diferente a la de los ciudadanos.", "speaker": null}, {"start": 195.6, "end": 199.0, "text": "Vamos a pensar que nosotros tres decidimos crear una empresa.", "speaker": null}, {"start": 200.98, "end": 203.76, "text": "Apple II, ese año.", "speaker": null}, {"start": 205.56, "end": 207.4, "text": "Y vamos a tener que aportar un capital.", "speaker": null}, {"start": 208.42, "end": 208.9, "text": "¿Correcto?", "speaker": null}, {"start": 210.14, "end": 214.94, "text": "Ese capital lo podemos aportar en efectivo o en bienes distintos al numerario.", "speaker": null}, {"start": 216.0, "end": 216.46, "text": "¿En qué?", "speaker": null}, {"start": 216.46, "end": 219.54, "text": "En efectivo o en bienes distintos al numerario.", "speaker": null}, {"start": 220.08, "end": 239.45801, "text": "O sea tenemos como bienes distintos al numerar cualquier otra cosa que no sea dinero Podr decir que a lo mejor Carlos que es el inform dice yo voy a ser el cerebro y como cerebro voy a poner mi hijo as de mi hijo", "speaker": null}, {"start": 240.798, "end": 247.598, "text": "A lo mejor yo te digo, ¿sabes qué? Yo quiero entrar a la sociedad chapa, pero yo no tengo dinero.", "speaker": null}, {"start": 247.598, "end": 249.518, "text": "pero que te parece", "speaker": null}, {"start": 249.518, "end": 252.018, "text": "si yo pongo las instalaciones", "speaker": null}, {"start": 252.018, "end": 253.95801, "text": "la infraestructura", "speaker": null}, {"start": 253.95801, "end": 257.378, "text": "yo pongo las oficinas", "speaker": null}, {"start": 257.378, "end": 260.958, "text": "que las oficinas no valen", "speaker": null}, {"start": 260.958, "end": 263.078, "text": "tengo que valer", "speaker": null}, {"start": 263.078, "end": 264.478, "text": "si", "speaker": null}, {"start": 264.478, "end": 267.038, "text": "y a lo mejor llega el Mike", "speaker": null}, {"start": 267.038, "end": 268.478, "text": "y el Mike dice sabes que", "speaker": null}, {"start": 268.478, "end": 271.838, "text": "pues yo si tengo pero no tengo todo", "speaker": null}, {"start": 271.838, "end": 273.578, "text": "pongo una parte", "speaker": null}, {"start": 273.578, "end": 275.238, "text": "en dinero y otra parte", "speaker": null}, {"start": 275.238, "end": 276.838, "text": "por ejemplo en equipo", "speaker": null}, {"start": 276.838, "end": 279.538, "text": "materiales, insumos", "speaker": null}, {"start": 279.538, "end": 280.278, "text": "y una que otra", "speaker": null}, {"start": 280.278, "end": 281.798, "text": "computer", "speaker": null}, {"start": 281.798, "end": 283.65802, "text": "¿sale?", "speaker": null}, {"start": 284.758, "end": 285.65802, "text": "¿se puede o no se puede?", "speaker": null}, {"start": 287.038, "end": 288.918, "text": "abuelita de Batman que si se puede", "speaker": null}, {"start": 288.918, "end": 291.198, "text": "¿de cuánto va a ser", "speaker": null}, {"start": 291.198, "end": 291.898, "text": "nuestra sociedad?", "speaker": null}, {"start": 293.578, "end": 295.338, "text": "no sé, pensemos que sea de", "speaker": null}, {"start": 295.338, "end": 296.578, "text": "un millón", "speaker": null}, {"start": 296.578, "end": 299.59802, "text": "aquí viene lo interesante", "speaker": null}, {"start": 299.59802, "end": 301.65802, "text": "cada uno de nosotros", "speaker": null}, {"start": 301.65802, "end": 303.418, "text": "va a tener acciones", "speaker": null}, {"start": 303.418, "end": 305.438, "text": "se convierte en", "speaker": null}, {"start": 305.438, "end": 306.038, "text": "accionista", "speaker": null}, {"start": 306.038, "end": 308.138, "text": "¿estamos de acuerdo?", "speaker": null}, {"start": 308.698, "end": 308.998, "text": "o no", "speaker": null}, {"start": 308.998, "end": 312.438, "text": "pero como cada quien usa diferente cantidad", "speaker": null}, {"start": 312.438, "end": 314.758, "text": "cada quien va a tener", "speaker": null}, {"start": 314.758, "end": 316.698, "text": "más o menos acciones", "speaker": null}, {"start": 316.698, "end": 318.698, "text": "dependiendo lo que va a la exportación", "speaker": null}, {"start": 318.698, "end": 320.778, "text": "¿cuánto quieres vender", "speaker": null}, {"start": 320.778, "end": 321.71802, "text": "tú de esa caucha?", "speaker": null}, {"start": 324.21802, "end": 325.05798, "text": "500", "speaker": null}, {"start": 325.05798, "end": 325.898, "text": "500", "speaker": null}, {"start": 325.898, "end": 329.518, "text": "¿cuánto voy a meter yo?", "speaker": null}, {"start": 329.518, "end": 330.598, "text": "¿cuánto voy a meter?", "speaker": null}, {"start": 330.71802, "end": 331.758, "text": "350", "speaker": null}, {"start": 331.758, "end": 335.438, "text": "una oficina pequeña", "speaker": null}, {"start": 335.438, "end": 336.058, "text": "para empezar", "speaker": null}, {"start": 336.058, "end": 341.898, "text": "y el mante", "speaker": null}, {"start": 341.898, "end": 343.198, "text": "va a poner", "speaker": null}, {"start": 343.198, "end": 343.998, "text": "150 mil", "speaker": null}, {"start": 343.998, "end": 348.138, "text": "50 mil en efectivo", "speaker": null}, {"start": 348.138, "end": 348.53802, "text": "lo demás", "speaker": null}, {"start": 348.53802, "end": 348.998, "text": "el equipo", "speaker": null}, {"start": 348.998, "end": 350.818, "text": "ahí viene", "speaker": null}, {"start": 350.818, "end": 351.15802, "text": "lo bueno", "speaker": null}, {"start": 351.15802, "end": 351.838, "text": "¿qué va a pasar?", "speaker": null}, {"start": 352.078, "end": 352.798, "text": "esa gana", "speaker": null}, {"start": 352.798, "end": 354.758, "text": "la van a usar", "speaker": null}, {"start": 354.758, "end": 355.338, "text": "en partida", "speaker": null}, {"start": 355.338, "end": 358.15802, "text": "el", "speaker": null}, {"start": 358.15802, "end": 359.518, "text": "activo fijo", "speaker": null}, {"start": 359.518, "end": 362.09802, "text": "¿cuánto va a valer?", "speaker": null}, {"start": 362.498, "end": 363.838, "text": "350 mil", "speaker": null}, {"start": 363.838, "end": 368.978, "text": "el activo circulante", "speaker": null}, {"start": 368.978, "end": 370.778, "text": "¿cuánto va a valer?", "speaker": null}, {"start": 371.998, "end": 373.73798, "text": "600 mil en bancos", "speaker": null}, {"start": 373.73798, "end": 375.258, "text": "que son los 500 tuyos", "speaker": null}, {"start": 375.258, "end": 376.71802, "text": "más", "speaker": null}, {"start": 376.71802, "end": 379.138, "text": "los 100 de Mike", "speaker": null}, {"start": 379.138, "end": 381.498, "text": "y 50 mil", "speaker": null}, {"start": 381.498, "end": 383.05798, "text": "a lo mejor en inventarios", "speaker": null}, {"start": 383.05798, "end": 385.17798, "text": "ya está el activo", "speaker": null}, {"start": 385.17798, "end": 387.098, "text": "si sumamos todo eso", "speaker": null}, {"start": 387.098, "end": 388.638, "text": "te va a dar un millón de pesos", "speaker": null}, {"start": 388.638, "end": 391.61798, "text": "¿cuál sería la contracuenta?", "speaker": null}, {"start": 392.61798, "end": 393.138, "text": "proveedores", "speaker": null}, {"start": 393.138, "end": 397.11798, "text": "no, porque no se lo vemos a nadie", "speaker": null}, {"start": 397.11798, "end": 400.018, "text": "acreedores diversos", "speaker": null}, {"start": 400.018, "end": 401.038, "text": "porque el Mike metió", "speaker": null}, {"start": 401.038, "end": 403.67798, "text": "equipo y yo metí activo fijo", "speaker": null}, {"start": 403.67798, "end": 404.61798, "text": "no", "speaker": null}, {"start": 404.61798, "end": 407.298, "text": "se va a la cuenta", "speaker": null}, {"start": 407.298, "end": 409.918, "text": "a capital contable pero a la cuenta", "speaker": null}, {"start": 409.918, "end": 410.21802, "text": "de", "speaker": null}, {"start": 410.21802, "end": 412.778, "text": "capital social", "speaker": null}, {"start": 412.778, "end": 417.418, "text": "aquí va a estar el número de personas", "speaker": null}, {"start": 417.418, "end": 420.298, "text": "a lo mejor lo que no entiendes", "speaker": null}, {"start": 420.298, "end": 421.758, "text": "tú dices bueno, ¿por qué", "speaker": null}, {"start": 421.758, "end": 424.498, "text": "financiera que te dicen que es una cuenta interna", "speaker": null}, {"start": 424.498, "end": 427.658, "text": "si es mía", "speaker": null}, {"start": 427.658, "end": 430.11798, "text": "no, no, no, no, no", "speaker": null}, {"start": 430.11798, "end": 431.458, "text": "usted", "speaker": null}, {"start": 431.458, "end": 434.138, "text": "ya perdió el piso señor", "speaker": null}, {"start": 434.138, "end": 436.338, "text": "porque estamos", "speaker": null}, {"start": 436.338, "end": 437.858, "text": "hablando de esta S.A.", "speaker": null}, {"start": 439.698, "end": 440.698, "text": "S.A.", "speaker": null}, {"start": 441.638, "end": 442.998, "text": "y la S.A.", "speaker": null}, {"start": 443.398, "end": 457.73602, "text": "usted tiene una personalidad diferente a la suya tiene una personalidad jur diferente a la m y una personalidad jur diferente a la del maestro Nosotros somos los due pero nuestra personalidad siendo", "speaker": null}, {"start": 457.73602, "end": 463.536, "text": "personas físicas, es diferente a la de las personas morales. Entonces, quiere decir que", "speaker": null}, {"start": 463.536, "end": 472.07602, "text": "la ex se adquiere su propia personalidad jurídica. Es un ente diferente, es parte tuya, pero", "speaker": null}, {"start": 472.07602, "end": 479.91602, "text": "no eres tú, es la empresa. ¿Qué quiere decir eso? Que este dinero es de la empresa", "speaker": null}, {"start": 479.91602, "end": 487.07602, "text": "que ya no es tuyo, ya no es tuyo, ahora es de la empresa. Y tú eres dueño de la empresa,", "speaker": null}, {"start": 487.976, "end": 497.256, "text": "pero la empresa ¿qué pasa? Ese dinero no lo usted debe. ¿Quién no lo debe? La empresa.", "speaker": null}, {"start": 497.256, "end": 501.91602, "text": "ahí ya no puedo decir que es mío", "speaker": null}, {"start": 501.91602, "end": 502.896, "text": "a los miembros de la empresa", "speaker": null}, {"start": 502.896, "end": 506.23602, "text": "entonces la empresa me debe ese dinero", "speaker": null}, {"start": 506.23602, "end": 509.256, "text": "aunque yo soy", "speaker": null}, {"start": 509.256, "end": 511.556, "text": "la empresa al final del día", "speaker": null}, {"start": 511.556, "end": 515.516, "text": "¿se observa?", "speaker": null}, {"start": 515.836, "end": 517.916, "text": "¿o no se observa?", "speaker": null}, {"start": 518.916, "end": 519.196, "text": "si", "speaker": null}, {"start": 519.196, "end": 523.116, "text": "buen día, buen regreso", "speaker": null}, {"start": 527.256, "end": 528.716, "text": "¿Seguro?", "speaker": null}, {"start": 529.31604, "end": 529.516, "text": "Sí.", "speaker": null}, {"start": 531.916, "end": 536.19604, "text": "Bueno, pues ahora vamos a empezar a dar un salto de ritmo.", "speaker": null}, {"start": 538.19604, "end": 539.856, "text": "Y vamos a empezar a entrar en materia.", "speaker": null}, {"start": 547.716, "end": 550.016, "text": "Vamos a pasar a entrar a lo que nos cruje.", "speaker": null}, {"start": 551.396, "end": 554.776, "text": "Aquí, esta materia, habíamos dicho que es fina.", "speaker": null}, {"start": 554.776, "end": 568.136, "text": "Y al ser finanzas, nos están obligando a vivir el programa, a desarrollar lo que corresponde al análisis financiero.", "speaker": null}, {"start": 568.756, "end": 571.416, "text": "¿Es correcto o me equivoco?", "speaker": null}, {"start": 573.456, "end": 583.236, "text": "Bueno, para que yo empiece a entender cómo funciona esto, aquí tenemos que comprender otra cosa antes.", "speaker": null}, {"start": 584.776, "end": 598.756, "text": "Si yo establezco la posición de la empresa en mi tiempo, voy a un parado que nosotros", "speaker": null}, {"start": 598.756, "end": 602.11597, "text": "conocemos como qué?", "speaker": null}, {"start": 604.11597, "end": 607.43604, "text": "Como una laeta, una plana que se da en el tiempo.", "speaker": null}, {"start": 609.036, "end": 611.296, "text": "Y normalmente los que matizamos nos aman.", "speaker": null}, {"start": 611.296, "end": 616.636, "text": "y yo voy a establecer en qué lugar del tiempo estoy.", "speaker": null}, {"start": 617.616, "end": 618.656, "text": "Se le llama fecha focal.", "speaker": null}, {"start": 622.496, "end": 625.956, "text": "Y yo quiero establecer que la fecha focal va a ser hoy.", "speaker": null}, {"start": 628.176, "end": 629.096, "text": "¿Se puede o no se puede?", "speaker": null}, {"start": 629.656, "end": 630.916, "text": "Por supuesto que sí.", "speaker": null}, {"start": 630.916, "end": 637.696, "text": "Si la fecha focal es hoy", "speaker": null}, {"start": 637.696, "end": 641.036, "text": "Esto me divide", "speaker": null}, {"start": 641.036, "end": 643.61597, "text": "Mi plana de tiempo", "speaker": null}, {"start": 643.61597, "end": 645.256, "text": "¿En cuántos tiempos?", "speaker": null}, {"start": 647.016, "end": 648.676, "text": "En dos", "speaker": null}, {"start": 648.676, "end": 651.056, "text": "¿En dos? Por supuesto que no", "speaker": null}, {"start": 651.056, "end": 654.376, "text": "¿En cuántos?", "speaker": null}, {"start": 654.376, "end": 654.496, "text": "¿En tres?", "speaker": null}, {"start": 655.896, "end": 657.496, "text": "En tres", "speaker": null}, {"start": 657.496, "end": 662.136, "text": "lo que está a su izquierda de ustedes", "speaker": null}, {"start": 662.136, "end": 668.396, "text": "que me va a representar el pasado", "speaker": null}, {"start": 668.396, "end": 681.154, "text": "el hoy que me representa el presente y lo que est a la derecha de ustedes que me va a representar el futuro", "speaker": null}, {"start": 681.154, "end": 687.754, "text": "¿se acuerdan que cuando iniciamos el repaso dijimos", "speaker": null}, {"start": 687.754, "end": 690.57404, "text": "bien claramente dijimos", "speaker": null}, {"start": 690.57404, "end": 695.51404, "text": "que en el mundo de las operaciones económicas financieras", "speaker": null}, {"start": 695.51404, "end": 698.334, "text": "inevitablemente deben existir", "speaker": null}, {"start": 698.334, "end": 700.39404, "text": "un registro de operaciones", "speaker": null}, {"start": 700.39404, "end": 705.334, "text": "y que dijimos que inevitablemente lo vamos a hacer a través de la contabilidad", "speaker": null}, {"start": 706.794, "end": 710.254, "text": "y que la contabilidad inevitablemente va a tener que emitir", "speaker": null}, {"start": 710.254, "end": 718.994, "text": "estados financieros. Eso es porque atrás de mí vi un año, dos años, tres años, cuatro", "speaker": null}, {"start": 718.994, "end": 726.234, "text": "años, cuatro años, y me han ido. Y adelante de mí me falta por vivir un año, dos años,", "speaker": null}, {"start": 726.234, "end": 734.594, "text": "tres años, cuatro años, cuatro años, y me han ido. ¿Estamos de acuerdo? Bueno, en el", "speaker": null}, {"start": 734.594, "end": 745.414, "text": "mundo financiero, en el mundo contable, el pasado no se llama pasado. En el mundo contable", "speaker": null}, {"start": 745.414, "end": 755.254, "text": "las operaciones, no podemos hablar de operaciones pasadas, de cifras pasadas. No, ¿de qué", "speaker": null}, {"start": 755.254, "end": 778.414, "text": "hablamos de cifras históricas. Y hacia el lado derecho tenemos las cifras futuras. Pero", "speaker": null}, {"start": 778.414, "end": 783.174, "text": "pero como yo no tengo cifras futuras todavía, ¿cómo las voy a conocer?", "speaker": null}, {"start": 784.714, "end": 790.294, "text": "Las voy a conocer porque las puedo estimar, o las puedo presupuestar,", "speaker": null}, {"start": 791.07404, "end": 797.77405, "text": "o las puedo proyectar, o las puedo… N conceptos, ustedes apliquen,", "speaker": null}, {"start": 798.51404, "end": 800.294, "text": "pero todavía no las conozco.", "speaker": null}, {"start": 803.294, "end": 804.594, "text": "Voy bien o me regreso.", "speaker": null}, {"start": 804.594, "end": 808.01404, "text": "esto traducido en castellano", "speaker": null}, {"start": 808.01404, "end": 809.574, "text": "significa señores", "speaker": null}, {"start": 809.574, "end": 811.554, "text": "que yo", "speaker": null}, {"start": 811.554, "end": 813.854, "text": "todas las escas históricas", "speaker": null}, {"start": 813.854, "end": 815.794, "text": "ya están", "speaker": null}, {"start": 815.794, "end": 817.374, "text": "perfectamente definidas", "speaker": null}, {"start": 817.374, "end": 819.414, "text": "realizadas y conocidas", "speaker": null}, {"start": 825.89404, "end": 826.834, "text": "si o no", "speaker": null}, {"start": 826.834, "end": 829.234, "text": "ya no hay duda", "speaker": null}, {"start": 829.234, "end": 830.834, "text": "porque ya fueron hechas", "speaker": null}, {"start": 830.834, "end": 833.914, "text": "muchas de ellas ya están hasta pagadas", "speaker": null}, {"start": 833.914, "end": 837.594, "text": "ya no las debo, ya hasta las pagué", "speaker": null}, {"start": 837.594, "end": 841.69403, "text": "aquí no pienso comprar", "speaker": null}, {"start": 841.69403, "end": 843.474, "text": "no pienso vender", "speaker": null}, {"start": 843.474, "end": 845.27405, "text": "ya compré", "speaker": null}, {"start": 845.27405, "end": 846.374, "text": "ya vendí", "speaker": null}, {"start": 846.374, "end": 851.034, "text": "son hechos ya consumados", "speaker": null}, {"start": 851.034, "end": 853.69403, "text": "del lado derecho", "speaker": null}, {"start": 853.69403, "end": 857.794, "text": "del lado derecho es lo que yo pienso", "speaker": null}, {"start": 857.794, "end": 859.594, "text": "lo que yo pienso comprar", "speaker": null}, {"start": 859.594, "end": 861.214, "text": "lo que yo pienso vender", "speaker": null}, {"start": 861.214, "end": 863.374, "text": "son proyecciones", "speaker": null}, {"start": 863.374, "end": 873.574, "text": "¿Estamos de acuerdo? Luego entonces el mundo financiero no estará, el mundo financiero", "speaker": null}, {"start": 873.574, "end": 881.574, "text": "no está loco, el mundo financiero ya creó métodos para poder analizar qué es lo que", "speaker": null}, {"start": 881.574, "end": 889.254, "text": "yo hice. De ahí que ustedes han olvidado de que en el mundo de los contadores hay un", "speaker": null}, {"start": 889.254, "end": 892.254, "text": "que tenemos nosotros que se llama auditorio.", "speaker": null}, {"start": 894.254, "end": 897.254, "text": "¿Para qué demonios sirve un auditorio?", "speaker": null}, {"start": 897.254, "end": 899.734, "text": "Se habrán dado cuenta que tus empresas cuando dicen", "speaker": null}]