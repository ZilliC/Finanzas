[{"start": 0.0, "end": 4.02, "text": "Los métodos de aumentos y disminuciones.", "speaker": null}, {"start": 6.3199997, "end": 7.2999997, "text": "¿Qué otros métodos tenemos?", "speaker": null}, {"start": 8.22, "end": 8.72, "text": "Charly.", "speaker": null}, {"start": 11.54, "end": 14.74, "text": "El método de punto de equilibrio.", "speaker": null}, {"start": 16.48, "end": 17.619999, "text": "¿Qué otros métodos hay?", "speaker": null}, {"start": 18.539999, "end": 24.199999, "text": "Por ejemplo, los métodos horizontales.", "speaker": null}, {"start": 25.96, "end": 27.599998, "text": "¿Qué otros métodos?", "speaker": null}, {"start": 27.599998, "end": 31.96, "text": "verticales", "speaker": null}, {"start": 31.96, "end": 33.3, "text": "yo creo que todos todavía", "speaker": null}, {"start": 33.3, "end": 39.12, "text": "no sé cuántos hayan alcanzado a ver", "speaker": null}, {"start": 39.12, "end": 41.6, "text": "pero mínimo", "speaker": null}, {"start": 41.6, "end": 43.679996, "text": "mínimo quiero pensar", "speaker": null}, {"start": 43.679996, "end": 44.3, "text": "que vivan", "speaker": null}, {"start": 44.3, "end": 47.219997, "text": "algunos de esos poesos", "speaker": null}, {"start": 47.219997, "end": 50.62, "text": "¿cómo creen?", "speaker": null}, {"start": 50.62, "end": 52.42, "text": "y más o menos", "speaker": null}, {"start": 52.42, "end": 54.659996, "text": "y eso más o menos", "speaker": null}, {"start": 54.659996, "end": 55.96, "text": "todavía está eso", "speaker": null}, {"start": 55.96, "end": 59.44, "text": "bueno, pues una de las razones", "speaker": null}, {"start": 59.44, "end": 61.32, "text": "es que el juego es el mismo que", "speaker": null}, {"start": 61.32, "end": 63.7, "text": "van a tener que reconocer", "speaker": null}, {"start": 63.7, "end": 66.04, "text": "así en su expresión", "speaker": null}, {"start": 66.04, "end": 66.76, "text": "el mínimo", "speaker": null}, {"start": 66.76, "end": 69.38, "text": "pero la realidad es que ya", "speaker": null}, {"start": 69.38, "end": 70.88, "text": "no tienen que manejar todos estos", "speaker": null}, {"start": 70.88, "end": 73.479996, "text": "porque habíamos convenido", "speaker": null}, {"start": 73.479996, "end": 75.159996, "text": "que ese tiempo nos alcanza a la mejor", "speaker": null}, {"start": 75.159996, "end": 76.14, "text": "a la mejor", "speaker": null}, {"start": 76.14, "end": 79.24, "text": "pudiéramos haber entrado", "speaker": null}, {"start": 79.24, "end": 80.659996, "text": "alguno de ellos adicionalmente", "speaker": null}, {"start": 80.659996, "end": 83.38, "text": "aunque no nos correspondería", "speaker": null}, {"start": 83.38, "end": 84.619995, "text": "¿vale?", "speaker": null}, {"start": 85.96, "end": 94.28, "text": "Ahora bien, si viene cierto lo que dice Carlos, pues tendríamos que repasar y verificar esos métodos.", "speaker": null}, {"start": 94.28, "end": 102.04, "text": "Dice Carlos que uno de los que ya maneja el delito es el método de razones, la cosa de sus.", "speaker": null}, {"start": 103.28, "end": 109.18, "text": "Cuando hablamos del método de razones, Carlos, ¿qué es lo mínimo que debiste haber visto?", "speaker": null}, {"start": 109.18, "end": 111.62, "text": "Bueno, pues sí", "speaker": null}, {"start": 111.62, "end": 114.76, "text": "En el mundo de razones", "speaker": null}, {"start": 114.76, "end": 118.26, "text": "¿Qué hora es?", "speaker": null}, {"start": 118.26, "end": 122.26, "text": "¿Qué hora es?", "speaker": null}, {"start": 123.44, "end": 124.38, "text": "9.28", "speaker": null}, {"start": 124.38, "end": 127.32, "text": "Tiene que meter un poquito de velocidad", "speaker": null}, {"start": 127.32, "end": 131.02, "text": "Cuando hablamos del mundo de razones", "speaker": null}, {"start": 131.02, "end": 134.54, "text": "Sabemos que las razones se van a clasificar", "speaker": null}, {"start": 134.54, "end": 136.7, "text": "Porque de alguna manera", "speaker": null}, {"start": 136.7, "end": 138.31999, "text": "Como los modelos los vamos a estudiar", "speaker": null}, {"start": 138.31999, "end": 145.07999, "text": "cómo las vamos a poder reconocer, cómo las vamos a poder identificar y cómo las vamos a poder aplicar.", "speaker": null}, {"start": 147.06, "end": 152.85999, "text": "En el mundo de las razones vamos a tener dos grandes clasificaciones.", "speaker": null}, {"start": 153.26, "end": 163.92, "text": "Una que son las famosas razones simples y otra que son las famosas razones estándar.", "speaker": null}, {"start": 163.92, "end": 168.02, "text": "dentro de las razones simples", "speaker": null}, {"start": 168.02, "end": 168.81999, "text": "¿cuáles tenemos?", "speaker": null}, {"start": 173.92, "end": 175.04, "text": "¿cuál es el ámbito?", "speaker": null}, {"start": 175.04, "end": 175.58, "text": "¿el que?", "speaker": null}, {"start": 178.06, "end": 179.12, "text": "bueno, sí", "speaker": null}, {"start": 179.12, "end": 181.04, "text": "podríamos decir que sí", "speaker": null}, {"start": 181.72, "end": 182.8, "text": "si hablamos", "speaker": null}, {"start": 182.8, "end": 185.4, "text": "al rubro general", "speaker": null}, {"start": 185.4, "end": 186.26, "text": "vamos a empezar", "speaker": null}, {"start": 186.26, "end": 189.3, "text": "vamos a empezar", "speaker": null}, {"start": 189.3, "end": 190.92, "text": "entonces déjame abrirle", "speaker": null}, {"start": 190.92, "end": 192.2, "text": "no, pero eso va a ser", "speaker": null}, {"start": 192.2, "end": 201.78, "text": "No pasa nada.", "speaker": null}, {"start": 205.7, "end": 207.59999, "text": "Vamos a arreglar esto un poco más.", "speaker": null}, {"start": 210.18, "end": 210.45999, "text": "¿Vale?", "speaker": null}, {"start": 211.45999, "end": 213.37999, "text": "Y este lo vamos a abrir un poquito más.", "speaker": null}, {"start": 214.48, "end": 215.98, "text": "Y este lo vamos a poner por acá.", "speaker": null}, {"start": 216.73999, "end": 216.98, "text": "¿Vale?", "speaker": null}, {"start": 218.36, "end": 218.87999, "text": "Buenísimo.", "speaker": null}, {"start": 218.87999, "end": 230.47801, "text": "entonces cuando hablamos de las razones simples vamos a tener que existen razones en el cuerpo de liquidez", "speaker": null}, {"start": 230.47801, "end": 235.878, "text": "que existen razones en el cuerpo", "speaker": null}, {"start": 235.878, "end": 238.018, "text": "de solvencia", "speaker": null}, {"start": 238.67801, "end": 242.25801, "text": "¿no?", "speaker": null}, {"start": 243.558, "end": 245.358, "text": "¿de que más razones tenemos?", "speaker": null}, {"start": 245.358, "end": 246.498, "text": "de abrazamiento", "speaker": null}, {"start": 246.498, "end": 258.018, "text": "¿Qué otro tipo de razones tenemos?", "speaker": null}, {"start": 258.918, "end": 263.65802, "text": "El ejemplo de rotación.", "speaker": null}, {"start": 265.298, "end": 266.918, "text": "¿Qué otras razones, por ejemplo?", "speaker": null}, {"start": 268.018, "end": 270.458, "text": "El tipo cronológico.", "speaker": null}, {"start": 271.798, "end": 274.258, "text": "¿Qué otras razones tenemos, por ejemplo?", "speaker": null}, {"start": 274.258, "end": 277.178, "text": "de rentabilidad", "speaker": null}, {"start": 277.178, "end": 279.65802, "text": "etcétera", "speaker": null}, {"start": 279.65802, "end": 281.238, "text": "porque también", "speaker": null}, {"start": 281.238, "end": 282.458, "text": "esas son iniciativas", "speaker": null}, {"start": 282.458, "end": 284.538, "text": "más no limitativas", "speaker": null}, {"start": 284.538, "end": 287.018, "text": "¿sí?", "speaker": null}, {"start": 287.638, "end": 287.958, "text": "¿sí?", "speaker": null}, {"start": 287.958, "end": 289.798, "text": "¿pero no es", "speaker": null}, {"start": 289.798, "end": 291.21802, "text": "¿a qué se refiere?", "speaker": null}, {"start": 291.438, "end": 292.15802, "text": "¿son iniciativas?", "speaker": null}, {"start": 292.838, "end": 295.618, "text": "estamos enunciando algunas", "speaker": null}, {"start": 295.618, "end": 297.598, "text": "de manera iniciativa", "speaker": null}, {"start": 297.598, "end": 298.898, "text": "más no con ello", "speaker": null}, {"start": 298.898, "end": 301.898, "text": "implica que estas sean limitativas", "speaker": null}, {"start": 301.898, "end": 302.998, "text": "es decir que son estas", "speaker": null}, {"start": 302.998, "end": 304.65802, "text": "hay más", "speaker": null}, {"start": 304.65802, "end": 307.138, "text": "de hecho para conocimiento de ustedes", "speaker": null}, {"start": 307.138, "end": 308.638, "text": "cuando menos hasta", "speaker": null}, {"start": 308.638, "end": 310.818, "text": "la semana pasada", "speaker": null}, {"start": 310.818, "end": 312.538, "text": "teníamos ya", "speaker": null}, {"start": 312.538, "end": 314.898, "text": "5.8 casos", "speaker": null}, {"start": 314.898, "end": 317.258, "text": "para la razón", "speaker": null}, {"start": 317.258, "end": 319.778, "text": "obviamente muchas de ellas", "speaker": null}, {"start": 319.778, "end": 320.758, "text": "son híbridas", "speaker": null}, {"start": 320.758, "end": 322.938, "text": "algunas de ellas son mezclas", "speaker": null}, {"start": 322.938, "end": 324.618, "text": "algunas son compuestas", "speaker": null}, {"start": 324.618, "end": 326.978, "text": "siguen siendo las mismas pero", "speaker": null}, {"start": 326.978, "end": 328.798, "text": "se van adecuando", "speaker": null}, {"start": 328.798, "end": 332.178, "text": "hoy por hoy ya manejamos razones híbridas", "speaker": null}, {"start": 332.178, "end": 334.018, "text": "entendemos como híbrido que", "speaker": null}, {"start": 334.018, "end": 337.798, "text": "la combinación de dos razones", "speaker": null}, {"start": 337.798, "end": 340.418, "text": "pero siguen siendo las mismas razones", "speaker": null}, {"start": 340.418, "end": 342.738, "text": "por naturaleza básica", "speaker": null}, {"start": 342.738, "end": 344.338, "text": "pero ya ves que", "speaker": null}, {"start": 344.338, "end": 345.998, "text": "hay que ir acuerdosando", "speaker": null}, {"start": 345.998, "end": 350.578, "text": "cuando hablamos de las razones", "speaker": null}, {"start": 350.578, "end": 351.378, "text": "estándar", "speaker": null}, {"start": 351.378, "end": 354.138, "text": "cuáles pudieran ser un ejemplo de ellos", "speaker": null}, {"start": 354.138, "end": 355.978, "text": "en el color", "speaker": null}, {"start": 355.978, "end": 356.61798, "text": "que", "speaker": null}, {"start": 356.61798, "end": 359.21802, "text": "la moda", "speaker": null}, {"start": 359.21802, "end": 363.678, "text": "la media", "speaker": null}, {"start": 363.678, "end": 368.758, "text": "la mediana", "speaker": null}, {"start": 368.758, "end": 372.55798, "text": "el diablo", "speaker": null}, {"start": 372.55798, "end": 373.798, "text": "la mediana", "speaker": null}, {"start": 373.798, "end": 374.678, "text": "el sábado", "speaker": null}, {"start": 374.678, "end": 375.298, "text": "etc", "speaker": null}, {"start": 375.298, "end": 379.538, "text": "ustedes dirán", "speaker": null}, {"start": 379.538, "end": 380.438, "text": "bueno y esto", "speaker": null}, {"start": 380.438, "end": 381.59802, "text": "que tiene que ver", "speaker": null}, {"start": 381.59802, "end": 382.578, "text": "con la Navidad", "speaker": null}, {"start": 382.578, "end": 383.59802, "text": "o que las casitas", "speaker": null}, {"start": 383.59802, "end": 384.818, "text": "están de esa manera", "speaker": null}, {"start": 384.818, "end": 386.21802, "text": "o que lo hacen", "speaker": null}, {"start": 386.21802, "end": 387.078, "text": "de esa forma", "speaker": null}, {"start": 387.078, "end": 388.278, "text": "esto es muy sencillo", "speaker": null}, {"start": 388.278, "end": 397.778, "text": "La clasificación se genera en función a qué? A que las razones simples son de naturaleza", "speaker": null}, {"start": 397.778, "end": 406.15802, "text": "física y las razones están dadas por el proceso. ¿Por qué motivo, por ejemplo, estas", "speaker": null}, {"start": 406.15802, "end": 413.378, "text": "las vamos a poder controlar nosotros, las vamos a poder medir e incluso las vamos a", "speaker": null}, {"start": 413.378, "end": 417.97803, "text": "modificar, modificar nosotros en base a los resultados de la empresa.", "speaker": null}, {"start": 418.958, "end": 424.758, "text": "Los resultados de la empresa, o sea, todo lo que se genera aquí adentro, ¿quién lo controla?", "speaker": null}, {"start": 425.418, "end": 426.05798, "text": "Nosotros.", "speaker": null}, {"start": 427.898, "end": 430.15802, "text": "Sin embargo, las estándar no.", "speaker": null}, {"start": 431.398, "end": 439.09802, "text": "Las estándar están diseñadas para medir todo lo que es en materia exógena, es decir,", "speaker": null}, {"start": 439.09802, "end": 441.298, "text": "es lo que está afuera de la empresa.", "speaker": null}, {"start": 441.298, "end": 442.938, "text": "ejemplo", "speaker": null}, {"start": 442.938, "end": 444.678, "text": "si nosotros quisiéramos", "speaker": null}, {"start": 444.678, "end": 456.656, "text": "verificar el estatus de mi empresa relacionada ejemplo con mi sector con mi ramo con mi actividad", "speaker": null}, {"start": 458.256, "end": 463.23602, "text": "con mi giro, etc. ¿No queda claro?", "speaker": null}, {"start": 464.116, "end": 468.036, "text": "O sea, los escenas son como de todo el...", "speaker": null}, {"start": 468.57602, "end": 471.17603, "text": "Por eso funciona tu ramo, tu giro, tu actividad.", "speaker": null}, {"start": 471.17603, "end": 491.13602, "text": "Ejemplo, hace un rato poníamos un ejemplo. Decíamos, ¿qué situación prevalece? Y salió al comentario el caso de Nissan Mexicana. Nissan Mexicana puede aplicar métodos de análisis simples.", "speaker": null}, {"start": 491.13602, "end": 493.896, "text": "cómo está funcionando Nissan por dentro", "speaker": null}, {"start": 493.896, "end": 495.63602, "text": "si tiene rigidez", "speaker": null}, {"start": 495.63602, "end": 497.816, "text": "si está generando rentabilidad", "speaker": null}, {"start": 497.816, "end": 499.67603, "text": "si tiene cronología", "speaker": null}, {"start": 499.67603, "end": 502.256, "text": "si tiene solvencia", "speaker": null}, {"start": 502.256, "end": 504.276, "text": "si tiene capacidad de pago", "speaker": null}, {"start": 504.276, "end": 505.91602, "text": "si tiene capacidad de", "speaker": null}, {"start": 505.91602, "end": 507.436, "text": "endeudamiento, etc.", "speaker": null}, {"start": 508.13602, "end": 509.756, "text": "ellos mismos van a tener que verificar", "speaker": null}, {"start": 509.756, "end": 511.436, "text": "su posición, su situación", "speaker": null}, {"start": 511.436, "end": 513.456, "text": "pero qué va a pasar", "speaker": null}, {"start": 513.456, "end": 514.796, "text": "ellos van a tener otra roca", "speaker": null}, {"start": 514.796, "end": 517.476, "text": "ellos se van a enfrentar a algo", "speaker": null}, {"start": 517.476, "end": 519.416, "text": "que no pueden controlar ellos de manera", "speaker": null}, {"start": 519.416, "end": 521.356, "text": "interno, como cuál?", "speaker": null}, {"start": 521.796, "end": 523.796, "text": "Dejémoslo de la competencia.", "speaker": null}, {"start": 524.93604, "end": 525.596, "text": "El mercado,", "speaker": null}, {"start": 525.81604, "end": 526.736, "text": "yo se los mencioné.", "speaker": null}, {"start": 527.336, "end": 529.596, "text": "¿Qué está pasando ahorita con los mercados automotrices?", "speaker": null}, {"start": 530.796, "end": 532.356, "text": "La tendencia está", "speaker": null}, {"start": 532.356, "end": 533.776, "text": "¿hacia dónde?", "speaker": null}, {"start": 534.836, "end": 535.676, "text": "Hacia lo", "speaker": null}, {"start": 535.676, "end": 537.276, "text": "tecnológico.", "speaker": null}, {"start": 537.276, "end": 539.116, "text": "Hoy, ¿qué le llama la atención?", "speaker": null}, {"start": 539.276, "end": 541.576, "text": "Bueno, ya me habías dicho que a ti no te interesa nada de eso.", "speaker": null}, {"start": 542.356, "end": 543.276, "text": "Al buen Mike", "speaker": null}, {"start": 543.276, "end": 545.116, "text": "le vale gorro, es independiente,", "speaker": null}, {"start": 545.216, "end": 546.596, "text": "es indiferente.", "speaker": null}, {"start": 547.236, "end": 549.016, "text": "Pero a lo mejor le preguntamos al señor", "speaker": null}, {"start": 549.016, "end": 550.616, "text": "¿Qué le interesaría a usted en un carro?", "speaker": null}, {"start": 579.016, "end": 585.016, "text": "entonces, imagínense, ustedes estar 3 o 4 meses nada más esperando que llegue la limpieza", "speaker": null}, {"start": 585.016, "end": 593.016, "text": "entonces, ese tipo de situaciones por ejemplo que interesan, si los motores se ven bien, si es automático, si es estándar", "speaker": null}, {"start": 593.016, "end": 602.016, "text": "yo por ejemplo, ahorro la segunda, cada millón no tiene ningún problema, como a nivel mecánico o a nivel funcional más que nada", "speaker": null}, {"start": 602.016, "end": 605.016, "text": "¿Qué computamos casualmente señor?", "speaker": null}, {"start": 605.016, "end": 606.536, "text": "y el señor no estaba", "speaker": null}, {"start": 606.536, "end": 609.996, "text": "entonces no comentamos eso", "speaker": null}, {"start": 609.996, "end": 611.196, "text": "de hecho", "speaker": null}, {"start": 611.196, "end": 613.596, "text": "un ejemplo de la vida", "speaker": null}, {"start": 613.596, "end": 613.856, "text": "real", "speaker": null}, {"start": 613.856, "end": 618.156, "text": "a la comal", "speaker": null}, {"start": 618.156, "end": 619.81604, "text": "tuvo la mala", "speaker": null}, {"start": 619.81604, "end": 621.796, "text": "fortuna de que le pegamos la camioneta", "speaker": null}, {"start": 621.796, "end": 622.236, "text": "y que", "speaker": null}, {"start": 622.236, "end": 624.776, "text": "lleva seis meses", "speaker": null}, {"start": 624.776, "end": 626.956, "text": "y la camioneta está parada", "speaker": null}, {"start": 626.956, "end": 628.796, "text": "¿por qué?", "speaker": null}, {"start": 628.796, "end": 629.81604, "text": "porque no hay", "speaker": null}, {"start": 629.81604, "end": 632.716, "text": "y la", "speaker": null}, {"start": 632.716, "end": 633.116, "text": "camioneta", "speaker": null}, {"start": 633.116, "end": 636.836, "text": "entonces lo que aparentemente", "speaker": null}, {"start": 636.836, "end": 638.43604, "text": "para un", "speaker": null}, {"start": 638.43604, "end": 641.396, "text": "comprador fue atractivo", "speaker": null}, {"start": 641.396, "end": 642.93604, "text": "fue un beneficio", "speaker": null}, {"start": 642.93604, "end": 644.93604, "text": "se convirtió en un problema", "speaker": null}, {"start": 644.93604, "end": 646.836, "text": "porque ahora", "speaker": null}, {"start": 646.836, "end": 648.236, "text": "pues", "speaker": null}, {"start": 648.236, "end": 650.296, "text": "aunque sacara el cargo de la defensa", "speaker": null}, {"start": 650.296, "end": 652.93604, "text": "porque si el mismo", "speaker": null}, {"start": 652.93604, "end": 654.256, "text": "proveedor no tiene las", "speaker": null}, {"start": 654.256, "end": 656.49603, "text": "y de modo usted lo va a arreglar", "speaker": null}, {"start": 656.49603, "end": 661.536, "text": "en que problema se convirtió", "speaker": null}, {"start": 661.536, "end": 663.256, "text": "van a comprar", "speaker": null}, {"start": 663.256, "end": 665.856, "text": "lo que aparentemente", "speaker": null}, {"start": 665.856, "end": 666.716, "text": "si van a comprar", "speaker": null}, {"start": 666.716, "end": 669.396, "text": "igual ni porque", "speaker": null}, {"start": 669.396, "end": 682.95404, "text": "no consumimos porque de alguna manera es psicol por todas las cosas que est que quieren vender pues ya se convirtieron en drogas porque al final la gente regresa", "speaker": null}, {"start": 682.95404, "end": 685.154, "text": "a un vehículo tradicional", "speaker": null}, {"start": 685.154, "end": 686.494, "text": "que les garantice", "speaker": null}, {"start": 686.494, "end": 688.57404, "text": "que van a tener caro", "speaker": null}, {"start": 688.57404, "end": 690.19403, "text": "ya olvídense de los demás", "speaker": null}, {"start": 690.19403, "end": 691.594, "text": "vas a tener caro", "speaker": null}, {"start": 691.594, "end": 695.994, "text": "entonces lo comentamos hace un rato", "speaker": null}, {"start": 695.994, "end": 696.874, "text": "si nos gustaba", "speaker": null}, {"start": 696.874, "end": 698.834, "text": "y casualmente nos convirtieron", "speaker": null}, {"start": 698.834, "end": 708.594, "text": "parece que es una loca, que si ahora vemos a los chavados a la fuga de ti, no se preocupan por eso, no se confíen lo que dicen,", "speaker": null}, {"start": 708.594, "end": 714.414, "text": "yo se lo dije de otra manera, pasan de lentes, pasan, y después me quedan los hijos,", "speaker": null}, {"start": 714.414, "end": 723.474, "text": "y me preguntan, a mí no me interesa, a los chavitos que les interesa la conectividad, la pantalla grandota,", "speaker": null}, {"start": 723.474, "end": 734.554, "text": "de la Tahuacan, que traiga su coche, el trono completo, que traiga llamas de camada, o tal", "speaker": null}, {"start": 734.554, "end": 742.39404, "text": "manera. ¿Sabes una cosa? A los líquidos lo que menos nos interesa es eso. Yo le puse", "speaker": null}, {"start": 742.39404, "end": 749.77405, "text": "el ejemplo hasta de los componentes del motor. Si hablamos de un vehículo 100% eléctrico,", "speaker": null}, {"start": 749.77405, "end": 750.57404, "text": "hoy en día", "speaker": null}, {"start": 750.57404, "end": 751.654, "text": "yo quiero saber", "speaker": null}, {"start": 751.654, "end": 752.654, "text": "para el cliente", "speaker": null}, {"start": 752.654, "end": 752.994, "text": "de modos", "speaker": null}, {"start": 752.994, "end": 753.674, "text": "de los modelos", "speaker": null}, {"start": 753.674, "end": 755.914, "text": "si tienen", "speaker": null}, {"start": 755.914, "end": 757.07404, "text": "la tecnología", "speaker": null}, {"start": 757.07404, "end": 758.554, "text": "y los scanners", "speaker": null}, {"start": 758.554, "end": 760.39404, "text": "para poder", "speaker": null}, {"start": 760.39404, "end": 761.234, "text": "revisarlo", "speaker": null}, {"start": 761.234, "end": 761.934, "text": "ya no le digo", "speaker": null}, {"start": 761.934, "end": 763.89404, "text": "arreglarlo", "speaker": null}, {"start": 763.89404, "end": 764.934, "text": "y supóngase", "speaker": null}, {"start": 764.934, "end": 765.69403, "text": "sin considerar", "speaker": null}, {"start": 765.69403, "end": 766.19403, "text": "que usted tiene", "speaker": null}, {"start": 766.19403, "end": 766.77405, "text": "el alarme", "speaker": null}, {"start": 766.77405, "end": 767.534, "text": "para comprar", "speaker": null}, {"start": 767.534, "end": 768.474, "text": "un equipo de esos", "speaker": null}, {"start": 768.474, "end": 769.69403, "text": "quiero saber", "speaker": null}, {"start": 769.69403, "end": 770.154, "text": "si lo sabe", "speaker": null}, {"start": 770.154, "end": 772.854, "text": "porque si un scanner", "speaker": null}, {"start": 772.854, "end": 773.594, "text": "global", "speaker": null}, {"start": 773.594, "end": 774.27405, "text": "hoy en día", "speaker": null}, {"start": 774.27405, "end": 776.07404, "text": "hay que", "speaker": null}, {"start": 776.07404, "end": 776.77405, "text": "porque hoy", "speaker": null}, {"start": 776.77405, "end": 777.234, "text": "ya no tenemos", "speaker": null}, {"start": 777.234, "end": 779.45404, "text": "los modelos", "speaker": null}, {"start": 779.45404, "end": 783.57404, "text": "si verdaderamente se han ocupado todas las funciones", "speaker": null}, {"start": 783.57404, "end": 786.154, "text": "porque hoy", "speaker": null}, {"start": 786.154, "end": 787.234, "text": "los cargos", "speaker": null}, {"start": 787.234, "end": 789.754, "text": "por muy buena marca que sea", "speaker": null}, {"start": 789.754, "end": 791.954, "text": "por buenas o por malas", "speaker": null}, {"start": 791.954, "end": 793.754, "text": "tecnológicamente hablando", "speaker": null}, {"start": 793.754, "end": 795.934, "text": "ya depende de", "speaker": null}, {"start": 795.934, "end": 797.554, "text": "modos en el futuro", "speaker": null}, {"start": 797.554, "end": 800.314, "text": "quiere decir que si ahora le destapas", "speaker": null}, {"start": 800.314, "end": 800.934, "text": "el cofre", "speaker": null}, {"start": 800.934, "end": 803.734, "text": "no esperes que el pinche coche te diga", "speaker": null}, {"start": 803.734, "end": 804.734, "text": "aquí está la valla", "speaker": null}, {"start": 804.734, "end": 807.874, "text": "si no lo escaneas correctamente", "speaker": null}, {"start": 807.874, "end": 810.574, "text": "en el model de aquel momento.", "speaker": null}, {"start": 812.13403, "end": 815.114, "text": "Y hoy tienes un problema enorme por buscarlo.", "speaker": null}, {"start": 816.89404, "end": 820.314, "text": "Que una calle, si no la tienes activa,", "speaker": null}, {"start": 821.074, "end": 823.454, "text": "o si no la detectas correctamente,", "speaker": null}, {"start": 824.51404, "end": 826.614, "text": "te produce fallas secuenciales.", "speaker": null}, {"start": 828.434, "end": 832.39404, "text": "Entonces, todo eso se convierte en un problema para el usuario.", "speaker": null}, {"start": 833.654, "end": 837.214, "text": "Porque al final del día, independientemente de la problemática,", "speaker": null}, {"start": 837.214, "end": 839.03406, "text": "a ese costo", "speaker": null}, {"start": 839.03406, "end": 840.89404, "text": "si tú te echas a ver a cuánto cuesta", "speaker": null}, {"start": 840.89404, "end": 842.294, "text": "un módulo automóvil", "speaker": null}, {"start": 842.294, "end": 845.89404, "text": "hay ocasiones que", "speaker": null}, {"start": 845.89404, "end": 847.89404, "text": "sencillamente", "speaker": null}, {"start": 847.89404, "end": 848.95404, "text": "la computadora", "speaker": null}, {"start": 848.95404, "end": 850.994, "text": "de carga", "speaker": null}, {"start": 850.994, "end": 853.174, "text": "te va a salir una", "speaker": null}, {"start": 853.174, "end": 854.474, "text": "de la autóctona", "speaker": null}, {"start": 854.474, "end": 857.254, "text": "y ya hablamos de la computadora de carga", "speaker": null}, {"start": 857.254, "end": 859.69403, "text": "hoy ya existen", "speaker": null}, {"start": 859.69403, "end": 861.614, "text": "módulos computarizados para las", "speaker": null}, {"start": 861.614, "end": 862.65405, "text": "transmisiones", "speaker": null}, {"start": 862.65405, "end": 866.19403, "text": "yo les mencionaba", "speaker": null}, {"start": 866.19403, "end": 869.01404, "text": "el tema de la vida chevere", "speaker": null}, {"start": 869.01404, "end": 872.374, "text": "en cuanto a que", "speaker": null}, {"start": 872.374, "end": 873.69403, "text": "pues", "speaker": null}, {"start": 873.69403, "end": 876.054, "text": "la tradición", "speaker": null}, {"start": 876.054, "end": 877.374, "text": "es hidrógena", "speaker": null}, {"start": 877.374, "end": 879.114, "text": "trae problemas en su mundo", "speaker": null}, {"start": 879.114, "end": 882.174, "text": "si hablamos", "speaker": null}, {"start": 882.174, "end": 882.714, "text": "de la", "speaker": null}, {"start": 882.714, "end": 885.334, "text": "no tengo a ser", "speaker": null}, {"start": 885.334, "end": 887.754, "text": "propaganda ni desprestigiada", "speaker": null}, {"start": 887.754, "end": 889.854, "text": "pero hoy", "speaker": null}, {"start": 889.854, "end": 891.174, "text": "muchas tradiciones", "speaker": null}, {"start": 891.174, "end": 893.27405, "text": "ya son de algunos", "speaker": null}, {"start": 893.27405, "end": 895.51404, "text": "lo cual", "speaker": null}, {"start": 895.51404, "end": 898.454, "text": "nos lleva a tener más o menos tradiciones", "speaker": null}]