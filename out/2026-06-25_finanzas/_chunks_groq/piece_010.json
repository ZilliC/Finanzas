[{"start": 0.0, "end": 1.9, "text": "hasta las direcciones.", "speaker": null}, {"start": 4.16, "end": 9.179999, "text": "Ya la mayor parte de los vehículos traen dirección asistida o electroasistida.", "speaker": null}, {"start": 10.94, "end": 16.84, "text": "Entonces, como veremos, eso se convierte, pues sí, en un avance tecnológico,", "speaker": null}, {"start": 17.02, "end": 19.02, "text": "pero también se puede convertir en un avance tecnológico.", "speaker": null}, {"start": 20.439999, "end": 23.779999, "text": "Porque aparte los cabos son hoy carnes más sensibles.", "speaker": null}, {"start": 24.08, "end": 27.08, "text": "Lo que decía el señor, aquí en México no lo sucede.", "speaker": null}, {"start": 27.08, "end": 30.52, "text": "pero imagínate que te encuentres en un bache", "speaker": null}, {"start": 30.52, "end": 32.64, "text": "o en un tope", "speaker": null}, {"start": 32.64, "end": 34.76, "text": "que aquí no son topes, parecen barbas", "speaker": null}, {"start": 34.76, "end": 37.14, "text": "y le llegas a dar un", "speaker": null}, {"start": 37.14, "end": 39.04, "text": "y le citas tu coche y le platicas", "speaker": null}, {"start": 39.04, "end": 40.739998, "text": "¿cómo fue con el coche?", "speaker": null}, {"start": 41.64, "end": 42.76, "text": "y lo que te va a costar", "speaker": null}, {"start": 42.76, "end": 47.02, "text": "o ya traes sensores para todo", "speaker": null}, {"start": 47.02, "end": 51.16, "text": "que no pones atención al mantenimiento", "speaker": null}, {"start": 51.16, "end": 52.399998, "text": "y te olvidas de los sensores", "speaker": null}, {"start": 52.399998, "end": 54.84, "text": "ya ya quedó", "speaker": null}, {"start": 54.84, "end": 56.3, "text": "y después lo cortas", "speaker": null}, {"start": 56.3, "end": 58.84, "text": "entonces efectivamente", "speaker": null}, {"start": 58.84, "end": 61.02, "text": "en eso estamos considerando", "speaker": null}, {"start": 61.02, "end": 63.379997, "text": "la competencia del sector", "speaker": null}, {"start": 63.379997, "end": 65.38, "text": "actualmente está", "speaker": null}, {"start": 65.38, "end": 67.979996, "text": "muy muy muy violenta", "speaker": null}, {"start": 67.979996, "end": 69.74, "text": "y sobre todo con los señores", "speaker": null}, {"start": 69.74, "end": 70.4, "text": "chinos", "speaker": null}, {"start": 70.4, "end": 73.06, "text": "desafortunadamente", "speaker": null}, {"start": 73.06, "end": 74.52, "text": "lo que mencionamos anteriormente", "speaker": null}, {"start": 74.52, "end": 75.5, "text": "lo puedo demostrar", "speaker": null}, {"start": 75.5, "end": 78.46, "text": "los chinos a México llegaron en la lente", "speaker": null}, {"start": 78.46, "end": 81.02, "text": "porque a México", "speaker": null}, {"start": 81.02, "end": 82.52, "text": "lamentablemente el mercado", "speaker": null}, {"start": 82.52, "end": 84.479996, "text": "no, no", "speaker": null}, {"start": 84.479996, "end": 86.81999, "text": "se han preocupado por la calidad", "speaker": null}, {"start": 86.81999, "end": 89.74, "text": "se están preocupando por el precio", "speaker": null}, {"start": 89.74, "end": 93.38, "text": "tuve la mayor parte de gente que trae caras", "speaker": null}, {"start": 93.38, "end": 97.31999, "text": "y les preguntas por qué", "speaker": null}, {"start": 97.31999, "end": 100.81999, "text": "pero no se han preocupado por lo que están haciendo", "speaker": null}, {"start": 100.81999, "end": 103.84, "text": "los saben por la calidad", "speaker": null}, {"start": 103.84, "end": 105.28, "text": "de sus motores", "speaker": null}, {"start": 105.28, "end": 109.6, "text": "y ya empezaron a flaquear con lo más sencillo", "speaker": null}, {"start": 109.6, "end": 110.439995, "text": "las reforzadas", "speaker": null}, {"start": 110.439995, "end": 113.7, "text": "si la refracción", "speaker": null}, {"start": 113.7, "end": 114.579994, "text": "de los valores en cuenta", "speaker": null}, {"start": 114.579994, "end": 115.939995, "text": "se imagina el cambio de motor", "speaker": null}, {"start": 115.939995, "end": 117.899994, "text": "que empieza a exigir", "speaker": null}, {"start": 117.899994, "end": 119.42, "text": "por naturaleza propia", "speaker": null}, {"start": 119.42, "end": 121.979996, "text": "ya no simples componentes", "speaker": null}, {"start": 121.979996, "end": 124.159996, "text": "sino ya las autopartes", "speaker": null}, {"start": 124.159996, "end": 124.759995, "text": "como lo es", "speaker": null}, {"start": 124.759995, "end": 129.15999, "text": "pero ellos se dividen", "speaker": null}, {"start": 129.15999, "end": 130.42, "text": "al final del día", "speaker": null}, {"start": 130.42, "end": 132.64, "text": "y cada vez tiene más presencia", "speaker": null}, {"start": 132.64, "end": 134.12, "text": "empezó por ahí", "speaker": null}, {"start": 134.12, "end": 136.08, "text": "hoy ve ya cuantas", "speaker": null}, {"start": 136.08, "end": 136.56, "text": "que no tienen", "speaker": null}, {"start": 136.56, "end": 140.28, "text": "y desafortunadamente", "speaker": null}, {"start": 140.28, "end": 145.86, "text": "cada vez hay más circulando. No digo eso profundamente en el sentido de media, sino", "speaker": null}, {"start": 145.86, "end": 153.31999, "text": "que efectivamente el mercado lo están captando los chinos. De hecho yo me atrevía a mencionar", "speaker": null}, {"start": 153.31999, "end": 157.62, "text": "las que se han hecho adelantos, se lo digo. Danes hace que le están poniendo contra la", "speaker": null}, {"start": 157.62, "end": 163.68, "text": "pared, ejemplo, a Alessandro. Ya le están poniendo contra la pared, ejemplo, a Volkswagen.", "speaker": null}, {"start": 163.68, "end": 166.35999, "text": "que ahorita están negociando", "speaker": null}, {"start": 166.35999, "end": 167.92, "text": "por una manera de meter", "speaker": null}, {"start": 167.92, "end": 169.51999, "text": "precisamente", "speaker": null}, {"start": 169.51999, "end": 173.09999, "text": "la parte de conectividad", "speaker": null}, {"start": 173.09999, "end": 173.93999, "text": "y pantallas", "speaker": null}, {"start": 173.93999, "end": 175.57999, "text": "chinas", "speaker": null}, {"start": 175.57999, "end": 177.84, "text": "a los vehículos alemanes", "speaker": null}, {"start": 177.84, "end": 180.4, "text": "casualmente ya se está", "speaker": null}, {"start": 180.4, "end": 182.51999, "text": "manejando ahorita la posible fusión", "speaker": null}, {"start": 182.51999, "end": 184.56, "text": "entre Nissan y Hyundai", "speaker": null}, {"start": 184.56, "end": 186.98, "text": "que de hecho ya la traen", "speaker": null}, {"start": 186.98, "end": 188.01999, "text": "con tiempo", "speaker": null}, {"start": 188.01999, "end": 192.34, "text": "bueno", "speaker": null}, {"start": 192.34, "end": 195.12, "text": "al menos que a los carros", "speaker": null}, {"start": 195.12, "end": 197.18, "text": "después hablamos de otras cosas", "speaker": null}, {"start": 197.18, "end": 198.01999, "text": "de su interés", "speaker": null}, {"start": 198.01999, "end": 201.2, "text": "pero por ahora vamos a tratar de", "speaker": null}, {"start": 201.2, "end": 203.31999, "text": "visualizar que estudio", "speaker": null}, {"start": 203.31999, "end": 204.58, "text": "que precisamente", "speaker": null}, {"start": 204.58, "end": 206.06, "text": "trata de", "speaker": null}, {"start": 206.06, "end": 210.76, "text": "esas situaciones", "speaker": null}, {"start": 210.76, "end": 212.3, "text": "¿vale?", "speaker": null}, {"start": 212.8, "end": 215.06, "text": "de hecho el programa no marca", "speaker": null}, {"start": 215.06, "end": 216.65999, "text": "no se mencionó porque existen", "speaker": null}, {"start": 216.65999, "end": 217.78, "text": "pero", "speaker": null}, {"start": 217.78, "end": 230.97801, "text": "no lo marca porque porque esos m no los vemos aqu esos m no van a ver ustedes en estad Regularmente llevan una materia de estad ah es donde ustedes van a estar poniendo", "speaker": null}, {"start": 231.97801, "end": 234.058, "text": "Es con los dos, ¿sabe?", "speaker": null}, {"start": 234.81801, "end": 242.31801, "text": "Ahí se los van a enseñar incluso con las curvas, que si son acílicas, que si no ven la sombra de la curva,", "speaker": null}, {"start": 242.978, "end": 249.438, "text": "van a ver la dirección estándar, la sombra de Diana, todo eso se ve en estadística.", "speaker": null}, {"start": 250.018, "end": 259.878, "text": "Si continuamos en la base con lo que en los centros nos corresponde, aquí ya podríamos hablar que existen distintas razones.", "speaker": null}, {"start": 260.918, "end": 268.49802, "text": "Vamos a comenzar con las que hay chicas que les pregunté por qué, porque son autores que las manejan a veces como financieras", "speaker": null}, {"start": 268.49802, "end": 273.018, "text": "y se van a encontrar que estas hay autores que se las separan.", "speaker": null}, {"start": 273.018, "end": 274.578, "text": "correcto", "speaker": null}, {"start": 274.578, "end": 275.558, "text": "si hablamos de", "speaker": null}, {"start": 275.558, "end": 280.418, "text": "índices financieros", "speaker": null}, {"start": 280.418, "end": 282.618, "text": "aquí podríamos hablar", "speaker": null}, {"start": 282.618, "end": 284.918, "text": "sencillamente de razones como cuáles", "speaker": null}, {"start": 284.918, "end": 286.678, "text": "como la libertad", "speaker": null}, {"start": 286.678, "end": 287.65802, "text": "de trabajo", "speaker": null}, {"start": 287.65802, "end": 289.99802, "text": "o la razón de capital de trabajo", "speaker": null}, {"start": 289.99802, "end": 292.698, "text": "cuando hablamos de solvencia", "speaker": null}, {"start": 292.698, "end": 294.318, "text": "va a haber quienes", "speaker": null}, {"start": 294.318, "end": 296.478, "text": "aquí incluyan", "speaker": null}, {"start": 296.478, "end": 298.49802, "text": "la razón de capital de trabajo", "speaker": null}, {"start": 298.49802, "end": 300.458, "text": "incluso en margen de seguridad", "speaker": null}, {"start": 300.458, "end": 302.078, "text": "etcétera", "speaker": null}, {"start": 302.078, "end": 308.798, "text": "Las deliquidez, pudiera acusar que van a encontrarse cuando menos la prueba severa y evidente.", "speaker": null}, {"start": 309.818, "end": 316.858, "text": "Cuando hablamos de rotación, estamos hablando que aquí, dependiendo del autor, van a encontrarse también diversas.", "speaker": null}, {"start": 317.318, "end": 321.418, "text": "Ejemplo, la razón de la rotación de cualquiera de los clientes,", "speaker": null}, {"start": 322.018, "end": 324.978, "text": "ejemplo, la razón de la rotación de cualquiera de los colegios,", "speaker": null}, {"start": 324.978, "end": 330.618, "text": "la razón de la rotación de inventarios, etc.", "speaker": null}, {"start": 332.078, "end": 340.818, "text": "cuando hablamos aquí de las cronológicas, hablamos, por ejemplo, del plazo de un de cobro,", "speaker": null}, {"start": 341.618, "end": 348.198, "text": "cuando hablamos de la cronológica, pudiéramos hablar del plazo de un de pago, y así sucesivamente, etc.", "speaker": null}, {"start": 350.03802, "end": 355.198, "text": "Y si ahora, aparte de clasificarlas, las quisiéramos nosotros aplicar,", "speaker": null}, {"start": 356.518, "end": 361.55798, "text": "bueno, quiero pensar que todos ustedes, a mí me ha de estar en su mente,", "speaker": null}, {"start": 362.078, "end": 364.738, "text": "¿Cuál es la fórmula que se aplica en cada caso?", "speaker": null}, {"start": 365.898, "end": 368.278, "text": "Y esa fórmula me gusta mucho, y es sencillo.", "speaker": null}, {"start": 369.078, "end": 373.21802, "text": "¿Por qué? Porque cuando me hablan de aquí voy a ocupar, por ejemplo, la prueba severa.", "speaker": null}, {"start": 373.678, "end": 376.618, "text": "Sabemos que la prueba severa va a ser igual a qué?", "speaker": null}, {"start": 377.918, "end": 382.758, "text": "Al activo circulante menos el inventario sobre el básico a 4.000 dólares.", "speaker": null}, {"start": 383.55798, "end": 387.298, "text": "Cuando hablamos de IRI, por ejemplo, sabemos que esta es la termina,", "speaker": null}, {"start": 387.298, "end": 393.318, "text": "considerando el efectivo en caja más el efectivo en bancos más el efectivo en inversión y", "speaker": null}, {"start": 393.318, "end": 396.938, "text": "materialización sobre el pasivo corto plazo.", "speaker": null}, {"start": 398.178, "end": 406.09802, "text": "Cuando hablamos de RCT hablamos de que consideramos el activo central sobre el pasivo corto plazo.", "speaker": null}, {"start": 406.778, "end": 413.09802, "text": "Cuando hablamos de el margen de seguridad hablamos de que vamos a considerar a CNT sobre", "speaker": null}, {"start": 413.71802, "end": 415.178, "text": "el pasivo corto plazo.", "speaker": null}, {"start": 415.178, "end": 417.678, "text": "cuando hablamos de CNT", "speaker": null}, {"start": 417.678, "end": 420.118, "text": "hablamos de que vamos a considerar", "speaker": null}, {"start": 420.118, "end": 424.59802, "text": "el valor de la actividad circulante", "speaker": null}, {"start": 424.59802, "end": 425.838, "text": "menos el vacío", "speaker": null}, {"start": 425.838, "end": 429.178, "text": "nuevamente se repite", "speaker": null}, {"start": 429.178, "end": 430.53802, "text": "el recente porque ya no nos", "speaker": null}, {"start": 430.53802, "end": 432.09802, "text": "entendemos en cáplica", "speaker": null}, {"start": 432.09802, "end": 434.898, "text": "tendríamos que ir a la actividad circulante", "speaker": null}, {"start": 434.898, "end": 435.618, "text": "sobre el vacío", "speaker": null}, {"start": 435.618, "end": 438.118, "text": "y así sucesivamente", "speaker": null}, {"start": 438.118, "end": 439.678, "text": "tendríamos que ir", "speaker": null}, {"start": 439.678, "end": 442.778, "text": "a la desarrollación", "speaker": null}, {"start": 442.778, "end": 456.476, "text": "cada una de ellas Obviamente eso lo debieron haber visto ya y t aqu lo tendr que aplicar Aqu lo tendr que aplicar", "speaker": null}, {"start": 456.476, "end": 460.51602, "text": "que ya básicamente nos tendríamos que basar a los índices", "speaker": null}, {"start": 460.51602, "end": 464.396, "text": "y ese índice, la tarea que tendríamos que desarrollar", "speaker": null}, {"start": 464.396, "end": 469.096, "text": "sería el darle su lectura o interpretación.", "speaker": null}, {"start": 470.07602, "end": 471.616, "text": "En el caso que así proceda,", "speaker": null}, {"start": 471.79602, "end": 473.91602, "text": "tendríamos que aplicar una lectura positiva", "speaker": null}, {"start": 473.91602, "end": 480.85602, "text": "con su defecto en el cálculo sin fusila, tendríamos que aplicar una lectura negativa.", "speaker": null}, {"start": 484.85602, "end": 486.396, "text": "Tú las has visto.", "speaker": null}, {"start": 487.35602, "end": 488.91602, "text": "Las que se llevan.", "speaker": null}, {"start": 491.376, "end": 494.91602, "text": "De la prueba se me da la disculpa, ¿cuál era la función de ese tipo?", "speaker": null}, {"start": 495.13602, "end": 495.816, "text": "¿La de ser musqueta?", "speaker": null}, {"start": 496.816, "end": 500.896, "text": "El agudo circulante de los alimentarios que pasó por tu casa.", "speaker": null}, {"start": 501.456, "end": 503.156, "text": "¿Eso es la que le dicen prueba de ácido?", "speaker": null}, {"start": 503.91602, "end": 511.17603, "text": "Si, hay autores que la conocen como prueba similar y hay autores que la conocen como prueba ácida.", "speaker": null}, {"start": 511.656, "end": 512.376, "text": "Es la misma.", "speaker": null}, {"start": 513.336, "end": 519.416, "text": "Por eso, en la experiencia que hemos dado, aquí hay autores que la manejan de una forma y otros que la manejan de otra.", "speaker": null}, {"start": 520.656, "end": 522.096, "text": "Aquí no tienes ningún problema.", "speaker": null}, {"start": 523.796, "end": 528.756, "text": "En esta, la puedes conocer como prueba similar o prueba ácida.", "speaker": null}, {"start": 529.49603, "end": 530.49603, "text": "Es la misma.", "speaker": null}, {"start": 531.49603, "end": 533.136, "text": "Nada más es fórmula.", "speaker": null}, {"start": 533.136, "end": 534.736, "text": "como la señala", "speaker": null}, {"start": 534.736, "end": 536.93604, "text": "en su defecto el autor", "speaker": null}, {"start": 536.93604, "end": 538.536, "text": "pero repito", "speaker": null}, {"start": 538.536, "end": 541.616, "text": "en la realidad es exactamente lo mismo", "speaker": null}, {"start": 541.616, "end": 545.376, "text": "dudas hasta que mal", "speaker": null}, {"start": 545.376, "end": 549.43604, "text": "¿cuáles", "speaker": null}, {"start": 549.43604, "end": 551.696, "text": "son las que vamos a utilizar", "speaker": null}, {"start": 551.696, "end": 552.556, "text": "principalmente?", "speaker": null}, {"start": 553.256, "end": 554.176, "text": "yo diría que todas", "speaker": null}, {"start": 554.176, "end": 556.796, "text": "y no nada más", "speaker": null}, {"start": 556.796, "end": 559.196, "text": "la 128", "speaker": null}, {"start": 559.196, "end": 572.93604, "text": "Mira, en realidad con que entiendas cómo se ocupa, con que entiendas de dónde salen las cifras,", "speaker": null}, {"start": 573.776, "end": 583.31604, "text": "y con que entiendas cómo darles lectura, no necesitas leer ni la 128, ni la 80, ni la 50.", "speaker": null}, {"start": 583.31604, "end": 586.716, "text": "todas llevan y se desarrollan", "speaker": null}, {"start": 586.716, "end": 588.096, "text": "bajo las mismas premisas", "speaker": null}, {"start": 588.096, "end": 589.456, "text": "todas", "speaker": null}, {"start": 589.456, "end": 591.136, "text": "incluso te repito", "speaker": null}, {"start": 591.136, "end": 592.656, "text": "si nos da tiempo", "speaker": null}, {"start": 592.656, "end": 596.256, "text": "estamos viendo", "speaker": null}, {"start": 596.256, "end": 598.43604, "text": "la petición de ustedes como repaso", "speaker": null}, {"start": 598.43604, "end": 599.93604, "text": "pero en realidad", "speaker": null}, {"start": 599.93604, "end": 601.416, "text": "eso se ha usado", "speaker": null}, {"start": 601.416, "end": 604.036, "text": "pero si nos da tiempo", "speaker": null}, {"start": 604.036, "end": 606.856, "text": "es más", "speaker": null}, {"start": 606.856, "end": 607.916, "text": "¿qué es lo que hacemos?", "speaker": null}, {"start": 608.476, "end": 609.43604, "text": "¿qué es lo que hacemos?", "speaker": null}, {"start": 610.076, "end": 611.276, "text": "¿estamos vacilados?", "speaker": null}, {"start": 611.276, "end": 616.476, "text": "Acuarela es un móvil, estimado Chávez, para los niños de Quiline.", "speaker": null}, {"start": 621.676, "end": 623.996, "text": "Vamos a empezar a desarrollar.", "speaker": null}, {"start": 626.136, "end": 629.43604, "text": "¿Cuál es el número de las alquileres que se están anunciando?", "speaker": null}, {"start": 631.896, "end": 640.296, "text": "Bien, si nosotros quisieramos ya aplicar este universo de medios,", "speaker": null}, {"start": 641.276, "end": 653.416, "text": "Pues tenemos que partir de premisas que nos permitan a nosotros tener ya herramientas para poder analizar a una empresa.", "speaker": null}, {"start": 654.336, "end": 658.276, "text": "Y esto trata de darnos esos elementos, esas herramientas.", "speaker": null}, {"start": 659.656, "end": 663.676, "text": "Y va a llegar el momento en que si tú logras manejar todo esto,", "speaker": null}, {"start": 664.516, "end": 668.276, "text": "con el simple hecho de ver la pura estructura del Estado financiero,", "speaker": null}, {"start": 668.276, "end": 669.976, "text": "financiero", "speaker": null}, {"start": 669.976, "end": 680.174, "text": "nada m con esto nosotros nos vamos a dar cuenta si la empresa est sana nos vamos a dar cuenta si la empresa est enferma", "speaker": null}, {"start": 680.174, "end": 681.674, "text": "o si la empresa", "speaker": null}, {"start": 681.674, "end": 683.974, "text": "hay que traerle un sacerdote", "speaker": null}, {"start": 683.974, "end": 685.174, "text": "porque ella está en política", "speaker": null}, {"start": 685.174, "end": 687.994, "text": "por lo que no lo creas", "speaker": null}, {"start": 687.994, "end": 689.834, "text": "esto está pasando", "speaker": null}, {"start": 689.834, "end": 691.39404, "text": "hoy en día allá afuera", "speaker": null}, {"start": 691.39404, "end": 694.274, "text": "hoy en día", "speaker": null}, {"start": 694.274, "end": 696.254, "text": "yo no sé", "speaker": null}, {"start": 696.254, "end": 697.51404, "text": "aclaro", "speaker": null}, {"start": 697.51404, "end": 698.714, "text": "si los dije desde el principio", "speaker": null}, {"start": 698.714, "end": 707.174, "text": "yo soy apolítico, no estoy a favor de nadie. Mis condiciones son muy personales. Pero desafortunadamente,", "speaker": null}, {"start": 707.734, "end": 713.754, "text": "cuando menos hasta ahorita los nuevos gobiernos, que es el de tu abuelo, el Eje, y el de tu", "speaker": null}, {"start": 713.754, "end": 720.77405, "text": "tía, es Claudia, no están entregando buenos resultados. Ahorita, en vez de que se generen", "speaker": null}, {"start": 720.77405, "end": 729.334, "text": "empresas. La realidad es que se está muriendo. Cada vez se están cerrando más empresas.", "speaker": null}, {"start": 730.474, "end": 736.174, "text": "Y si eso no agrega hasta la problemática global, que ya les mencioné también. De", "speaker": null}, {"start": 736.174, "end": 742.774, "text": "ejemplo, ahorita uno de los principales escenarios de enfrentamiento que tenemos es tu compadre", "speaker": null}, {"start": 742.77405, "end": 751.154, "text": "Trump, en donde él está poniendo tranquilidad en situaciones complicadas a la economía", "speaker": null}, {"start": 751.154, "end": 758.334, "text": "mexicana, comenzando por los aranceles. A mucha gente los aranceles, porque ya les", "speaker": null}, {"start": 758.334, "end": 762.794, "text": "preocupaba, yo te diría, están impactando en muchos sectores de la economía nacional.", "speaker": null}, {"start": 764.854, "end": 770.51404, "text": "Y si a eso le agregamos las bloques que tenemos, que van del otro lado del mundo, pues esto", "speaker": null}, {"start": 770.51404, "end": 778.39404, "text": "nos viene a poner otro, otro coscorro, nada menos en el sector energético.", "speaker": null}, {"start": 783.754, "end": 789.714, "text": "Más adelante vamos a tener que comentar este tipo de situaciones, pero cuando tengamos", "speaker": null}, {"start": 789.714, "end": 794.45404, "text": "un poquito más de elementos, un poquito más de herramientas, porque a lo mejor ahorita", "speaker": null}, {"start": 794.45404, "end": 800.494, "text": "estamos hablando un poco de un dato al aire. Cuando ya podamos hablar de situaciones de", "speaker": null}, {"start": 800.494, "end": 807.074, "text": "solvencia, de rentabilidad, de liquidez, de determinación de flujos, vamos a poder entrar", "speaker": null}, {"start": 807.074, "end": 812.89404, "text": "a temáticas un poquito más avanzadas. Yo ahorita te podría poner nada más con hipótesis", "speaker": null}, {"start": 812.89404, "end": 817.154, "text": "y básicamente aquí vas a empezar a desarrollar las primeras habilidades.", "speaker": null}, {"start": 817.154, "end": 819.974, "text": "¿cuáles voy a poner los escenarios?", "speaker": null}, {"start": 819.974, "end": 822.154, "text": "¿cuáles voy a poner los escenarios?", "speaker": null}, {"start": 828.174, "end": 829.614, "text": "si nosotros", "speaker": null}, {"start": 829.614, "end": 831.39404, "text": "tuviéramos un ejemplo", "speaker": null}, {"start": 847.154, "end": 849.794, "text": "Dos empresas diferentes, ya saben lo que es esto.", "speaker": null}, {"start": 851.234, "end": 853.51404, "text": "Son estados de posesión financiera.", "speaker": null}, {"start": 857.874, "end": 863.414, "text": "Quisiéramos tener un escenario A o una empresa A, un escenario B o empresa B.", "speaker": null}, {"start": 864.63403, "end": 868.334, "text": "Lo primero que me vendría a la mente preguntar es,", "speaker": null}, {"start": 870.274, "end": 872.454, "text": "¿qué pueden ver en esas empresas?", "speaker": null}, {"start": 872.934, "end": 874.934, "text": "Así como están con la pura estructura.", "speaker": null}, {"start": 875.254, "end": 876.534, "text": "¿Puedes ver algo en cada uno?", "speaker": null}, {"start": 877.154, "end": 881.154, "text": "¿No?", "speaker": null}, {"start": 882.494, "end": 884.114, "text": "¿Puedes ver algo así?", "speaker": null}, {"start": 884.39404, "end": 885.214, "text": "¿Con ese estructura?", "speaker": null}, {"start": 890.214, "end": 891.814, "text": "¿Ves aquí los pasivos?", "speaker": null}, {"start": 892.034, "end": 892.934, "text": "¿Es lo que podrías ver?", "speaker": null}, {"start": 893.714, "end": 894.89404, "text": "Y un capitán.", "speaker": null}, {"start": 895.674, "end": 896.314, "text": "¿Nombre?", "speaker": null}, {"start": 896.914, "end": 897.174, "text": "José.", "speaker": null}, {"start": 897.63403, "end": 899.694, "text": "José, ¿puedes ver algo ahí con eso?", "speaker": null}]