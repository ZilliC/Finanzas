[{"start": 0.35999998, "end": 5.0, "text": "Entre otros impuestos tenemos impuestos federales e impuestos locales.", "speaker": null}, {"start": 6.04, "end": 16.8, "text": "Los impuestos federales son aquellos que aplican en toda la República.", "speaker": null}, {"start": 18.199999, "end": 19.18, "text": "Es el mismo impuesto.", "speaker": null}, {"start": 30.0, "end": 41.56, "text": "los impuestos generales de pico son criterios que aplican en todo el barrio", "speaker": null}, {"start": 41.56, "end": 45.66, "text": "si yo hablo de impuestos generales", "speaker": null}, {"start": 45.66, "end": 47.26, "text": "a quienes podríamos señalar", "speaker": null}, {"start": 47.26, "end": 49.5, "text": "el ejemplo", "speaker": null}, {"start": 49.5, "end": 50.56, "text": "al IVA", "speaker": null}, {"start": 50.56, "end": 52.5, "text": "es el impuesto en barrio legal", "speaker": null}, {"start": 52.5, "end": 55.14, "text": "el ejemplo", "speaker": null}, {"start": 55.14, "end": 57.559998, "text": "al ISM", "speaker": null}, {"start": 57.559998, "end": 59.66, "text": "es el impuesto sobre la renta", "speaker": null}, {"start": 60.0, "end": 61.66, "text": "¿Qué más?", "speaker": null}, {"start": 62.28, "end": 64.0, "text": "Por ejemplo, el IES", "speaker": null}, {"start": 64.0, "end": 68.1, "text": "es el Impuesto Especial sobre", "speaker": null}, {"start": 68.1, "end": 70.52, "text": "Producción y Servicio, etc.", "speaker": null}, {"start": 71.64, "end": 74.24, "text": "Y tenemos impuestos locales", "speaker": null}, {"start": 75.24, "end": 76.4, "text": "como cuáles", "speaker": null}, {"start": 76.4, "end": 77.22, "text": "¡Ah! ¡Ojo aquí!", "speaker": null}, {"start": 78.48, "end": 80.42, "text": "Aquí vamos a hablar de que hay impuestos", "speaker": null}, {"start": 80.42, "end": 82.52, "text": "directos e impuestos", "speaker": null}, {"start": 82.52, "end": 83.78, "text": "indirectos", "speaker": null}, {"start": 83.78, "end": 86.32, "text": "Por ejemplo, el ISR", "speaker": null}, {"start": 86.32, "end": 87.56, "text": "es un impuesto", "speaker": null}, {"start": 87.56, "end": 89.32, "text": "directo", "speaker": null}, {"start": 89.32, "end": 100.28, "text": "El IVA es un impuesto indirecto, el IES es un impuesto indirecto y así sucesivamente.", "speaker": null}, {"start": 103.54, "end": 105.5, "text": "¿Cuál es la diferencia?", "speaker": null}, {"start": 108.44, "end": 114.299995, "text": "Los impuestos directos son los que yo pago a Chaleco, yo que los pago.", "speaker": null}, {"start": 114.299995, "end": 120.63999, "text": "Y los impuestos indirectos son aquellos que los puedo trasladar.", "speaker": null}, {"start": 121.38, "end": 124.979996, "text": "Es decir, que me toca a mí, pero se los puedo trasladar a mi hijo.", "speaker": null}, {"start": 125.579994, "end": 128.51999, "text": "Y él se los puede trasladar al pancho.", "speaker": null}, {"start": 129.65999, "end": 130.54, "text": "Y eso es sucesivamente.", "speaker": null}, {"start": 132.65999, "end": 133.26, "text": "Ok.", "speaker": null}, {"start": 134.0, "end": 141.36, "text": "Cuando hablamos, cuando hablamos de un impuesto directo,", "speaker": null}, {"start": 141.36, "end": 143.12, "text": "repito, es el que yo tengo que pagar.", "speaker": null}, {"start": 144.3, "end": 148.0, "text": "El impuesto de la renta lo tiene que pagar cada uno de ustedes.", "speaker": null}, {"start": 148.8, "end": 151.32, "text": "¿En función a qué? A sus intereses.", "speaker": null}, {"start": 152.7, "end": 154.58, "text": "Dependiendo de lo que ganes y lo que pagues.", "speaker": null}, {"start": 155.40001, "end": 158.64, "text": "De ahí también le da de todo el mundo el que más gane y más pague.", "speaker": null}, {"start": 159.66, "end": 160.3, "text": "¿Estamos de acuerdo?", "speaker": null}, {"start": 160.98, "end": 163.58, "text": "Pero la ley del impuesto de la renta no lo consideras.", "speaker": null}, {"start": 163.86, "end": 165.52, "text": "La ley del impuesto de la renta no la consideras.", "speaker": null}, {"start": 165.68001, "end": 170.96, "text": "En sí, en las previsas, en donde tienes que ver que hay una idea de los tres.", "speaker": null}, {"start": 170.96, "end": 173.31999, "text": "si se llega a la ventaja", "speaker": null}, {"start": 173.31999, "end": 174.81999, "text": "que tengas más deducciones", "speaker": null}, {"start": 174.81999, "end": 176.45999, "text": "es decir, han escuchado", "speaker": null}, {"start": 176.45999, "end": 179.06, "text": "en la época de los impuestos", "speaker": null}, {"start": 179.06, "end": 181.09999, "text": "todo lo que estaba contigo", "speaker": null}, {"start": 181.09999, "end": 182.81999, "text": "checa tus deducciones", "speaker": null}, {"start": 182.81999, "end": 185.43999, "text": "¿para qué? para que no pares", "speaker": null}, {"start": 185.43999, "end": 187.51999, "text": "si tú tienes", "speaker": null}, {"start": 187.51999, "end": 188.65999, "text": "más deducciones", "speaker": null}, {"start": 188.65999, "end": 190.23999, "text": "o suficientes deducciones", "speaker": null}, {"start": 190.23999, "end": 192.87999, "text": "mayormente están en base a tu pago de impuestos", "speaker": null}, {"start": 192.87999, "end": 195.35999, "text": "a diferencia de él", "speaker": null}, {"start": 195.35999, "end": 197.51999, "text": "él va a ser trasladado", "speaker": null}, {"start": 197.51999, "end": 201.13998, "text": "es importante que ustedes sepan", "speaker": null}, {"start": 201.13998, "end": 202.01999, "text": "de esto mucho más", "speaker": null}, {"start": 202.01999, "end": 204.23999, "text": "es que nos estamos haciendo", "speaker": null}, {"start": 204.23999, "end": 205.93999, "text": "un tema de los que nos preocupan", "speaker": null}, {"start": 205.93999, "end": 207.79999, "text": "vamos para allá", "speaker": null}, {"start": 207.79999, "end": 211.9, "text": "han escuchado que hay", "speaker": null}, {"start": 211.9, "end": 214.51999, "text": "mucha gente que se pide", "speaker": null}, {"start": 214.51999, "end": 216.12, "text": "dice", "speaker": null}, {"start": 216.12, "end": 217.77998, "text": "ah, pues yo tengo que pagar", "speaker": null}, {"start": 217.77998, "end": 219.87999, "text": "me toca pagar yo, la madre", "speaker": null}, {"start": 219.87999, "end": 230.018, "text": "me voy a quedar sin dinero han escuchado esto o no tengo dinero para pagarme Yo te digo no me gastas nada Porque yo concibo que", "speaker": null}, {"start": 230.67801, "end": 232.018, "text": "...sobre todo, sobre todo, sobre todo, sobre todo...", "speaker": null}, {"start": 233.198, "end": 235.17801, "text": "...dice, oiga, y si no es que...", "speaker": null}, {"start": 235.17801, "end": 237.798, "text": "...que yo te puse pronto, que yo te puse...", "speaker": null}, {"start": 237.798, "end": 240.018, "text": "...que yo...", "speaker": null}, {"start": 241.53801, "end": 242.018, "text": "...que yo...", "speaker": null}, {"start": 242.018, "end": 246.018, "text": "...oiga, no charly...", "speaker": null}, {"start": 247.03801, "end": 247.858, "text": "...no te quiero...", "speaker": null}, {"start": 250.018, "end": 251.878, "text": "es que no te van a venir y darte", "speaker": null}, {"start": 251.878, "end": 253.81801, "text": "y te van a ir", "speaker": null}, {"start": 253.81801, "end": 255.998, "text": "y si, y cada día me ponen en brotes", "speaker": null}, {"start": 255.998, "end": 258.018, "text": "tú te vas a ir consiguiendo dinero", "speaker": null}, {"start": 258.018, "end": 259.038, "text": "para la chica", "speaker": null}, {"start": 259.038, "end": 261.71802, "text": "a ver, a ver, a ver", "speaker": null}, {"start": 261.71802, "end": 264.15802, "text": "a ver, no me tomas espacio ya", "speaker": null}, {"start": 264.15802, "end": 265.738, "text": "si", "speaker": null}, {"start": 265.738, "end": 268.398, "text": "es que siempre te vas a ir consiguiendo dinero", "speaker": null}, {"start": 268.398, "end": 269.138, "text": "para la chica", "speaker": null}, {"start": 269.138, "end": 272.598, "text": "como aquí ya desde ahí", "speaker": null}, {"start": 272.598, "end": 273.238, "text": "estamos dando", "speaker": null}, {"start": 273.238, "end": 275.418, "text": "porque es muy difícil", "speaker": null}, {"start": 275.418, "end": 276.918, "text": "¿sabes?", "speaker": null}, {"start": 277.758, "end": 279.71802, "text": "y de ahí no tienes que pagar nunca", "speaker": null}, {"start": 279.71802, "end": 309.698, "text": "¿Para quién?", "speaker": null}, {"start": 309.71802, "end": 313.678, "text": "que yo soy así", "speaker": null}, {"start": 313.678, "end": 317.138, "text": "yo les explico", "speaker": null}, {"start": 317.138, "end": 318.818, "text": "háganme cuenta que yo soy así", "speaker": null}, {"start": 318.818, "end": 320.698, "text": "yo les digo a la gente", "speaker": null}, {"start": 320.698, "end": 323.678, "text": "todos, todo el grupo", "speaker": null}, {"start": 323.678, "end": 324.998, "text": "aquí ya pasó todo", "speaker": null}, {"start": 324.998, "end": 327.118, "text": "todo el grupo tiene que pagar", "speaker": null}, {"start": 327.118, "end": 329.518, "text": "y el de ese sitio", "speaker": null}, {"start": 329.518, "end": 332.038, "text": "porque yo soy la generación", "speaker": null}, {"start": 332.038, "end": 334.078, "text": "a mí me da la culpa", "speaker": null}, {"start": 334.078, "end": 336.498, "text": "pero yo no tengo que pagar", "speaker": null}, {"start": 336.498, "end": 339.038, "text": "por cualquiera de los puestos que marcarán", "speaker": null}, {"start": 339.038, "end": 341.71802, "text": "y los impuestos van a ser ¿por qué?", "speaker": null}, {"start": 342.538, "end": 343.678, "text": "por inagilación", "speaker": null}, {"start": 343.678, "end": 345.338, "text": "¿verdad? ¿por qué?", "speaker": null}, {"start": 346.338, "end": 347.918, "text": "por aros comerciales", "speaker": null}, {"start": 347.918, "end": 349.59802, "text": "por arreglamiento", "speaker": null}, {"start": 349.59802, "end": 352.238, "text": "por donde te muevas", "speaker": null}, {"start": 352.238, "end": 353.71802, "text": "por actos o actividades", "speaker": null}, {"start": 353.71802, "end": 355.758, "text": "donde te muevas tienes que pagar", "speaker": null}, {"start": 355.758, "end": 357.678, "text": "¿por qué?", "speaker": null}, {"start": 357.938, "end": 359.798, "text": "porque ese impuesto", "speaker": null}, {"start": 359.798, "end": 361.038, "text": "ese dinero es para mí", "speaker": null}, {"start": 361.038, "end": 363.498, "text": "es mío", "speaker": null}, {"start": 363.498, "end": 363.918, "text": "¿de acuerdo?", "speaker": null}, {"start": 365.198, "end": 366.818, "text": "entonces si usted le vende algo", "speaker": null}, {"start": 366.818, "end": 368.578, "text": "al mal", "speaker": null}, {"start": 368.578, "end": 371.358, "text": "tiene que ir con IVA", "speaker": null}, {"start": 371.358, "end": 374.71802, "text": "IVA a la tasa del 16%", "speaker": null}, {"start": 374.71802, "end": 376.03802, "text": "¿de acuerdo?", "speaker": null}, {"start": 377.678, "end": 379.678, "text": "entonces si el maestro le da algo", "speaker": null}, {"start": 379.678, "end": 381.078, "text": "al pancho", "speaker": null}, {"start": 381.078, "end": 383.678, "text": "¿de acuerdo?", "speaker": null}, {"start": 386.05798, "end": 386.61798, "text": "¿sí?", "speaker": null}, {"start": 388.018, "end": 389.438, "text": "y así sucesivamente", "speaker": null}, {"start": 389.438, "end": 390.978, "text": "hasta el último día", "speaker": null}, {"start": 390.978, "end": 401.638, "text": "¿cuál es la esencia de Dios?", "speaker": null}, {"start": 404.078, "end": 405.898, "text": "que lo va a pagar", "speaker": null}, {"start": 405.898, "end": 408.11798, "text": "quien te desarrolle el acto", "speaker": null}, {"start": 408.11798, "end": 411.078, "text": "correcto", "speaker": null}, {"start": 411.078, "end": 413.498, "text": "entonces ¿qué sucede?", "speaker": null}, {"start": 414.498, "end": 415.498, "text": "yo les voy a decir", "speaker": null}, {"start": 415.498, "end": 417.818, "text": "todo el vida que ustedes", "speaker": null}, {"start": 417.818, "end": 419.638, "text": "cobran", "speaker": null}, {"start": 419.638, "end": 425.238, "text": "pero Charly se pone a escuchar y dice", "speaker": null}, {"start": 425.238, "end": 425.918, "text": "oiga", "speaker": null}, {"start": 425.918, "end": 429.09802, "text": "pero hay un argumento que yo también", "speaker": null}, {"start": 429.09802, "end": 430.838, "text": "me convierto en consumidor", "speaker": null}, {"start": 430.838, "end": 435.09802, "text": "y ahí también me van a cobrar el IVA", "speaker": null}, {"start": 435.09802, "end": 438.298, "text": "y ahí te va a pasar", "speaker": null}, {"start": 438.298, "end": 441.578, "text": "el IVA que te pagas", "speaker": null}, {"start": 441.578, "end": 443.438, "text": "yo te lo devuelvo", "speaker": null}, {"start": 443.438, "end": 454.596, "text": "porque est usando un IVA que no es tuyo acuerdo Bueno Entonces el IVA que cobre", "speaker": null}, {"start": 455.116, "end": 455.57602, "text": "¿qué tienes?", "speaker": null}, {"start": 457.07602, "end": 458.036, "text": "Ya siento.", "speaker": null}, {"start": 459.256, "end": 460.696, "text": "Entonces, me lo tienes que entregar.", "speaker": null}, {"start": 462.13602, "end": 462.816, "text": "¿De acuerdo, chaval?", "speaker": null}, {"start": 463.63602, "end": 464.876, "text": "Cuando tú le vendas", "speaker": null}, {"start": 464.876, "end": 467.036, "text": "algo a un cliente,", "speaker": null}, {"start": 467.556, "end": 469.67603, "text": "¿le vas a cobrar algo?", "speaker": null}, {"start": 473.696, "end": 474.29602, "text": "Bueno.", "speaker": null}, {"start": 475.036, "end": 477.976, "text": "Ese IVA que tú cobras,", "speaker": null}, {"start": 479.23602, "end": 480.216, "text": "¿de dónde viene este carácter?", "speaker": null}, {"start": 480.956, "end": 484.476, "text": "Ejemplo, le vendiste algo en 10.000 pesos,", "speaker": null}, {"start": 485.776, "end": 488.336, "text": "¿cuánto le tienes que cobrar a Carlos?", "speaker": null}, {"start": 489.196, "end": 492.256, "text": "Digo, a Mike.", "speaker": null}, {"start": 493.13602, "end": 493.936, "text": "¿11.600?", "speaker": null}, {"start": 494.036, "end": 494.956, "text": "Le vendiste la lava.", "speaker": null}, {"start": 495.496, "end": 496.216, "text": "¿Sabes qué es eso?", "speaker": null}, {"start": 496.696, "end": 499.496, "text": "Le vendiste la lava a Mike.", "speaker": null}, {"start": 501.256, "end": 502.896, "text": "La lava vale 10.000.", "speaker": null}, {"start": 502.896, "end": 505.836, "text": "pero como tienes la obligación de pagar", "speaker": null}, {"start": 505.836, "end": 508.316, "text": "en cuánto se va a vender", "speaker": null}, {"start": 508.316, "end": 509.096, "text": "al baile", "speaker": null}, {"start": 509.096, "end": 511.036, "text": "en 11.600", "speaker": null}, {"start": 511.036, "end": 514.636, "text": "de los 11.600 que te pagas", "speaker": null}, {"start": 514.636, "end": 516.756, "text": "1.600 menos", "speaker": null}, {"start": 516.756, "end": 517.536, "text": "que los 1.000", "speaker": null}, {"start": 517.536, "end": 520.136, "text": "los otros 1.000 son dichos", "speaker": null}, {"start": 520.136, "end": 522.256, "text": "¿estamos de acuerdo?", "speaker": null}, {"start": 522.376, "end": 522.856, "text": "¿estamos de acuerdo?", "speaker": null}, {"start": 524.116, "end": 524.376, "text": "¿sí?", "speaker": null}, {"start": 525.396, "end": 527.896, "text": "pero va a llegar el momento en que a lo mejor", "speaker": null}, {"start": 527.896, "end": 529.036, "text": "si viene", "speaker": null}, {"start": 529.036, "end": 530.336, "text": "Pancho", "speaker": null}, {"start": 530.336, "end": 533.49603, "text": "y Pancho que vende", "speaker": null}, {"start": 533.49603, "end": 537.236, "text": "un teléfono", "speaker": null}, {"start": 537.236, "end": 538.31604, "text": "u otra computadora", "speaker": null}, {"start": 538.31604, "end": 541.236, "text": "y", "speaker": null}, {"start": 541.236, "end": 543.49603, "text": "Pancho que vende", "speaker": null}, {"start": 543.49603, "end": 544.616, "text": "la computadora", "speaker": null}, {"start": 544.616, "end": 546.516, "text": "en su conjunto", "speaker": null}, {"start": 546.516, "end": 549.056, "text": "otro", "speaker": null}, {"start": 549.056, "end": 551.016, "text": "diferente, más barato", "speaker": null}, {"start": 551.016, "end": 554.456, "text": "entonces", "speaker": null}, {"start": 554.456, "end": 556.296, "text": "Pancho que trae los movimientos", "speaker": null}, {"start": 556.296, "end": 558.336, "text": "cuando Pancho venga", "speaker": null}, {"start": 558.336, "end": 560.93604, "text": "va a cobrar un IVA", "speaker": null}, {"start": 560.93604, "end": 562.376, "text": "y ese IVA", "speaker": null}, {"start": 562.376, "end": 569.776, "text": "¿cuánto va a cobrar de IVA Pancho?", "speaker": null}, {"start": 570.556, "end": 571.31604, "text": "8.000", "speaker": null}, {"start": 571.31604, "end": 574.836, "text": "entonces ya le hice unos datos", "speaker": null}, {"start": 574.836, "end": 575.636, "text": "sobre el físico", "speaker": null}, {"start": 575.636, "end": 577.456, "text": "tú no vas a pagar 1.600", "speaker": null}, {"start": 577.456, "end": 579.156, "text": "Pancho no va a pagar 800", "speaker": null}, {"start": 579.156, "end": 581.296, "text": "otro no va a pagar 500", "speaker": null}, {"start": 581.296, "end": 582.896, "text": "otro no va a pagar 5.000", "speaker": null}, {"start": 582.896, "end": 584.236, "text": "voy bien o mal", "speaker": null}, {"start": 584.236, "end": 587.116, "text": "pero entonces tú que vas a decir", "speaker": null}, {"start": 587.116, "end": 589.136, "text": "oye Fisco", "speaker": null}, {"start": 589.136, "end": 590.69604, "text": "espérate tantito", "speaker": null}, {"start": 590.69604, "end": 592.356, "text": "si tú dices que el IVA es tuyo", "speaker": null}, {"start": 592.356, "end": 595.756, "text": "está bien yo te lo voy a entregar", "speaker": null}, {"start": 595.756, "end": 597.556, "text": "pero ¿qué crees?", "speaker": null}, {"start": 598.336, "end": 599.556, "text": "cuando yo le compré", "speaker": null}, {"start": 599.556, "end": 600.556, "text": "a Pancho", "speaker": null}, {"start": 600.556, "end": 602.836, "text": "yo le pagué un IVA", "speaker": null}, {"start": 602.836, "end": 604.616, "text": "no lo cobré", "speaker": null}, {"start": 604.616, "end": 606.216, "text": "entonces", "speaker": null}, {"start": 606.216, "end": 609.036, "text": "dale de tu IVA", "speaker": null}, {"start": 609.036, "end": 610.556, "text": "para pagar su IVA", "speaker": null}, {"start": 610.556, "end": 612.676, "text": "¿o no?", "speaker": null}, {"start": 614.536, "end": 616.276, "text": "entonces yo te voy a contestar", "speaker": null}, {"start": 616.276, "end": 619.43604, "text": "No, no, no, espérate, charla, imagínate que yo esté regresando,", "speaker": null}, {"start": 619.776, "end": 625.656, "text": "depositándote IVAs, cabotos, no manches, son millones de contribuyentes.", "speaker": null}, {"start": 626.956, "end": 627.476, "text": "No puedo.", "speaker": null}, {"start": 628.49603, "end": 630.176, "text": "¿Qué te parece que hagamos un negocio?", "speaker": null}, {"start": 631.776, "end": 635.836, "text": "Al IVA que tú cobres, quítale el IVA que tú pagas.", "speaker": null}, {"start": 637.31604, "end": 639.036, "text": "Y me entregas la diferencia.", "speaker": null}, {"start": 639.036, "end": 649.036, "text": "¿Es algo o no?", "speaker": null}, {"start": 650.156, "end": 650.536, "text": "Sí", "speaker": null}, {"start": 650.536, "end": 653.136, "text": "La chamba te la dejo a ti", "speaker": null}, {"start": 653.136, "end": 654.476, "text": "No la hago yo", "speaker": null}, {"start": 654.476, "end": 659.756, "text": "Y cada vez me entregas la diferencia", "speaker": null}, {"start": 659.756, "end": 662.736, "text": "¿Voy bien o me regreso?", "speaker": null}, {"start": 663.736, "end": 664.256, "text": "Ok", "speaker": null}, {"start": 664.256, "end": 666.716, "text": "¿Cómo lo controlamos contablemente?", "speaker": null}, {"start": 666.716, "end": 669.43604, "text": "contable viste", "speaker": null}, {"start": 669.43604, "end": 681.154, "text": "e iba a re por el IVA que t cobras el IVA que t cobras", "speaker": null}, {"start": 681.154, "end": 683.674, "text": "se va a llamar IVA", "speaker": null}, {"start": 683.674, "end": 684.354, "text": "¿qué?", "speaker": null}, {"start": 687.354, "end": 688.19403, "text": "traslada", "speaker": null}, {"start": 688.19403, "end": 692.034, "text": "y el IVA que tú pagas", "speaker": null}, {"start": 692.034, "end": 695.874, "text": "porque tú también vas a pagar el IVA", "speaker": null}, {"start": 695.874, "end": 699.214, "text": "se va a llamar IVA", "speaker": null}, {"start": 699.214, "end": 727.214, "text": "Pensemos que tú cobraste cien, o mil, o diez mil, o cien mil vivas, en teoría ese es el", "speaker": null}, {"start": 727.214, "end": 736.57404, "text": "pero resulta", "speaker": null}, {"start": 736.57404, "end": 738.674, "text": "que tú", "speaker": null}, {"start": 738.674, "end": 740.294, "text": "pagaste IVA", "speaker": null}, {"start": 740.294, "end": 741.234, "text": "ejemplo", "speaker": null}, {"start": 741.234, "end": 746.474, "text": "o como lo teníamos ahorita", "speaker": null}, {"start": 746.474, "end": 748.114, "text": "eran 1800 y 800", "speaker": null}, {"start": 748.114, "end": 749.554, "text": "no, 1600", "speaker": null}, {"start": 749.554, "end": 750.994, "text": "600 y 800", "speaker": null}, {"start": 750.994, "end": 753.934, "text": "o eran 1800 y allá", "speaker": null}, {"start": 753.934, "end": 756.654, "text": "entre lo de Pancho y otros", "speaker": null}, {"start": 756.654, "end": 759.254, "text": "proveedores, pagaste", "speaker": null}, {"start": 759.254, "end": 761.354, "text": "mil dos kilos. Digo, aquí las hijos", "speaker": null}, {"start": 761.354, "end": 762.414, "text": "no te los pudo, no,", "speaker": null}, {"start": 762.51404, "end": 765.07404, "text": "estamos de acuerdo.", "speaker": null}, {"start": 766.174, "end": 766.474, "text": "Ok,", "speaker": null}, {"start": 767.034, "end": 769.174, "text": "¿qué sucede cuando", "speaker": null}, {"start": 769.174, "end": 770.234, "text": "hacemos esta operación?", "speaker": null}, {"start": 772.01404, "end": 773.034, "text": "Si aquí el", "speaker": null}, {"start": 773.034, "end": 773.934, "text": "inacreditable", "speaker": null}, {"start": 773.934, "end": 776.834, "text": "es menor que el", "speaker": null}, {"start": 776.834, "end": 778.754, "text": "acatadado, el saldo es de cinco.", "speaker": null}, {"start": 781.994, "end": 783.094, "text": "Oye, pero si fuera", "speaker": null}, {"start": 783.094, "end": 783.63403, "text": "al revés,", "speaker": null}, {"start": 783.63403, "end": 789.754, "text": "aquí también", "speaker": null}, {"start": 789.754, "end": 790.434, "text": "la suma", "speaker": null}, {"start": 790.434, "end": 793.254, "text": "¿cuál es la diferencia?", "speaker": null}, {"start": 794.254, "end": 795.274, "text": "¿qué es el saldo a favor?", "speaker": null}, {"start": 796.214, "end": 796.934, "text": "efectivamente", "speaker": null}, {"start": 796.934, "end": 799.51404, "text": "aquí como el trasladado", "speaker": null}, {"start": 799.51404, "end": 801.174, "text": "es mayor que el acreditable", "speaker": null}, {"start": 801.174, "end": 803.374, "text": "el IVA de Hacienda", "speaker": null}, {"start": 803.374, "end": 805.234, "text": "es mayor", "speaker": null}, {"start": 805.234, "end": 808.314, "text": "entonces como consecuencia", "speaker": null}, {"start": 808.314, "end": 809.914, "text": "pagaste lo que", "speaker": null}, {"start": 809.914, "end": 811.554, "text": "tenía que pagar Hacienda", "speaker": null}, {"start": 811.554, "end": 814.07404, "text": "y como consecuencia", "speaker": null}, {"start": 814.07404, "end": 815.39404, "text": "te sobraron 50", "speaker": null}, {"start": 815.39404, "end": 818.554, "text": "esos 50 no son tuyos Carlos", "speaker": null}, {"start": 818.554, "end": 819.89404, "text": "¿de quién son?", "speaker": null}, {"start": 821.27405, "end": 822.51404, "text": "de Hacienda", "speaker": null}, {"start": 822.51404, "end": 823.674, "text": "entonces", "speaker": null}, {"start": 823.674, "end": 825.714, "text": "esto va a ser un IVA", "speaker": null}, {"start": 825.714, "end": 829.114, "text": "por pagar", "speaker": null}, {"start": 829.114, "end": 831.674, "text": "¿por qué es por pagar?", "speaker": null}, {"start": 831.89404, "end": 833.974, "text": "porque tú se lo tienes que devolverse", "speaker": null}, {"start": 833.974, "end": 834.974, "text": "lo tienes que entregar", "speaker": null}, {"start": 834.974, "end": 836.254, "text": "se lo tienes que pagar a Hacienda", "speaker": null}, {"start": 836.254, "end": 841.294, "text": "aquí el IVA trasladado", "speaker": null}, {"start": 841.294, "end": 842.954, "text": "fue menor que lo acreditable.", "speaker": null}, {"start": 846.534, "end": 847.094, "text": "¿Qué va a pasar?", "speaker": null}, {"start": 847.974, "end": 849.414, "text": "Tú pagaste más", "speaker": null}, {"start": 849.414, "end": 850.774, "text": "a nombre de Hacienda", "speaker": null}, {"start": 850.774, "end": 853.274, "text": "que lo que cobraste de Hacienda.", "speaker": null}, {"start": 854.694, "end": 855.294, "text": "Luego entonces", "speaker": null}, {"start": 855.294, "end": 856.594, "text": "te pusiste de tu lana.", "speaker": null}, {"start": 857.994, "end": 858.734, "text": "¿Qué pasa aquí?", "speaker": null}, {"start": 865.034, "end": 865.934, "text": "Tienes un libro.", "speaker": null}, {"start": 871.294, "end": 880.294, "text": "Este te lo tendrá que devolver Hacienda, pero normalmente no te lo defiende, te lo devuelve.", "speaker": null}, {"start": 880.294, "end": 886.294, "text": "¿Qué te va a decir? Manténgalo a favor y para el siguiente mes lo acredites.", "speaker": null}, {"start": 886.294, "end": 889.294, "text": "Pero si hay manera de que te lo regresen.", "speaker": null}, {"start": 889.294, "end": 894.294, "text": "Sí, sí. Al cierre del ejercicio, damos a los solicitantes el saldo a favor.", "speaker": null}, {"start": 894.294, "end": 899.734, "text": "No sé si has visto que ahora que estuvieron anunciando, decían, hay devolución automática,", "speaker": null}]