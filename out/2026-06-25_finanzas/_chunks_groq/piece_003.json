[{"start": 0.0, "end": 1.8399999, "text": "nos indica que así debe ser.", "speaker": null}, {"start": 2.78, "end": 4.6, "text": "Entonces, ¿cómo las vamos a ordenar?", "speaker": null}, {"start": 4.7599998, "end": 9.48, "text": "Por ejemplo, por su grado de disponibilidad.", "speaker": null}, {"start": 10.639999, "end": 13.179999, "text": "Y su grado de disponibilidad tendrá que ser", "speaker": null}, {"start": 13.179999, "end": 17.66, "text": "que menor o igual a un grado.", "speaker": null}, {"start": 19.46, "end": 23.119999, "text": "El lado contrario, por eso se llama contrario,", "speaker": null}, {"start": 24.46, "end": 25.56, "text": "va a ser al revés.", "speaker": null}, {"start": 26.039999, "end": 29.56, "text": "Aquí las vamos a ordenar en función de su grado de disponibilidad.", "speaker": null}, {"start": 30.0, "end": 31.46, "text": "exigibles.", "speaker": null}, {"start": 32.82, "end": 34.42, "text": "Y este también tendrá que ser", "speaker": null}, {"start": 34.42, "end": 36.7, "text": "menor o máximo igual", "speaker": null}, {"start": 36.7, "end": 38.78, "text": "a un año.", "speaker": null}, {"start": 40.14, "end": 42.04, "text": "De este lado, ¿qué es lo que vamos a tener?", "speaker": null}, {"start": 42.56, "end": 43.94, "text": "Los activos fijos.", "speaker": null}, {"start": 44.84, "end": 45.92, "text": "Y los activos fijos,", "speaker": null}, {"start": 45.92, "end": 47.84, "text": "ya lo saben, es movilidad,", "speaker": null}, {"start": 47.96, "end": 48.739998, "text": "es un tipo.", "speaker": null}, {"start": 49.16, "end": 51.78, "text": "Esto es un activo fijo.", "speaker": null}, {"start": 54.38, "end": 55.059998, "text": "Esto", "speaker": null}, {"start": 55.059998, "end": 57.16, "text": "es un activo fijo.", "speaker": null}, {"start": 58.5, "end": 59.079998, "text": "Un auto", "speaker": null}, {"start": 59.079998, "end": 70.579994, "text": "es un activo fijo. Esto es un activo fijo. ¿Correcto? Y finalmente tenemos al activo", "speaker": null}, {"start": 70.579994, "end": 79.42, "text": "diferido. En donde el activo diferido vamos a concatenar aquellos partidas como los gastos", "speaker": null}, {"start": 79.42, "end": 87.979996, "text": "de instalación, como los gastos notariales y una serie de gastos que normalmente se van", "speaker": null}, {"start": 87.979996, "end": 99.35999, "text": "a tener que amortizar los gastos de constitución. Entonces, como consecuencia, nada más nos", "speaker": null}, {"start": 99.35999, "end": 104.439995, "text": "quedaría de este lado las cuentas de capital contable, que es en donde nosotros normalmente", "speaker": null}, {"start": 104.439995, "end": 111.299995, "text": "lo que vamos a controlar es la inversión y el patrimonio de los accionistas. ¿Es correcto?", "speaker": null}, {"start": 111.299995, "end": 119.299995, "text": "Bien, luego entonces, la primera carta que me viene a aparecer aquí sería acá.", "speaker": null}, {"start": 119.299995, "end": 123.299995, "text": "Por su grave disponibilidad, la siguiente sería vamos.", "speaker": null}, {"start": 123.299995, "end": 129.29999, "text": "Por su grave disponibilidad, la siguiente sería que sea inversión y no capitalización.", "speaker": null}, {"start": 129.29999, "end": 136.29999, "text": "La siguiente por su disponibilidad, ¿cuál sería? Probablemente clientes.", "speaker": null}, {"start": 136.3, "end": 137.94, "text": "y así básicamente", "speaker": null}, {"start": 137.94, "end": 139.78, "text": "la realidad alimentaria", "speaker": null}, {"start": 139.78, "end": 141.48, "text": "fue que ayer fue hasta ahí", "speaker": null}, {"start": 141.48, "end": 142.6, "text": "hasta donde nos quedamos", "speaker": null}, {"start": 142.6, "end": 145.88, "text": "habíamos visto que en la caja", "speaker": null}, {"start": 145.88, "end": 148.26001, "text": "no tengo más que abrir el cajón y tengo mi lana", "speaker": null}, {"start": 148.26001, "end": 150.34, "text": "habíamos visto que en bancos", "speaker": null}, {"start": 150.34, "end": 152.64, "text": "no tengo más que elaborar un título de crédito", "speaker": null}, {"start": 152.64, "end": 153.84, "text": "denominado cheque", "speaker": null}, {"start": 153.84, "end": 155.34, "text": "que no es otra cosa", "speaker": null}, {"start": 155.34, "end": 158.22, "text": "más que una orden incondicional de pagos", "speaker": null}, {"start": 158.22, "end": 160.04001, "text": "o de saldo que yo tengo", "speaker": null}, {"start": 160.04001, "end": 161.78, "text": "en mi cuenta bancaria", "speaker": null}, {"start": 161.78, "end": 163.94, "text": "por eso es que a ustedes", "speaker": null}, {"start": 163.94, "end": 166.24, "text": "les enseñan también a hacer conciliación", "speaker": null}, {"start": 166.24, "end": 177.34, "text": "bancarias para saber cuánta la mantienen ustedes. Y así estuvimos explicando cuenta por cuenta.", "speaker": null}, {"start": 177.34, "end": 183.9, "text": "Creo que ya terminamos con la cuenta. Bueno, esto es nada más enunciativo, más no limitativo.", "speaker": null}, {"start": 184.31999, "end": 189.63998, "text": "Aquí pueden tener N cuentas. Aquí, por ejemplo, no les puse más para no meterlos en bronca,", "speaker": null}, {"start": 189.64, "end": 192.6, "text": "pero aquí vienen cuentas hasta de impuestos", "speaker": null}, {"start": 192.6, "end": 195.8, "text": "ejemplo el IVA creditable", "speaker": null}, {"start": 195.8, "end": 199.18, "text": "ejemplo los impuestos a favor", "speaker": null}, {"start": 199.18, "end": 201.92, "text": "puta madre, aquí hay N cuentas", "speaker": null}, {"start": 201.92, "end": 203.2, "text": "son muchas cuentas", "speaker": null}, {"start": 203.2, "end": 207.8, "text": "aquí nada más consiguen las cuentas de manera iniciativa", "speaker": null}, {"start": 207.8, "end": 209.08, "text": "más no limitativa", "speaker": null}, {"start": 209.08, "end": 213.3, "text": "y veíamos que la última cuenta que normalmente aparece", "speaker": null}, {"start": 213.3, "end": 215.78, "text": "es la de los inventarios, ¿por qué?", "speaker": null}, {"start": 215.78, "end": 232.938, "text": "qu esa no la consideramos tan disponible Porque todav se tienen que vender para que se convierta en dinero Pues no lo pueden vender as en s de todo Podr ser Oye pero si yo como le traigo a alguien a la frente de la venta de garaje", "speaker": null}, {"start": 234.47801, "end": 240.378, "text": "a lo mejor vuela mis prendas, a lo mejor vuela mis mochilas, a lo mejor vuela mis compiúes.", "speaker": null}, {"start": 241.518, "end": 244.45801, "text": "Es algo que le llama mucho la atención, ¿o no?", "speaker": null}, {"start": 244.45801, "end": 249.11801, "text": "O a lo mejor le traigo a alguien a la frente de la venta de la cultura.", "speaker": null}, {"start": 250.018, "end": 253.878, "text": "o a lo mejor no hay mejor manera", "speaker": null}, {"start": 253.878, "end": 255.138, "text": "como que te lo diga", "speaker": null}, {"start": 255.138, "end": 256.018, "text": "o un link", "speaker": null}, {"start": 256.018, "end": 258.338, "text": "¿ya me escuchas?", "speaker": null}, {"start": 258.338, "end": 258.458, "text": "¿ya me escuchas?", "speaker": null}, {"start": 263.758, "end": 266.15802, "text": "no podré modificar eso", "speaker": null}, {"start": 266.15802, "end": 270.778, "text": "¿casi?", "speaker": null}, {"start": 275.558, "end": 276.59802, "text": "¿pudiera ser?", "speaker": null}, {"start": 276.59802, "end": 283.178, "text": "aún así", "speaker": null}, {"start": 283.178, "end": 284.278, "text": "el vendalio", "speaker": null}, {"start": 284.278, "end": 286.198, "text": "sigue siendo", "speaker": null}, {"start": 286.198, "end": 288.09802, "text": "un pequeño", "speaker": null}, {"start": 288.09802, "end": 289.338, "text": "gran problema", "speaker": null}, {"start": 289.338, "end": 291.618, "text": "y después", "speaker": null}, {"start": 291.618, "end": 293.49802, "text": "no va a tener", "speaker": null}, {"start": 293.49802, "end": 294.09802, "text": "tanto más", "speaker": null}, {"start": 294.09802, "end": 297.058, "text": "pero sí", "speaker": null}, {"start": 297.058, "end": 297.71802, "text": "que es el que", "speaker": null}, {"start": 297.71802, "end": 298.09802, "text": "al final", "speaker": null}, {"start": 298.09802, "end": 298.538, "text": "no es", "speaker": null}, {"start": 298.538, "end": 300.858, "text": "porque", "speaker": null}, {"start": 300.858, "end": 302.938, "text": "de aquí ya vamos a empezar", "speaker": null}, {"start": 302.938, "end": 305.398, "text": "a manejarlo con", "speaker": null}, {"start": 305.398, "end": 307.65802, "text": "números, ya vamos a empezar", "speaker": null}, {"start": 307.65802, "end": 309.21802, "text": "a meter números,", "speaker": null}, {"start": 309.338, "end": 311.09802, "text": "vamos a empezar a ocupar fórmulas.", "speaker": null}, {"start": 312.058, "end": 313.618, "text": "Entonces, si ustedes no tienen bien claro", "speaker": null}, {"start": 313.618, "end": 314.778, "text": "esto, ustedes van a tener que", "speaker": null}, {"start": 314.778, "end": 317.758, "text": "ahí te va.", "speaker": null}, {"start": 319.138, "end": 319.878, "text": "Yo les", "speaker": null}, {"start": 319.878, "end": 321.438, "text": "contesto ahorita, Carlos,", "speaker": null}, {"start": 322.318, "end": 323.818, "text": "cómo podría yo", "speaker": null}, {"start": 323.818, "end": 326.138, "text": "acelerar la disponibilidad", "speaker": null}, {"start": 326.138, "end": 327.438, "text": "de", "speaker": null}, {"start": 327.438, "end": 329.238, "text": "la convertibilidad", "speaker": null}, {"start": 329.238, "end": 331.678, "text": "de inventar", "speaker": null}, {"start": 331.678, "end": 332.958, "text": "si usted la ha hecho.", "speaker": null}, {"start": 332.958, "end": 335.59802, "text": "yo les dije", "speaker": null}, {"start": 335.59802, "end": 338.238, "text": "se me ocurre que a lo mejor le pongo", "speaker": null}, {"start": 338.238, "end": 338.578, "text": "ayuda", "speaker": null}, {"start": 338.578, "end": 342.298, "text": "se me ocurre que a lo mejor", "speaker": null}, {"start": 342.298, "end": 343.918, "text": "lo manejo como un móvil", "speaker": null}, {"start": 343.918, "end": 346.478, "text": "se me ocurre que a lo mejor", "speaker": null}, {"start": 346.478, "end": 349.178, "text": "lo puedo mover a través de", "speaker": null}, {"start": 349.178, "end": 350.998, "text": "no lo sé", "speaker": null}, {"start": 350.998, "end": 352.698, "text": "una veta nocturna", "speaker": null}, {"start": 352.698, "end": 353.738, "text": "¿verdad?", "speaker": null}, {"start": 353.738, "end": 355.21802, "text": "se me ocurre que a lo mejor", "speaker": null}, {"start": 355.21802, "end": 357.758, "text": "lo puedo reventar", "speaker": null}, {"start": 357.758, "end": 359.078, "text": "a través de online", "speaker": null}, {"start": 359.078, "end": 361.71802, "text": "hoy en día hay muchos", "speaker": null}, {"start": 361.71802, "end": 378.638, "text": "y con eso crees que va a ser una buena respuesta, la respuesta de cambio fue sí, que lo dije", "speaker": null}, {"start": 378.638, "end": 379.65802, "text": "no lo creo", "speaker": null}, {"start": 379.65802, "end": 381.59802, "text": "y lo voy a poner", "speaker": null}, {"start": 381.59802, "end": 384.118, "text": "bien sencillo", "speaker": null}, {"start": 384.118, "end": 386.138, "text": "imagínate", "speaker": null}, {"start": 386.138, "end": 388.398, "text": "o imaginemos", "speaker": null}, {"start": 388.398, "end": 391.358, "text": "que ustedes van a ser", "speaker": null}, {"start": 391.358, "end": 392.47803, "text": "empresarios", "speaker": null}, {"start": 392.47803, "end": 393.878, "text": "correcto", "speaker": null}, {"start": 393.878, "end": 395.198, "text": "y que su empresa", "speaker": null}, {"start": 395.198, "end": 397.018, "text": "es", "speaker": null}, {"start": 397.018, "end": 399.618, "text": "no se se me viene a la mente", "speaker": null}, {"start": 399.618, "end": 400.458, "text": "tan rápido", "speaker": null}, {"start": 400.458, "end": 403.03802, "text": "derivada de", "speaker": null}, {"start": 403.03802, "end": 407.798, "text": "ropa y calzada", "speaker": null}, {"start": 407.798, "end": 410.278, "text": "porque ropa y calza", "speaker": null}, {"start": 410.278, "end": 413.118, "text": "todos tenemos que vestir", "speaker": null}, {"start": 413.118, "end": 414.258, "text": "todo el mundo", "speaker": null}, {"start": 414.258, "end": 416.358, "text": "más o menos en las grandes ciudades como esta", "speaker": null}, {"start": 416.358, "end": 417.618, "text": "tenemos que calzar", "speaker": null}, {"start": 417.618, "end": 420.018, "text": "que allá afuera no lo sienten descalzo", "speaker": null}, {"start": 420.018, "end": 422.818, "text": "allá afuera no lo sienten con guagachos", "speaker": null}, {"start": 422.818, "end": 424.378, "text": "que allá afuera no", "speaker": null}, {"start": 424.378, "end": 424.918, "text": "por gente", "speaker": null}, {"start": 424.918, "end": 427.97803, "text": "en bandas", "speaker": null}, {"start": 427.97803, "end": 430.498, "text": "normalmente todos", "speaker": null}, {"start": 430.498, "end": 432.21802, "text": "más o menos aquí alrededor", "speaker": null}, {"start": 432.21802, "end": 433.838, "text": "visten calza", "speaker": null}, {"start": 433.838, "end": 436.198, "text": "es una necesidad", "speaker": null}, {"start": 436.198, "end": 437.198, "text": "¿No es peligroso?", "speaker": null}, {"start": 438.198, "end": 438.458, "text": "¿O no?", "speaker": null}, {"start": 439.458, "end": 440.838, "text": "Entonces, ¿qué dice el empresario?", "speaker": null}, {"start": 441.078, "end": 442.238, "text": "¿Qué quiere decir un negocio?", "speaker": null}, {"start": 442.278, "end": 442.878, "text": "¿Un negocio?", "speaker": null}, {"start": 443.078, "end": 454.656, "text": "Que sea a largo plazo Que no nada m venda ahorita Y a lo mejor ma ya no venda Si estamos de acuerdo o no estamos de acuerdo ser interesante seguir", "speaker": null}, {"start": 457.336, "end": 458.01602, "text": "¿Podría ser?", "speaker": null}, {"start": 461.23602, "end": 464.35602, "text": "Mal, si tú estuvieras en esa situación,", "speaker": null}, {"start": 466.536, "end": 472.23602, "text": "¿a qué tipo, a qué género te interese a los hombres o a las mujeres?", "speaker": null}, {"start": 473.91602, "end": 474.876, "text": "¿Y por qué?", "speaker": null}, {"start": 475.036, "end": 478.996, "text": "piensa bien en cada uno que te lo hace", "speaker": null}, {"start": 478.996, "end": 479.57602, "text": "pensar", "speaker": null}, {"start": 479.57602, "end": 503.456, "text": "vamos a ver que pudiera pasar por nuestra mente", "speaker": null}, {"start": 503.456, "end": 507.276, "text": "para poder tomar una decisión de esas.", "speaker": null}, {"start": 508.336, "end": 511.516, "text": "Y vamos a marcar los dos escenarios, hombres y mujeres.", "speaker": null}, {"start": 512.056, "end": 512.636, "text": "No hay que verlo.", "speaker": null}, {"start": 514.216, "end": 517.696, "text": "Bueno, cada mano, cada mano, cada escuadrón.", "speaker": null}, {"start": 530.696, "end": 531.956, "text": "Hasta que sea claro.", "speaker": null}, {"start": 533.456, "end": 534.256, "text": "¿Tus jeans?", "speaker": null}, {"start": 535.156, "end": 535.596, "text": "Lo mismo.", "speaker": null}, {"start": 536.396, "end": 536.916, "text": "Lo mismo.", "speaker": null}, {"start": 537.736, "end": 541.136, "text": "¿Podría ser que una o dos veces salga?", "speaker": null}, {"start": 542.576, "end": 543.476, "text": "¿Tú crees?", "speaker": null}, {"start": 543.756, "end": 544.156, "text": "No.", "speaker": null}, {"start": 546.416, "end": 547.196, "text": "¿Qué dices?", "speaker": null}, {"start": 547.276, "end": 549.536, "text": "Si la clivas la vas a...", "speaker": null}, {"start": 549.536, "end": 552.736, "text": "Ya no te tocará cuando te amestices.", "speaker": null}, {"start": 553.596, "end": 554.196, "text": "Prendas.", "speaker": null}, {"start": 554.796, "end": 556.356, "text": "Como cada seis, siete años.", "speaker": null}, {"start": 556.776, "end": 557.49603, "text": "Ah, claro.", "speaker": null}, {"start": 558.376, "end": 559.31604, "text": "Vamos a sufrir.", "speaker": null}, {"start": 560.476, "end": 562.276, "text": "Eres de muy cuidadoso, entonces.", "speaker": null}, {"start": 563.456, "end": 575.996, "text": "¿Tu calzado? ¿Cuántos cuáles de zapatos de hilo, de botitas, de calzado para vestir, etcétera, tienes en casa?", "speaker": null}, {"start": 576.236, "end": 576.956, "text": "Creo que cuatro.", "speaker": null}, {"start": 577.476, "end": 578.576, "text": "¿Cuatro cuáles?", "speaker": null}, {"start": 579.576, "end": 583.176, "text": "¿O tres o cuatro?", "speaker": null}, {"start": 583.416, "end": 585.516, "text": "Tres o cuatro. ¿Y con eso las aportan?", "speaker": null}, {"start": 586.596, "end": 587.356, "text": "¿Seguros?", "speaker": null}, {"start": 588.576, "end": 589.536, "text": "Puede ser.", "speaker": null}, {"start": 589.536, "end": 593.156, "text": "pero lamentablemente no tenemos", "speaker": null}, {"start": 593.156, "end": 594.116, "text": "mujeresitas aquí", "speaker": null}, {"start": 594.116, "end": 596.856, "text": "pero si les preguntamos a las mujeresitas", "speaker": null}, {"start": 596.856, "end": 597.216, "text": "aquí", "speaker": null}, {"start": 597.216, "end": 599.536, "text": "yo te garantizo que", "speaker": null}, {"start": 599.536, "end": 601.256, "text": "mis amigas", "speaker": null}, {"start": 601.256, "end": 603.916, "text": "si bien les va", "speaker": null}, {"start": 603.916, "end": 605.796, "text": "están en ropa mínimo", "speaker": null}, {"start": 605.796, "end": 607.776, "text": "mínimo", "speaker": null}, {"start": 607.776, "end": 609.836, "text": "no digo", "speaker": null}, {"start": 609.836, "end": 611.31604, "text": "completo", "speaker": null}, {"start": 611.31604, "end": 613.156, "text": "pero en algo", "speaker": null}, {"start": 613.156, "end": 616.49603, "text": "un pantalón", "speaker": null}, {"start": 616.49603, "end": 618.056, "text": "unos jeans", "speaker": null}, {"start": 618.056, "end": 621.916, "text": "un afán, un vestimiento para la ocasión", "speaker": null}, {"start": 621.916, "end": 626.556, "text": "si les hablamos de calzado", "speaker": null}, {"start": 626.556, "end": 629.316, "text": "a mí me sorprende que les pregunten a las niñas", "speaker": null}, {"start": 629.316, "end": 632.876, "text": "por lo largo de cuántos años y cuántos años tienes", "speaker": null}, {"start": 632.876, "end": 635.796, "text": "la respuesta casi siempre es", "speaker": null}, {"start": 635.796, "end": 636.876, "text": "¿de qué tipo?", "speaker": null}, {"start": 639.276, "end": 642.656, "text": "pues sí, porque ellas dicen calzado", "speaker": null}, {"start": 642.656, "end": 643.356, "text": "de piso", "speaker": null}, {"start": 643.356, "end": 647.756, "text": "en casa, calzado formal", "speaker": null}, {"start": 647.756, "end": 650.07605, "text": "utilizan", "speaker": null}, {"start": 650.07605, "end": 650.99603, "text": "de tarón", "speaker": null}, {"start": 650.99603, "end": 654.396, "text": "utilizan botas", "speaker": null}, {"start": 654.396, "end": 657.43604, "text": "utilizan", "speaker": null}, {"start": 657.43604, "end": 659.19604, "text": "calzado deportivo", "speaker": null}, {"start": 659.19604, "end": 661.416, "text": "y así sucesivamente", "speaker": null}, {"start": 661.416, "end": 664.876, "text": "y lo más curioso es cuando me contestan", "speaker": null}, {"start": 664.876, "end": 666.49603, "text": "no quiero saber", "speaker": null}, {"start": 666.49603, "end": 667.976, "text": "también de qué cobro", "speaker": null}, {"start": 667.976, "end": 680.01404, "text": "porque puedes usar tacones pero m tienen lo que ellas le llaman los b", "speaker": null}, {"start": 681.674, "end": 683.434, "text": "¿Cuáles son los básicos, Chay?", "speaker": null}, {"start": 683.794, "end": 685.754, "text": "Unos negros y unos rojos.", "speaker": null}, {"start": 686.034, "end": 689.654, "text": "Negro, blanco, ¿qué más?", "speaker": null}, {"start": 690.874, "end": 696.054, "text": "Café, rojo, azul y párale de contacto.", "speaker": null}, {"start": 696.054, "end": 700.33405, "text": "antes se regalan", "speaker": null}, {"start": 700.33405, "end": 701.774, "text": "se les demuestra su capacidad", "speaker": null}, {"start": 701.774, "end": 703.214, "text": "de ser un pereno", "speaker": null}, {"start": 703.214, "end": 704.934, "text": "una maestra o un pereno", "speaker": null}, {"start": 704.934, "end": 706.094, "text": "de los exalumnos", "speaker": null}, {"start": 706.094, "end": 709.614, "text": "para que crean su espíritu", "speaker": null}, {"start": 709.614, "end": 710.19403, "text": "realmente", "speaker": null}, {"start": 710.19403, "end": 712.734, "text": "y si ellos le regalan", "speaker": null}, {"start": 712.734, "end": 714.19403, "text": "son compradores", "speaker": null}, {"start": 714.19403, "end": 717.314, "text": "que aunque no necesiten", "speaker": null}, {"start": 717.314, "end": 718.034, "text": "de los exilios", "speaker": null}, {"start": 718.034, "end": 720.27405, "text": "lo compran", "speaker": null}, {"start": 720.27405, "end": 723.154, "text": "y no nos están metiendo en bloques de cosméticos", "speaker": null}, {"start": 723.154, "end": 724.054, "text": "y otras cosas", "speaker": null}, {"start": 724.054, "end": 726.374, "text": "porque es otro tema", "speaker": null}, {"start": 726.374, "end": 730.034, "text": "si pudiéramos ver que ese es un", "speaker": null}, {"start": 730.034, "end": 732.234, "text": "mercado potencial", "speaker": null}, {"start": 732.234, "end": 734.95404, "text": "tú vas a decir", "speaker": null}, {"start": 734.95404, "end": 737.63403, "text": "de aquí soy", "speaker": null}, {"start": 737.63403, "end": 739.534, "text": "lejos al género", "speaker": null}, {"start": 739.534, "end": 746.674, "text": "pero ahora que te parece", "speaker": null}, {"start": 746.674, "end": 748.114, "text": "si vemos el lado contrario", "speaker": null}, {"start": 748.114, "end": 748.914, "text": "de la moneda", "speaker": null}, {"start": 748.914, "end": 755.494, "text": "Charlie", "speaker": null}, {"start": 755.494, "end": 757.814, "text": "supóngase que te tocan", "speaker": null}, {"start": 757.814, "end": 759.39404, "text": "y necesitas", "speaker": null}, {"start": 759.39404, "end": 761.734, "text": "cambiar", "speaker": null}, {"start": 761.734, "end": 762.69403, "text": "el pantalón", "speaker": null}, {"start": 762.69403, "end": 765.654, "text": "ya no sé que quieras", "speaker": null}, {"start": 765.654, "end": 767.314, "text": "ya te toca", "speaker": null}, {"start": 767.314, "end": 771.554, "text": "y pensamos que a ti te interesaría", "speaker": null}, {"start": 771.554, "end": 773.27405, "text": "a lo mejor un pantalón", "speaker": null}, {"start": 773.27405, "end": 774.054, "text": "con los jeans", "speaker": null}, {"start": 774.054, "end": 777.27405, "text": "coloración marina", "speaker": null}, {"start": 777.27405, "end": 779.874, "text": "¿Cuánto tesoro quieres andar en ese momento?", "speaker": null}, {"start": 781.414, "end": 782.07404, "text": "¿Cuánto cuento?", "speaker": null}, {"start": 784.154, "end": 796.094, "text": "Y cuando vas a la tienda, la que tú quieres, centro comercial, la Lies, no sé, a donde deciden que te pueda dar.", "speaker": null}, {"start": 797.57404, "end": 799.974, "text": "¿Cuánto costarán unos milbaques?", "speaker": null}, {"start": 802.454, "end": 804.734, "text": "Unos mil doscientos.", "speaker": null}, {"start": 804.734, "end": 809.63403, "text": "No, por lo menos no se han visto los compras. Yo los he visto los compras en el año 2000.", "speaker": null}, {"start": 811.094, "end": 816.654, "text": "Pero ¿por qué? Dependiendo del modelo. Porque los leyes son por modelo.", "speaker": null}, {"start": 817.714, "end": 820.954, "text": "O por clave.", "speaker": null}, {"start": 822.814, "end": 826.534, "text": "Bueno, pensamos que va sobre unos leyes.", "speaker": null}, {"start": 827.574, "end": 828.934, "text": "Traducido en castellano, un bar.", "speaker": null}, {"start": 828.934, "end": 833.814, "text": "¿Por qué? ¿Por qué? ¿Y los leyes son un libro?", "speaker": null}, {"start": 834.734, "end": 837.054, "text": "pero ¿qué crees mi chaval?", "speaker": null}, {"start": 837.234, "end": 837.994, "text": "si los tengo", "speaker": null}, {"start": 837.994, "end": 840.054, "text": "y valen los ocho cientos", "speaker": null}, {"start": 840.054, "end": 842.914, "text": "pero", "speaker": null}, {"start": 842.914, "end": 844.974, "text": "ahí tenemos azul", "speaker": null}, {"start": 844.974, "end": 846.114, "text": "claro", "speaker": null}, {"start": 846.114, "end": 848.51404, "text": "tenemos grises", "speaker": null}, {"start": 848.51404, "end": 850.054, "text": "tenemos negro", "speaker": null}, {"start": 850.054, "end": 856.354, "text": "esos", "speaker": null}, {"start": 856.354, "end": 858.994, "text": "no son de lo que tú quieres", "speaker": null}, {"start": 858.994, "end": 860.614, "text": "pero los tengo en milagros", "speaker": null}, {"start": 860.614, "end": 864.07404, "text": "y por si fuera algo", "speaker": null}, {"start": 864.07404, "end": 865.534, "text": "por este lado tengo otros", "speaker": null}, {"start": 865.534, "end": 867.354, "text": "¿qué tamaño tiene?", "speaker": null}, {"start": 869.354, "end": 870.154, "text": "36", "speaker": null}, {"start": 870.154, "end": 871.89404, "text": "no sé, 36", "speaker": null}, {"start": 871.89404, "end": 872.63403, "text": "30", "speaker": null}, {"start": 872.63403, "end": 875.354, "text": "tiene que ver con unos", "speaker": null}, {"start": 875.354, "end": 878.434, "text": "desde 34 hasta 38", "speaker": null}, {"start": 878.434, "end": 880.714, "text": "pero", "speaker": null}, {"start": 880.714, "end": 882.494, "text": "son de un", "speaker": null}, {"start": 882.494, "end": 884.414, "text": "granos", "speaker": null}, {"start": 884.414, "end": 886.474, "text": "pequeños defectos", "speaker": null}, {"start": 886.474, "end": 888.214, "text": "no sé", "speaker": null}, {"start": 888.214, "end": 889.174, "text": "los hilos de", "speaker": null}, {"start": 889.174, "end": 891.054, "text": "la valencia", "speaker": null}, {"start": 891.054, "end": 893.574, "text": "está un poquito", "speaker": null}, {"start": 893.574, "end": 895.574, "text": "atractiva", "speaker": null}, {"start": 895.574, "end": 897.074, "text": "y", "speaker": null}, {"start": 897.074, "end": 898.754, "text": "a mi favor", "speaker": null}]