[{"start": 0.0, "end": 8.0, "text": "como potente, seguro, robusto.", "speaker": null}, {"start": 9.9, "end": 12.179999, "text": "Yo hago lo contrario de lo que compraría.", "speaker": null}, {"start": 14.08, "end": 18.0, "text": "Yo no me interesa los carros compactos.", "speaker": null}, {"start": 19.52, "end": 19.939999, "text": "Paga, paga.", "speaker": null}, {"start": 21.039999, "end": 24.16, "text": "Paga, aunque tenga que pagar un poco más.", "speaker": null}, {"start": 25.06, "end": 27.14, "text": "Pero para mí mi seguridad es mi vida.", "speaker": null}, {"start": 27.14, "end": 30.06, "text": "para mi mi comunidad", "speaker": null}, {"start": 30.06, "end": 31.099998, "text": "es el mundo", "speaker": null}, {"start": 31.099998, "end": 36.62, "text": "hoy en día", "speaker": null}, {"start": 36.62, "end": 39.7, "text": "si tu ves los cabellos modernos", "speaker": null}, {"start": 39.7, "end": 41.64, "text": "el que tu quieras", "speaker": null}, {"start": 41.64, "end": 44.059998, "text": "ya cambio su tecnología", "speaker": null}, {"start": 44.059998, "end": 47.16, "text": "el tiempo que me pasa", "speaker": null}, {"start": 47.16, "end": 49.079998, "text": "la mayor parte de carcachas que yo tengo", "speaker": null}, {"start": 49.079998, "end": 50.32, "text": "para que estén viejas", "speaker": null}, {"start": 50.32, "end": 53.399998, "text": "yo te las pongo frente", "speaker": null}, {"start": 53.399998, "end": 54.28, "text": "con el alma", "speaker": null}, {"start": 54.28, "end": 56.6, "text": "y vas a ver que no me piden", "speaker": null}, {"start": 56.6, "end": 69.82, "text": "Pero él mencionó algo bien importante, dijo un alquilamiento bajo el régimen de los fondos, que a lo económico fue todo lo que se ha estado.", "speaker": null}, {"start": 69.82, "end": 78.64, "text": "Te voy a poner un simple ejemplo. Hay motores, si sabes de motores, no?", "speaker": null}, {"start": 79.54, "end": 91.5, "text": "No, después se me están investigando los motores. Hay motores que su mecanismo interno, hoy por hoy, viene de cuatro valores por cinta.", "speaker": null}, {"start": 91.979996, "end": 99.06, "text": "Hoy por hoy tiene que ser así. Estamos ya en la innovación tecnológica, hoy por hoy tenemos un fin de inyección.", "speaker": null}, {"start": 99.06, "end": 100.34, "text": "está bien", "speaker": null}, {"start": 100.34, "end": 101.799995, "text": "no vas a tener", "speaker": null}, {"start": 101.799995, "end": 103.7, "text": "hoy por hoy", "speaker": null}, {"start": 103.7, "end": 105.04, "text": "soy tu vocada", "speaker": null}, {"start": 105.04, "end": 106.74, "text": "está bien", "speaker": null}, {"start": 106.74, "end": 108.46, "text": "te coloca conmigo", "speaker": null}, {"start": 108.46, "end": 111.28, "text": "pero sabes una cosa", "speaker": null}, {"start": 111.28, "end": 111.979996, "text": "ejemplo", "speaker": null}, {"start": 111.979996, "end": 114.14, "text": "yo te puedo colocar", "speaker": null}, {"start": 114.14, "end": 115.88, "text": "a los cargos de mis hijos", "speaker": null}, {"start": 115.88, "end": 117.92, "text": "yo se lo digo a mis hijos", "speaker": null}, {"start": 117.92, "end": 122.259995, "text": "mis hijos coinciden con cargos", "speaker": null}, {"start": 122.259995, "end": 124.02, "text": "así te lo digo", "speaker": null}, {"start": 124.02, "end": 126.21999, "text": "y más decirles", "speaker": null}, {"start": 126.21999, "end": 128.73999, "text": "no para que escriban", "speaker": null}, {"start": 128.73999, "end": 130.23999, "text": "un animal", "speaker": null}, {"start": 130.23999, "end": 132.77998, "text": "porque en mi trabajo", "speaker": null}, {"start": 132.77998, "end": 134.01999, "text": "no hay lugar de estacionarse", "speaker": null}, {"start": 134.01999, "end": 135.93999, "text": "porque", "speaker": null}, {"start": 135.93999, "end": 137.63998, "text": "me sale un calado", "speaker": null}, {"start": 137.63998, "end": 141.04, "text": "porque en el trabajo", "speaker": null}, {"start": 141.04, "end": 142.12, "text": "es muy complicado", "speaker": null}, {"start": 142.12, "end": 144.93999, "text": "por muchas razones", "speaker": null}, {"start": 144.93999, "end": 147.63998, "text": "y me dijo", "speaker": null}, {"start": 147.63998, "end": 149.35999, "text": "para ti trago las recomendaciones", "speaker": null}, {"start": 149.35999, "end": 151.18, "text": "yo te trago muchas", "speaker": null}, {"start": 151.18, "end": 153.18, "text": "y él me dijo", "speaker": null}, {"start": 153.18, "end": 154.41998, "text": "no, que ya no te pones a", "speaker": null}, {"start": 154.41998, "end": 156.79999, "text": "no, no", "speaker": null}, {"start": 156.8, "end": 175.62, "text": "La transmisión CBT es una maldad, pero lamentablemente no viene en ciclos a la vez.", "speaker": null}, {"start": 176.62, "end": 180.12, "text": "Y es un dolor de cabeza con todo el estado de la experiencia.", "speaker": null}, {"start": 180.12, "end": 180.46, "text": "¿Qué es CBT?", "speaker": null}, {"start": 182.3, "end": 184.48, "text": "Ah, me dijeron.", "speaker": null}, {"start": 184.78, "end": 185.16, "text": "Cheddar.", "speaker": null}, {"start": 185.16, "end": 188.48, "text": "una novia", "speaker": null}, {"start": 188.48, "end": 189.81999, "text": "trae transmisión", "speaker": null}, {"start": 189.81999, "end": 191.15999, "text": "y su trónico", "speaker": null}, {"start": 191.15999, "end": 194.29999, "text": "y esa tiene el problema", "speaker": null}, {"start": 194.29999, "end": 196.45999, "text": "de los módulos electrónicos", "speaker": null}, {"start": 196.45999, "end": 197.81999, "text": "en fin", "speaker": null}, {"start": 197.81999, "end": 199.45999, "text": "estuvimos analizando", "speaker": null}, {"start": 199.45999, "end": 200.73999, "text": "y yo le di una explicación", "speaker": null}, {"start": 200.73999, "end": 203.91998, "text": "yo no lo compraría", "speaker": null}, {"start": 203.91998, "end": 204.69998, "text": "es tu lado", "speaker": null}, {"start": 204.69998, "end": 207.43999, "text": "yo no lo compraría por esto", "speaker": null}, {"start": 207.43999, "end": 211.12, "text": "y llegamos a una conclusión", "speaker": null}, {"start": 211.12, "end": 211.93999, "text": "y esa no se explica", "speaker": null}, {"start": 211.93999, "end": 214.69998, "text": "este que está en correo", "speaker": null}, {"start": 214.7, "end": 219.8, "text": "y ya su sistema de distribución no trae la distinción.", "speaker": null}, {"start": 221.0, "end": 231.558, "text": "No puede tener la distinci va a ser la ventaja o la desventaja Pues que ahora hay la mayor que traen colegas pero entonces tienes que tener mucho cuidado con su tipo de trabajo", "speaker": null}, {"start": 232.47801, "end": 233.598, "text": "Porque eso es máximo", "speaker": null}, {"start": 233.598, "end": 234.938, "text": "de lo que te han metido en la iglesia.", "speaker": null}, {"start": 235.218, "end": 236.31801, "text": "Si te han llevado a la iglesia,", "speaker": null}, {"start": 236.698, "end": 238.11801, "text": "yo te lo voy a llevar a la casa.", "speaker": null}, {"start": 241.75801, "end": 242.998, "text": "Uno de mis hijos tiene", "speaker": null}, {"start": 242.998, "end": 245.238, "text": "un buscador de pintos en la calle", "speaker": null}, {"start": 245.238, "end": 246.03801, "text": "que compra un carro.", "speaker": null}, {"start": 247.558, "end": 248.95801, "text": "Y se le da caso, se lo dice.", "speaker": null}, {"start": 250.018, "end": 251.83801, "text": "Ah, lo que usted cree es que es una equidad.", "speaker": null}, {"start": 252.39801, "end": 253.39801, "text": "Y que es algo completo.", "speaker": null}, {"start": 253.83801, "end": 254.298, "text": "Es completo.", "speaker": null}, {"start": 255.17801, "end": 257.21802, "text": "Yo hago mi opinión, es que no lo voy a contar.", "speaker": null}, {"start": 258.118, "end": 261.318, "text": "Fíjate que me engañé todo el mundo por utilizar el cuerpo.", "speaker": null}, {"start": 262.898, "end": 264.278, "text": "Yo tampoco lo he utilizado.", "speaker": null}, {"start": 264.838, "end": 265.518, "text": "Pasó el tiempo.", "speaker": null}, {"start": 267.118, "end": 268.638, "text": "Y la gente no lo ve, no lo ve.", "speaker": null}, {"start": 270.778, "end": 275.978, "text": "Pasó el tiempo y el movimiento ya le reventó la cabeza de la institución.", "speaker": null}, {"start": 275.978, "end": 279.058, "text": "hace poco me abrió la cara", "speaker": null}, {"start": 279.058, "end": 279.298, "text": "y me dijo", "speaker": null}, {"start": 279.298, "end": 283.778, "text": "¿qué es lo que quieres?", "speaker": null}, {"start": 284.318, "end": 285.21802, "text": "y yo dije", "speaker": null}, {"start": 285.21802, "end": 287.538, "text": "¿qué es lo que quieres?", "speaker": null}, {"start": 288.358, "end": 290.138, "text": "y se lo va a llevar a la casa", "speaker": null}, {"start": 290.138, "end": 292.278, "text": "a vuelta de correr", "speaker": null}, {"start": 292.278, "end": 293.418, "text": "y se lo lleva a la casa", "speaker": null}, {"start": 293.418, "end": 295.778, "text": "y me dijo", "speaker": null}, {"start": 295.778, "end": 296.418, "text": "¿qué es lo que quieres?", "speaker": null}, {"start": 296.418, "end": 300.378, "text": "y le va a salir", "speaker": null}, {"start": 300.378, "end": 301.178, "text": "que tanto", "speaker": null}, {"start": 301.178, "end": 304.178, "text": "ahora si el típico", "speaker": null}, {"start": 304.178, "end": 305.618, "text": "te lo dije", "speaker": null}, {"start": 305.618, "end": 307.138, "text": "¿Y hoy?", "speaker": null}, {"start": 308.978, "end": 310.778, "text": "¿Tú sabes que este pobre muchacho", "speaker": null}, {"start": 310.778, "end": 313.298, "text": "ya lleva como seis meses sin cargo?", "speaker": null}, {"start": 314.018, "end": 315.198, "text": "Porque está juntando", "speaker": null}, {"start": 315.198, "end": 317.038, "text": "para la ficha de reparación.", "speaker": null}, {"start": 318.818, "end": 319.758, "text": "Y se lo diga a mi hijo.", "speaker": null}, {"start": 320.518, "end": 321.378, "text": "Ahí está tu compadre.", "speaker": null}, {"start": 323.298, "end": 324.838, "text": "No se documentó,", "speaker": null}, {"start": 325.238, "end": 326.298, "text": "no se orientó,", "speaker": null}, {"start": 327.198, "end": 328.818, "text": "no se informó.", "speaker": null}, {"start": 328.818, "end": 329.818, "text": "Y estamos con eso.", "speaker": null}, {"start": 331.398, "end": 332.758, "text": "Pero ahora ya no soy", "speaker": null}, {"start": 332.758, "end": 333.958, "text": "el ejemplo.", "speaker": null}, {"start": 333.958, "end": 335.878, "text": "sabemos que buscamos eso", "speaker": null}, {"start": 335.878, "end": 338.738, "text": "pero no se trata de lo que a mi me gusta", "speaker": null}, {"start": 338.738, "end": 340.178, "text": "yo checo", "speaker": null}, {"start": 340.178, "end": 342.978, "text": "lo que yo conozco con mis clientes", "speaker": null}, {"start": 342.978, "end": 346.938, "text": "y hemos visto que ahora la silencia de los jóvenes", "speaker": null}, {"start": 346.938, "end": 348.71802, "text": "tú puedes responder", "speaker": null}, {"start": 348.71802, "end": 349.498, "text": "tú te buscas", "speaker": null}, {"start": 349.498, "end": 353.05798, "text": "y si te queda algo curioso", "speaker": null}, {"start": 353.05798, "end": 354.418, "text": "para que espero que te pueda comer", "speaker": null}, {"start": 354.418, "end": 355.338, "text": "si es que puede", "speaker": null}, {"start": 355.338, "end": 359.138, "text": "porque si no yo te puedo llevar", "speaker": null}, {"start": 359.138, "end": 360.61798, "text": "a mis clientes para que vean que las cosas", "speaker": null}, {"start": 360.61798, "end": 361.298, "text": "como son", "speaker": null}, {"start": 361.298, "end": 363.398, "text": "nos hemos dado cuenta", "speaker": null}, {"start": 363.398, "end": 364.818, "text": "que ahora los jóvenes", "speaker": null}, {"start": 364.818, "end": 366.73798, "text": "aparte que son ignorantes", "speaker": null}, {"start": 366.73798, "end": 368.578, "text": "por lo que dicen porque son jóvenes", "speaker": null}, {"start": 368.578, "end": 371.318, "text": "o sea no conocen de muchas cosas", "speaker": null}, {"start": 371.318, "end": 374.638, "text": "ellos buscan una cosa diferente", "speaker": null}, {"start": 374.638, "end": 377.078, "text": "ahora los chavitos", "speaker": null}, {"start": 377.078, "end": 378.278, "text": "lo que les llama la atención", "speaker": null}, {"start": 378.278, "end": 380.418, "text": "es la conectividad", "speaker": null}, {"start": 380.418, "end": 384.17798, "text": "las pantallas", "speaker": null}, {"start": 384.17798, "end": 386.658, "text": "que sea", "speaker": null}, {"start": 386.658, "end": 388.278, "text": "comunitarizada", "speaker": null}, {"start": 388.278, "end": 390.498, "text": "casi casi que en Chicago", "speaker": null}, {"start": 390.498, "end": 391.578, "text": "se mueva el sofá", "speaker": null}, {"start": 391.578, "end": 394.978, "text": "se han dado cuenta de eso", "speaker": null}, {"start": 394.978, "end": 396.678, "text": "entonces oye", "speaker": null}, {"start": 396.678, "end": 398.978, "text": "ejemplo los chinos", "speaker": null}, {"start": 398.978, "end": 402.238, "text": "fíjate que la mayor parte de carros chinos", "speaker": null}, {"start": 402.238, "end": 403.898, "text": "hoy todo es digital", "speaker": null}, {"start": 403.898, "end": 404.938, "text": "y computarizado", "speaker": null}, {"start": 404.938, "end": 407.318, "text": "y están teniendo un éxito", "speaker": null}, {"start": 407.318, "end": 408.978, "text": "que no tiene nadie en México", "speaker": null}, {"start": 408.978, "end": 412.05798, "text": "y aparte tienen una casa muy grande", "speaker": null}, {"start": 412.05798, "end": 414.198, "text": "que son muy baratos", "speaker": null}, {"start": 414.198, "end": 417.198, "text": "entonces", "speaker": null}, {"start": 417.198, "end": 419.278, "text": "si te das cuenta", "speaker": null}, {"start": 419.278, "end": 421.638, "text": "China está entrando con todo", "speaker": null}, {"start": 421.638, "end": 423.938, "text": "en todas las economías y México no lo es", "speaker": null}, {"start": 423.938, "end": 425.55798, "text": "¿por qué no lo es?", "speaker": null}, {"start": 426.09802, "end": 427.978, "text": "porque tiene un tipo de interés", "speaker": null}, {"start": 427.978, "end": 429.09802, "text": "que le llama la atención", "speaker": null}, {"start": 429.09802, "end": 430.55798, "text": "es ir a un bar", "speaker": null}, {"start": 430.55798, "end": 433.61798, "text": "yo tengo una amiga casual", "speaker": null}, {"start": 433.61798, "end": 434.55798, "text": "que es maestra", "speaker": null}, {"start": 434.55798, "end": 437.858, "text": "que hace dos años", "speaker": null}, {"start": 437.858, "end": 439.378, "text": "me preguntó", "speaker": null}, {"start": 439.378, "end": 441.918, "text": "oye, yo quiero un carcajo", "speaker": null}, {"start": 441.918, "end": 443.278, "text": "¿qué carcajo me recomiendas?", "speaker": null}, {"start": 443.578, "end": 444.098, "text": "lo mismo", "speaker": null}, {"start": 444.098, "end": 454.556, "text": "y me dijo no no el camioneta Pues una misi Ah", "speaker": null}, {"start": 455.896, "end": 458.79602, "text": "Te recomiendo esta de Toyota.", "speaker": null}, {"start": 459.67603, "end": 461.116, "text": "Te recomiendo esta de Ford.", "speaker": null}, {"start": 461.836, "end": 463.756, "text": "Y te recomiendo esta de...", "speaker": null}, {"start": 463.756, "end": 465.216, "text": "Ah.", "speaker": null}, {"start": 466.276, "end": 467.41602, "text": "Abuela de Correo.", "speaker": null}, {"start": 468.29602, "end": 469.23602, "text": "Se fue con su esposo.", "speaker": null}, {"start": 469.316, "end": 470.63602, "text": "El esposo es un sabelotón.", "speaker": null}, {"start": 470.63602, "end": 471.41602, "text": "¿Qué es lo que es?", "speaker": null}, {"start": 471.41602, "end": 471.776, "text": "¿Qué es lo que es?", "speaker": null}, {"start": 471.776, "end": 472.95602, "text": "¿Qué es lo que es?", "speaker": null}, {"start": 475.036, "end": 491.316, "text": "Y el primer lugar donde llegó el niño, bueno, tuvo la mala suerte de que le pegaron, tuvo la mala suerte de que le pegaron su camioneta.", "speaker": null}, {"start": 491.316, "end": 495.63602, "text": "hasta donde yo soy", "speaker": null}, {"start": 495.63602, "end": 497.156, "text": "como 6 meses", "speaker": null}, {"start": 497.156, "end": 499.276, "text": "sin camioneta", "speaker": null}, {"start": 499.276, "end": 502.01602, "text": "porque efectivamente", "speaker": null}, {"start": 502.01602, "end": 503.876, "text": "su camioneta estaba segura", "speaker": null}, {"start": 503.876, "end": 505.216, "text": "le hablamos al seguro", "speaker": null}, {"start": 505.216, "end": 507.216, "text": "no se preocupe don Carlos", "speaker": null}, {"start": 507.216, "end": 508.656, "text": "no hay bronca", "speaker": null}, {"start": 508.656, "end": 512.096, "text": "le vamos a mandar su camioneta", "speaker": null}, {"start": 512.096, "end": 512.736, "text": "a la agencia", "speaker": null}, {"start": 512.736, "end": 516.216, "text": "y entonces se la vamos a entregar como nueva", "speaker": null}, {"start": 516.216, "end": 518.796, "text": "y más porque usted no tuvo la culpa", "speaker": null}, {"start": 518.796, "end": 520.096, "text": "estamos de acuerdo", "speaker": null}, {"start": 520.096, "end": 522.036, "text": "o sus precios", "speaker": null}, {"start": 522.036, "end": 525.376, "text": "que no hay refugios", "speaker": null}, {"start": 525.376, "end": 528.576, "text": "6 pinches", "speaker": null}, {"start": 528.576, "end": 531.036, "text": "y no hay refugios", "speaker": null}, {"start": 531.036, "end": 536.176, "text": "la quisieron sacar", "speaker": null}, {"start": 536.176, "end": 537.796, "text": "para llevarla a un particular", "speaker": null}, {"start": 537.796, "end": 540.416, "text": "porque ellos pensaban que la agencia", "speaker": null}, {"start": 540.416, "end": 541.416, "text": "se estaba haciendo tarde", "speaker": null}, {"start": 541.416, "end": 544.836, "text": "y no tienen los aparatos", "speaker": null}, {"start": 544.836, "end": 546.956, "text": "porque es electrónica", "speaker": null}, {"start": 546.956, "end": 548.776, "text": "hay muchos componentes electrónicos", "speaker": null}, {"start": 548.776, "end": 550.236, "text": "en donde se requieren", "speaker": null}, {"start": 550.236, "end": 552.036, "text": "escanos muy especializados", "speaker": null}, {"start": 552.036, "end": 553.99603, "text": "y no los tienen porque son carísimos", "speaker": null}, {"start": 553.99603, "end": 557.676, "text": "entonces ahorita está entre las bailas", "speaker": null}, {"start": 557.676, "end": 558.49603, "text": "y te hago", "speaker": null}, {"start": 558.49603, "end": 561.456, "text": "mi amor, no te puedes echar a ese corazón", "speaker": null}, {"start": 561.456, "end": 563.376, "text": "yo en su momento te dije", "speaker": null}, {"start": 563.376, "end": 565.016, "text": "que no compraras esa porquería", "speaker": null}, {"start": 565.016, "end": 567.976, "text": "tu esposo dijo que la comprara", "speaker": null}, {"start": 567.976, "end": 570.076, "text": "a tu esposo te lo respeto", "speaker": null}, {"start": 570.076, "end": 570.596, "text": "a mi amor", "speaker": null}, {"start": 570.596, "end": 573.81604, "text": "yo lo que haría me desagüe", "speaker": null}, {"start": 573.81604, "end": 575.736, "text": "ese pedazo de porquería", "speaker": null}, {"start": 575.736, "end": 577.516, "text": "pero ahorita no te puedo", "speaker": null}, {"start": 577.516, "end": 578.256, "text": "no te conigo", "speaker": null}, {"start": 578.256, "end": 580.456, "text": "porque está desmontado", "speaker": null}, {"start": 580.456, "end": 582.69604, "text": "lo debiste haber hecho", "speaker": null}, {"start": 582.69604, "end": 585.236, "text": "antes cuando todavía estaba caminando", "speaker": null}, {"start": 585.236, "end": 587.716, "text": "ahorita si te quieres deshacer", "speaker": null}, {"start": 587.716, "end": 589.016, "text": "de lo que es que medio regalo", "speaker": null}, {"start": 589.016, "end": 592.276, "text": "estás metido en un problema", "speaker": null}, {"start": 592.276, "end": 593.49603, "text": "en un círculo vicioso", "speaker": null}, {"start": 593.49603, "end": 597.276, "text": "ya llevas casi seis meses", "speaker": null}, {"start": 597.276, "end": 598.096, "text": "sin hacer cosas", "speaker": null}, {"start": 598.096, "end": 600.596, "text": "porque no algo", "speaker": null}, {"start": 600.596, "end": 601.576, "text": "hace como", "speaker": null}, {"start": 601.576, "end": 603.536, "text": "una semana", "speaker": null}, {"start": 603.536, "end": 607.576, "text": "que está en el hogar con su esposo", "speaker": null}, {"start": 607.576, "end": 610.916, "text": "la manera de pedir un crédito para comprar otro coche.", "speaker": null}, {"start": 613.636, "end": 614.196, "text": "Fíjate.", "speaker": null}, {"start": 615.536, "end": 617.93604, "text": "Porque ya llevan casi seis meses sin coche.", "speaker": null}, {"start": 620.856, "end": 623.056, "text": "O sea, lo que fue para ti una posible solución", "speaker": null}, {"start": 623.056, "end": 624.236, "text": "se convirtió en un problema.", "speaker": null}, {"start": 625.416, "end": 628.156, "text": "Y te lo pongo en frente", "speaker": null}, {"start": 628.156, "end": 629.43604, "text": "porque lo ve que no es mejor.", "speaker": null}, {"start": 632.416, "end": 633.836, "text": "Ese tipo de cosas, señor,", "speaker": null}, {"start": 633.876, "end": 635.236, "text": "es lo que a nosotros nos consume.", "speaker": null}, {"start": 636.136, "end": 637.376, "text": "Por eso somos asesores.", "speaker": null}, {"start": 637.576, "end": 641.456, "text": "y tenemos que tener conocimiento de todo eso", "speaker": null}, {"start": 641.456, "end": 643.736, "text": "y tú puse como ejemplo", "speaker": null}, {"start": 643.736, "end": 645.796, "text": "podemos hablar de maquinaria", "speaker": null}, {"start": 645.796, "end": 647.716, "text": "podemos hablar de lo que tú quieras", "speaker": null}, {"start": 647.716, "end": 649.196, "text": "por eso yo dije", "speaker": null}, {"start": 649.196, "end": 651.196, "text": "tenemos que tener hasta", "speaker": null}, {"start": 651.196, "end": 653.896, "text": "conocimientos generales", "speaker": null}, {"start": 653.896, "end": 655.196, "text": "cultura general", "speaker": null}, {"start": 655.196, "end": 657.496, "text": "tú vas a decir a mí que me gusta", "speaker": null}, {"start": 657.496, "end": 658.456, "text": "el mundo de Oscar", "speaker": null}, {"start": 658.456, "end": 661.396, "text": "a mí háblame de computers", "speaker": null}, {"start": 661.396, "end": 663.81604, "text": "háblame de sistemas", "speaker": null}, {"start": 663.81604, "end": 665.896, "text": "háblame de", "speaker": null}, {"start": 665.896, "end": 667.516, "text": "módulos electrónicos", "speaker": null}, {"start": 667.516, "end": 668.356, "text": "a la mejor.", "speaker": null}, {"start": 669.596, "end": 680.39404, "text": "Porque yo soy clase de alumnos de ingenier y que soy de todos los de clase de alumnos de ingenier en el front Y eso de alumnos de ingenier electr Y es lo que ellos me dicen Oiga es lo que te interesa Son los m electr", "speaker": null}, {"start": 681.614, "end": 682.33405, "text": "A mí me interesa", "speaker": null}, {"start": 682.33405, "end": 683.314, "text": "la digitalización.", "speaker": null}, {"start": 684.534, "end": 685.13403, "text": "A mí me interesa.", "speaker": null}, {"start": 687.63403, "end": 688.494, "text": "¿Qué te pasa?", "speaker": null}, {"start": 689.494, "end": 690.13403, "text": "¿Qué es lo que crees?", "speaker": null}, {"start": 691.07404, "end": 692.13403, "text": "Que eso no es", "speaker": null}, {"start": 692.13403, "end": 694.294, "text": "como venir y sentarse y aquí vas a", "speaker": null}, {"start": 694.294, "end": 695.254, "text": "manejar todo eso.", "speaker": null}, {"start": 697.63403, "end": 698.07404, "text": "Lo mismo.", "speaker": null}, {"start": 698.07404, "end": 701.63403, "text": "Tienes que saber que se puede sistematizar.", "speaker": null}, {"start": 701.814, "end": 703.19403, "text": "Que no se puede sistematizar.", "speaker": null}, {"start": 704.174, "end": 707.374, "text": "Tú, para poder sistematizar algo, porque tú eres ingeniero,", "speaker": null}, {"start": 708.594, "end": 710.354, "text": "tienes que saber mis necesidades.", "speaker": null}, {"start": 710.57404, "end": 712.714, "text": "No como un demonio las vas a sistematizar.", "speaker": null}, {"start": 714.834, "end": 717.674, "text": "Porque a diferencia de ustedes, ustedes son software.", "speaker": null}, {"start": 719.63403, "end": 720.474, "text": "Ellos son hardware.", "speaker": null}, {"start": 721.45404, "end": 722.114, "text": "¿O me equivoco?", "speaker": null}, {"start": 725.114, "end": 725.994, "text": "¿Me equivoco?", "speaker": null}, {"start": 725.994, "end": 727.774, "text": "No, no tengo que ver.", "speaker": null}, {"start": 728.07404, "end": 733.01404, "text": "imagínate, yo tengo que hablar el idioma de los indígenas", "speaker": null}, {"start": 733.01404, "end": 737.114, "text": "tengo que hablar, tengo clientes que son médicos", "speaker": null}, {"start": 737.114, "end": 741.154, "text": "tengo que hablar el idioma de los indígenas", "speaker": null}, {"start": 741.154, "end": 744.69403, "text": "y así sucesivamente", "speaker": null}, {"start": 744.69403, "end": 746.45404, "text": "tengo que hablar el idioma de los abogados", "speaker": null}, {"start": 746.45404, "end": 749.334, "text": "porque tengo clientes que son abogados", "speaker": null}, {"start": 749.334, "end": 753.614, "text": "aunque no lo creas, también los abogados llevan contabilidad", "speaker": null}, {"start": 753.614, "end": 756.19403, "text": "y también cobran, también pagan", "speaker": null}, {"start": 756.19403, "end": 761.07404, "text": "y casualmente a los abogados tampoco les gustaba contar el libro", "speaker": null}, {"start": 761.07404, "end": 762.69403, "text": "casualmente", "speaker": null}, {"start": 762.69403, "end": 764.89404, "text": "si, vamos a entender", "speaker": null}, {"start": 764.89404, "end": 766.554, "text": "bueno", "speaker": null}, {"start": 766.554, "end": 768.89404, "text": "bueno", "speaker": null}, {"start": 768.89404, "end": 770.854, "text": "ok, nos quedamos en que", "speaker": null}, {"start": 770.854, "end": 772.414, "text": "los que vencimos desde el año", "speaker": null}, {"start": 772.414, "end": 774.554, "text": "cuando nos enseñaron", "speaker": null}, {"start": 774.554, "end": 782.77405, "text": "a manejar", "speaker": null}, {"start": 782.77405, "end": 784.054, "text": "documentos financieros", "speaker": null}, {"start": 784.054, "end": 791.354, "text": "Y cuando manejaron los documentos financieros, dijeron que este era un estado de posición financiera.", "speaker": null}, {"start": 791.934, "end": 796.234, "text": "Y por lo que me acuerdo, como dicen ustedes, que nos quedamos allí,", "speaker": null}, {"start": 796.994, "end": 802.334, "text": "cuando les enseñaron cómo era este documento, les dijeron que este documento", "speaker": null}, {"start": 802.334, "end": 808.174, "text": "se va a acompañar del activo, del pasivo y del capital contable.", "speaker": null}, {"start": 809.054, "end": 811.77405, "text": "Cuando hablamos del activo, pasivo y capital contable,", "speaker": null}, {"start": 811.77405, "end": 820.754, "text": "Habíamos dicho que a ustedes les debían haber explicado que el activo se va a dominar entre todos nuestros bienes y derechos.", "speaker": null}, {"start": 822.594, "end": 827.994, "text": "Y vamos a clasificar cada una de esas partidas, estos rubros.", "speaker": null}, {"start": 829.07404, "end": 834.15405, "text": "Y si de este lado vamos a tener el activo, del lado contrario tenemos al pasivo.", "speaker": null}, {"start": 835.254, "end": 837.314, "text": "El activo que representa bienes y derechos.", "speaker": null}, {"start": 837.314, "end": 842.574, "text": "El pasivo que más representa es las mil obligaciones.", "speaker": null}, {"start": 843.714, "end": 853.214, "text": "El activo se va a subdividir en activo circulante, activo fijo y activo diferido.", "speaker": null}, {"start": 854.234, "end": 860.77405, "text": "El pasivo se va a subdividir en corto plazo y pasivo a largo plazo.", "speaker": null}, {"start": 861.054, "end": 864.314, "text": "Y las cuentas de capital no nos integran con sus propios conceptos.", "speaker": null}, {"start": 864.314, "end": 865.19403, "text": "¿De acuerdo?", "speaker": null}, {"start": 865.19403, "end": 868.434, "text": "bien, a mí me ha comentado", "speaker": null}, {"start": 868.434, "end": 869.734, "text": "y creo que estábamos", "speaker": null}, {"start": 869.734, "end": 870.954, "text": "desalentando esa parte", "speaker": null}, {"start": 870.954, "end": 873.474, "text": "de que esto", "speaker": null}, {"start": 873.474, "end": 874.954, "text": "se va a", "speaker": null}, {"start": 874.954, "end": 878.234, "text": "componer de distintas cuentas", "speaker": null}, {"start": 878.234, "end": 879.614, "text": "son cuentas contables", "speaker": null}, {"start": 879.614, "end": 881.674, "text": "y esas cuentas", "speaker": null}, {"start": 881.674, "end": 883.974, "text": "las van a tener que ordenar ustedes", "speaker": null}, {"start": 883.974, "end": 886.434, "text": "primero porque las deben", "speaker": null}, {"start": 886.434, "end": 887.57404, "text": "así lo señalan", "speaker": null}, {"start": 887.57404, "end": 890.094, "text": "y segundo porque no es como", "speaker": null}, {"start": 890.094, "end": 891.63403, "text": "se nos dé la gana hacer las cosas", "speaker": null}, {"start": 891.63403, "end": 893.714, "text": "hay normatividad", "speaker": null}, {"start": 893.714, "end": 897.434, "text": "hay de alguna manera técnicas", "speaker": null}, {"start": 897.434, "end": 898.934, "text": "hay metodologías", "speaker": null}]