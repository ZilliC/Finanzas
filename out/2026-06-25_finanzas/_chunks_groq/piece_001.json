[{"start": 0.0, "end": 12.5, "text": "Entonces, si no es lo tuyo, no hay problema, si no te lo coges, pues está bien que sea", "speaker": null}, {"start": 12.5, "end": 20.279999, "text": "la marca capaz de tener precio, pero lamentablemente tienes muchas limitaciones.", "speaker": null}, {"start": 20.279999, "end": 28.039999, "text": "Yo reconozco y respeto", "speaker": null}, {"start": 28.039999, "end": 30.259998, "text": "que si te hablo de nóminas,", "speaker": null}, {"start": 30.339998, "end": 31.919998, "text": "la nómina la tienes al sentado.", "speaker": null}, {"start": 32.82, "end": 34.48, "text": "Pero si te hablo de estados financieros,", "speaker": null}, {"start": 34.579998, "end": 36.68, "text": "los estados financieros los tienes al sentado.", "speaker": null}, {"start": 37.62, "end": 38.98, "text": "Si te hablo de contabilidad,", "speaker": null}, {"start": 39.14, "end": 40.379997, "text": "la contabilidad es de caro.", "speaker": null}, {"start": 40.379997, "end": 41.26, "text": "Si te hablo de caro,", "speaker": null}, {"start": 41.26, "end": 43.859997, "text": "no lo tuvieras al sentado.", "speaker": null}, {"start": 44.679996, "end": 46.16, "text": "Porque tú te la debes a ti.", "speaker": null}, {"start": 47.699997, "end": 49.079998, "text": "Eso no pasa en todos los días.", "speaker": null}, {"start": 49.079998, "end": 51.92, "text": "sería pecado que no me hicieras bien.", "speaker": null}, {"start": 53.98, "end": 54.8, "text": "Y se lo dije.", "speaker": null}, {"start": 55.659996, "end": 57.519997, "text": "Mira mi pleno, como lo tengo sacado,", "speaker": null}, {"start": 57.699997, "end": 58.82, "text": "con este llevado al ciego,", "speaker": null}, {"start": 59.679996, "end": 60.6, "text": "no solo me lo escribí,", "speaker": null}, {"start": 60.679996, "end": 61.739998, "text": "me lo sacó de la educación,", "speaker": null}, {"start": 62.539997, "end": 63.399998, "text": "no de la matriz,", "speaker": null}, {"start": 64.619995, "end": 65.32, "text": "la tercera,", "speaker": null}, {"start": 65.88, "end": 67.52, "text": "y era la que me salvó el chavismo,", "speaker": null}, {"start": 67.72, "end": 70.14, "text": "y fue el que me destruyó.", "speaker": null}, {"start": 71.52, "end": 72.619995, "text": "Y el tiro un poco viaje,", "speaker": null}, {"start": 73.14, "end": 74.02, "text": "y un poco viaje,", "speaker": null}, {"start": 75.02, "end": 77.32, "text": "y la ríe así.", "speaker": null}, {"start": 77.32, "end": 79.76, "text": "ahorita fue en esto", "speaker": null}, {"start": 79.76, "end": 82.56, "text": "la ocasión pasada fue en esto", "speaker": null}, {"start": 82.56, "end": 84.38, "text": "y en otras ocasiones", "speaker": null}, {"start": 84.38, "end": 85.36, "text": "ha sido en esto", "speaker": null}, {"start": 85.36, "end": 88.4, "text": "entonces no te preocupes", "speaker": null}, {"start": 88.4, "end": 89.04, "text": "no te preocupes", "speaker": null}, {"start": 89.04, "end": 94.2, "text": "esta es una idea que va a otra", "speaker": null}, {"start": 94.2, "end": 97.659996, "text": "el próximo error", "speaker": null}, {"start": 97.659996, "end": 99.7, "text": "que me pagas", "speaker": null}, {"start": 99.7, "end": 104.24, "text": "yo ahorita voy a hablar con el director", "speaker": null}, {"start": 104.24, "end": 106.54, "text": "para que saque una partida", "speaker": null}, {"start": 106.54, "end": 107.54, "text": "Gracias.", "speaker": null}, {"start": 136.54, "end": 144.09999, "text": "Aquí tiene el sello. Allá afuera, no. Allá afuera los errores se pagan.", "speaker": null}, {"start": 146.73999, "end": 153.76, "text": "A veces pasa la familia, ella misma, presentó una declaración y la presentó con errores.", "speaker": null}, {"start": 155.9, "end": 158.04, "text": "Nos gustó la exposición de ese guarda-albos.", "speaker": null}, {"start": 158.04, "end": 163.85999, "text": "Entonces, se acabó con el barrio y se quedó pagada.", "speaker": null}, {"start": 163.86, "end": 166.94, "text": "doctor", "speaker": null}, {"start": 166.94, "end": 169.14, "text": "estoy buscando", "speaker": null}, {"start": 169.14, "end": 169.44, "text": "un libro", "speaker": null}, {"start": 169.44, "end": 171.58, "text": "que nos lo regrese", "speaker": null}, {"start": 171.58, "end": 177.54, "text": "para que me lo regrese", "speaker": null}, {"start": 177.54, "end": 179.3, "text": "para que me lo regrese", "speaker": null}, {"start": 179.3, "end": 179.86, "text": "que pague", "speaker": null}, {"start": 179.86, "end": 182.62, "text": "para que me lo regrese", "speaker": null}, {"start": 182.62, "end": 183.62, "text": "yo soy un hombre", "speaker": null}, {"start": 183.62, "end": 185.7, "text": "que se lo expone", "speaker": null}, {"start": 185.7, "end": 189.54, "text": "no puedo entregar", "speaker": null}, {"start": 189.54, "end": 190.92, "text": "pero se lo expone", "speaker": null}, {"start": 190.92, "end": 202.2, "text": "¿Por qué?", "speaker": null}, {"start": 202.5, "end": 203.54, "text": "¿Por qué esa actitud?", "speaker": null}, {"start": 205.38, "end": 207.42, "text": "Porque si no lo hacemos de esa manera", "speaker": null}, {"start": 207.42, "end": 209.4, "text": "mi cliente va a poner en lugar", "speaker": null}, {"start": 209.4, "end": 211.86, "text": "la calidad del trabajo", "speaker": null}, {"start": 211.86, "end": 213.44, "text": "¿Estás de acuerdo?", "speaker": null}, {"start": 214.22, "end": 215.26, "text": "¿Vas a ir a una licenciado?", "speaker": null}, {"start": 216.88, "end": 218.2, "text": "Usted me asesora", "speaker": null}, {"start": 218.2, "end": 219.59999, "text": "y te viene pagando", "speaker": null}, {"start": 219.59999, "end": 229.998, "text": "fue el momento que usted no se dio cuenta Pues cuando usted no se dio cuenta que usted es mi asesor pues su chamba no la est haciendo correctamente", "speaker": null}, {"start": 230.95801, "end": 231.298, "text": "¿O no?", "speaker": null}, {"start": 232.858, "end": 234.518, "text": "¿Tú crees que yo puedo permitir eso?", "speaker": null}, {"start": 236.198, "end": 236.518, "text": "¿No?", "speaker": null}, {"start": 237.698, "end": 239.018, "text": "¿Sabes qué más te va a pasar?", "speaker": null}, {"start": 239.158, "end": 239.578, "text": "No, no, no, no.", "speaker": null}, {"start": 240.17801, "end": 241.578, "text": "El error fue de tu gente.", "speaker": null}, {"start": 242.558, "end": 243.238, "text": "Y aquí está.", "speaker": null}, {"start": 243.39801, "end": 244.158, "text": "Y tráemela.", "speaker": null}, {"start": 246.098, "end": 246.498, "text": "Tráemela.", "speaker": null}, {"start": 246.498, "end": 250.11801, "text": "y en la junta", "speaker": null}, {"start": 250.11801, "end": 251.67801, "text": "tuve que bajar los pantalones", "speaker": null}, {"start": 251.67801, "end": 252.55801, "text": "y usar la cintura", "speaker": null}, {"start": 252.55801, "end": 254.418, "text": "entonces yo me di a mi", "speaker": null}, {"start": 254.418, "end": 255.298, "text": "que te dio el falso", "speaker": null}, {"start": 255.298, "end": 260.678, "text": "y se te olvidó", "speaker": null}, {"start": 260.678, "end": 261.798, "text": "que en el día oficial", "speaker": null}, {"start": 261.798, "end": 262.338, "text": "de la dictadura", "speaker": null}, {"start": 262.338, "end": 265.198, "text": "y se te olvidó esto", "speaker": null}, {"start": 265.198, "end": 266.678, "text": "y se te olvidó esto", "speaker": null}, {"start": 266.678, "end": 268.298, "text": "y por qué no lo hiciste", "speaker": null}, {"start": 268.298, "end": 270.638, "text": "es que desconocía eso", "speaker": null}, {"start": 270.638, "end": 273.618, "text": "para ti crees que estoy yo", "speaker": null}, {"start": 273.618, "end": 278.518, "text": "me quisiste vincar", "speaker": null}, {"start": 278.518, "end": 280.678, "text": "me quisiste hacer las cosas", "speaker": null}, {"start": 280.678, "end": 281.71802, "text": "como tú quieres", "speaker": null}, {"start": 281.71802, "end": 283.758, "text": "¿sabía o no?", "speaker": null}, {"start": 285.498, "end": 286.518, "text": "entonces estoy muchísimo", "speaker": null}, {"start": 286.518, "end": 287.238, "text": "de ti", "speaker": null}, {"start": 287.238, "end": 289.198, "text": "entonces", "speaker": null}, {"start": 289.198, "end": 291.638, "text": "entonces", "speaker": null}, {"start": 291.638, "end": 294.198, "text": "director, ¿quién tiene que pagar", "speaker": null}, {"start": 294.198, "end": 295.118, "text": "los platos rotos?", "speaker": null}, {"start": 295.118, "end": 295.238, "text": "¿sabía o no?", "speaker": null}, {"start": 298.638, "end": 299.278, "text": "observación", "speaker": null}, {"start": 299.278, "end": 301.558, "text": "que se lo descuento", "speaker": null}, {"start": 301.558, "end": 303.178, "text": "lo me encanta", "speaker": null}, {"start": 303.178, "end": 317.998, "text": "No lo sé.", "speaker": null}, {"start": 333.178, "end": 336.938, "text": "y eso tiene un costo", "speaker": null}, {"start": 336.938, "end": 339.398, "text": "pero bueno", "speaker": null}, {"start": 339.398, "end": 342.178, "text": "vamos a regresar a la muerte", "speaker": null}, {"start": 342.178, "end": 344.498, "text": "ahora lo que hay es", "speaker": null}, {"start": 344.498, "end": 346.178, "text": "el que se pasa a los años", "speaker": null}, {"start": 346.178, "end": 348.778, "text": "que es", "speaker": null}, {"start": 348.778, "end": 350.458, "text": "antes de que recuerden", "speaker": null}, {"start": 350.458, "end": 351.958, "text": "lo que dieron", "speaker": null}, {"start": 351.958, "end": 353.298, "text": "en otras materias", "speaker": null}, {"start": 353.298, "end": 355.918, "text": "me siento mal", "speaker": null}, {"start": 355.918, "end": 357.398, "text": "pero me siento mal", "speaker": null}, {"start": 357.398, "end": 360.398, "text": "yo para poder manejar mi materia", "speaker": null}, {"start": 360.398, "end": 362.378, "text": "voy a estar", "speaker": null}, {"start": 362.378, "end": 364.818, "text": "no en mi materia", "speaker": null}, {"start": 364.818, "end": 368.758, "text": "sino en mi materia", "speaker": null}, {"start": 368.758, "end": 370.438, "text": "con las demás materias", "speaker": null}, {"start": 370.438, "end": 373.03802, "text": "porque el mundo de las finanzas corporativas", "speaker": null}, {"start": 373.03802, "end": 374.59802, "text": "es muy disciplinado", "speaker": null}, {"start": 374.59802, "end": 376.318, "text": "aquí yo necesito", "speaker": null}, {"start": 376.318, "end": 378.498, "text": "este conocimiento de derecho", "speaker": null}, {"start": 378.498, "end": 380.178, "text": "necesito que tenga", "speaker": null}, {"start": 380.178, "end": 381.898, "text": "conocimiento de informática", "speaker": null}, {"start": 381.898, "end": 384.53802, "text": "necesito que tenga conocimiento de fonda", "speaker": null}, {"start": 384.53802, "end": 386.338, "text": "de administración", "speaker": null}, {"start": 386.338, "end": 387.898, "text": "de economía", "speaker": null}, {"start": 387.898, "end": 390.378, "text": "hasta de obra de iconografía", "speaker": null}, {"start": 390.378, "end": 392.438, "text": "porque esta materia", "speaker": null}, {"start": 392.438, "end": 394.59802, "text": "es de las corporativas", "speaker": null}, {"start": 394.59802, "end": 396.03802, "text": "y", "speaker": null}, {"start": 396.03802, "end": 399.118, "text": "lamentablemente las de las corporativas", "speaker": null}, {"start": 399.118, "end": 401.498, "text": "la relación que tiene", "speaker": null}, {"start": 401.498, "end": 402.358, "text": "nuestra empresa", "speaker": null}, {"start": 402.358, "end": 405.278, "text": "no nada más es de manera interna", "speaker": null}, {"start": 405.278, "end": 406.59802, "text": "sino", "speaker": null}, {"start": 406.59802, "end": 408.178, "text": "es exógena", "speaker": null}, {"start": 408.178, "end": 410.078, "text": "es con todo lo que la rodea", "speaker": null}, {"start": 410.078, "end": 412.018, "text": "y se va a ver afectada", "speaker": null}, {"start": 412.018, "end": 413.358, "text": "o se va a ver beneficiada", "speaker": null}, {"start": 413.358, "end": 416.278, "text": "de todo lo que suceda a su alrededor", "speaker": null}, {"start": 416.278, "end": 418.518, "text": "y hablamos a su alrededor", "speaker": null}, {"start": 418.518, "end": 419.638, "text": "no nada más", "speaker": null}, {"start": 419.638, "end": 426.21802, "text": "en México, sin inclusión en el Estado, en el Estado de México. Yo sé que aquí en", "speaker": null}, {"start": 426.21802, "end": 432.67798, "text": "la Facultad, por azares del destino, se les prepara, se les prepara lo mejor posible,", "speaker": null}, {"start": 433.55798, "end": 438.198, "text": "pero normalmente se les prepara nada más en México, y la realidad es que la verdad", "speaker": null}, {"start": 438.198, "end": 458.276, "text": "no funciona as Yo lo he comentado muchas veces con mis autoridades en parte tienen el razonamiento como dicen los hijos chavos Nada m viendo lo mexicano no puede pues probablemente si le metemos otras cosas m complicadas menos van a poder", "speaker": null}, {"start": 459.536, "end": 465.29602, "text": "Y bueno, en parte tienen razón, por eso hay especialidades, por eso tenemos posgrados,", "speaker": null}, {"start": 466.35602, "end": 472.13602, "text": "porque pues ahí ya vemos las cosas a otro nivel, como lo que te comento, cuestiones de comercio internacional.", "speaker": null}, {"start": 472.13602, "end": 474.616, "text": "yo sé que ahorita muchos de ustedes", "speaker": null}, {"start": 474.616, "end": 476.656, "text": "una de las mil cosas que les vale", "speaker": null}, {"start": 476.656, "end": 478.216, "text": "a parte del mundial", "speaker": null}, {"start": 478.216, "end": 481.156, "text": "es lo que pasa allá afuera", "speaker": null}, {"start": 481.156, "end": 482.836, "text": "yo te podría decir", "speaker": null}, {"start": 482.836, "end": 483.896, "text": "ahorita estamos", "speaker": null}, {"start": 483.896, "end": 487.13602, "text": "ante todos los acontecimientos", "speaker": null}, {"start": 487.13602, "end": 488.41602, "text": "que están pasando en el exterior", "speaker": null}, {"start": 488.41602, "end": 490.696, "text": "ejemplo de lo que está pasando", "speaker": null}, {"start": 490.696, "end": 491.73602, "text": "con la guerra de Irán", "speaker": null}, {"start": 491.73602, "end": 493.57602, "text": "a mucha gente le vale gorro", "speaker": null}, {"start": 493.57602, "end": 496.316, "text": "a nosotros no", "speaker": null}, {"start": 496.316, "end": 498.29602, "text": "a nosotros no", "speaker": null}, {"start": 498.29602, "end": 500.056, "text": "porque yo tengo creencias", "speaker": null}, {"start": 500.056, "end": 503.45602, "text": "que operan y dependen", "speaker": null}, {"start": 503.45602, "end": 505.936, "text": "de los petróleos", "speaker": null}, {"start": 505.936, "end": 509.496, "text": "¿tú sabes cómo está la situación", "speaker": null}, {"start": 509.496, "end": 510.716, "text": "ahorita con el petróleo?", "speaker": null}, {"start": 511.156, "end": 512.37604, "text": "¿está quedando de maestros?", "speaker": null}, {"start": 514.096, "end": 515.596, "text": "estamos en expectativa", "speaker": null}, {"start": 515.596, "end": 516.976, "text": "de que se analice de buenos", "speaker": null}, {"start": 516.976, "end": 517.876, "text": "el señor Stroll", "speaker": null}, {"start": 517.876, "end": 520.296, "text": "o se amanece de malas", "speaker": null}, {"start": 520.296, "end": 521.476, "text": "¿por qué?", "speaker": null}, {"start": 521.616, "end": 522.616, "text": "porque yo tengo un país", "speaker": null}, {"start": 522.616, "end": 525.236, "text": "que opera en el petróleo", "speaker": null}, {"start": 525.236, "end": 528.896, "text": "y no sé si sepas", "speaker": null}, {"start": 528.896, "end": 529.976, "text": "en nuestra vida vital,", "speaker": null}, {"start": 530.796, "end": 533.136, "text": "ahorita se está viendo afectada", "speaker": null}, {"start": 533.136, "end": 534.176, "text": "por los ángeles.", "speaker": null}, {"start": 535.396, "end": 537.216, "text": "Nos pusieron ángeles.", "speaker": null}, {"start": 538.236, "end": 539.156, "text": "Eso nos afecta", "speaker": null}, {"start": 539.156, "end": 541.336, "text": "y nos mueve inevitablemente", "speaker": null}, {"start": 541.336, "end": 543.056, "text": "los costos de cualquier producto.", "speaker": null}, {"start": 544.576, "end": 545.716, "text": "¿Qué industria automotriz?", "speaker": null}, {"start": 547.136, "end": 549.576, "text": "Supongo que están enterados", "speaker": null}, {"start": 549.576, "end": 551.336, "text": "y yo se los diría que yo necesito", "speaker": null}, {"start": 551.336, "end": 552.93604, "text": "que tengan hasta cultura general.", "speaker": null}, {"start": 553.99603, "end": 555.416, "text": "Hasta cultura general", "speaker": null}, {"start": 555.416, "end": 556.356, "text": "necesitan tener.", "speaker": null}, {"start": 556.356, "end": 559.296, "text": "¿por qué?", "speaker": null}, {"start": 559.836, "end": 560.736, "text": "vuelvo a repetir", "speaker": null}, {"start": 560.736, "end": 562.636, "text": "el movimiento de los factores", "speaker": null}, {"start": 562.636, "end": 565.136, "text": "y estamos enfrentando", "speaker": null}, {"start": 565.136, "end": 566.836, "text": "infinidad de problemas", "speaker": null}, {"start": 566.836, "end": 569.156, "text": "no es que para muchas personas", "speaker": null}, {"start": 569.156, "end": 570.49603, "text": "no sean escabullos", "speaker": null}, {"start": 570.49603, "end": 572.256, "text": "de todo el mundo", "speaker": null}, {"start": 572.256, "end": 573.536, "text": "¿sabes que arriba", "speaker": null}, {"start": 573.536, "end": 575.636, "text": "o sabían ustedes que arriba", "speaker": null}, {"start": 575.636, "end": 578.656, "text": "la isla está yendo a balas?", "speaker": null}, {"start": 581.69604, "end": 581.956, "text": "¿no?", "speaker": null}, {"start": 582.096, "end": 582.796, "text": "¿sabes que sí?", "speaker": null}, {"start": 584.31604, "end": 586.216, "text": "o sea, si los estériles negros", "speaker": null}, {"start": 586.216, "end": 588.536, "text": "¿cómo que se salían?", "speaker": null}, {"start": 589.256, "end": 589.456, "text": "¿no?", "speaker": null}, {"start": 590.456, "end": 592.776, "text": "yo escucho todos los días con mis amigos", "speaker": null}, {"start": 592.776, "end": 593.81604, "text": "con mis alumnos", "speaker": null}, {"start": 593.81604, "end": 596.596, "text": "no, no, no, no, porque ya salió", "speaker": null}, {"start": 596.596, "end": 597.736, "text": "ejemplo", "speaker": null}, {"start": 597.736, "end": 600.216, "text": "el Nissan híbrido", "speaker": null}, {"start": 600.216, "end": 600.876, "text": "¡wow!", "speaker": null}, {"start": 601.916, "end": 602.656, "text": "aquí abajo", "speaker": null}, {"start": 602.656, "end": 606.876, "text": "ya les están pegando los helímetros", "speaker": null}, {"start": 606.876, "end": 607.896, "text": "¡wow!", "speaker": null}, {"start": 609.096, "end": 609.93604, "text": "se digan ¡ah!", "speaker": null}, {"start": 609.93604, "end": 610.296, "text": "¡ah!", "speaker": null}, {"start": 612.456, "end": 613.336, "text": "el Nissan", "speaker": null}, {"start": 613.336, "end": 615.736, "text": "ya les está dando", "speaker": null}, {"start": 615.736, "end": 623.736, "text": "¿Qué va a poner en su pleno?", "speaker": null}, {"start": 625.236, "end": 626.69604, "text": "¿Sabían que el San Yacer", "speaker": null}, {"start": 626.69604, "end": 627.516, "text": "fue su plan?", "speaker": null}, {"start": 628.956, "end": 629.856, "text": "¿Y mueren?", "speaker": null}, {"start": 631.536, "end": 632.096, "text": "¿No?", "speaker": null}, {"start": 632.456, "end": 633.116, "text": "¿No sabían?", "speaker": null}, {"start": 634.336, "end": 636.156, "text": "Se hizo con la noticia en red", "speaker": null}, {"start": 636.156, "end": 637.396, "text": "internacional", "speaker": null}, {"start": 637.396, "end": 640.376, "text": "¿Y sabe que ya", "speaker": null}, {"start": 640.376, "end": 641.476, "text": "tenía una planta", "speaker": null}, {"start": 641.476, "end": 643.356, "text": "aquí en Zimbabue?", "speaker": null}, {"start": 645.736, "end": 649.736, "text": "Esa planta se llamaba y ya la cerraron.", "speaker": null}, {"start": 651.956, "end": 653.296, "text": "Ya la cerraron.", "speaker": null}, {"start": 655.93604, "end": 657.296, "text": "¿Qué pasó con ella?", "speaker": null}, {"start": 657.69604, "end": 663.136, "text": "Tuvieron que absorberla y la otra planta que tienen en aguas calientes.", "speaker": null}, {"start": 664.276, "end": 668.736, "text": "Si todas las operaciones que son principales, ahora se trasladaron a aguas calientes.", "speaker": null}, {"start": 668.736, "end": 688.054, "text": "la raz de un canter Mantiene una operaci A diferencia de M Morelos ahora hasta Aguascalientes entonces va complicadamente tal vez est complicando que ahorita est en pl con los otros grandes negocios", "speaker": null}, {"start": 688.054, "end": 698.054, "text": "asiáticos, por ejemplo, Quinta, sabías que Fuegues Bailón también trae broncos,", "speaker": null}, {"start": 698.054, "end": 702.654, "text": "Chécate, chécate, no me creas.", "speaker": null}, {"start": 703.854, "end": 707.554, "text": "Ahorita están tratando de hacer negociaciones con los asiáticos.", "speaker": null}, {"start": 708.594, "end": 710.77405, "text": "Porque sus carros son muy buenos.", "speaker": null}, {"start": 711.13403, "end": 714.414, "text": "Muy buenos, tienen muy buenos motocicletas, tienen buenas tradiciones.", "speaker": null}, {"start": 715.434, "end": 717.154, "text": "Pero están quedando fuera del mercado.", "speaker": null}, {"start": 718.57404, "end": 720.094, "text": "Ya después vamos a hablar de carros.", "speaker": null}, {"start": 720.474, "end": 722.89404, "text": "Si les interesa, si les interesa.", "speaker": null}, {"start": 722.89404, "end": 731.89404, "text": "¿Por qué? Porque es muy tan fácil. Se tiene que enfrentar. Para que una empresa se sostenida,", "speaker": null}, {"start": 731.89404, "end": 741.89404, "text": "tienes que atender las necesidades de tus clientes, los gustos de tus clientes, las preferencias de tus clientes.", "speaker": null}, {"start": 741.89404, "end": 749.39404, "text": "Yo te puedo decir si te preguntas algo, o le preguntas a alguien de anciana, o a gente de eterna.", "speaker": null}, {"start": 751.874, "end": 752.374, "text": "Ahí te va.", "speaker": null}, {"start": 753.754, "end": 756.39404, "text": "¿Tú qué buscas en un carro, doctor?", "speaker": null}, {"start": 758.554, "end": 759.034, "text": "Nada.", "speaker": null}, {"start": 759.63403, "end": 760.654, "text": "Jamás compraría un carro.", "speaker": null}, {"start": 761.174, "end": 761.374, "text": "¿Cómo?", "speaker": null}, {"start": 761.594, "end": 762.654, "text": "Jamás compraría un carro.", "speaker": null}, {"start": 762.934, "end": 763.214, "text": "¿Por qué?", "speaker": null}, {"start": 763.814, "end": 764.334, "text": "No me gusta.", "speaker": null}, {"start": 765.234, "end": 766.674, "text": "Bien, entonces, ¿qué pretendes mover?", "speaker": null}, {"start": 767.01404, "end": 767.774, "text": "¿Qué te mueve?", "speaker": null}, {"start": 767.774, "end": 770.214, "text": "Me meto en bicicleta, taxi.", "speaker": null}, {"start": 770.214, "end": 772.594, "text": "Sí, sí, pero comprar un coche no.", "speaker": null}, {"start": 772.794, "end": 777.614, "text": "¿Y si lo comprarías, qué es lo que buscarías en un carro?", "speaker": null}, {"start": 778.414, "end": 779.854, "text": "Que sea híbrido.", "speaker": null}, {"start": 780.63403, "end": 782.114, "text": "¿Que sea híbrido, por qué?", "speaker": null}, {"start": 782.154, "end": 785.474, "text": "Porque tiene mayor eficiencia energética.", "speaker": null}, {"start": 786.554, "end": 786.914, "text": "Ok.", "speaker": null}, {"start": 787.57404, "end": 788.414, "text": "Y tú gastas menos.", "speaker": null}, {"start": 789.294, "end": 792.034, "text": "Es más económico a tu bolsillo.", "speaker": null}, {"start": 793.654, "end": 798.63403, "text": "A ti sí te preocupa, entre comillas, la contaminación.", "speaker": null}, {"start": 798.63403, "end": 799.27405, "text": "No.", "speaker": null}, {"start": 800.214, "end": 802.174, "text": "¿No? ¿Qué te preocuparía?", "speaker": null}, {"start": 803.934, "end": 806.214, "text": "Que sea compacto.", "speaker": null}, {"start": 816.57404, "end": 818.214, "text": "Que sea de bajo mantenimiento.", "speaker": null}, {"start": 819.334, "end": 819.674, "text": "Ok.", "speaker": null}, {"start": 821.334, "end": 823.734, "text": "Mantenimiento accesible, vamos a decir.", "speaker": null}, {"start": 824.494, "end": 824.95404, "text": "Muy bien.", "speaker": null}, {"start": 826.534, "end": 828.034, "text": "Ok. ¿Y tú, Mike?", "speaker": null}, {"start": 828.034, "end": 828.034, "text": "", "speaker": null}, {"start": 830.214, "end": 831.614, "text": "no me cambia", "speaker": null}, {"start": 831.614, "end": 833.03406, "text": "no me cambia", "speaker": null}, {"start": 833.03406, "end": 834.01404, "text": "un poco", "speaker": null}, {"start": 834.01404, "end": 836.77405, "text": "luego platicamos", "speaker": null}, {"start": 836.77405, "end": 837.594, "text": "no nos preguntáis", "speaker": null}, {"start": 837.594, "end": 838.114, "text": "cuando caemos", "speaker": null}, {"start": 838.114, "end": 841.674, "text": "y ahí me quedé", "speaker": null}, {"start": 841.674, "end": 843.354, "text": "si una pregunta es una persona", "speaker": null}, {"start": 843.354, "end": 845.034, "text": "anciana como yo", "speaker": null}, {"start": 845.034, "end": 847.854, "text": "vieja como yo", "speaker": null}, {"start": 847.854, "end": 850.01404, "text": "que nosotros si tenemos caro", "speaker": null}, {"start": 850.01404, "end": 851.994, "text": "porque lo necesitamos", "speaker": null}, {"start": 851.994, "end": 852.854, "text": "no porque", "speaker": null}, {"start": 852.854, "end": 856.69403, "text": "de alguna manera es un gusto", "speaker": null}, {"start": 856.69403, "end": 857.734, "text": "un lujo", "speaker": null}, {"start": 857.734, "end": 859.794, "text": "para nosotros ha sido", "speaker": null}, {"start": 859.794, "end": 861.474, "text": "y es una necesidad", "speaker": null}, {"start": 861.474, "end": 864.714, "text": "yo te voy a decir", "speaker": null}, {"start": 864.714, "end": 866.314, "text": "que la mayoría de nosotros", "speaker": null}, {"start": 866.314, "end": 867.074, "text": "buscamos", "speaker": null}, {"start": 867.074, "end": 870.354, "text": "que el vehículo tenga un motor", "speaker": null}, {"start": 870.354, "end": 872.434, "text": "eficiente y duradero", "speaker": null}, {"start": 872.434, "end": 876.874, "text": "potencia", "speaker": null}, {"start": 876.874, "end": 879.834, "text": "seguridad", "speaker": null}, {"start": 879.834, "end": 882.51404, "text": "y comodidad", "speaker": null}, {"start": 882.51404, "end": 884.13403, "text": "es lo que buscamos", "speaker": null}, {"start": 884.13403, "end": 885.994, "text": "yo a diferencia", "speaker": null}, {"start": 885.994, "end": 888.01404, "text": "a diferencia de", "speaker": null}, {"start": 888.01404, "end": 891.754, "text": "en marcha de los historios de los que cada vez tenemos sus preferencias.", "speaker": null}, {"start": 893.414, "end": 895.094, "text": "A mí me gustan los buenos carros.", "speaker": null}, {"start": 896.054, "end": 899.574, "text": "Y para mí un buen carro es un carro que era bueno.", "speaker": null}]