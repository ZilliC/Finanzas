[{"start": 0.0, "end": 1.1999999, "text": "¿Qué pasa si presentas el tiempo?", "speaker": null}, {"start": 5.18, "end": 5.7799997, "text": "¿Sí?", "speaker": null}, {"start": 6.2799997, "end": 7.44, "text": "¿Hacen los sencillos?", "speaker": null}, {"start": 8.48, "end": 9.48, "text": "¿Pues qué es lo que va a pasar?", "speaker": null}, {"start": 10.059999, "end": 11.2, "text": "El IVA acreditable", "speaker": null}, {"start": 11.2, "end": 14.0, "text": "es tuyo, en teoría.", "speaker": null}, {"start": 14.86, "end": 15.58, "text": "Es un derecho.", "speaker": null}, {"start": 16.0, "end": 17.32, "text": "Digo, no es tuyo.", "speaker": null}, {"start": 17.8, "end": 18.88, "text": "Tienes el derecho de", "speaker": null}, {"start": 18.88, "end": 19.939999, "text": "que", "speaker": null}, {"start": 19.939999, "end": 22.98, "text": "te lo reembolsen.", "speaker": null}, {"start": 23.66, "end": 26.18, "text": "Luego entonces, entra dentro de tus bienes y derechos.", "speaker": null}, {"start": 27.119999, "end": 28.14, "text": "¿Qué tipo de cuenta es", "speaker": null}, {"start": 28.14, "end": 29.14, "text": "para el activo?", "speaker": null}, {"start": 30.0, "end": 33.06, "text": "el IVA por pagar ya no es tuyo", "speaker": null}, {"start": 33.06, "end": 34.44, "text": "al contrario es de Hacienda", "speaker": null}, {"start": 34.44, "end": 36.66, "text": "es una obligación para ti", "speaker": null}, {"start": 36.66, "end": 38.8, "text": "¿qué obligación tienes? devolverse lo haciendo", "speaker": null}, {"start": 38.8, "end": 40.52, "text": "le llamamos pagar", "speaker": null}, {"start": 40.52, "end": 42.44, "text": "pero la verdad es que se está devolviendo", "speaker": null}, {"start": 42.44, "end": 44.06, "text": "¿están de acuerdo?", "speaker": null}, {"start": 44.54, "end": 47.06, "text": "entonces el IVA por pagar es una cuenta de pasión", "speaker": null}, {"start": 47.06, "end": 48.94, "text": "¿por qué? porque te genera", "speaker": null}, {"start": 48.94, "end": 51.1, "text": "una deuda o una obligación", "speaker": null}, {"start": 51.1, "end": 56.46, "text": "¿qué problema tiene esto?", "speaker": null}, {"start": 58.46, "end": 59.38, "text": "sencillito", "speaker": null}, {"start": 59.38, "end": 71.6, "text": "Ahora, aquí mismo vamos a contestar la premisa de hace rato. Hace rato dijimos que nuestro cliente se está quejando de que cada mes tiene que pagar y no. ¿Está pagando y no?", "speaker": null}, {"start": 71.6, "end": 76.92, "text": "¿qué es lo que hizo?", "speaker": null}, {"start": 77.92, "end": 78.979996, "text": "¿cuándo se gastó el dinero?", "speaker": null}, {"start": 79.52, "end": 81.74, "text": "no, se gastó el dinero que nos dieron", "speaker": null}, {"start": 81.74, "end": 82.58, "text": "¿por qué no?", "speaker": null}, {"start": 84.42, "end": 85.78, "text": "porque tú cuando", "speaker": null}, {"start": 85.78, "end": 86.7, "text": "pediste", "speaker": null}, {"start": 86.7, "end": 89.479996, "text": "cobraste 11.600", "speaker": null}, {"start": 89.479996, "end": 91.38, "text": "entonces", "speaker": null}, {"start": 91.38, "end": 93.7, "text": "¿a dónde entró esa lana?", "speaker": null}, {"start": 93.82, "end": 94.54, "text": "al banco", "speaker": null}, {"start": 94.54, "end": 96.68, "text": "¿quién tiene esa lana? yo", "speaker": null}, {"start": 96.68, "end": 99.04, "text": "¿qué es lo que hace la gente?", "speaker": null}, {"start": 99.2, "end": 100.6, "text": "digamos, tienes lana, sí, sí", "speaker": null}, {"start": 100.6, "end": 104.04, "text": "y al cierre de mes", "speaker": null}, {"start": 104.04, "end": 105.46, "text": "oye Jesús, hay que poner el IVA", "speaker": null}, {"start": 105.46, "end": 107.619995, "text": "o sea, hay que devolver el IVA", "speaker": null}, {"start": 107.619995, "end": 109.799995, "text": "no tengo dinero", "speaker": null}, {"start": 109.799995, "end": 110.52, "text": "en el banco", "speaker": null}, {"start": 110.52, "end": 113.52, "text": "a ver, a ver, a ver", "speaker": null}, {"start": 113.52, "end": 114.46, "text": "¿cómo te quedas de dinero?", "speaker": null}, {"start": 116.46, "end": 117.68, "text": "si, es que no hay dinero", "speaker": null}, {"start": 117.68, "end": 120.04, "text": "no hay dinero porque te gastaste", "speaker": null}, {"start": 120.04, "end": 121.4, "text": "lo que no era tuyo", "speaker": null}, {"start": 121.4, "end": 124.24, "text": "pero el IVA no lo estás pagando tú", "speaker": null}, {"start": 124.24, "end": 126.46, "text": "el IVA lo único que tenías que haber hecho", "speaker": null}, {"start": 126.46, "end": 127.9, "text": "era separarlo", "speaker": null}, {"start": 127.9, "end": 128.95999, "text": "y no agarrarlo", "speaker": null}, {"start": 128.95999, "end": 132.45999, "text": "y devolvérselo a su hija.", "speaker": null}, {"start": 132.79999, "end": 134.23999, "text": "Pero el IVA no lo pagaste tú.", "speaker": null}, {"start": 135.93999, "end": 138.13998, "text": "El IVA no lo pagó el consumidor final.", "speaker": null}, {"start": 139.13998, "end": 142.23999, "text": "El que al final no tuvo a quien trasladarse.", "speaker": null}, {"start": 145.57999, "end": 146.54, "text": "¿Se observa?", "speaker": null}, {"start": 147.49998, "end": 152.9, "text": "Entonces, en ese periodo en lo que tú cobras y pagas el IVA,", "speaker": null}, {"start": 153.31999, "end": 155.01999, "text": "¿se puede quimetear?", "speaker": null}, {"start": 155.18, "end": 156.29999, "text": "Por supuesto que sí.", "speaker": null}, {"start": 156.3, "end": 158.42, "text": "siempre y cuando el termo de mes", "speaker": null}, {"start": 158.42, "end": 159.44, "text": "tenga que volar", "speaker": null}, {"start": 159.44, "end": 162.40001, "text": "claro que sí", "speaker": null}, {"start": 162.40001, "end": 164.8, "text": "porque el IVA no es tuyo", "speaker": null}, {"start": 164.8, "end": 166.96, "text": "así lo hacen muchos", "speaker": null}, {"start": 166.96, "end": 169.0, "text": "los que controlamos", "speaker": null}, {"start": 169.0, "end": 171.22, "text": "pero los que", "speaker": null}, {"start": 171.22, "end": 172.32, "text": "se atarantan", "speaker": null}, {"start": 172.32, "end": 174.82, "text": "lo ocupan y no lo devuelven", "speaker": null}, {"start": 174.82, "end": 177.26001, "text": "ahí es donde se las dejan caer", "speaker": null}, {"start": 177.26001, "end": 178.54001, "text": "y así lo hacen a los que", "speaker": null}, {"start": 178.54001, "end": 179.48, "text": "no tienen que pagar", "speaker": null}, {"start": 179.48, "end": 181.8, "text": "como no me pagaste", "speaker": null}, {"start": 181.8, "end": 183.16, "text": "me vas a pagar el cambio", "speaker": null}, {"start": 183.16, "end": 185.96, "text": "y me vas a pagar la actualización", "speaker": null}, {"start": 185.96, "end": 188.48, "text": "y me vas a pagar multa", "speaker": null}, {"start": 188.48, "end": 190.76, "text": "por haber agarrado mi dinero.", "speaker": null}, {"start": 193.34, "end": 194.81999, "text": "Y es lo que realmente me gusta.", "speaker": null}, {"start": 195.35999, "end": 197.18, "text": "Porque se las deja caer.", "speaker": null}, {"start": 198.9, "end": 199.85999, "text": "O sea, si la das tonta.", "speaker": null}, {"start": 201.43999, "end": 203.54, "text": "Si andas sobre la lana como perra.", "speaker": null}, {"start": 205.93999, "end": 206.65999, "text": "Muy bien.", "speaker": null}, {"start": 209.65999, "end": 210.18, "text": "¿Dudas?", "speaker": null}, {"start": 212.04, "end": 214.63998, "text": "Bueno, entonces lo que entiendo es que", "speaker": null}, {"start": 214.64, "end": 218.64, "text": "como que se va acumulando la cadena de fotos,", "speaker": null}, {"start": 218.64, "end": 237.11801, "text": "bueno cada vez al fin y al cabo se va acumulando o sea cada compra y al final o sea que lo puedes consumir al final Por supuesto aqu hablamos de las cooperaciones pero si hablamos no s a lo mejor de Apple de HP de Samsung de Motorola", "speaker": null}, {"start": 237.11801, "end": 242.238, "text": "sellos, obviamente cuando venden a computador detrás nada, ni nada", "speaker": null}, {"start": 242.238, "end": 246.858, "text": "pero ¿qué va a pasar? van a tener un fin de vida acreditado", "speaker": null}, {"start": 246.858, "end": 248.598, "text": "porque le va a pagar a los", "speaker": null}, {"start": 248.598, "end": 251.098, "text": "a las tablillas, a los transistores", "speaker": null}, {"start": 251.098, "end": 252.83801, "text": "a los... cada uno", "speaker": null}, {"start": 252.83801, "end": 254.738, "text": "de los componentes es un proveedor diferente", "speaker": null}, {"start": 254.738, "end": 257.018, "text": "no todos los proveedores", "speaker": null}, {"start": 257.018, "end": 258.798, "text": "te venden todos los componentes", "speaker": null}, {"start": 260.018, "end": 260.698, "text": "¿están de acuerdo?", "speaker": null}, {"start": 261.578, "end": 263.138, "text": "va a haber quien te venda las teclas", "speaker": null}, {"start": 263.138, "end": 264.678, "text": "va a haber quien te venda, repito", "speaker": null}, {"start": 264.678, "end": 266.678, "text": "la tablilla, quien te venda los cablecitos", "speaker": null}, {"start": 266.678, "end": 269.21802, "text": "quien te venda los chips, quien te venda las resistencias", "speaker": null}, {"start": 269.21802, "end": 270.018, "text": "quien te venda los", "speaker": null}, {"start": 270.018, "end": 272.458, "text": "los diodos, quien te venda", "speaker": null}, {"start": 272.458, "end": 275.038, "text": "en el componente", "speaker": null}, {"start": 275.038, "end": 277.638, "text": "a cada uno de ellos le estás pagando", "speaker": null}, {"start": 277.638, "end": 279.15802, "text": "le estás pagando, le estás pagando", "speaker": null}, {"start": 279.15802, "end": 281.558, "text": "al cierre del mes", "speaker": null}, {"start": 281.558, "end": 284.078, "text": "sumas el IVA de todos los que lo pagaste", "speaker": null}, {"start": 284.078, "end": 285.638, "text": "y ese es un IVA acreditable", "speaker": null}, {"start": 285.638, "end": 287.938, "text": "lo mismo, a lo mejor vendiste", "speaker": null}, {"start": 287.938, "end": 289.418, "text": "no nada más una computadora en Mac", "speaker": null}, {"start": 289.418, "end": 291.878, "text": "se la vendiste una Mac", "speaker": null}, {"start": 291.878, "end": 294.138, "text": "una Lupita, una Chencho", "speaker": null}, {"start": 294.138, "end": 296.018, "text": "una Pedro, ¿verdad?", "speaker": null}, {"start": 297.21802, "end": 297.758, "text": "eso me explico", "speaker": null}, {"start": 297.758, "end": 299.49802, "text": "pasas un marco del IVA", "speaker": null}, {"start": 299.49802, "end": 300.59802, "text": "y ese IVA trasladado", "speaker": null}, {"start": 300.59802, "end": 303.678, "text": "por eso lo manejas en cuentas en mayo", "speaker": null}, {"start": 303.678, "end": 305.638, "text": "es más o menos para el género", "speaker": null}, {"start": 305.638, "end": 307.358, "text": "y el metano bajo", "speaker": null}, {"start": 307.358, "end": 310.618, "text": "cuando hablamos de cuentas de", "speaker": null}, {"start": 310.618, "end": 312.518, "text": "balance, si maestro", "speaker": null}, {"start": 312.518, "end": 315.238, "text": "me ha enseñado que contablemente", "speaker": null}, {"start": 315.238, "end": 317.398, "text": "las cuentas", "speaker": null}, {"start": 317.398, "end": 318.458, "text": "de activo", "speaker": null}, {"start": 318.458, "end": 320.118, "text": "son de naturaleza", "speaker": null}, {"start": 320.118, "end": 320.838, "text": "de doble", "speaker": null}, {"start": 320.838, "end": 323.05798, "text": "excepto", "speaker": null}, {"start": 323.05798, "end": 326.118, "text": "que las cuentas complementarias", "speaker": null}, {"start": 326.118, "end": 328.198, "text": "y algunas especiales", "speaker": null}, {"start": 328.198, "end": 330.418, "text": "las cuentas de pasivo", "speaker": null}, {"start": 330.418, "end": 332.118, "text": "y capital son de naturaleza", "speaker": null}, {"start": 332.118, "end": 333.678, "text": "la naturaleza acrénula.", "speaker": null}, {"start": 336.078, "end": 337.018, "text": "Volviendo al reto.", "speaker": null}, {"start": 337.978, "end": 339.318, "text": "Y para rematar,", "speaker": null}, {"start": 339.558, "end": 341.258, "text": "aquellos que no entiendan esto,", "speaker": null}, {"start": 341.838, "end": 342.678, "text": "esto es bien fácil.", "speaker": null}, {"start": 343.438, "end": 345.398, "text": "Cuando te nos enseña esto la maestra,", "speaker": null}, {"start": 345.59802, "end": 346.358, "text": "la maestra te dice,", "speaker": null}, {"start": 346.478, "end": 349.59802, "text": "para que entiendas esto", "speaker": null}, {"start": 349.59802, "end": 351.478, "text": "te lo voy a enseñar en mesitas.", "speaker": null}, {"start": 353.198, "end": 353.798, "text": "¿Correcto?", "speaker": null}, {"start": 354.638, "end": 355.358, "text": "Y te dice,", "speaker": null}, {"start": 355.898, "end": 357.638, "text": "las buenas lectoras", "speaker": null}, {"start": 357.638, "end": 359.818, "text": "son aquellas que adivinan", "speaker": null}, {"start": 359.818, "end": 360.918, "text": "con los cargos.", "speaker": null}, {"start": 362.11798, "end": 364.11798, "text": "y disminuye con los abonos.", "speaker": null}, {"start": 365.258, "end": 367.898, "text": "Las celdas acreedoras", "speaker": null}, {"start": 367.898, "end": 369.29797, "text": "es lo contrario.", "speaker": null}, {"start": 370.018, "end": 371.71802, "text": "Son aquellas que unigan con", "speaker": null}, {"start": 371.71802, "end": 373.23798, "text": "los abonos", "speaker": null}, {"start": 373.23798, "end": 375.73798, "text": "y disminuye con los caídos.", "speaker": null}, {"start": 384.55798, "end": 385.898, "text": "¿O no?", "speaker": null}, {"start": 387.17798, "end": 388.918, "text": "Así de sencillo.", "speaker": null}, {"start": 392.11798, "end": 397.378, "text": "¿Por qué en la sacerdote no se estudia con H?", "speaker": null}, {"start": 398.578, "end": 400.17798, "text": "¿Cómo? Porque así no se puede.", "speaker": null}, {"start": 401.518, "end": 407.21802, "text": "De hecho, esto al final te va a decir que la fórmula matemática de balance", "speaker": null}, {"start": 407.21802, "end": 409.17798, "text": "es una ecuación matemática.", "speaker": null}, {"start": 409.318, "end": 411.578, "text": "Por eso dije, aguas con esto porque ya lo hacían los números.", "speaker": null}, {"start": 412.878, "end": 414.61798, "text": "Cuando hablamos de ecuaciones matemáticas,", "speaker": null}, {"start": 415.458, "end": 421.11798, "text": "la suma del activo va a ser igual a la suma del pasivo más el capital.", "speaker": null}, {"start": 422.11798, "end": 424.858, "text": "la suma de todas estas cuentas", "speaker": null}, {"start": 424.858, "end": 426.578, "text": "la suma de todas estas cuentas", "speaker": null}, {"start": 426.578, "end": 428.338, "text": "debe dar el objetivo", "speaker": null}, {"start": 428.338, "end": 430.958, "text": "es una ecuación de igualdad", "speaker": null}, {"start": 430.958, "end": 432.578, "text": "por eso se habla que a todo cargo", "speaker": null}, {"start": 432.578, "end": 433.838, "text": "corresponde una bond", "speaker": null}, {"start": 433.838, "end": 436.898, "text": "tienes que cuadrar", "speaker": null}, {"start": 436.898, "end": 437.638, "text": "la operación", "speaker": null}, {"start": 437.638, "end": 441.078, "text": "es como ahorita, como te enseñaron a registrar", "speaker": null}, {"start": 441.078, "end": 442.838, "text": "nosotros estábamos hablando hace un momento", "speaker": null}, {"start": 442.838, "end": 444.838, "text": "de una venda, de una compra", "speaker": null}, {"start": 444.838, "end": 455.436, "text": "vamos a pensar que soy yo el que compro la computadora No fuiste t Yo tendr que registrar mi operaci Yo yo", "speaker": null}, {"start": 455.976, "end": 457.716, "text": "Si yo te compro la computadora,", "speaker": null}, {"start": 458.17603, "end": 459.316, "text": "¿cómo te la compró el Pancho?", "speaker": null}, {"start": 460.876, "end": 462.936, "text": "¿Tú me vendiste la computadora hasta el museo?", "speaker": null}, {"start": 464.216, "end": 466.116, "text": "Entonces, si yo soy Pancho,", "speaker": null}, {"start": 466.336, "end": 467.476, "text": "¿cómo registro mi operación?", "speaker": null}, {"start": 468.51602, "end": 470.596, "text": "Si yo hago un cargo, por ejemplo,", "speaker": null}, {"start": 472.51602, "end": 474.616, "text": "¿a qué activo dijo?", "speaker": null}, {"start": 475.036, "end": 477.396, "text": "Porque la computadora para mí va a ser un activo fijo.", "speaker": null}, {"start": 478.29602, "end": 480.696, "text": "Pero no hay una cuenta que se llame activo fijo.", "speaker": null}, {"start": 481.976, "end": 482.936, "text": "¿Cómo se llama la cuenta?", "speaker": null}, {"start": 484.23602, "end": 486.036, "text": "Ejemplo, se va a llamar", "speaker": null}, {"start": 486.036, "end": 490.79602, "text": "equipo de cómputo.", "speaker": null}, {"start": 496.476, "end": 497.79602, "text": "¿Con qué la voy a pagar?", "speaker": null}, {"start": 500.716, "end": 503.35602, "text": "Con efectivo, con un cheque.", "speaker": null}, {"start": 505.036, "end": 522.016, "text": "¿Cuánto me costó la computadora?", "speaker": null}, {"start": 522.476, "end": 523.016, "text": "10 mil", "speaker": null}, {"start": 523.016, "end": 525.096, "text": "No me costó un 6 mil 600", "speaker": null}, {"start": 525.096, "end": 526.396, "text": "¿Me costó?", "speaker": null}, {"start": 528.396, "end": 529.516, "text": "10 mil", "speaker": null}, {"start": 529.516, "end": 532.776, "text": "Oye, pero no checa ni cuadra", "speaker": null}, {"start": 532.776, "end": 534.256, "text": "No es lo mismo", "speaker": null}, {"start": 534.256, "end": 535.19604, "text": "a papá", "speaker": null}, {"start": 535.19604, "end": 535.93604, "text": "iba a acreditar", "speaker": null}, {"start": 535.93604, "end": 550.576, "text": "10 mil", "speaker": null}, {"start": 550.576, "end": 552.396, "text": "más 1.600", "speaker": null}, {"start": 552.396, "end": 553.43604, "text": "son 11.600", "speaker": null}, {"start": 553.43604, "end": 555.176, "text": "llegado del TV", "speaker": null}, {"start": 555.176, "end": 558.176, "text": "con las 1.600", "speaker": null}, {"start": 558.176, "end": 559.756, "text": "de la verga", "speaker": null}, {"start": 559.756, "end": 560.796, "text": "se matan", "speaker": null}, {"start": 560.796, "end": 562.656, "text": "a todo cargo", "speaker": null}, {"start": 562.656, "end": 563.596, "text": "corresponde a un abono.", "speaker": null}, {"start": 572.19604, "end": 573.19604, "text": "En mi caso,", "speaker": null}, {"start": 574.236, "end": 575.596, "text": "aquí una salida del banco.", "speaker": null}, {"start": 577.69604, "end": 579.016, "text": "Si te das cuenta, es una salida.", "speaker": null}, {"start": 580.156, "end": 582.056, "text": "Bancos es una cuenta de activo.", "speaker": null}, {"start": 585.016, "end": 586.796, "text": "Bancos es de naturaleza deudora.", "speaker": null}, {"start": 588.19604, "end": 588.616, "text": "Aquí está.", "speaker": null}, {"start": 588.99603, "end": 590.276, "text": "Bancos es una cuenta de activo,", "speaker": null}, {"start": 590.276, "end": 591.236, "text": "es de naturaleza deudora.", "speaker": null}, {"start": 591.236, "end": 593.016, "text": "¿Qué pasa con las renovas?", "speaker": null}, {"start": 593.216, "end": 595.396, "text": "Aumentan con los cargos, con los abonos", "speaker": null}, {"start": 595.396, "end": 598.136, "text": "Yo hice un abono", "speaker": null}, {"start": 598.136, "end": 598.69604, "text": "¿Qué pasó?", "speaker": null}, {"start": 599.136, "end": 599.976, "text": "Disminuyó", "speaker": null}, {"start": 599.976, "end": 602.556, "text": "Si yo tenía 50 mil pesos", "speaker": null}, {"start": 602.556, "end": 604.516, "text": "Ahora tengo 50 mil", "speaker": null}, {"start": 604.516, "end": 606.116, "text": "Menos 11 mil 600", "speaker": null}, {"start": 606.116, "end": 607.716, "text": "¿Por qué? Porque saqué dinero", "speaker": null}, {"start": 607.716, "end": 614.356, "text": "Si se observa, se observa", "speaker": null}, {"start": 614.356, "end": 616.716, "text": "Qué maldito problema tiene esto", "speaker": null}, {"start": 621.236, "end": 632.536, "text": "si fuera la operación contraria", "speaker": null}, {"start": 632.536, "end": 634.016, "text": "¿cómo la tendría que hacer?", "speaker": null}, {"start": 635.076, "end": 635.876, "text": "pues al revés", "speaker": null}, {"start": 635.876, "end": 638.676, "text": "un cargo a bancos porque te trae el dinero", "speaker": null}, {"start": 638.676, "end": 641.396, "text": "¿una bomba a dónde?", "speaker": null}, {"start": 643.076, "end": 645.916, "text": "a ventas", "speaker": null}, {"start": 645.916, "end": 648.116, "text": "tú estás vendiendo", "speaker": null}, {"start": 648.116, "end": 652.136, "text": "y un abonado", "speaker": null}, {"start": 652.136, "end": 654.076, "text": "ahí va", "speaker": null}, {"start": 654.076, "end": 655.356, "text": "tras la", "speaker": null}, {"start": 655.356, "end": 656.636, "text": "porque estás cobrando", "speaker": null}, {"start": 656.636, "end": 662.416, "text": "no", "speaker": null}, {"start": 662.416, "end": 664.976, "text": "así de sencillo", "speaker": null}, {"start": 664.976, "end": 679.33405, "text": "hasta aqu voy bien o me regreso Ok continuamos entonces", "speaker": null}, {"start": 680.89404, "end": 684.354, "text": "Había un punto que entonces es un escenario,", "speaker": null}, {"start": 685.114, "end": 691.57404, "text": "pero ese escenario va a ser desde el punto de vista contable.", "speaker": null}, {"start": 693.57404, "end": 698.434, "text": "Pero yo puedo tener el mismo documento con las mismas cuentas", "speaker": null}, {"start": 698.434, "end": 704.034, "text": "con las mismas cifras", "speaker": null}, {"start": 704.034, "end": 706.45404, "text": "creo que ahí lo vamos a hacer así", "speaker": null}, {"start": 706.45404, "end": 707.874, "text": "hagan de cuenta que", "speaker": null}, {"start": 707.874, "end": 711.114, "text": "este es el original y acá vamos a poner la copia", "speaker": null}, {"start": 711.114, "end": 713.374, "text": "hagan de cuenta que esta es una impresión", "speaker": null}, {"start": 713.374, "end": 714.854, "text": "y lo dividimos dos veces", "speaker": null}, {"start": 714.854, "end": 717.69403, "text": "vamos a traer ese para acá", "speaker": null}, {"start": 717.69403, "end": 720.094, "text": "si trajeramos ese para acá", "speaker": null}, {"start": 720.094, "end": 723.594, "text": "estaría más o menos así", "speaker": null}, {"start": 723.594, "end": 724.614, "text": "digo más o menos", "speaker": null}, {"start": 724.614, "end": 737.854, "text": "¿Estamos de acuerdo?", "speaker": null}, {"start": 738.57404, "end": 750.89404, "text": "Aquí tendríamos el activo circulante, aquí tendríamos el activo de alto plazo, aquí tendríamos el activo tipo, aquí tendríamos el activo diferido, aquí tendríamos el activo a largo plazo, aquí tendríamos el activo de alto plazo.", "speaker": null}, {"start": 750.89404, "end": 754.69403, "text": "Imaginemos que aquí tenemos las mismas cuentas", "speaker": null}, {"start": 754.69403, "end": 755.494, "text": "Nuevamente", "speaker": null}, {"start": 755.494, "end": 758.114, "text": "Caja, pago, inversión", "speaker": null}, {"start": 758.114, "end": 759.734, "text": "Inmediata organización", "speaker": null}, {"start": 759.734, "end": 761.51404, "text": "Clientes, etc", "speaker": null}, {"start": 761.51404, "end": 763.054, "text": "Y ventana", "speaker": null}, {"start": 763.054, "end": 767.19403, "text": "Este es el mismo que hice", "speaker": null}, {"start": 767.19403, "end": 769.254, "text": "El activo y el vacío", "speaker": null}, {"start": 769.254, "end": 772.534, "text": "Aquí me dicen que la ayuda es igual", "speaker": null}, {"start": 772.534, "end": 776.19403, "text": "Es el mismo documento", "speaker": null}, {"start": 776.19403, "end": 778.494, "text": "Lo imprimí dos veces", "speaker": null}, {"start": 778.494, "end": 780.69403, "text": "Pero ojo aquí", "speaker": null}, {"start": 780.69403, "end": 789.01404, "text": "Ahora nos vamos a empezar a olvidar de lo que ustedes ya saben y vamos a empezar a entrar", "speaker": null}, {"start": 789.01404, "end": 795.01404, "text": "a lo que debimos saber aquí, que se supone que también ya saben, eso es todo.", "speaker": null}, {"start": 795.01404, "end": 797.01404, "text": "¿Qué va a pasar el próximo año?", "speaker": null}, {"start": 797.01404, "end": 799.01404, "text": "¿Para qué quiero dos?", "speaker": null}, {"start": 799.01404, "end": 806.01404, "text": "Pues ya es el mismo, nada más para demostrar que en el mundo financiero lo vamos a ver", "speaker": null}, {"start": 806.01404, "end": 808.01404, "text": "con una óptica diferente.", "speaker": null}, {"start": 808.01404, "end": 821.01404, "text": "Este era desde el punto de vista contable, pero ahora lo vamos a ver desde el punto de vista financiero.", "speaker": null}, {"start": 822.374, "end": 826.63403, "text": "Si nosotros lo queremos ver desde un punto de vista financiero, aquí cambian las cosas.", "speaker": null}, {"start": 827.994, "end": 835.01404, "text": "Porque ahora lo que para mí eran bienes y derechos y es todo el activo,", "speaker": null}, {"start": 835.01404, "end": 837.334, "text": "¿correcto?", "speaker": null}, {"start": 838.114, "end": 839.39404, "text": "porque ya hemos dicho que el activo", "speaker": null}, {"start": 839.39404, "end": 840.63403, "text": "representa bienes y derechos", "speaker": null}, {"start": 840.63403, "end": 843.434, "text": "y el pasivo", "speaker": null}, {"start": 843.434, "end": 844.874, "text": "me representa bienes y derechos", "speaker": null}, {"start": 844.874, "end": 847.334, "text": "¿qué me representa el capital?", "speaker": null}, {"start": 851.794, "end": 853.574, "text": "la inversión y el patrimonio", "speaker": null}, {"start": 853.574, "end": 854.474, "text": "de los accionistas", "speaker": null}, {"start": 854.474, "end": 859.414, "text": "¿qué va a pasar ahora?", "speaker": null}, {"start": 859.414, "end": 861.714, "text": "como verán, el pasivo es diferente al capital", "speaker": null}, {"start": 861.714, "end": 864.074, "text": "el pasivo me representa", "speaker": null}, {"start": 864.074, "end": 865.194, "text": "la deudación de inversiones", "speaker": null}, {"start": 865.194, "end": 866.534, "text": "pero el capital", "speaker": null}, {"start": 866.534, "end": 868.114, "text": "me representa aquí", "speaker": null}, {"start": 868.114, "end": 871.234, "text": "la inversión", "speaker": null}, {"start": 871.234, "end": 872.674, "text": "y el patrimonio de los accionistas", "speaker": null}, {"start": 872.674, "end": 873.774, "text": "son cosas diferentes", "speaker": null}, {"start": 873.774, "end": 875.234, "text": "bueno", "speaker": null}, {"start": 875.234, "end": 878.654, "text": "cuando nosotros llegamos al mundo financiero", "speaker": null}, {"start": 878.654, "end": 880.074, "text": "resulta que ahora", "speaker": null}, {"start": 880.074, "end": 882.434, "text": "todo el activo", "speaker": null}, {"start": 882.434, "end": 884.354, "text": "es todo esto", "speaker": null}, {"start": 884.354, "end": 890.534, "text": "ya no me va a representar", "speaker": null}, {"start": 890.534, "end": 891.274, "text": "bienes y derechos", "speaker": null}, {"start": 891.27405, "end": 894.594, "text": "ahora lo voy a conocer como", "speaker": null}, {"start": 894.594, "end": 899.69403, "text": "fuentes de inversión", "speaker": null}]