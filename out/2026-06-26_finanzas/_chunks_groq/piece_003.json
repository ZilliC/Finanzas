[{"start": 0.0, "end": 0.94, "text": "¿Cómo está mi país?", "speaker": null}, {"start": 1.8399999, "end": 3.0, "text": "Es algo parecido.", "speaker": null}, {"start": 3.8, "end": 4.18, "text": "¿Me explico?", "speaker": null}, {"start": 5.18, "end": 8.059999, "text": "Ok. Bueno, vamos a partir de esa teoría.", "speaker": null}, {"start": 9.24, "end": 10.5, "text": "Si esto es cierto,", "speaker": null}, {"start": 10.7, "end": 12.099999, "text": "nosotros hasta la clase pasada", "speaker": null}, {"start": 12.099999, "end": 13.84, "text": "ya sabemos que estos son estados", "speaker": null}, {"start": 13.84, "end": 14.78, "text": "de posición de la ciencia.", "speaker": null}, {"start": 16.14, "end": 16.94, "text": "Los dos.", "speaker": null}, {"start": 19.52, "end": 20.32, "text": "Si bien,", "speaker": null}, {"start": 20.4, "end": 21.68, "text": "si las estructuras son diferentes,", "speaker": null}, {"start": 22.9, "end": 24.32, "text": "y vamos a demostrarlo,", "speaker": null}, {"start": 24.5, "end": 26.0, "text": "tan es así que yo no traigo ya", "speaker": null}, {"start": 26.0, "end": 27.76, "text": "un ejercicio hecho en otra,", "speaker": null}, {"start": 27.76, "end": 29.7, "text": "pero yo no soy como", "speaker": null}, {"start": 29.7, "end": 30.58, "text": "más maestro", "speaker": null}, {"start": 30.58, "end": 32.84, "text": "a ver, sácate tu libro y le pasas", "speaker": null}, {"start": 32.84, "end": 36.38, "text": "el caso número 5 de la página 6", "speaker": null}, {"start": 36.38, "end": 39.88, "text": "aquí vamos a demostrar que el que me pongas", "speaker": null}, {"start": 39.88, "end": 41.42, "text": "en frente lo puedo desbaratar", "speaker": null}, {"start": 41.42, "end": 42.76, "text": "el que sea", "speaker": null}, {"start": 42.76, "end": 45.34, "text": "ustedes van a poner las cifras", "speaker": null}, {"start": 45.34, "end": 46.3, "text": "¿sale?", "speaker": null}, {"start": 47.3, "end": 49.78, "text": "aquí vamos a tener un activo, un pasivo", "speaker": null}, {"start": 49.78, "end": 51.56, "text": "y las fuentes de calidad", "speaker": null}, {"start": 51.56, "end": 54.079998, "text": "un activo, un pasivo", "speaker": null}, {"start": 54.079998, "end": 55.18, "text": "y las fuentes de calidad", "speaker": null}, {"start": 55.18, "end": 57.06, "text": "¿de qué vamos a partir?", "speaker": null}, {"start": 57.06, "end": 58.979996, "text": "vamos a partir de la premisa", "speaker": null}, {"start": 58.979996, "end": 61.46, "text": "numérica, es decir", "speaker": null}, {"start": 61.46, "end": 63.46, "text": "ya no vamos a poner números", "speaker": null}, {"start": 63.46, "end": 66.119995, "text": "a la condición", "speaker": null}, {"start": 66.119995, "end": 66.96, "text": "contable", "speaker": null}, {"start": 66.96, "end": 69.759995, "text": "el estado financiero por su propia", "speaker": null}, {"start": 69.759995, "end": 71.619995, "text": "naturaleza tiene una fórmula", "speaker": null}, {"start": 71.619995, "end": 73.259995, "text": "que se tiene que cumplir a fuerza", "speaker": null}, {"start": 73.259995, "end": 75.439995, "text": "matemáticamente hablando", "speaker": null}, {"start": 75.439995, "end": 77.52, "text": "este estado financiero tiene que ser", "speaker": null}, {"start": 77.52, "end": 79.64, "text": "el activo", "speaker": null}, {"start": 79.64, "end": 81.52, "text": "va a ser igual a la suma de", "speaker": null}, {"start": 81.52, "end": 83.38, "text": "pasivo más", "speaker": null}, {"start": 83.38, "end": 85.619995, "text": "por donde te hagas", "speaker": null}, {"start": 85.619995, "end": 86.56, "text": "para donde te hagas", "speaker": null}, {"start": 86.56, "end": 89.34, "text": "debe de estar equilibrado", "speaker": null}, {"start": 89.34, "end": 91.68, "text": "por eso dicen que a todo cargo corresponde un abono", "speaker": null}, {"start": 91.68, "end": 95.46, "text": "entonces, si esto es cierto", "speaker": null}, {"start": 95.46, "end": 97.159996, "text": "esto también se tiene que mirar", "speaker": null}, {"start": 97.159996, "end": 99.979996, "text": "el activo es igual a la suma", "speaker": null}, {"start": 99.979996, "end": 100.799995, "text": "de la cita", "speaker": null}, {"start": 100.799995, "end": 101.939995, "text": "más cita", "speaker": null}, {"start": 101.939995, "end": 105.68, "text": "vamos a poner", "speaker": null}, {"start": 105.68, "end": 106.079994, "text": "en un", "speaker": null}, {"start": 106.079994, "end": 109.28, "text": "vamos a pensar que estas empresas", "speaker": null}, {"start": 109.28, "end": 111.46, "text": "las dos", "speaker": null}, {"start": 111.46, "end": 113.659996, "text": "su activo", "speaker": null}, {"start": 113.659996, "end": 115.88, "text": "la sumatoria del activo", "speaker": null}, {"start": 115.88, "end": 117.88, "text": "todo esto vale", "speaker": null}, {"start": 117.88, "end": 119.24, "text": "¿cuánto es esto?", "speaker": null}, {"start": 120.24, "end": 121.88, "text": "80 millones de pesos", "speaker": null}, {"start": 121.88, "end": 133.87999, "text": "vamos a ver cómo se comporta", "speaker": null}, {"start": 133.87999, "end": 135.87999, "text": "una estructura y otra estructura", "speaker": null}, {"start": 136.56, "end": 138.18, "text": "los dos de ellos", "speaker": null}, {"start": 138.18, "end": 139.44, "text": "van a tener", "speaker": null}, {"start": 139.44, "end": 143.81999, "text": "80 millones", "speaker": null}, {"start": 143.81999, "end": 146.14, "text": "¿Sabe el valor?", "speaker": null}, {"start": 148.35999, "end": 149.51999, "text": "Más o menos", "speaker": null}, {"start": 149.51999, "end": 151.35999, "text": "Si todo esto vale 80 millones", "speaker": null}, {"start": 151.35999, "end": 153.34, "text": "Aquí esto más o menos cuánto vale?", "speaker": null}, {"start": 155.73999, "end": 156.87999, "text": "Unos 60", "speaker": null}, {"start": 156.87999, "end": 158.87999, "text": "¿Sí?", "speaker": null}, {"start": 160.01999, "end": 161.62, "text": "Bueno, supongo que ya saben", "speaker": null}, {"start": 161.62, "end": 162.59999, "text": "Leer los números", "speaker": null}, {"start": 162.59999, "end": 167.92, "text": "Los millones los expresamos", "speaker": null}, {"start": 167.92, "end": 168.95999, "text": "Con apóstrofes", "speaker": null}, {"start": 168.95999, "end": 170.98, "text": "Los miles con comas", "speaker": null}, {"start": 170.98, "end": 173.34, "text": "Para no llenar aquí de seres", "speaker": null}, {"start": 173.34, "end": 175.04, "text": "60 miligramos", "speaker": null}, {"start": 175.04, "end": 176.12, "text": "¿ok?", "speaker": null}, {"start": 177.22, "end": 178.92, "text": "entonces este más o menos cuánto valdrá?", "speaker": null}, {"start": 179.2, "end": 179.5, "text": "20", "speaker": null}, {"start": 179.5, "end": 182.86, "text": "más o menos", "speaker": null}, {"start": 182.86, "end": 185.45999, "text": "si este vale 60", "speaker": null}, {"start": 185.45999, "end": 186.86, "text": "más o menos cuánto valdrá este?", "speaker": null}, {"start": 190.86, "end": 191.34, "text": "30", "speaker": null}, {"start": 191.34, "end": 192.9, "text": "30", "speaker": null}, {"start": 192.9, "end": 193.0, "text": "30", "speaker": null}, {"start": 193.0, "end": 195.95999, "text": "30", "speaker": null}, {"start": 195.95999, "end": 199.9, "text": "35", "speaker": null}, {"start": 199.9, "end": 202.48, "text": "35", "speaker": null}, {"start": 202.48, "end": 204.48, "text": "¿Cuánto?", "speaker": null}, {"start": 204.48, "end": 208.48, "text": "45 son 70 y este 30.", "speaker": null}, {"start": 208.48, "end": 210.48, "text": "¿Sí? Más o menos.", "speaker": null}, {"start": 212.48, "end": 216.48, "text": "Acá lo mismo, de los 80, más o menos, ¿cuánto vale este?", "speaker": null}, {"start": 219.48, "end": 230.018, "text": "Como 40 Si estos son 40 entonces esto debe resolver ah no si esto no es esperable", "speaker": null}, {"start": 230.018, "end": 232.018, "text": "que la regla, que se dice", "speaker": null}, {"start": 232.018, "end": 234.018, "text": "180", "speaker": null}, {"start": 234.018, "end": 236.018, "text": "si", "speaker": null}, {"start": 236.018, "end": 238.018, "text": "60, 20, 180, 20", "speaker": null}, {"start": 238.018, "end": 240.018, "text": "180", "speaker": null}, {"start": 240.018, "end": 242.018, "text": "10 y 10", "speaker": null}, {"start": 242.018, "end": 244.018, "text": "o le cambias", "speaker": null}, {"start": 244.018, "end": 246.018, "text": "le ponemos que son 100", "speaker": null}, {"start": 246.018, "end": 248.018, "text": "si", "speaker": null}, {"start": 248.018, "end": 258.858, "text": "Bueno, si fuera así, entonces este ya no valdría 40, este se valdría cuánto? 50, no? Más o menos.", "speaker": null}, {"start": 258.858, "end": 275.258, "text": "50, no? Si este es 25, este es 25, sí, más o menos. Si este vale 25, entonces este va a pesar que como 30, más o menos.", "speaker": null}, {"start": 275.258, "end": 277.258, "text": "¿35?", "speaker": null}, {"start": 280.538, "end": 280.818, "text": "¿Sí?", "speaker": null}, {"start": 281.098, "end": 281.798, "text": "¿Y 50?", "speaker": null}, {"start": 282.398, "end": 282.99802, "text": "¿Y 50?", "speaker": null}, {"start": 283.138, "end": 283.698, "text": "¿Y 45?", "speaker": null}, {"start": 284.71802, "end": 285.258, "text": "¿Son 35?", "speaker": null}, {"start": 285.918, "end": 286.398, "text": "¿35?", "speaker": null}, {"start": 287.058, "end": 291.838, "text": "¿Número 30, 30, 40?", "speaker": null}, {"start": 293.378, "end": 294.21802, "text": "¿30?", "speaker": null}, {"start": 294.838, "end": 295.778, "text": "¿Y 40?", "speaker": null}, {"start": 296.538, "end": 298.178, "text": "¿Y 40 millones?", "speaker": null}, {"start": 298.498, "end": 298.618, "text": "¿No?", "speaker": null}, {"start": 299.038, "end": 303.358, "text": "Ok, vamos a empezar de lo general a lo particular.", "speaker": null}, {"start": 303.358, "end": 317.398, "text": "Obviamente sabemos que estos 60 millones de pesos están acomodados en caja, en bancos, en clientes, en deudores diversos, impuestos por pagar, para un impuesto a favor, todas las cuentas contables.", "speaker": null}, {"start": 318.038, "end": 324.138, "text": "Vamos a comenzar de lo general a lo particular, es decir, de lo sencillo a lo más completo, si no, no van a poder.", "speaker": null}, {"start": 324.138, "end": 326.818, "text": "bueno", "speaker": null}, {"start": 326.818, "end": 328.918, "text": "si eso fuera cierto señores", "speaker": null}, {"start": 328.918, "end": 333.378, "text": "van a ver que esto tiene un paso", "speaker": null}, {"start": 333.378, "end": 334.818, "text": "esto", "speaker": null}, {"start": 334.818, "end": 336.458, "text": "es para llamar a todos", "speaker": null}, {"start": 336.458, "end": 339.298, "text": "a la mejor no a nivel", "speaker": null}, {"start": 339.298, "end": 340.418, "text": "de acuarelas uno", "speaker": null}, {"start": 340.418, "end": 343.21802, "text": "a la mejor a nivel ya", "speaker": null}, {"start": 343.21802, "end": 344.418, "text": "de tijeritas dos", "speaker": null}, {"start": 344.418, "end": 345.898, "text": "pero sigue siendo", "speaker": null}, {"start": 345.898, "end": 349.11798, "text": "yo me imagino que", "speaker": null}, {"start": 349.11798, "end": 350.17798, "text": "hoy ya se lo veamos", "speaker": null}, {"start": 350.17798, "end": 353.67798, "text": "a los sobrinitos", "speaker": null}, {"start": 353.678, "end": 356.178, "text": "ya nada más faltaría que les den", "speaker": null}, {"start": 356.178, "end": 357.71802, "text": "esto en el kindergarten", "speaker": null}, {"start": 357.71802, "end": 358.858, "text": "en Tijeritas 2", "speaker": null}, {"start": 358.858, "end": 362.318, "text": "vamos a aplicar", "speaker": null}, {"start": 362.318, "end": 364.378, "text": "en uno de los rasgos, se me ocurre pensar", "speaker": null}, {"start": 364.378, "end": 365.318, "text": "ejemplo", "speaker": null}, {"start": 365.318, "end": 368.47803, "text": "R7", "speaker": null}, {"start": 368.47803, "end": 370.71802, "text": "R7", "speaker": null}, {"start": 370.71802, "end": 372.21802, "text": "¿qué significa?", "speaker": null}, {"start": 373.278, "end": 373.91803, "text": "significa", "speaker": null}, {"start": 373.91803, "end": 375.97803, "text": "razón de capital de trabajo", "speaker": null}, {"start": 375.97803, "end": 378.758, "text": "la razón de capital", "speaker": null}, {"start": 378.758, "end": 379.378, "text": "de trabajo", "speaker": null}, {"start": 379.378, "end": 382.238, "text": "la vamos a calcular", "speaker": null}, {"start": 382.238, "end": 384.578, "text": "considerando que el activo circulante", "speaker": null}, {"start": 384.578, "end": 386.078, "text": "es lo que está haciendo", "speaker": null}, {"start": 386.078, "end": 388.53802, "text": "entonces", "speaker": null}, {"start": 388.53802, "end": 390.71802, "text": "si a mi me dieron la fórmula", "speaker": null}, {"start": 390.71802, "end": 392.53802, "text": "pues esto ya es para comido", "speaker": null}, {"start": 392.53802, "end": 394.758, "text": "lo único que tengo que hacer es", "speaker": null}, {"start": 394.758, "end": 396.338, "text": "meterle a mi maquinita", "speaker": null}, {"start": 396.338, "end": 398.878, "text": "que jale el casillero del activo circulante", "speaker": null}, {"start": 398.878, "end": 401.318, "text": "que se lo divida", "speaker": null}, {"start": 401.318, "end": 402.71802, "text": "hagan de vuelta en un excel", "speaker": null}, {"start": 402.71802, "end": 405.018, "text": "con el pasivo a corto plazo", "speaker": null}, {"start": 405.018, "end": 407.018, "text": "y el ampliado y enter", "speaker": null}, {"start": 407.018, "end": 408.198, "text": "y solito me lo va a calcular", "speaker": null}, {"start": 408.198, "end": 409.438, "text": "¿qué va a hacer la maquinita?", "speaker": null}, {"start": 410.618, "end": 411.97803, "text": "va a sustituir", "speaker": null}, {"start": 411.97803, "end": 415.73798, "text": "y va a decir, ¿dónde demonios está el activo circular?", "speaker": null}, {"start": 416.73798, "end": 419.878, "text": "Aquí, en el A2.", "speaker": null}, {"start": 420.478, "end": 424.358, "text": "Vamos a la A2, Carlos, y poner aquí 69.", "speaker": null}, {"start": 425.538, "end": 427.518, "text": "Oye, ¿el pasivo corto plazo dónde está?", "speaker": null}, {"start": 428.23798, "end": 431.498, "text": "No sé, en el H20.", "speaker": null}, {"start": 432.038, "end": 435.398, "text": "Por favor, no lo suponiendo, es exagerado, tratando de acercar a ustedes.", "speaker": null}, {"start": 436.538, "end": 439.438, "text": "Pero la realidad es que esto ustedes van a tener que ver con un diseñador.", "speaker": null}, {"start": 439.438, "end": 440.318, "text": "¿Están de acuerdo?", "speaker": null}, {"start": 440.318, "end": 442.418, "text": "ok, pero esa si es el senso", "speaker": null}, {"start": 442.418, "end": 444.85797, "text": "entonces dividimos", "speaker": null}, {"start": 444.85797, "end": 455.23602, "text": "los 60 entre los 35 esta vez igual El presente qu va a ser igual", "speaker": null}, {"start": 459.696, "end": 460.996, "text": "No creo.", "speaker": null}, {"start": 465.23602, "end": 466.656, "text": "¿1. qué?", "speaker": null}, {"start": 467.45602, "end": 468.056, "text": "71.", "speaker": null}, {"start": 468.876, "end": 469.876, "text": "¿1.70?", "speaker": null}, {"start": 470.436, "end": 471.57602, "text": "71.4.", "speaker": null}, {"start": 472.316, "end": 474.996, "text": "Esto es igual a 1.60.", "speaker": null}, {"start": 475.036, "end": 485.976, "text": "30 millones. ¿Es correcto? Aquí tendríamos que hacer lo mismo. ¿Cierto? El RCT va a", "speaker": null}, {"start": 485.976, "end": 491.896, "text": "ser igual, no a la interactividad circulante, sino que va a ser con corto plazo, el RCT", "speaker": null}, {"start": 491.896, "end": 502.816, "text": "va a ser 