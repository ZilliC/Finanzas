aker": null}, {"start": 792.114, "end": 792.954, "text": "que existan", "speaker": null}, {"start": 792.954, "end": 795.454, "text": "ustedes deben de poder identificar", "speaker": null}, {"start": 795.454, "end": 797.474, "text": "cuando menos tres tipos", "speaker": null}, {"start": 797.474, "end": 799.334, "text": "entre todas ellas", "speaker": null}, {"start": 799.334, "end": 801.294, "text": "¿cuáles van a ser estas?", "speaker": null}, {"start": 801.834, "end": 804.19403, "text": "van a ser las razones de tipo financiero", "speaker": null}, {"start": 804.19403, "end": 808.054, "text": "van a ser las razones rotativas", "speaker": null}, {"start": 808.054, "end": 811.27405, "text": "y van a ser las razones cronológicas.", "speaker": null}, {"start": 811.834, "end": 814.434, "text": "Es decir, para efectos de interpretación", "speaker": null}, {"start": 814.434, "end": 818.254, "text": "tenemos que identificar cada una de estas", "speaker": null}, {"start": 818.254, "end": 821.594, "text": "o estas en qué clasificación caen.", "speaker": null}, {"start": 822.474, "end": 822.89404, "text": "¿Por qué?", "speaker": null}, {"start": 823.614, "end": 825.594, "text": "Porque todas las razones financieras,", "speaker": null}, {"start": 825.594, "end": 828.094, "text": "todas, sea el nombre que le pongan,", "speaker": null}, {"start": 828.614, "end": 829.914, "text": "sea el tipo que sea,", "speaker": null}, {"start": 830.674, "end": 832.834, "text": "todas se van a leer", "speaker": null}, {"start": 832.834, "end": 836.51404, "text": "en dinero", "speaker": null}, {"start": 836.51404, "end": 838.63403, "text": "o en porcentaje.", "speaker": null}, {"start": 839.39404, "end": 840.034, "text": "¿O en qué?", "speaker": null}, {"start": 840.314, "end": 841.15405, "text": "Porcentaje.", "speaker": null}, {"start": 843.714, "end": 845.294, "text": "Todas las razones", "speaker": null}, {"start": 845.294, "end": 847.854, "text": "rotativas, todas en excepción,", "speaker": 