[{"start": 0.0, "end": 5.8799996, "text": "¿Todavía podrías pagar 70 centavos de cada leo que tenías?", "speaker": null}, {"start": 6.7999997, "end": 7.8799996, "text": "¿O no lo necesitas?", "speaker": null}, {"start": 9.3, "end": 12.82, "text": "¿Pero dónde me cogiste eso?", "speaker": null}, {"start": 13.299999, "end": 14.44, "text": "¿O por qué lo necesitas?", "speaker": null}, {"start": 15.46, "end": 19.06, "text": "Pues porque eso es lo que significa el costo a un hito de trabajo.", "speaker": null}, {"start": 19.76, "end": 23.06, "text": "Eso es lo que te queda después de pagar tus pasillos.", "speaker": null}, {"start": 23.32, "end": 25.1, "text": "¿Cuál sería la determinación de eso?", "speaker": null}, {"start": 26.26, "end": 27.16, "text": "Dios, chévere.", "speaker": null}, {"start": 30.0, "end": 35.0, "text": "que después de pagar tu deuda...", "speaker": null}, {"start": 35.0, "end": 37.0, "text": "No.", "speaker": null}, {"start": 37.0, "end": 39.0, "text": "Sí.", "speaker": null}, {"start": 39.0, "end": 44.0, "text": "No, que después de pagar tu deuda con lo que...", "speaker": null}, {"start": 44.0, "end": 46.0, "text": "No.", "speaker": null}, {"start": 46.0, "end": 51.0, "text": "Ah, de la deuda que tenías, si la pagas con lo que...", "speaker": null}, {"start": 51.0, "end": 55.0, "text": "Y todavía te queda...", "speaker": null}, {"start": 55.0, "end": 58.0, "text": "Podría estar bien pagar...", "speaker": null}, {"start": 58.0, "end": 59.0, "text": "Pero no sabe de finanzas.", "speaker": null}, {"start": 59.0, "end": 62.1, "text": "No sabe de finanzas.", "speaker": null}, {"start": 65.98, "end": 67.38, "text": "¿Qué estás analizando?", "speaker": null}, {"start": 67.6, "end": 68.28, "text": "Porque estás...", "speaker": null}, {"start": 68.28, "end": 73.28, "text": "A ver, vamos a ver.", "speaker": null}, {"start": 74.1, "end": 76.159996, "text": "Ay, qué charla, qué charla.", "speaker": null}, {"start": 77.0, "end": 80.08, "text": "Primero se tiene que mencionar la cifra del...", "speaker": null}, {"start": 80.08, "end": 83.04, "text": "del pasivo a corto plazo.", "speaker": null}, {"start": 83.06, "end": 83.74, "text": "No, es cierto.", "speaker": null}, {"start": 83.9, "end": 84.02, "text": "¿No?", "speaker": null}, {"start": 84.2, "end": 84.5, "text": "Claro.", "speaker": null}, {"start": 85.06, "end": 85.46, "text": "Entonces.", "speaker": null}, {"start": 86.52, "end": 87.14, "text": "A ver, ya.", "speaker": null}, {"start": 88.0, "end": 95.6, "text": "Mi fórmula me dice que es MS igual a CMT entre el básico corto plazo.", "speaker": null}, {"start": 96.6, "end": 98.02, "text": "Este va a ser mi antecedente.", "speaker": null}, {"start": 99.52, "end": 105.48, "text": "Esta que es la operación, la operación, y este es el consecuente.", "speaker": null}, {"start": 106.54, "end": 111.26, "text": "Nada más que aquí, aquí tengo un detalle que estás omitiendo.", "speaker": null}, {"start": 111.26, "end": 113.979996, "text": "aquí que me detalle", "speaker": null}, {"start": 113.979996, "end": 115.92, "text": "es que tu antecedente", "speaker": null}, {"start": 115.92, "end": 118.59999, "text": "no es una cuenta o un rubro", "speaker": null}, {"start": 118.59999, "end": 120.52, "text": "contable, es una", "speaker": null}, {"start": 120.52, "end": 121.27999, "text": "fórmula", "speaker": null}, {"start": 121.27999, "end": 124.27999, "text": "la fórmula es CNT", "speaker": null}, {"start": 124.27999, "end": 126.7, "text": "es como", "speaker": null}, {"start": 126.7, "end": 128.62, "text": "ahora lo voy a hacer de una manera", "speaker": null}, {"start": 128.62, "end": 129.18, "text": "diferente", "speaker": null}, {"start": 129.18, "end": 132.18, "text": "tú hiciste trampa", "speaker": null}, {"start": 132.18, "end": 134.68, "text": "y lo hiciste por la vía más", "speaker": null}, {"start": 134.68, "end": 135.57999, "text": "sencilla", "speaker": null}, {"start": 135.57999, "end": 137.95999, "text": "¿qué dijo Charlie? yo soy de chingón", "speaker": null}, {"start": 137.95999, "end": 140.78, "text": "yo soy informático y me lo paso por el arco", "speaker": null}, {"start": 140.78, "end": 143.34, "text": "viste CNT", "speaker": null}, {"start": 143.34, "end": 145.02, "text": "CNT", "speaker": null}, {"start": 145.02, "end": 148.16, "text": "es igual a 5 millones", "speaker": null}, {"start": 148.16, "end": 149.62, "text": "sobre", "speaker": null}, {"start": 149.62, "end": 151.28, "text": "pasivo a corto plazo", "speaker": null}, {"start": 151.28, "end": 153.3, "text": "pasivo a corto plazo", "speaker": null}, {"start": 153.3, "end": 155.28, "text": "es igual a 35 millones", "speaker": null}, {"start": 155.28, "end": 157.24, "text": "y el charly dice", "speaker": null}, {"start": 157.24, "end": 158.42, "text": "ya le he hecho", "speaker": null}, {"start": 158.42, "end": 159.95999, "text": "ya le he hecho", "speaker": null}, {"start": 159.95999, "end": 162.38, "text": "fíjate que ha gustado la salud del charly", "speaker": null}, {"start": 162.38, "end": 163.26, "text": "no está mal", "speaker": null}, {"start": 163.26, "end": 165.12, "text": "no está mal lo que hiciste", "speaker": null}, {"start": 165.12, "end": 168.54, "text": "pero está bien para cuando ya sabes", "speaker": null}, {"start": 168.54, "end": 169.94, "text": "cómo manejarlo", "speaker": null}, {"start": 169.94, "end": 172.66, "text": "cuando no sabes", "speaker": null}, {"start": 172.66, "end": 175.46, "text": "debes de haber entendido", "speaker": null}, {"start": 175.46, "end": 176.34, "text": "que es lo que pasó", "speaker": null}, {"start": 176.34, "end": 179.40001, "text": "si lo volvemos a sustituir", "speaker": null}, {"start": 179.40001, "end": 181.5, "text": "MS", "speaker": null}, {"start": 181.5, "end": 182.78, "text": "va a ser igual a qué", "speaker": null}, {"start": 182.78, "end": 186.14, "text": "la técnica me dice que yo debía haber sustituido", "speaker": null}, {"start": 186.14, "end": 187.14, "text": "CNT", "speaker": null}, {"start": 187.14, "end": 189.76, "text": "es igual a la cantidad circulante", "speaker": null}, {"start": 189.76, "end": 192.12, "text": "menos el pasivo a corto plazo", "speaker": null}, {"start": 192.12, "end": 193.66, "text": "todo esto", "speaker": null}, {"start": 193.66, "end": 195.46, "text": "sobre pasivo", "speaker": null}, {"start": 195.46, "end": 197.0, "text": "a corto plazo", "speaker": null}, {"start": 197.0, "end": 199.12, "text": "¿es correcto?", "speaker": null}, {"start": 199.12, "end": 213.84, "text": "Luego entonces, MS es igual a 60 millones de pesos menos 35 millones de pesos sobre 35 millones de pesos.", "speaker": null}, {"start": 215.58, "end": 230.11801, "text": "MS es igual a 60 millones menos 35 menos 25 millones de pesos sobre 35 millones de pesos Es lo mismo Es lo mismo pero diferente qu Porque lo que me est diciendo la f", "speaker": null}, {"start": 230.11801, "end": 232.878, "text": "La fórmula es, paga lo que debes.", "speaker": null}, {"start": 235.33801, "end": 237.098, "text": "Paga lo que debes.", "speaker": null}, {"start": 237.33801, "end": 238.89801, "text": "Primero pagas lo que debes.", "speaker": null}, {"start": 239.778, "end": 240.418, "text": "Correcto.", "speaker": null}, {"start": 241.058, "end": 245.83801, "text": "Y con el recibo me dices que representa en función a la deuda.", "speaker": null}, {"start": 245.83801, "end": 248.498, "text": "quiere decir entonces que aquí", "speaker": null}, {"start": 248.498, "end": 249.75801, "text": "mi empresa", "speaker": null}, {"start": 249.75801, "end": 252.858, "text": "es capaz de pagar", "speaker": null}, {"start": 252.858, "end": 254.198, "text": "toda la deuda", "speaker": null}, {"start": 254.198, "end": 255.45801, "text": "porque aquí ya la pagó", "speaker": null}, {"start": 255.45801, "end": 258.438, "text": "aquí ya la pagó", "speaker": null}, {"start": 258.438, "end": 259.838, "text": "o no", "speaker": null}, {"start": 259.838, "end": 261.958, "text": "estos 25", "speaker": null}, {"start": 261.958, "end": 263.898, "text": "ya son 25", "speaker": null}, {"start": 263.898, "end": 268.49802, "text": "de hecho", "speaker": null}, {"start": 268.49802, "end": 270.538, "text": "MS es una razón de", "speaker": null}, {"start": 270.538, "end": 271.798, "text": "confirmación", "speaker": null}, {"start": 271.798, "end": 272.958, "text": "así se llama", "speaker": null}, {"start": 272.958, "end": 275.558, "text": "¿por qué?", "speaker": null}, {"start": 275.838, "end": 285.358, "text": "Porque aquí me está diciendo la fórmula que yo pague lo que debo y verifique si todavía", "speaker": null}, {"start": 285.358, "end": 286.558, "text": "tengo un excedente.", "speaker": null}, {"start": 288.358, "end": 300.258, "text": "Aquí estoy pagando lo que debo y mi excedente me representa el 71% de la deuda.", "speaker": null}, {"start": 300.258, "end": 312.438, "text": "original, es decir, puedo pagar la deuda y todavía me sobra el equivalente al 71% de", "speaker": null}, {"start": 312.438, "end": 323.438, "text": "mi deuda original. Quiere decir entonces que MS técnicamente viene haciendo que esto se", "speaker": null}, {"start": 323.438, "end": 325.138, "text": "que es lo que me sobra", "speaker": null}, {"start": 325.138, "end": 328.338, "text": "y este equivale al 71%", "speaker": null}, {"start": 328.338, "end": 330.938, "text": "yo tengo una capacidad", "speaker": null}, {"start": 330.938, "end": 332.558, "text": "del deudamiento equivalente", "speaker": null}, {"start": 332.558, "end": 335.558, "text": "al 71%", "speaker": null}, {"start": 335.558, "end": 336.758, "text": "yo puedo tomar", "speaker": null}, {"start": 336.758, "end": 337.538, "text": "más deuda", "speaker": null}, {"start": 337.538, "end": 339.958, "text": "me puedo comprometer", "speaker": null}, {"start": 339.958, "end": 341.978, "text": "y si no me quiero comprometer", "speaker": null}, {"start": 341.978, "end": 343.098, "text": "puedo invertir", "speaker": null}, {"start": 343.098, "end": 346.118, "text": "si no quiero invertir puedo gastar", "speaker": null}, {"start": 346.118, "end": 349.178, "text": "tengo dinero de sobra", "speaker": null}, {"start": 353.438, "end": 363.758, "text": "Bueno, pienso que entonces tener ese dinero que sobra, pues es casi como tener, o sea, si lo tienes en el banco sin ninguna inversión, pues lo estás tirando a los otros.", "speaker": null}, {"start": 363.938, "end": 364.398, "text": "Ahí sí.", "speaker": null}, {"start": 364.838, "end": 366.578, "text": "Pero, o sea, te conviene…", "speaker": null}, {"start": 366.578, "end": 368.438, "text": "Tomar decisiones, algo con ese dinero.", "speaker": null}, {"start": 368.59802, "end": 371.938, "text": "Sí, o tomar más deuda o invertirlo.", "speaker": null}, {"start": 372.338, "end": 373.65802, "text": "O poder invertirlo en algo.", "speaker": null}, {"start": 374.09802, "end": 380.438, "text": "O puedo comprar algo, puedo comprar a lo mejor, si ese equivalente se toma como un porcentaje impasible, a lo mejor puedo comprar un ratito.", "speaker": null}, {"start": 380.818, "end": 382.03802, "text": "Ajá, o dar que lo pico.", "speaker": null}, {"start": 382.03802, "end": 385.038, "text": "por eso puedo comprar un activo", "speaker": null}, {"start": 385.038, "end": 387.278, "text": "¿te acuerdas que dijimos que", "speaker": null}, {"start": 387.278, "end": 389.658, "text": "las fuentes de inversión", "speaker": null}, {"start": 389.658, "end": 391.918, "text": "si yo tengo este", "speaker": null}, {"start": 391.918, "end": 393.658, "text": "lo puedo pasar para acá", "speaker": null}, {"start": 393.658, "end": 395.918, "text": "y el desde que esté ocioso", "speaker": null}, {"start": 395.918, "end": 397.598, "text": "puedo comprar otra máquina", "speaker": null}, {"start": 397.598, "end": 399.538, "text": "o puedo comprar", "speaker": null}, {"start": 399.538, "end": 400.718, "text": "un camión", "speaker": null}, {"start": 400.718, "end": 403.078, "text": "o puedo comprar algo", "speaker": null}, {"start": 403.078, "end": 405.958, "text": "¿y eso podría pasar", "speaker": null}, {"start": 405.958, "end": 407.578, "text": "a pagar parte de", "speaker": null}, {"start": 407.578, "end": 408.438, "text": "por ejemplo", "speaker": null}, {"start": 408.438, "end": 411.458, "text": "o si quiero pagar parte de mi deuda de compras", "speaker": null}, {"start": 411.458, "end": 413.03802, "text": "pero no me conguí", "speaker": null}, {"start": 413.03802, "end": 415.47803, "text": "porque tienen que pagar por adelantar", "speaker": null}, {"start": 415.47803, "end": 416.97803, "text": "y por seguir pagando por adelantar", "speaker": null}, {"start": 416.97803, "end": 419.558, "text": "a menos que te estén", "speaker": null}, {"start": 419.558, "end": 421.858, "text": "cortando más intereses de lo que puedes", "speaker": null}, {"start": 421.858, "end": 423.758, "text": "y tú no sigues", "speaker": null}, {"start": 423.758, "end": 424.318, "text": "en la inversión", "speaker": null}, {"start": 424.318, "end": 427.198, "text": "¿qué puedo hacer?", "speaker": null}, {"start": 427.938, "end": 428.998, "text": "reestructurar mi deuda", "speaker": null}, {"start": 428.998, "end": 430.998, "text": "yo debo a la agroclasia", "speaker": null}, {"start": 430.998, "end": 433.498, "text": "pero si aquí tengo una carga muy alta", "speaker": null}, {"start": 433.498, "end": 435.458, "text": "¿sabes qué? mejor que te la paso", "speaker": null}, {"start": 435.458, "end": 436.458, "text": "para que hay un compuesto", "speaker": null}, {"start": 436.458, "end": 439.898, "text": "y elimino la carga financiera", "speaker": null}, {"start": 439.898, "end": 452.256, "text": "Ya no me siento c y bastante senados El saber c est mi empresa me permite tomar decisiones Hay un programa qu nos habla", "speaker": null}, {"start": 455.216, "end": 457.056, "text": "O sea, el programa no está mal.", "speaker": null}, {"start": 458.63602, "end": 460.35602, "text": "El programa lo que está haciendo", "speaker": null}, {"start": 460.35602, "end": 464.316, "text": "es que está suponiendo que todo esto ustedes ya lo saben.", "speaker": null}, {"start": 465.57602, "end": 466.73602, "text": "Ese es el problema.", "speaker": null}, {"start": 468.07602, "end": 470.13602, "text": "Y el problema no es que supongan que ya lo saben,", "speaker": null}, {"start": 470.29602, "end": 471.496, "text": "el problema es que no lo saben.", "speaker": null}, {"start": 472.496, "end": 474.476, "text": "Porque deberían de saberlo", "speaker": null}, {"start": 474.476, "end": 480.91602, "text": "aplicación de las técnicas de análisis", "speaker": null}, {"start": 480.91602, "end": 483.536, "text": "esta es una técnica de análisis", "speaker": null}, {"start": 483.536, "end": 487.73602, "text": "como ven, estamos sobre el programa", "speaker": null}, {"start": 487.73602, "end": 490.596, "text": "pero necesito que tengan las bases", "speaker": null}, {"start": 490.596, "end": 492.79602, "text": "si no tienen las bases, como chingados lo van a hacer", "speaker": null}, {"start": 492.79602, "end": 495.276, "text": "ahora si ya estamos en nuestro programa", "speaker": null}, {"start": 495.276, "end": 496.456, "text": "ya estamos aplicando", "speaker": null}, {"start": 496.456, "end": 498.896, "text": "los métodos de análisis", "speaker": null}, {"start": 498.896, "end": 501.256, "text": "¿qué puedo hacer con este cuate, Chay?", "speaker": null}, {"start": 501.756, "end": 503.596, "text": "¿o qué puedo hacer con este cuate?", "speaker": null}, {"start": 504.476, "end": 507.07602, "text": "Bueno, pues este cuate tiene una boca también de caguama.", "speaker": null}, {"start": 508.73602, "end": 511.056, "text": "Tú vas a decir lo que diría cualquier insensato.", "speaker": null}, {"start": 511.536, "end": 516.516, "text": "Ah, bueno, si no tengo dinero para pagar, ¿cuál sería la solución?", "speaker": null}, {"start": 516.616, "end": 518.576, "text": "¿Qué nos diría cualquier persona común y corriente?", "speaker": null}, {"start": 518.99603, "end": 519.636, "text": "Que vendan.", "speaker": null}, {"start": 519.81604, "end": 521.616, "text": "Pues pide un préstamo, ¿no?", "speaker": null}, {"start": 522.036, "end": 523.296, "text": "Pide un préstamo para pagar.", "speaker": null}, {"start": 525.616, "end": 526.956, "text": "Vamos a ver si es cierto.", "speaker": null}, {"start": 528.696, "end": 533.536, "text": "Si tú pides un préstamo, va a entrar el dinero.", "speaker": null}, {"start": 533.536, "end": 535.256, "text": "¿cuánto tendrías que pedir de préstamo?", "speaker": null}, {"start": 536.076, "end": 537.456, "text": "según esto, 30 millones", "speaker": null}, {"start": 537.456, "end": 540.43604, "text": "entonces, tú metes aquí", "speaker": null}, {"start": 540.43604, "end": 545.216, "text": "30 millones", "speaker": null}, {"start": 545.216, "end": 546.456, "text": "con 30 millones", "speaker": null}, {"start": 546.456, "end": 550.676, "text": "ya puedes pagar", "speaker": null}, {"start": 550.676, "end": 552.676, "text": "o no", "speaker": null}, {"start": 552.676, "end": 555.31604, "text": "si, nada más que se te olvidó algo", "speaker": null}, {"start": 555.31604, "end": 557.236, "text": "¿a quién se lo debes?", "speaker": null}, {"start": 557.676, "end": 559.536, "text": "al banco capo", "speaker": null}, {"start": 559.536, "end": 560.836, "text": "este", "speaker": null}, {"start": 560.836, "end": 563.456, "text": "como no puedo pagar porque ya me tengo que usar", "speaker": null}, {"start": 563.456, "end": 565.836, "text": "haz de cuenta que lo vas a hacer hasta acá", "speaker": null}, {"start": 565.836, "end": 568.796, "text": "este también creció", "speaker": null}, {"start": 568.796, "end": 570.856, "text": "no resolviste el problema", "speaker": null}, {"start": 570.856, "end": 573.076, "text": "te metiste en uno peor", "speaker": null}, {"start": 573.076, "end": 574.93604, "text": "porque ahora", "speaker": null}, {"start": 574.93604, "end": 576.136, "text": "ya le ves más", "speaker": null}, {"start": 576.136, "end": 577.836, "text": "ya no se lo debes al Mike", "speaker": null}, {"start": 577.836, "end": 579.276, "text": "ahora se lo debes al banco", "speaker": null}, {"start": 579.276, "end": 583.116, "text": "el Mike es tu cuate", "speaker": null}, {"start": 583.116, "end": 585.016, "text": "el banco no", "speaker": null}, {"start": 585.016, "end": 585.81604, "text": "el banco te va a decir", "speaker": null}, {"start": 585.81604, "end": 586.536, "text": "¿sabes qué caro?", "speaker": null}, {"start": 587.556, "end": 588.656, "text": "los 30 millones", "speaker": null}, {"start": 588.656, "end": 591.81604, "text": "más los intereses", "speaker": null}, {"start": 591.81604, "end": 593.776, "text": "¿Y qué crees?", "speaker": null}, {"start": 594.536, "end": 596.376, "text": "Que los intereses no aparecen aquí", "speaker": null}, {"start": 596.376, "end": 600.256, "text": "Aparentemente no están", "speaker": null}, {"start": 600.256, "end": 602.336, "text": "Pero no es cierto, si están", "speaker": null}, {"start": 602.336, "end": 603.916, "text": "No los ves", "speaker": null}, {"start": 603.916, "end": 605.636, "text": "Porque ¿en dónde están?", "speaker": null}, {"start": 606.276, "end": 608.016, "text": "En el estado de los resultados", "speaker": null}, {"start": 608.016, "end": 616.136, "text": "Entonces tú solito te metiste un golpe bajo", "speaker": null}, {"start": 616.136, "end": 617.716, "text": "Y ni cuenta que estás ahí", "speaker": null}, {"start": 617.716, "end": 619.896, "text": "¿Por qué si no aparece?", "speaker": null}, {"start": 621.81604, "end": 623.69604, "text": "Va a aparecer en el estado de resultados.", "speaker": null}, {"start": 624.616, "end": 626.256, "text": "Y al estar en el estado de resultados,", "speaker": null}, {"start": 626.396, "end": 627.31604, "text": "si tú tienes utilidad,", "speaker": null}, {"start": 628.636, "end": 629.356, "text": "se llamaba,", "speaker": null}, {"start": 629.516, "end": 631.076, "text": "ya no tienes utilidad, compá.", "speaker": null}, {"start": 632.536, "end": 633.596, "text": "Porque ahora no tienes.", "speaker": null}, {"start": 638.19604, "end": 640.396, "text": "Si vio que hayas pedido prestado,", "speaker": null}, {"start": 641.216, "end": 642.016, "text": "no, maestro,", "speaker": null}, {"start": 642.776, "end": 643.616, "text": "te uniste más.", "speaker": null}, {"start": 645.096, "end": 645.93604, "text": "Por eso es que", "speaker": null}, {"start": 645.93604, "end": 647.556, "text": "los bancos son de la base.", "speaker": null}, {"start": 648.956, "end": 650.176, "text": "Los bancos siempre te dicen,", "speaker": null}, {"start": 650.176, "end": 651.336, "text": "tienes problemas.", "speaker": null}, {"start": 651.81604, "end": 654.81604, "text": "creo que te van a tragar.", "speaker": null}, {"start": 654.81604, "end": 656.81604, "text": "O al menos sientas el deseo.", "speaker": null}, {"start": 656.81604, "end": 661.81604, "text": "Y hay una importancia que veamos el sistema financiero.", "speaker": null}, {"start": 661.81604, "end": 665.81604, "text": "Para que veas cómo se comporta el sistema financiero.", "speaker": null}, {"start": 665.81604, "end": 669.81604, "text": "Y por qué el sistema financiero mueve muchísimo tu dinero.", "speaker": null}, {"start": 669.81604, "end": 679.45404, "text": "es el propio derecho del banco S se est observando Entonces dices s mira s mira otra soluci puedo dar", "speaker": null}, {"start": 681.154, "end": 681.974, "text": "ah, bien fácil", "speaker": null}, {"start": 681.974, "end": 683.414, "text": "no va a faltar el que diga a alguien", "speaker": null}, {"start": 683.414, "end": 684.654, "text": "oye", "speaker": null}, {"start": 684.654, "end": 687.734, "text": "¿qué te parece si en vez de que consiga", "speaker": null}, {"start": 687.734, "end": 688.154, "text": "dinero", "speaker": null}, {"start": 688.154, "end": 691.654, "text": "haga una capitalización de pasivos", "speaker": null}, {"start": 691.654, "end": 693.494, "text": "¿sí sabes lo que es una capitalización de pasivos?", "speaker": null}, {"start": 693.95404, "end": 694.154, "text": "no", "speaker": null}, {"start": 694.154, "end": 696.63403, "text": "es que la deuda", "speaker": null}, {"start": 696.63403, "end": 699.174, "text": "en vez de estar acá, la pasas para acá", "speaker": null}, {"start": 699.174, "end": 702.594, "text": "entonces hay mucha gente que lo que hace", "speaker": null}, {"start": 702.594, "end": 705.114, "text": "es que te dice bueno en vez de que yo te pague", "speaker": null}, {"start": 705.114, "end": 706.554, "text": "¿qué te parece si te hago socio?", "speaker": null}, {"start": 706.834, "end": 708.094, "text": "ya se oí hablar de eso", "speaker": null}, {"start": 708.094, "end": 710.834, "text": "con las acciones", "speaker": null}, {"start": 710.834, "end": 713.674, "text": "en vez de ser aquí", "speaker": null}, {"start": 713.674, "end": 716.114, "text": "capitalizo el pasivo", "speaker": null}, {"start": 716.114, "end": 717.13403, "text": "te paso para acá", "speaker": null}, {"start": 717.13403, "end": 719.834, "text": "y si ahora eres mi socio ya no te debo", "speaker": null}, {"start": 719.834, "end": 721.89404, "text": "ya no te tengo que pagar", "speaker": null}, {"start": 721.89404, "end": 723.274, "text": "ya no me puedes cobrar", "speaker": null}, {"start": 723.274, "end": 725.39404, "text": "si cabrón", "speaker": null}, {"start": 725.39404, "end": 727.734, "text": "nada más te dije que te quito un capital", "speaker": null}, {"start": 727.734, "end": 728.554, "text": "es de 15", "speaker": null}, {"start": 728.554, "end": 731.934, "text": "lo que te falta de pasivo", "speaker": null}, {"start": 731.934, "end": 735.27405, "text": "son 30", "speaker": null}, {"start": 735.27405, "end": 738.174, "text": "cuando tú pases", "speaker": null}, {"start": 738.174, "end": 739.734, "text": "este para acá", "speaker": null}, {"start": 739.734, "end": 742.314, "text": "este ya va a ser de 45", "speaker": null}, {"start": 742.314, "end": 743.914, "text": "¿ok?", "speaker": null}, {"start": 744.974, "end": 746.07404, "text": "este lo resolviste", "speaker": null}, {"start": 746.07404, "end": 747.754, "text": "pero ahora tienes una bronca", "speaker": null}, {"start": 747.754, "end": 749.834, "text": "tu socio", "speaker": null}, {"start": 749.834, "end": 752.234, "text": "se convierte en mayoritario", "speaker": null}, {"start": 752.234, "end": 754.814, "text": "y si eres mayoritario", "speaker": null}, {"start": 754.814, "end": 755.77405, "text": "¿qué crees?", "speaker": null}, {"start": 755.89404, "end": 757.27405, "text": "ya no es tu empresa", "speaker": null}, {"start": 757.27405, "end": 759.69403, "text": "ahora es mi empresa", "speaker": null}, {"start": 759.69403, "end": 762.094, "text": "perdiste la empresa", "speaker": null}, {"start": 762.094, "end": 764.234, "text": "¿por qué no?", "speaker": null}, {"start": 766.814, "end": 767.714, "text": "¿qué crees que hace", "speaker": null}, {"start": 767.714, "end": 768.374, "text": "Wulbert?", "speaker": null}, {"start": 769.494, "end": 770.674, "text": "¿qué crees que hace", "speaker": null}, {"start": 770.674, "end": 772.674, "text": "quien mencionamos?", "speaker": null}, {"start": 775.334, "end": 776.114, "text": "el señor Slim", "speaker": null}, {"start": 776.114, "end": 777.714, "text": "no, o sea, tú les da créditos", "speaker": null}, {"start": 777.714, "end": 779.034, "text": "y luego cuando no lo pueden pagar", "speaker": null}, {"start": 779.034, "end": 780.334, "text": "las absorbe", "speaker": null}, {"start": 780.334, "end": 783.734, "text": "no dijimos que", "speaker": null}, {"start": 783.734, "end": 784.874, "text": "él es experto en comprar", "speaker": null}, {"start": 784.874, "end": 785.934, "text": "tres astronadas", "speaker": null}, {"start": 785.934, "end": 789.334, "text": "las compra bien baratas", "speaker": null}, {"start": 789.334, "end": 791.714, "text": "y después los se les envuelve", "speaker": null}, {"start": 791.714, "end": 796.594, "text": "digo, no es así de sencillo", "speaker": null}, {"start": 796.594, "end": 798.294, "text": "porque el ocupante de la línea financiera", "speaker": null}, {"start": 798.294, "end": 800.214, "text": "es algo más sofisticado que esto", "speaker": null}, {"start": 800.214, "end": 802.794, "text": "mucho más sofisticado que esto", "speaker": null}, {"start": 802.794, "end": 805.174, "text": "pero vamos, al hablar de una empresa tronada", "speaker": null}, {"start": 805.174, "end": 806.914, "text": "estás hablando de una empresa con problemas", "speaker": null}, {"start": 806.914, "end": 810.19403, "text": "una empresa con problemas está desesperada", "speaker": null}, {"start": 810.19403, "end": 811.294, "text": "por salir de sus bloques", "speaker": null}, {"start": 811.294, "end": 813.674, "text": "o mal barata", "speaker": null}, {"start": 813.674, "end": 816.69403, "text": "o toma decisiones", "speaker": null}, {"start": 816.69403, "end": 818.19403, "text": "que muchas veces", "speaker": null}, {"start": 818.19403, "end": 819.834, "text": "no son bien estudiadas", "speaker": null}, {"start": 819.834, "end": 822.534, "text": "son más perjudiciales.", "speaker": null}, {"start": 823.834, "end": 824.674, "text": "¿Se alcanza a observar", "speaker": null}, {"start": 824.674, "end": 825.63403, "text": "o no se alcanza a observar?", "speaker": null}, {"start": 826.254, "end": 827.454, "text": "Eso es lo que quiere el programa", "speaker": null}, {"start": 827.454, "end": 828.234, "text": "que haga ustedes.", "speaker": null}, {"start": 829.914, "end": 830.994, "text": "¿Cómo lo puedo hacer?", "speaker": null}, {"start": 831.354, "end": 832.254, "text": "A simple vista,", "speaker": null}, {"start": 833.154, "end": 835.63403, "text": "los que ya manejamos estudios", "speaker": null}, {"start": 835.63403, "end": 837.454, "text": "en los que yo nada más converto estructura", "speaker": null}, {"start": 837.454, "end": 839.01404, "text": "no se si son bien estudiados.", "speaker": null}, {"start": 841.354, "end": 842.334, "text": "Digo porque estudio", "speaker": null}, {"start": 842.334, "end": 843.214, "text": "lo hago todos los días.", "speaker": null}, {"start": 843.674, "end": 846.674, "text": "ustedes no, ustedes necesitan los métodos", "speaker": null}, {"start": 846.674, "end": 849.594, "text": "pero cada una vez que estoy viendo las hijas", "speaker": null}, {"start": 849.594, "end": 851.174, "text": "les digo, ay caramba, me superan un tanto", "speaker": null}, {"start": 851.174, "end": 855.39404, "text": "o sea que tienen que llevar un milagro", "speaker": null}, {"start": 855.39404, "end": 857.574, "text": "con carma, antes de tomar una decisión", "speaker": null}, {"start": 857.574, "end": 859.794, "text": "no coopere, pero es algo no más que coopere", "speaker": null}, {"start": 859.794, "end": 864.19403, "text": "tú vas a decir cuando no hay bronca", "speaker": null}, {"start": 864.19403, "end": 866.174, "text": "el chat es bien rápido de mentes", "speaker": null}, {"start": 866.174, "end": 867.414, "text": "un pito de broncas", "speaker": null}, {"start": 867.414, "end": 869.954, "text": "vendo algo", "speaker": null}, {"start": 869.954, "end": 873.01404, "text": "¿qué puedes vender Charlie?", "speaker": null}, {"start": 873.674, "end": 878.574, "text": "Si esto ya está fuera, lo único que te queda, no puedes vender un activo diferido, ¿sí?", "speaker": null}, {"start": 879.374, "end": 881.734, "text": "No, porque esos ejemplos fueron gastos.", "speaker": null}, {"start": 882.454, "end": 883.574, "text": "¿Cómo vas a vender un gasto?", "speaker": null}, {"start": 884.994, "end": 886.914, "text": "Lo bueno es que no todo es gasto.", "speaker": null}, {"start": 887.454, "end": 894.094, "text": "Tengo, a lo mejor, gastos de instalación que está representado en toda la red de suministro eléctrico del edificio.", "speaker": null}, {"start": 894.974, "end": 897.994, "text": "Ok, quítale la red eléctrica y ahora compre el chico nuestro.", "speaker": null}]