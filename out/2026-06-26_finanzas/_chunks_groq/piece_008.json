[{"start": 0.0, "end": 0.88, "text": "Te llamabas.", "speaker": null}, {"start": 1.0799999, "end": 3.26, "text": "¿Qué es? ¿No ya estás vendiendo todo lo que es?", "speaker": null}, {"start": 3.6599998, "end": 5.7799997, "text": "Pues bueno, entonces, esto no lo puedo vender.", "speaker": null}, {"start": 6.54, "end": 7.3799996, "text": "¿Qué puedes vender?", "speaker": null}, {"start": 7.74, "end": 8.639999, "text": "Tu activo fijo.", "speaker": null}, {"start": 9.84, "end": 10.32, "text": "Pues igual.", "speaker": null}, {"start": 11.66, "end": 14.28, "text": "Si vendes maquinaria, entonces, ¿ahora con qué produces?", "speaker": null}, {"start": 15.339999, "end": 20.5, "text": "Si vendes los camiones, ¿ahora con qué distribuyes?", "speaker": null}, {"start": 22.24, "end": 26.779999, "text": "Si vendes el edificio, ¿ahora dónde demonios trabajas?", "speaker": null}, {"start": 30.0, "end": 33.22, "text": "vamos viendo que ya no está tan fácil", "speaker": null}, {"start": 33.22, "end": 34.1, "text": "como lo veía", "speaker": null}, {"start": 34.1, "end": 40.3, "text": "ahí es a donde entran ustedes", "speaker": null}, {"start": 40.3, "end": 43.84, "text": "¿cómo resuelvo este problema?", "speaker": null}, {"start": 45.32, "end": 46.6, "text": "pues tengo que pensar", "speaker": null}, {"start": 46.6, "end": 49.399998, "text": "entonces ahorita ya en la mente", "speaker": null}, {"start": 49.399998, "end": 50.46, "text": "de Charlie se me han dado aguas", "speaker": null}, {"start": 50.46, "end": 51.34, "text": "cuando yo en la pinche", "speaker": null}, {"start": 51.34, "end": 52.64, "text": "¿se acuerdan que les pregunté", "speaker": null}, {"start": 52.64, "end": 54.3, "text": "cuáles eran las empresas que comprarían?", "speaker": null}, {"start": 56.3, "end": 57.579998, "text": "y ustedes ingenuamente", "speaker": null}, {"start": 57.579998, "end": 59.54, "text": "pero correctamente me dijeron", "speaker": null}, {"start": 59.54, "end": 61.359997, "text": "yo compraría esta", "speaker": null}, {"start": 61.359997, "end": 63.459995, "text": "es lo que contestaron ustedes", "speaker": null}, {"start": 63.459995, "end": 66.619995, "text": "yo te dije yo, yo compraría esta", "speaker": null}, {"start": 66.619995, "end": 67.52, "text": "yo", "speaker": null}, {"start": 67.52, "end": 69.84, "text": "aguántenme tantito", "speaker": null}, {"start": 69.84, "end": 72.0, "text": "déjenme enseñarles otras cosas más", "speaker": null}, {"start": 72.0, "end": 73.799995, "text": "y ya sabré por qué yo compraría esta", "speaker": null}, {"start": 73.799995, "end": 78.2, "text": "si tú sabes utilizar", "speaker": null}, {"start": 78.2, "end": 79.28, "text": "el mundo financiero", "speaker": null}, {"start": 79.28, "end": 80.71999, "text": "estás del otro lado", "speaker": null}, {"start": 80.71999, "end": 82.799995, "text": "pero del otro lado", "speaker": null}, {"start": 82.799995, "end": 85.619995, "text": "¿se acuerdan que les acabo de decir que", "speaker": null}, {"start": 85.619995, "end": 87.14, "text": "hay empresas que están impérdidas", "speaker": null}, {"start": 87.14, "end": 89.72, "text": "y que son rentables", "speaker": null}, {"start": 89.72, "end": 91.42, "text": "pero esperense un momento", "speaker": null}, {"start": 91.42, "end": 93.12, "text": "a ver que se", "speaker": null}, {"start": 93.12, "end": 96.92, "text": "hasta que se va a entender", "speaker": null}, {"start": 96.92, "end": 98.54, "text": "o no", "speaker": null}, {"start": 98.54, "end": 100.94, "text": "seguros", "speaker": null}, {"start": 100.94, "end": 104.88, "text": "entonces cual sería la lectura negativa", "speaker": null}, {"start": 104.88, "end": 110.4, "text": "y bien sencillo", "speaker": null}, {"start": 110.4, "end": 111.7, "text": "empiezas con lo que eres", "speaker": null}, {"start": 111.7, "end": 114.84, "text": "el consecuente cual es el pasivo", "speaker": null}, {"start": 114.84, "end": 116.1, "text": "35", "speaker": null}, {"start": 116.1, "end": 121.1, "text": "Yo, entonces, comienzo con lo que debo.", "speaker": null}, {"start": 121.7, "end": 129.09999, "text": "Mi empresa es capaz de pagar toda su deuda y todavía tiene un excedente equivalente al 71%.", "speaker": null}, {"start": 129.09999, "end": 131.28, "text": "Comienzas a crecer.", "speaker": null}, {"start": 132.68, "end": 135.98, "text": "En la primera comienzas con lo que tienes y terminas con lo que debes.", "speaker": null}, {"start": 136.54, "end": 141.08, "text": "En la segunda comienzas con lo que debes y terminas con lo que tienes.", "speaker": null}, {"start": 141.78, "end": 144.26, "text": "Pero dice lo mismo con otras palabras.", "speaker": null}, {"start": 146.09999, "end": 148.13998, "text": "hoy vino la reacción", "speaker": null}, {"start": 148.13998, "end": 152.79999, "text": "si nosotros ahora aplicamos el margen de seguridad", "speaker": null}, {"start": 152.79999, "end": 153.87999, "text": "aquí", "speaker": null}, {"start": 153.87999, "end": 156.01999, "text": "aquí tienes", "speaker": null}, {"start": 156.01999, "end": 158.18, "text": "un 30 millones de pesos", "speaker": null}, {"start": 158.18, "end": 159.15999, "text": "en cantinos", "speaker": null}, {"start": 159.15999, "end": 161.93999, "text": "esto que te dice", "speaker": null}, {"start": 161.93999, "end": 164.06, "text": "que no tienes margen de seguridad", "speaker": null}, {"start": 164.06, "end": 166.49998, "text": "¿por qué no tengo margen de seguridad?", "speaker": null}, {"start": 167.09999, "end": 168.26, "text": "porque no me sobra", "speaker": null}, {"start": 168.26, "end": 169.91998, "text": "y no me sobra porque", "speaker": null}, {"start": 169.91998, "end": 171.43999, "text": "ni siquiera me alcanza para pagar", "speaker": null}, {"start": 171.43999, "end": 173.99998, "text": "tan sencillo como es", "speaker": null}, {"start": 174.0, "end": 176.56, "text": "Bueno", "speaker": null}, {"start": 176.56, "end": 180.68, "text": "¿Qué malito problema tiene esto?", "speaker": null}, {"start": 183.08, "end": 183.84, "text": "Ninguno", "speaker": null}, {"start": 183.84, "end": 188.2, "text": "Vamos a ver otra razóncita", "speaker": null}, {"start": 188.2, "end": 188.88, "text": "¿Vale?", "speaker": null}, {"start": 191.2, "end": 191.64, "text": "Ok", "speaker": null}, {"start": 191.64, "end": 193.58, "text": "Hasta ese momento", "speaker": null}, {"start": 193.58, "end": 195.28, "text": "Decíamos que", "speaker": null}, {"start": 195.28, "end": 199.76, "text": "Esta empresa está", "speaker": null}, {"start": 199.76, "end": 200.8, "text": "Aparentemente", "speaker": null}, {"start": 200.8, "end": 202.8, "text": "¿Sabe?", "speaker": null}, {"start": 204.0, "end": 208.64, "text": "Pero en el mundo financiero no me puedo conformar con una simple razón.", "speaker": null}, {"start": 210.1, "end": 217.14, "text": "Tengo que aplicar más razones y más métodos para poder determinar cuál es su verdadera condición financiera.", "speaker": null}, {"start": 218.34, "end": 231.078, "text": "ser una posible raz o cu podr ser otra raz que yo pueda aplicar Ejemplo la prueba seria o tambi conocida como prueba de vac", "speaker": null}, {"start": 232.17801, "end": 242.378, "text": "Esta prueba que me dice que yo tengo que considerar el activo circulante menos el inventario sobre vacío con tocas.", "speaker": null}, {"start": 243.39801, "end": 244.998, "text": "No, creo que eso es lo que me dice.", "speaker": null}, {"start": 244.998, "end": 251.998, "text": "Y si yo quiero hacer eso, pues ahora sí voy a tener que empezar a conocer las cuentas.", "speaker": null}, {"start": 258.438, "end": 263.838, "text": "Yo hasta ahorita he ocupado rubros, rubros con tapas.", "speaker": null}, {"start": 274.99802, "end": 284.878, "text": "Yo hasta ahorita estaba ocupando algunos contratos", "speaker": null}, {"start": 284.878, "end": 288.978, "text": "Pero pensé que íbamos a partir de lo general hacia donde", "speaker": null}, {"start": 288.978, "end": 291.038, "text": "A lo particular", "speaker": null}, {"start": 291.038, "end": 295.338, "text": "Entonces ahora ya no puedo continuar así", "speaker": null}, {"start": 295.338, "end": 298.458, "text": "Ahora sí necesito conocer las cuentas", "speaker": null}, {"start": 298.458, "end": 298.838, "text": "¿Por qué?", "speaker": null}, {"start": 298.838, "end": 303.498, "text": "Porque ahora me dicen que identifique el inventario", "speaker": null}, {"start": 303.498, "end": 310.698, "text": "La clase pasada veíamos que esta empresa probablemente pueda ser transformada, probablemente.", "speaker": null}, {"start": 312.138, "end": 315.338, "text": "Esta empresa, ¿qué tipo de empresa es?", "speaker": null}, {"start": 316.538, "end": 319.958, "text": "Probablemente comercializada, porque tiene un activo mucho en la creación.", "speaker": null}, {"start": 321.198, "end": 325.778, "text": "Y si es comercializadora, normalmente en dónde consiste la mayor parte del dinero?", "speaker": null}, {"start": 325.998, "end": 327.678, "text": "En inventarios.", "speaker": null}, {"start": 333.498, "end": 344.038, "text": "Si nosotros deseamos que aquí yo puedo tener cuentas como caja, como banco, como inversiones,", "speaker": null}, {"start": 344.038, "end": 350.798, "text": "como inversiones inmediatas de administración, como clientes, dirigentes, inventarios, aquí", "speaker": null}, {"start": 350.798, "end": 352.698, "text": "vemos que esto va a ser 60 millones.", "speaker": null}, {"start": 354.17798, "end": 357.59802, "text": "Quiere decir que estos 60 millones de pesos van a estar en estas cuentas.", "speaker": null}, {"start": 357.59802, "end": 359.458, "text": "¿cómo?", "speaker": null}, {"start": 359.678, "end": 361.398, "text": "si es una empresa comercializadora", "speaker": null}, {"start": 361.398, "end": 362.778, "text": "¿en dónde debería de estar?", "speaker": null}, {"start": 362.938, "end": 365.298, "text": "¿cómo crees tú que estaría repartido ese dinero?", "speaker": null}, {"start": 368.358, "end": 370.438, "text": "¿metería los 60 millones de pesos en caja?", "speaker": null}, {"start": 371.198, "end": 372.838, "text": "¿ahí en el cajón del escritorio?", "speaker": null}, {"start": 374.09802, "end": 375.358, "text": "no, normalmente la caja", "speaker": null}, {"start": 375.358, "end": 376.298, "text": "¿para qué la ocupamos?", "speaker": null}, {"start": 377.438, "end": 378.738, "text": "gastos menores, ¿no?", "speaker": null}, {"start": 378.838, "end": 380.238, "text": "copias, dar cambios", "speaker": null}, {"start": 380.238, "end": 383.578, "text": "la recarga del pasaje", "speaker": null}, {"start": 383.578, "end": 385.15802, "text": "del mensajero", "speaker": null}, {"start": 385.15802, "end": 386.958, "text": "pagar un Uber", "speaker": null}, {"start": 386.958, "end": 389.258, "text": "¿no?", "speaker": null}, {"start": 390.47803, "end": 391.118, "text": "lógico", "speaker": null}, {"start": 391.118, "end": 393.798, "text": "dicen que los 60 millones no están bien", "speaker": null}, {"start": 393.798, "end": 396.378, "text": "¿en dónde quieren que estén", "speaker": null}, {"start": 396.378, "end": 397.338, "text": "esos 60 millones?", "speaker": null}, {"start": 397.778, "end": 399.278, "text": "pónganselos, venga de aquí", "speaker": null}, {"start": 399.278, "end": 401.638, "text": "yo diría unos 50 y inventar", "speaker": null}, {"start": 401.638, "end": 404.238, "text": "tú le pondrías 50 y inventar", "speaker": null}, {"start": 404.238, "end": 406.958, "text": "¿cómo se llama?", "speaker": null}, {"start": 407.59802, "end": 408.498, "text": "¿cómo se llama?", "speaker": null}, {"start": 409.318, "end": 411.638, "text": "no sé, ustedes, Estróceca", "speaker": null}, {"start": 411.638, "end": 413.498, "text": "¿es una empresa?", "speaker": null}, {"start": 413.97803, "end": 414.838, "text": "no lo sé", "speaker": null}, {"start": 414.838, "end": 418.15802, "text": "5 en banco", "speaker": null}, {"start": 418.15802, "end": 421.398, "text": "5 millones en bancos", "speaker": null}, {"start": 421.398, "end": 424.878, "text": "Hay que comprar", "speaker": null}, {"start": 424.878, "end": 426.798, "text": "Un año", "speaker": null}, {"start": 426.798, "end": 428.898, "text": "En caja", "speaker": null}, {"start": 428.898, "end": 430.538, "text": "¿Un millón de pesos en caja?", "speaker": null}, {"start": 431.05798, "end": 432.378, "text": "Es algo de dinero, ¿no?", "speaker": null}, {"start": 432.61798, "end": 433.758, "text": "Son muchas cosas", "speaker": null}, {"start": 433.758, "end": 435.17798, "text": "¿Seguro?", "speaker": null}, {"start": 436.538, "end": 437.55798, "text": "¿Qué opinas, Mike?", "speaker": null}, {"start": 437.918, "end": 439.638, "text": "¿Tiene 3 millones de pesos en caja?", "speaker": null}, {"start": 439.638, "end": 441.518, "text": "¿Es que cito billetes sobre billetes?", "speaker": null}, {"start": 441.858, "end": 442.038, "text": "No", "speaker": null}, {"start": 442.038, "end": 444.038, "text": "¿Cómo?", "speaker": null}, {"start": 444.038, "end": 456.556, "text": "vali que acabamos con esto ser Un 200 100 Ustedes son los expertos Yo no debo aplicar", "speaker": null}, {"start": 456.556, "end": 457.51602, "text": "lo que ustedes tienen", "speaker": null}, {"start": 457.51602, "end": 464.63602, "text": "Yo por mucho", "speaker": null}, {"start": 464.63602, "end": 466.91602, "text": "le dejaría unos 50 mil pesos", "speaker": null}, {"start": 466.91602, "end": 469.41602, "text": "y eso estoy diciendo que es un chingo de dinero", "speaker": null}, {"start": 469.41602, "end": 472.896, "text": "Le digo nada para que sea representativo", "speaker": null}, {"start": 472.896, "end": 474.596, "text": "Lo digo usted", "speaker": null}, {"start": 474.596, "end": 476.396, "text": "¿Qué es esto? ¿Gastos menores?", "speaker": null}, {"start": 477.096, "end": 478.756, "text": "Son gastos menores, ¿no?", "speaker": null}, {"start": 479.756, "end": 480.63602, "text": "Y ahí me queda", "speaker": null}, {"start": 480.63602, "end": 482.556, "text": "la mano todavía hasta para irme a insurgentes", "speaker": null}, {"start": 482.556, "end": 484.07602, "text": "con las públicas, maestro.", "speaker": null}, {"start": 489.51602, "end": 490.57602, "text": "Pues como lo metemos,", "speaker": null}, {"start": 490.73602, "end": 490.936, "text": "maestro.", "speaker": null}, {"start": 497.836, "end": 498.57602, "text": "Y, jefe,", "speaker": null}, {"start": 498.63602, "end": 499.73602, "text": "no tienes nada para invertir,", "speaker": null}, {"start": 499.73602, "end": 501.956, "text": "no tienes nada disponible, ninguna inversión,", "speaker": null}, {"start": 501.956, "end": 502.396, "text": "ni nada.", "speaker": null}, {"start": 502.396, "end": 504.79602, "text": "¿Tus clientes no te deben nada?", "speaker": null}, {"start": 511.276, "end": 512.19604, "text": "Dos", "speaker": null}, {"start": 512.19604, "end": 517.236, "text": "¿Y los de inversiones?", "speaker": null}, {"start": 518.236, "end": 520.176, "text": "¿Tres millones?", "speaker": null}, {"start": 522.076, "end": 523.276, "text": "Nada más, tres millones", "speaker": null}, {"start": 523.276, "end": 525.836, "text": "No, no sé", "speaker": null}, {"start": 525.836, "end": 528.676, "text": "¿O quieres cambiar tus islas?", "speaker": null}, {"start": 528.676, "end": 529.796, "text": "Como tú quieras", "speaker": null}, {"start": 529.796, "end": 531.076, "text": "Entonces vamos a analizar", "speaker": null}, {"start": 531.076, "end": 532.036, "text": "¿Qué pasa? ¿No le da un trompo?", "speaker": null}, {"start": 534.676, "end": 535.87604, "text": "¿Tenemos un cimitario?", "speaker": null}, {"start": 537.356, "end": 539.256, "text": "Yo creo que tenemos 40.", "speaker": null}, {"start": 540.956, "end": 542.19604, "text": "¿Dónde cambiamos?", "speaker": null}, {"start": 542.396, "end": 542.99603, "text": "¿Dónde cambiamos?", "speaker": null}, {"start": 547.096, "end": 548.19604, "text": "40 millones.", "speaker": null}, {"start": 551.69604, "end": 553.37604, "text": "De estos pensamos más,", "speaker": null}, {"start": 553.516, "end": 554.556, "text": "porque pensamos mucho.", "speaker": null}, {"start": 554.99603, "end": 556.776, "text": "Pensamos que tenemos 10 millones.", "speaker": null}, {"start": 557.43604, "end": 558.916, "text": "Y cuando nos quedan,", "speaker": null}, {"start": 558.916, "end": 560.87604, "text": "4 millones lo decimos en el camino.", "speaker": null}, {"start": 561.076, "end": 562.916, "text": "¿no?", "speaker": null}, {"start": 564.37604, "end": 565.256, "text": "¿podría ser?", "speaker": null}, {"start": 566.556, "end": 567.396, "text": "¿puede ser?", "speaker": null}, {"start": 569.176, "end": 569.356, "text": "¿no?", "speaker": null}, {"start": 571.156, "end": 571.796, "text": "¿cómo?", "speaker": null}, {"start": 572.796, "end": 573.416, "text": "¿cuál es?", "speaker": null}, {"start": 573.756, "end": 575.93604, "text": "para mí debería ser más grande la inversión", "speaker": null}, {"start": 575.93604, "end": 577.396, "text": "¿para mí?", "speaker": null}, {"start": 578.736, "end": 580.556, "text": "pues si son de inmediata realización", "speaker": null}, {"start": 580.556, "end": 582.556, "text": "están bastante líquidos", "speaker": null}, {"start": 582.556, "end": 583.836, "text": "pero sí, sí, conmigo", "speaker": null}, {"start": 583.836, "end": 585.796, "text": "vamos a cambiar, vamos a poner aquí", "speaker": null}, {"start": 585.796, "end": 586.716, "text": "3 millones", "speaker": null}, {"start": 586.716, "end": 589.956, "text": "3 millones", "speaker": null}, {"start": 589.956, "end": 592.176, "text": "y aquí serían 7 millones", "speaker": null}, {"start": 592.176, "end": 592.996, "text": "¿no es 6?", "speaker": null}, {"start": 593.396, "end": 596.416, "text": "7 millones", "speaker": null}, {"start": 596.416, "end": 597.69604, "text": "¿no es 7?", "speaker": null}, {"start": 597.69604, "end": 597.736, "text": "¿no es 7?", "speaker": null}, {"start": 598.336, "end": 600.116, "text": "¿no es 7?", "speaker": null}, {"start": 602.69604, "end": 603.496, "text": "¿no?", "speaker": null}, {"start": 604.356, "end": 605.776, "text": "¿con los 50?", "speaker": null}, {"start": 608.596, "end": 609.356, "text": "¿no?", "speaker": null}, {"start": 609.516, "end": 610.096, "text": "¿son 6?", "speaker": null}, {"start": 611.496, "end": 612.756, "text": "¿ah, son 6?", "speaker": null}, {"start": 613.536, "end": 614.556, "text": "¿son 7?", "speaker": null}, {"start": 614.556, "end": 614.896, "text": "¿no?", "speaker": null}, {"start": 614.896, "end": 615.396, "text": "un chicle.", "speaker": null}, {"start": 616.81604, "end": 617.056, "text": "¿No?", "speaker": null}, {"start": 618.756, "end": 620.596, "text": "Pensemos que esa es la estructura de los chicles.", "speaker": null}, {"start": 621.756, "end": 622.136, "text": "Bueno,", "speaker": null}, {"start": 623.116, "end": 625.19604, "text": "vamos a ver si es cierto que yo pensaba", "speaker": null}, {"start": 625.19604, "end": 625.836, "text": "que esta era", "speaker": null}, {"start": 625.836, "end": 632.276, "text": "la que tiene pura merma", "speaker": null}, {"start": 632.276, "end": 632.976, "text": "de los chicles.", "speaker": null}, {"start": 634.036, "end": 636.31604, "text": "No necesariamente, porque no voy a ir", "speaker": null}, {"start": 636.31604, "end": 638.516, "text": "todavía hasta allá, todavía no he visto.", "speaker": null}, {"start": 640.396, "end": 642.516, "text": "Ok, si voy a aplicar", "speaker": null}, {"start": 642.516, "end": 644.296, "text": "la prueba severa o la prueba acida", "speaker": null}, {"start": 644.296, "end": 646.836, "text": "esta me dice que va a ser el activo circulante", "speaker": null}, {"start": 646.836, "end": 648.536, "text": "que sería en este caso", "speaker": null}, {"start": 648.536, "end": 649.956, "text": "los 60 millones", "speaker": null}, {"start": 649.956, "end": 653.576, "text": "¿correcto? menos los inventarios", "speaker": null}, {"start": 653.576, "end": 655.036, "text": "que en este caso son", "speaker": null}, {"start": 655.036, "end": 656.016, "text": "40 millones", "speaker": null}, {"start": 656.016, "end": 659.276, "text": "sobre el pasivo a corto plazo", "speaker": null}, {"start": 659.276, "end": 660.796, "text": "que en este caso estamos hablando", "speaker": null}, {"start": 660.796, "end": 662.476, "text": "son 35 millones", "speaker": null}, {"start": 662.476, "end": 664.356, "text": "¿es correcto?", "speaker": null}, {"start": 665.216, "end": 666.956, "text": "en el circuito de hoy esto es igual", "speaker": null}, {"start": 666.956, "end": 668.256, "text": "a 20 millones", "speaker": null}, {"start": 668.256, "end": 679.914, "text": "sobre 35 millones si esto es correcto qu es igual Punto cincuenta y siete", "speaker": null}, {"start": 680.114, "end": 681.374, "text": "Cero punto cincuenta y siete.", "speaker": null}, {"start": 682.33405, "end": 684.554, "text": "Cero punto cincuenta y siete.", "speaker": null}, {"start": 686.494, "end": 695.19403, "text": "Prueba severa o prueba ácida es igual a cero punto cincuenta y siete.", "speaker": null}, {"start": 697.19403, "end": 698.654, "text": "¿Qué es lo que se llama?", "speaker": null}, {"start": 698.654, "end": 702.89404, "text": "¿Correcto?", "speaker": null}, {"start": 704.554, "end": 705.434, "text": "No es cierto.", "speaker": null}, {"start": 707.714, "end": 708.414, "text": "M es esa.", "speaker": null}, {"start": 708.414, "end": 719.374, "text": "¿Sí o no?", "speaker": null}, {"start": 720.474, "end": 721.39404, "text": "¿Sí?", "speaker": null}, {"start": 723.01404, "end": 726.01404, "text": "Entonces ya tenemos mi RCT.", "speaker": null}, {"start": 726.01404, "end": 728.95404, "text": "ya tengo mi CNT", "speaker": null}, {"start": 728.95404, "end": 731.294, "text": "ya tengo mi MS", "speaker": null}, {"start": 731.294, "end": 733.07404, "text": "y ahora voy por mi pre-base", "speaker": null}, {"start": 733.07404, "end": 737.094, "text": "¿qué me dice mi pre-base?", "speaker": null}, {"start": 749.094, "end": 750.094, "text": "¿qué me dice?", "speaker": null}, {"start": 756.01404, "end": 763.01404, "text": "de lo que tienes sin contar el inventario te alcanza para pagar?", "speaker": null}, {"start": 763.01404, "end": 767.01404, "text": "no, el inventario, recuerda que tu no puedes hablar de las cuentas de la formula", "speaker": null}, {"start": 767.01404, "end": 773.01404, "text": "no puedes hablar del nombre de la formula, tienes que interpretar el resultado, nada mas", "speaker": null}, {"start": 773.01404, "end": 778.01404, "text": "pues si yo interpreto el resultado esto es bien fácil", "speaker": null}, {"start": 778.01404, "end": 785.754, "text": "Mi empresa únicamente cuenta con 57 centavos para pagar cada peso que le dé.", "speaker": null}, {"start": 787.054, "end": 794.834, "text": "Viceversa, por cada peso que le dé, yo líquidamente, únicamente, cuento con 57 centavos.", "speaker": null}, {"start": 795.854, "end": 798.454, "text": "Les recuerdo que estas son fórmulas de solvencia.", "speaker": null}, {"start": 799.794, "end": 802.094, "text": "Esta ya es una fórmula de liquidez.", "speaker": null}, {"start": 802.094, "end": 809.234, "text": "Para eso tenemos que entender la diferencia entre solvencia y liquidez. ¿Liquidez y solvencia es lo mismo?", "speaker": null}, {"start": 811.39404, "end": 820.39404, "text": "Pues claro que no, no puede ser lo mismo, señores. Se parece, pero no es lo mismo. ¿Cuál es la diferencia?", "speaker": null}, {"start": 821.774, "end": 825.234, "text": "Las de liquidez exigen mayor grado de estonio.", "speaker": null}, {"start": 825.234, "end": 831.594, "text": "No, señor. ¿Cuál es la diferencia? A ver, ¿cuál es la diferencia?", "speaker": null}, {"start": 832.094, "end": 836.89404, "text": "¿Pero eso lo tiene la empresa?", "speaker": null}, {"start": 837.594, "end": 839.474, "text": "No, pues todo eso lo tiene la empresa.", "speaker": null}, {"start": 840.534, "end": 841.494, "text": "Ay, chavitos.", "speaker": null}, {"start": 842.074, "end": 843.494, "text": "¿Qué voy a hacer con ustedes?", "speaker": null}, {"start": 845.034, "end": 846.574, "text": "A ver, hay un ejemplo.", "speaker": null}, {"start": 848.474, "end": 849.814, "text": "A ver si así lo entienden.", "speaker": null}, {"start": 851.814, "end": 855.454, "text": "Imagínate, Mike, que tienes aquí al chavo.", "speaker": null}, {"start": 858.474, "end": 860.314, "text": "Imagínate que el chavo trabaja.", "speaker": null}, {"start": 860.454, "end": 861.474, "text": "Imagínate que trabaja.", "speaker": null}, {"start": 861.474, "end": 862.974, "text": "No creo que sea un sospechoso.", "speaker": null}, {"start": 863.77405, "end": 866.234, "text": "Ya vimos que él es magnate de los negocios.", "speaker": null}, {"start": 867.454, "end": 868.554, "text": "Él es empresario.", "speaker": null}, {"start": 870.114, "end": 871.154, "text": "Él es en fin.", "speaker": null}, {"start": 872.354, "end": 875.13403, "text": "Pero imagínate lo que fuera un vulgar empleado.", "speaker": null}, {"start": 875.89404, "end": 876.714, "text": "La verdad es así.", "speaker": null}, {"start": 877.314, "end": 877.57404, "text": "¿Sabes?", "speaker": null}, {"start": 879.314, "end": 881.69403, "text": "¿Cómo cuánto ganaría un vulgar empleado?", "speaker": null}, {"start": 882.294, "end": 885.234, "text": "Así en el género común.", "speaker": null}, {"start": 885.674, "end": 886.114, "text": "Entiendo.", "speaker": null}, {"start": 887.294, "end": 889.19403, "text": "¿10 mil pesos te parece bien?", "speaker": null}, {"start": 890.19403, "end": 890.974, "text": "¿A la quinchana?", "speaker": null}, {"start": 891.474, "end": 891.974, "text": "¿Al mes?", "speaker": null}, {"start": 892.39404, "end": 892.994, "text": "¿Al mes?", "speaker": null}, {"start": 893.334, "end": 895.534, "text": "Bueno, sí, es muy, muy caro.", "speaker": null}, {"start": 896.534, "end": 898.234, "text": "Diez mil besitos al mes.", "speaker": null}, {"start": 898.734, "end": 899.554, "text": "No tiene nada malo.", "speaker": null}]