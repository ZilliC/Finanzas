[{"start": 0.0, "end": 3.8, "text": "No, no, no, mal para que dos rayitas, cabrón.", "speaker": null}, {"start": 5.2, "end": 7.08, "text": "Usted se me sobreesfuerza y se me queda ahí.", "speaker": null}, {"start": 7.32, "end": 10.96, "text": "Soy un bestia, precisamente por eso vengo a correr diario, por eso voy al gym.", "speaker": null}, {"start": 11.82, "end": 14.9, "text": "Sí, pero su cuchara no lo va a aguantar.", "speaker": null}, {"start": 17.32, "end": 18.68, "text": "¿No ha visto que eso sucede?", "speaker": null}, {"start": 19.0, "end": 19.22, "text": "Sí.", "speaker": null}, {"start": 19.88, "end": 21.94, "text": "Ha habido compas que se quedan unos 100 y salen.", "speaker": null}, {"start": 22.94, "end": 26.88, "text": "Porque nunca se... ¿Por qué es que ahora me despiden un certificado médico?", "speaker": null}, {"start": 30.0, "end": 32.54, "text": "¿Por qué digo cánones que se tienen ahí?", "speaker": null}, {"start": 36.32, "end": 39.56, "text": "¿Por qué? Porque tenía un antecedente carriaco.", "speaker": null}, {"start": 40.8, "end": 43.66, "text": "No lo tomó en cuenta, tuvo un sobresfuerzo, pelas.", "speaker": null}, {"start": 45.14, "end": 46.36, "text": "Hasta ahí se llamaba.", "speaker": null}, {"start": 51.5, "end": 55.74, "text": "Y te lo digo porque yo tengo dos clientes.", "speaker": null}, {"start": 57.28, "end": 58.98, "text": "Que son centros deportivos.", "speaker": null}, {"start": 60.0, "end": 63.94, "text": "y a mi me ha tocado", "speaker": null}, {"start": 63.94, "end": 65.58, "text": "una broncota", "speaker": null}, {"start": 65.58, "end": 69.7, "text": "cortaron mal el pasto", "speaker": null}, {"start": 69.7, "end": 71.68, "text": "la cancha de la chueca", "speaker": null}, {"start": 71.68, "end": 74.04, "text": "se nos acaba de morir un cabrón", "speaker": null}, {"start": 74.04, "end": 75.74, "text": "era un cabrón", "speaker": null}, {"start": 75.74, "end": 76.98, "text": "un cabrón", "speaker": null}, {"start": 76.98, "end": 79.74, "text": "el que ya saltaba", "speaker": null}, {"start": 79.74, "end": 81.34, "text": "se agarraron", "speaker": null}, {"start": 81.34, "end": 84.38, "text": "no sabemos que le paso", "speaker": null}, {"start": 84.38, "end": 85.14, "text": "se quedó tieso", "speaker": null}, {"start": 85.14, "end": 85.86, "text": "el cabrón", "speaker": null}, {"start": 85.86, "end": 90.42, "text": "Vamos a ver, es una bronca de tamaño caguama", "speaker": null}, {"start": 90.42, "end": 91.16, "text": "¿Qué pasó?", "speaker": null}, {"start": 92.32, "end": 93.6, "text": "Nos van a echar la culpa", "speaker": null}, {"start": 93.6, "end": 96.06, "text": "A ver aquí", "speaker": null}, {"start": 96.06, "end": 99.1, "text": "Relájese, vamos a ver cómo está la suerte", "speaker": null}, {"start": 99.1, "end": 101.48, "text": "¿Quién es el presunto?", "speaker": null}, {"start": 101.96, "end": 103.18, "text": "Pues ese que está ahí tirado", "speaker": null}, {"start": 103.18, "end": 105.08, "text": "¿Es socio?", "speaker": null}, {"start": 105.26, "end": 106.1, "text": "Sí, sí, es socio", "speaker": null}, {"start": 106.1, "end": 107.76, "text": "El expediente, cabrón", "speaker": null}, {"start": 107.76, "end": 112.18, "text": "El certificado médico", "speaker": null}, {"start": 112.18, "end": 114.3, "text": "Aquí está", "speaker": null}, {"start": 114.3, "end": 116.78, "text": "con esa nos la libramos", "speaker": null}, {"start": 116.78, "end": 118.3, "text": "que vengan las autoridades", "speaker": null}, {"start": 118.3, "end": 120.42, "text": "no fue responsabilidad de nosotros", "speaker": null}, {"start": 120.42, "end": 123.58, "text": "el señor abusó de su condición física", "speaker": null}, {"start": 123.58, "end": 126.28, "text": "tenía conocimiento de que tenía ese padecimiento", "speaker": null}, {"start": 126.28, "end": 127.3, "text": "y a pesar de eso", "speaker": null}, {"start": 127.3, "end": 133.0, "text": "la autoridad es por ser", "speaker": null}, {"start": 133.0, "end": 136.02, "text": "tenemos responsabilidad nosotros", "speaker": null}, {"start": 136.02, "end": 139.48, "text": "no tenemos responsabilidad", "speaker": null}, {"start": 139.48, "end": 141.5, "text": "no explico", "speaker": null}, {"start": 141.5, "end": 143.42, "text": "o no me explico", "speaker": null}, {"start": 143.42, "end": 148.42, "text": "Aguas chavos, allá en la vida real las cosas no son como ustedes piensan.", "speaker": null}, {"start": 148.42, "end": 154.42, "text": "Allá en la vida real las cosas tienen otro escenario.", "speaker": null}, {"start": 154.42, "end": 159.42, "text": "¿Qué tal si llegan los familiares y nos tengan responsabilidad?", "speaker": null}, {"start": 159.42, "end": 164.42, "text": "El entrenador, pinche locarlo, lo forzó y por culpa de él le reventó el corazón.", "speaker": null}, {"start": 164.42, "end": 170.42, "text": "Chuchuchuchu, se pegué en ese caballo.", "speaker": null}, {"start": 170.42, "end": 174.02, "text": "No es por culpa del entrenador, es por culpa de su condición física.", "speaker": null}, {"start": 174.54, "end": 177.0, "text": "Él no podía hacer ese tipo de actividad.", "speaker": null}, {"start": 177.9, "end": 179.62, "text": "Y por decisión propia de eso.", "speaker": null}, {"start": 183.32, "end": 183.88, "text": "No.", "speaker": null}, {"start": 185.76, "end": 186.86, "text": "Pues con la pena.", "speaker": null}, {"start": 188.1, "end": 190.36, "text": "Nos vamos a entender, no nos vamos a entender.", "speaker": null}, {"start": 191.82, "end": 192.84, "text": "Dudas hasta aquí.", "speaker": null}, {"start": 195.34, "end": 198.62, "text": "Bueno, entiendo entonces, el antecedente siempre es activo y con su condición.", "speaker": null}, {"start": 198.62, "end": 200.68, "text": "No, claro que no.", "speaker": null}, {"start": 201.44, "end": 203.08, "text": "Claro que no, maestro.", "speaker": null}, {"start": 204.3, "end": 208.78, "text": "Bueno, vamos a...", "speaker": null}, {"start": 208.78, "end": 210.18, "text": "Aquí sería lo contrario.", "speaker": null}, {"start": 211.52, "end": 214.98, "text": "Para no dejarlo en el aire, aquí me sobran 35 millones de pesos", "speaker": null}, {"start": 214.98, "end": 217.06, "text": "después de pagar los cerdos.", "speaker": null}, {"start": 218.34, "end": 219.6, "text": "En el segundo caso, ¿qué pasa?", "speaker": null}, {"start": 219.6, "end": 228.718, "text": "Yo sobre el 35 CNT ser igual a 40 millones de pesos menos 70 millones", "speaker": null}, {"start": 230.018, "end": 230.938, "text": "¿Es correcto o no?", "speaker": null}, {"start": 231.858, "end": 239.578, "text": "Luego entonces, aquí, si el T es igual a 30 millones, ¿pero qué?", "speaker": null}, {"start": 239.858, "end": 240.418, "text": "Negativos.", "speaker": null}, {"start": 240.778, "end": 241.578, "text": "Negativos.", "speaker": null}, {"start": 241.578, "end": 244.358, "text": "quiere decir", "speaker": null}, {"start": 244.358, "end": 246.558, "text": "que aquí a mi me habían", "speaker": null}, {"start": 246.558, "end": 248.098, "text": "falta 30 millones de pesos", "speaker": null}, {"start": 248.098, "end": 250.798, "text": "para cumplir con mis obligaciones", "speaker": null}, {"start": 250.798, "end": 252.638, "text": "no puedo pagar", "speaker": null}, {"start": 252.638, "end": 256.678, "text": "y si no puedo pagar que tengo que hacer", "speaker": null}, {"start": 256.678, "end": 260.298, "text": "o pago con", "speaker": null}, {"start": 260.298, "end": 262.918, "text": "activos hijos o renegocio", "speaker": null}, {"start": 262.918, "end": 264.738, "text": "la deuda o pido", "speaker": null}, {"start": 264.738, "end": 265.678, "text": "un préstamo", "speaker": null}, {"start": 265.678, "end": 267.738, "text": "algo tengo que hacer", "speaker": null}, {"start": 267.738, "end": 269.758, "text": "porque mi empresa no puede pagar", "speaker": null}, {"start": 269.758, "end": 276.438, "text": "¿Sí?", "speaker": null}, {"start": 277.098, "end": 278.758, "text": "¿Entonces ese sería el consecuente?", "speaker": null}, {"start": 278.918, "end": 279.21802, "text": "¿El 30?", "speaker": null}, {"start": 279.538, "end": 280.21802, "text": "¿Cómo?", "speaker": null}, {"start": 280.518, "end": 282.918, "text": "¿El 30 negativo sería el consecuente entonces?", "speaker": null}, {"start": 283.938, "end": 284.638, "text": "No", "speaker": null}, {"start": 284.638, "end": 286.858, "text": "El 30 negativo que es", "speaker": null}, {"start": 286.858, "end": 288.118, "text": "El resultado", "speaker": null}, {"start": 288.118, "end": 291.058, "text": "Aquí en el precedente", "speaker": null}, {"start": 291.058, "end": 293.558, "text": "Sigue siendo el activo", "speaker": null}, {"start": 293.558, "end": 298.738, "text": "Este es igual", "speaker": null}, {"start": 298.738, "end": 301.458, "text": "el activo circulante menos el pasivo", "speaker": null}, {"start": 301.458, "end": 305.738, "text": "el antecedente sigue siendo el activo", "speaker": null}, {"start": 305.738, "end": 307.21802, "text": "y el consecuente es el pasivo", "speaker": null}, {"start": 307.21802, "end": 309.378, "text": "tu pregunta fue", "speaker": null}, {"start": 309.378, "end": 311.99802, "text": "en todos los casos el activo va a ser el antecedente", "speaker": null}, {"start": 311.99802, "end": 313.698, "text": "y en todos los casos el pasivo va a ser el consecuente", "speaker": null}, {"start": 313.698, "end": 315.018, "text": "te dije no", "speaker": null}, {"start": 315.018, "end": 317.678, "text": "en esta fórmula", "speaker": null}, {"start": 317.678, "end": 318.978, "text": "en estas dos sí", "speaker": null}, {"start": 318.978, "end": 322.838, "text": "porque coincidió que el antecedente es el activo", "speaker": null}, {"start": 322.838, "end": 323.758, "text": "tanto el RCD", "speaker": null}, {"start": 323.758, "end": 325.478, "text": "tiene como antecedente el activo", "speaker": null}, {"start": 325.478, "end": 328.678, "text": "como CND tiene como antecedente el activo", "speaker": null}, {"start": 328.678, "end": 330.518, "text": "pero ¿qué pasa?", "speaker": null}, {"start": 331.118, "end": 332.758, "text": "si yo hablo de otro tipo de razón", "speaker": null}, {"start": 332.758, "end": 333.738, "text": "por ejemplo", "speaker": null}, {"start": 333.738, "end": 340.578, "text": "vamos a hablar de otra razón", "speaker": null}, {"start": 340.578, "end": 342.038, "text": "¿cuál sería otra razón?", "speaker": null}, {"start": 342.038, "end": 342.118, "text": "¿cuál sería otra razón?", "speaker": null}, {"start": 345.378, "end": 346.178, "text": "MS", "speaker": null}, {"start": 346.178, "end": 348.518, "text": "¿ok?", "speaker": null}, {"start": 349.05798, "end": 351.538, "text": "MS es igual a CNT", "speaker": null}, {"start": 351.538, "end": 352.578, "text": "sobre", "speaker": null}, {"start": 352.578, "end": 355.898, "text": "casualmente esta que preguntamos es otra", "speaker": null}, {"start": 355.898, "end": 357.738, "text": "¿está bien?", "speaker": null}, {"start": 358.678, "end": 371.41803, "text": "Si yo sustituyo como lo hago, y una vez, necesito que se sientan siempre muy bien.", "speaker": null}, {"start": 388.678, "end": 407.558, "text": "Ahora, ¿qué significa eso?", "speaker": null}, {"start": 407.558, "end": 407.59802, "text": "¿Qué significa eso?", "speaker": null}, {"start": 407.59802, "end": 420.358, "text": "el que está antes de la ecuación", "speaker": null}, {"start": 420.358, "end": 422.47803, "text": "el antecedente siempre va a ser", "speaker": null}, {"start": 422.47803, "end": 423.678, "text": "el que está antes de la ecuación", "speaker": null}, {"start": 423.678, "end": 426.53802, "text": "y el consecuente siempre va a ser", "speaker": null}, {"start": 426.53802, "end": 428.578, "text": "el que está después de la ecuación", "speaker": null}, {"start": 437.59802, "end": 461.196, "text": "con un capital de digo con un aqu capital de trabajo de 25 millones y pasivos a corto plazo de 35 millones", "speaker": null}, {"start": 461.196, "end": 466.156, "text": "tengo un margen de seguridad de 71%", "speaker": null}, {"start": 466.156, "end": 474.436, "text": "¿Y si me lo quiere comprar?", "speaker": null}, {"start": 475.036, "end": 480.776, "text": "¿Qué es el porcentaje?", "speaker": null}, {"start": 485.776, "end": 487.23602, "text": "Sería, ¿sabe qué?", "speaker": null}, {"start": 487.23602, "end": 487.776, "text": "¿Qué es el porcentaje?", "speaker": null}, {"start": 493.776, "end": 496.01602, "text": "Yo no entiendo los porcentajes.", "speaker": null}, {"start": 497.216, "end": 499.396, "text": "Ya quedamos que yo en el cuarto del mercado,", "speaker": null}, {"start": 499.63602, "end": 502.056, "text": "en la central de abastos, en el negocio.", "speaker": null}, {"start": 505.036, "end": 506.63602, "text": "¿Cómo está mi empresa?", "speaker": null}, {"start": 508.13602, "end": 508.936, "text": "Sí, yo me digo que...", "speaker": null}, {"start": 508.936, "end": 512.93604, "text": "Claro que no puedes poner en la respuesta el nombre de la razón.", "speaker": null}, {"start": 514.31604, "end": 517.99603, "text": "O sea, tú no me puedes decir que yo tengo un margen de seguridad del 71%.", "speaker": null}, {"start": 517.99603, "end": 520.836, "text": "No es cierto. Eso es incorrecto.", "speaker": null}, {"start": 521.516, "end": 526.576, "text": "Porque mi pregunta como tu cliente fue, ¿qué significa margen de seguridad?", "speaker": null}, {"start": 527.356, "end": 529.43604, "text": "¿Cuál es el margen de seguridad de mi empresa?", "speaker": null}, {"start": 530.716, "end": 532.716, "text": "Entonces no me puedes contestar con margen de seguridad.", "speaker": null}, {"start": 535.036, "end": 565.016, "text": "¿Podrías perder 71 centavos?", "speaker": null}, {"start": 565.036, "end": 567.916, "text": "¿Y aún así podrías pagar tus deudas de corto plazo?", "speaker": null}, {"start": 568.896, "end": 569.296, "text": "No.", "speaker": null}, {"start": 570.016, "end": 570.476, "text": "Sí, sí.", "speaker": null}, {"start": 571.216, "end": 571.43604, "text": "Bueno.", "speaker": null}, {"start": 572.93604, "end": 574.156, "text": "A ver, May, ayúdame a echar.", "speaker": null}, {"start": 574.856, "end": 582.176, "text": "Que después de pagar las deudas te quedan 0.71 centavos.", "speaker": null}, {"start": 583.456, "end": 584.016, "text": "Sí.", "speaker": null}, {"start": 584.096, "end": 584.796, "text": "¿Y la negativa?", "speaker": null}, {"start": 584.796, "end": 584.796, "text": "", "speaker": null}, {"start": 587.49603, "end": 594.796, "text": "Que tienes 0.71 centavos después de pagar todas tus deudas.", "speaker": null}, {"start": 595.036, "end": 595.796, "text": "¿Cómo?", "speaker": null}, {"start": 596.296, "end": 598.276, "text": "Después de pagar el...", "speaker": null}, {"start": 598.276, "end": 604.81604, "text": "No señor, si la negativa te dice que comiences con el consecuente,", "speaker": null}, {"start": 605.916, "end": 608.116, "text": "entonces ¿cómo, con qué tienes que empezar? ¿Con lo que eres?", "speaker": null}, {"start": 609.116, "end": 611.176, "text": "Entonces ¿cómo quedaría la respuesta?", "speaker": null}, {"start": 617.896, "end": 621.69604, "text": "Puedo pagar el dinero y me dicen que hay un 0.70 y no se me cambia.", "speaker": null}, {"start": 623.136, "end": 623.69604, "text": "Sí.", "speaker": null}, {"start": 623.69604, "end": 625.196, "text": "¿Estamos claros?", "speaker": null}, {"start": 626.036, "end": 627.776, "text": "¿O no, Charo? ¿Por qué más o menos?", "speaker": null}, {"start": 628.796, "end": 629.836, "text": "Bueno, es que no le quedarían", "speaker": null}, {"start": 629.836, "end": 631.11597, "text": "0.75 centavos, ¿no?", "speaker": null}, {"start": 632.11597, "end": 633.496, "text": "¿Por cada peso que tiene?", "speaker": null}, {"start": 634.296, "end": 635.896, "text": "No, es que ahí no tiene un peso.", "speaker": null}, {"start": 637.496, "end": 638.976, "text": "Ahí no tiene ningún peso.", "speaker": null}, {"start": 639.756, "end": 641.056, "text": "A ver, analízalo, Charo.", "speaker": null}, {"start": 641.196, "end": 642.676, "text": "Tranquilo, analízalo.", "speaker": null}, {"start": 644.016, "end": 645.356, "text": "Ahí no tiene ningún peso.", "speaker": null}, {"start": 653.696, "end": 654.696, "text": "Gracias.", "speaker": null}, {"start": 670.054, "end": 700.034, "text": "El rey de los cielos.", "speaker": null}, {"start": 700.054, "end": 730.034, "text": "¿Qué pasa?", "speaker": null}, {"start": 730.054, "end": 732.95404, "text": "No, es que...", "speaker": null}, {"start": 732.95404, "end": 737.414, "text": "A ver, revisa los parámetros de lectura.", "speaker": null}, {"start": 737.63403, "end": 738.734, "text": "Ahí viene la clave.", "speaker": null}, {"start": 739.89404, "end": 741.174, "text": "Y revisa tu fórmula.", "speaker": null}, {"start": 743.51404, "end": 747.414, "text": "Esos parámetros, tú los tienes que identificar en tu fórmula.", "speaker": null}, {"start": 753.094, "end": 755.414, "text": "O sea, los parámetros de...", "speaker": null}, {"start": 755.414, "end": 758.434, "text": "...postenete de trabajo.", "speaker": null}, {"start": 758.554, "end": 759.414, "text": "...de un institucional.", "speaker": null}, {"start": 760.054, "end": 790.034, "text": "El rey de la iglesia.", "speaker": null}, {"start": 790.054, "end": 791.054, "text": "Gracias.", "speaker": null}, {"start": 820.054, "end": 830.854, "text": "Entonces, ¿usted cómo haría la lectura positiva?", "speaker": null}, {"start": 831.334, "end": 831.714, "text": "¿Perdón?", "speaker": null}, {"start": 831.954, "end": 834.63403, "text": "¿Usted cómo haría la lectura positiva a su cliente?", "speaker": null}, {"start": 834.63403, "end": 836.834, "text": "¿Cómo haría la lectura positiva?", "speaker": null}, {"start": 837.89404, "end": 847.07404, "text": "Considerando sus parámetros y únicamente considero las que claran los elementos.", "speaker": null}, {"start": 850.054, "end": 855.054, "text": "aquí los elementos son diferentes", "speaker": null}, {"start": 855.054, "end": 858.214, "text": "en los elementos antes", "speaker": null}, {"start": 858.214, "end": 860.414, "text": "y esa fue la pregunta que hiciste", "speaker": null}, {"start": 860.414, "end": 862.57404, "text": "siempre debo de considerar", "speaker": null}, {"start": 862.57404, "end": 864.474, "text": "el activo circulante como antecedente", "speaker": null}, {"start": 864.474, "end": 865.854, "text": "yo digo que es de nombre", "speaker": null}, {"start": 865.854, "end": 868.974, "text": "dependiendo de la fórmula", "speaker": null}, {"start": 868.974, "end": 871.814, "text": "y aquí ya", "speaker": null}, {"start": 871.814, "end": 873.114, "text": "te lo estoy demostrando", "speaker": null}, {"start": 873.114, "end": 876.494, "text": "aquí la fórmula ya no toma en cuenta", "speaker": null}, {"start": 876.494, "end": 878.294, "text": "el activo circulante", "speaker": null}, {"start": 878.294, "end": 879.69403, "text": "es más el activo circulante ahí", "speaker": null}, {"start": 879.69403, "end": 881.69403, "text": "¿En serio?", "speaker": null}, {"start": 893.734, "end": 899.734, "text": "¿Podrías decir que con lo que te queda después de pagar tu deuda?", "speaker": null}]