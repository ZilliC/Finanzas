[{"start": 0.0, "end": 4.0, "text": "La negativa cual sería?", "speaker": null}, {"start": 4.0, "end": 13.0, "text": "Por cada peso que debo, mi empresa en este momento únicamente cuenta con 57 centavos para pagar.", "speaker": null}, {"start": 13.0, "end": 17.0, "text": "No lo puedo pagar, no le alcanza.", "speaker": null}, {"start": 17.0, "end": 22.0, "text": "¿Qué le explico?", "speaker": null}, {"start": 22.0, "end": 25.0, "text": "¿Entonces la empresa tiene problemas? No.", "speaker": null}, {"start": 25.0, "end": 27.539999, "text": "No, porque tiene una solvencia.", "speaker": null}, {"start": 31.119999, "end": 32.8, "text": "O sea, tiene capacidad de pago.", "speaker": null}, {"start": 33.579998, "end": 34.74, "text": "Lo que no tiene es liquidez.", "speaker": null}, {"start": 39.7, "end": 41.94, "text": "Tú dirás, no, es que entonces siempre me va a salir así.", "speaker": null}, {"start": 42.04, "end": 44.04, "text": "No, maestro, claro que no.", "speaker": null}, {"start": 44.899998, "end": 48.3, "text": "Porque aquí tengo otras cuentas, tengo clientes.", "speaker": null}, {"start": 49.98, "end": 51.48, "text": "Puedo tener de dos versos.", "speaker": null}, {"start": 52.54, "end": 53.68, "text": "Puedo tener impuestos a favor.", "speaker": null}, {"start": 53.68, "end": 56.16, "text": "puedo tener otras cuentas", "speaker": null}, {"start": 56.16, "end": 59.02, "text": "aquí porque tenemos muy poquitas cuentas", "speaker": null}, {"start": 59.02, "end": 60.54, "text": "pero en la vida real tenemos que tomar", "speaker": null}, {"start": 60.54, "end": 61.72, "text": "todas las cuentas", "speaker": null}, {"start": 61.72, "end": 63.92, "text": "obviamente", "speaker": null}, {"start": 63.92, "end": 65.78, "text": "va a variar", "speaker": null}, {"start": 65.78, "end": 69.16, "text": "dependiendo cada caso", "speaker": null}, {"start": 69.16, "end": 71.58, "text": "¿se me explicó?", "speaker": null}, {"start": 74.08, "end": 74.72, "text": "dudas", "speaker": null}, {"start": 74.72, "end": 75.36, "text": "las que sean", "speaker": null}, {"start": 75.36, "end": 77.82, "text": "¿cómo vamos a estar fichando?", "speaker": null}, {"start": 77.82, "end": 79.56, "text": "¿se va entendiendo o no se va entendiendo?", "speaker": null}, {"start": 80.22, "end": 80.7, "text": "muy bien", "speaker": null}, {"start": 80.7, "end": 90.434, "text": "hay que estudiar pero Pues no hay otra ya se los dije Vamos a dejar esto aqu por el d de hoy", "speaker": null}, {"start": 91.314, "end": 92.454, "text": "Mañana continuamos.", "speaker": null}, {"start": 93.154, "end": 93.354004, "text": "Mañana.", "speaker": null}, {"start": 93.634, "end": 94.274, "text": "El lunes.", "speaker": null}, {"start": 95.574005, "end": 98.014, "text": "Para el lunes, chiquitos, voy a seguir con las cosas.", "speaker": null}, {"start": 98.754, "end": 99.614, "text": "Las que faltan.", "speaker": null}, {"start": 101.354004, "end": 102.654, "text": "Pónganse en estudio, por favor.", "speaker": null}, {"start": 103.734, "end": 104.214005, "text": "Bueno.", "speaker": null}, {"start": 105.674, "end": 109.574005, "text": "Bueno, pues no me resta más que desearles que tengan un excelente fin de semana.", "speaker": null}, {"start": 109.574005, "end": 112.754, "text": "y hay que ver", "speaker": null}, {"start": 112.754, "end": 114.814, "text": "qué va a pasar porque me acaban de decir", "speaker": null}, {"start": 114.814, "end": 115.734, "text": "que el martes va a ser raro", "speaker": null}, {"start": 115.734, "end": 120.954, "text": "creo que van a jugar el martes", "speaker": null}, {"start": 120.954, "end": 121.434006, "text": "otra vez", "speaker": null}, {"start": 121.434006, "end": 123.734, "text": "creo que sí", "speaker": null}, {"start": 123.734, "end": 126.173996, "text": "hay que ver qué nos dicen", "speaker": null}, {"start": 126.173996, "end": 127.274, "text": "¿qué dicen?", "speaker": null}, {"start": 127.274, "end": 127.894, "text": "¿qué nos han dicho?", "speaker": null}, {"start": 128.994, "end": 131.014, "text": "porque yo les pregunté a mis colegas", "speaker": null}, {"start": 131.014, "end": 132.15399, "text": "si dicen que no salen", "speaker": null}, {"start": 132.15399, "end": 132.914, "text": "¿cuándo salen?", "speaker": null}, {"start": 133.414, "end": 134.134, "text": "¿la noche?", "speaker": null}, {"start": 135.534, "end": 137.934, "text": "si yo hace rato me dijeron los futbolistas", "speaker": null}, {"start": 137.934, "end": 139.034, "text": "que todavía no salían", "speaker": null}, {"start": 139.034, "end": 142.434, "text": "No me van a checar.", "speaker": null}, {"start": 146.134, "end": 157.43399, "text": "¿A ver si te da algo?", "speaker": null}, {"start": 159.23401, "end": 159.634, "text": "¿Sí?", "speaker": null}, {"start": 160.894, "end": 161.334, "text": "Sí.", "speaker": null}, {"start": 161.334, "end": 162.814, "text": "¿Va a ser igual?", "speaker": null}, {"start": 162.854, "end": 163.294, "text": "Sí.", "speaker": null}, {"start": 164.71399, "end": 165.634, "text": "¿Va a ser igual entonces?", "speaker": null}, {"start": 166.17401, "end": 166.354, "text": "Sí.", "speaker": null}, {"start": 169.034, "end": 170.314, "text": "muchos", "speaker": null}]