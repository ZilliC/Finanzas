[{"start": 0.58, "end": 4.2999997, "text": "¿Por qué? Porque si se dan cuenta, yo ya estoy ocupando fórmulas.", "speaker": null}, {"start": 5.68, "end": 13.08, "text": "Entonces, para este método van a existir dos tipos de ecuaciones.", "speaker": null}, {"start": 14.58, "end": 21.34, "text": "Estas ecuaciones son para el método, no quiere decir que sea para la norma aritmética, que son cosas diferentes.", "speaker": null}, {"start": 22.22, "end": 27.08, "text": "Las matemáticas por naturaleza se ocupan, pero no se revuelven.", "speaker": null}, {"start": 27.08, "end": 37.16, "text": "Aquí va a haber razones de tipo aritmético y va a haber razones de tipo geométrico.", "speaker": null}, {"start": 38.76, "end": 39.42, "text": "¿De acuerdo?", "speaker": null}, {"start": 40.52, "end": 52.34, "text": "Las razones de tipo aritmético van a ser aquellas que en su ecuación se componen con sumas o restas.", "speaker": null}, {"start": 52.34, "end": 57.14, "text": "y las razones de tipo geométrico", "speaker": null}, {"start": 57.14, "end": 59.66, "text": "van a ser aquellas que en la ecuación", "speaker": null}, {"start": 59.66, "end": 63.74, "text": "se consagran con operaciones de multiplicación", "speaker": null}, {"start": 63.74, "end": 66.9, "text": "o división", "speaker": null}, {"start": 66.9, "end": 68.7, "text": "creo que si se los enseñan a ustedes", "speaker": null}, {"start": 68.7, "end": 70.78, "text": "si?", "speaker": null}, {"start": 72.36, "end": 74.06, "text": "voy bien o me regreso", "speaker": null}, {"start": 74.06, "end": 78.62, "text": "entiende que las geométricas es como para entender proporciones", "speaker": null}, {"start": 78.62, "end": 80.62, "text": "más o menos", "speaker": null}, {"start": 80.62, "end": 82.31999, "text": "más o menos", "speaker": null}, {"start": 82.31999, "end": 85.259995, "text": "¿por qué? porque estas", "speaker": null}, {"start": 85.259995, "end": 87.56, "text": "únicamente", "speaker": null}, {"start": 87.56, "end": 89.079994, "text": "se van a aplicar a quienes", "speaker": null}, {"start": 89.079994, "end": 92.88, "text": "a las financieras", "speaker": null}, {"start": 92.88, "end": 98.439995, "text": "muy bien, ahora regreso", "speaker": null}, {"start": 98.439995, "end": 101.77999, "text": "y ahora", "speaker": null}, {"start": 101.77999, "end": 104.899994, "text": "tendríamos que entender otra parte también", "speaker": null}, {"start": 104.899994, "end": 106.67999, "text": "que va a haber", "speaker": null}, {"start": 106.67999, "end": 108.42, "text": "dos tipos de lecturas", "speaker": null}, {"start": 108.42, "end": 110.42, "text": "la lectura", "speaker": null}, {"start": 110.42, "end": 115.24, "text": "positiva", "speaker": null}, {"start": 115.24, "end": 119.4, "text": "y la lectura", "speaker": null}, {"start": 119.4, "end": 122.1, "text": "negativa.", "speaker": null}, {"start": 124.1, "end": 126.46, "text": "En donde la lectura positiva", "speaker": null}, {"start": 126.46, "end": 130.84, "text": "va a ser aquella que va a comenzar con el antecedente", "speaker": null}, {"start": 130.84, "end": 133.36, "text": "y termina", "speaker": null}, {"start": 133.36, "end": 136.4, "text": "con el consecuente.", "speaker": null}, {"start": 138.14, "end": 140.3, "text": "Por él, la lectura negativa", "speaker": null}, {"start": 140.3, "end": 142.16, "text": "va a comenzar con qué?", "speaker": null}, {"start": 143.14, "end": 144.88, "text": "Con su franco de consecuente", "speaker": null}, {"start": 144.88, "end": 146.96, "text": "y termina con el", "speaker": null}, {"start": 146.96, "end": 149.6, "text": "antecedente.", "speaker": null}, {"start": 152.54001, "end": 155.0, "text": "Si nosotros seguimos estos parámetros,", "speaker": null}, {"start": 155.88, "end": 157.66, "text": "esos parámetros me van a permitir", "speaker": null}, {"start": 157.66, "end": 160.04001, "text": "que se me facilite a mí", "speaker": null}, {"start": 160.04001, "end": 163.46, "text": "leer o interpretar", "speaker": null}, {"start": 163.46, "end": 165.92, "text": "los resultados de la razón.", "speaker": null}, {"start": 167.74, "end": 169.0, "text": "¿Dudas hasta aquí?", "speaker": null}, {"start": 170.3, "end": 175.36, "text": "las que sean", "speaker": null}, {"start": 175.36, "end": 177.72, "text": "sino para ya hablar de una vez", "speaker": null}, {"start": 177.72, "end": 180.46, "text": "pues hasta ahí no", "speaker": null}, {"start": 180.46, "end": 182.22, "text": "pero no entiendo entonces", "speaker": null}, {"start": 182.22, "end": 184.3, "text": "como es lo de la lectura positiva", "speaker": null}, {"start": 184.3, "end": 186.48, "text": "o sea como se habla", "speaker": null}, {"start": 186.48, "end": 191.06, "text": "o sea cada razón tiene una lectura positiva", "speaker": null}, {"start": 191.06, "end": 192.1, "text": "y una lectura negativa", "speaker": null}, {"start": 192.1, "end": 192.74, "text": "si", "speaker": null}, {"start": 192.74, "end": 196.96, "text": "tu voz aplica la que te de más claridad", "speaker": null}, {"start": 196.96, "end": 197.76001, "text": "para entender", "speaker": null}, {"start": 197.76001, "end": 199.98, "text": "la situación de la iglesia", "speaker": null}, {"start": 199.98, "end": 202.76, "text": "te van a decir lo mismo", "speaker": null}, {"start": 202.76, "end": 205.4, "text": "las dos te van a decir lo mismo", "speaker": null}, {"start": 205.4, "end": 207.84, "text": "haz de cuenta que te van a decir lo mismo", "speaker": null}, {"start": 207.84, "end": 209.26, "text": "pero con diferentes palabras", "speaker": null}, {"start": 209.26, "end": 213.04, "text": "por eso es un menazgo", "speaker": null}, {"start": 213.04, "end": 217.51999, "text": "¿sí o no?", "speaker": null}, {"start": 217.51999, "end": 217.56, "text": "¿sí o no?", "speaker": null}, {"start": 220.76, "end": 233.018, "text": "a ver Carlos dame la lectura negativa de esta raz s S ya te di los elementos Bueno es que no entiendo c ser el", "speaker": null}, {"start": 233.53801, "end": 235.218, "text": "Ustedes son informáticos.", "speaker": null}, {"start": 235.238, "end": 236.718, "text": "El antecedente y el consecuente.", "speaker": null}, {"start": 237.638, "end": 239.11801, "text": "Ustedes son informáticos.", "speaker": null}, {"start": 240.718, "end": 244.018, "text": "Ok, se las voy a poner todavía más baratas, para que no se...", "speaker": null}, {"start": 244.81801, "end": 249.39801, "text": "Así como que a menos de que ponga a masticar la comida, les voy a dar el vercajón.", "speaker": null}, {"start": 249.39801, "end": 250.75801, "text": "si ya con esto no puede", "speaker": null}, {"start": 250.75801, "end": 254.05801, "text": "a ver como le hace", "speaker": null}, {"start": 254.05801, "end": 257.678, "text": "lo más que se les puede facilitar", "speaker": null}, {"start": 257.678, "end": 259.338, "text": "va a ser lo siguiente", "speaker": null}, {"start": 259.338, "end": 264.21802, "text": "si nos están diciendo que las razones geométricas", "speaker": null}, {"start": 264.21802, "end": 266.598, "text": "son financieras", "speaker": null}, {"start": 266.598, "end": 269.178, "text": "aquí podemos llegar a una conclusión", "speaker": null}, {"start": 269.178, "end": 271.65802, "text": "se los voy a sintetizar yo", "speaker": null}, {"start": 271.65802, "end": 273.818, "text": "si supone que con esto es más que suficiente", "speaker": null}, {"start": 273.818, "end": 275.258, "text": "para que ustedes lo hagan mortal", "speaker": null}, {"start": 275.258, "end": 276.698, "text": "pero bueno", "speaker": null}, {"start": 276.698, "end": 278.978, "text": "en el mundo financiero", "speaker": null}, {"start": 278.978, "end": 280.458, "text": "las razones aritméticas", "speaker": null}, {"start": 280.458, "end": 281.058, "text": "estas", "speaker": null}, {"start": 281.058, "end": 285.018, "text": "siempre se van a tener que ver en dinero", "speaker": null}, {"start": 285.018, "end": 288.71802, "text": "en el mundo", "speaker": null}, {"start": 288.71802, "end": 290.458, "text": "de las razones financieras", "speaker": null}, {"start": 290.458, "end": 292.618, "text": "las geométricas", "speaker": null}, {"start": 292.618, "end": 295.118, "text": "siempre se van a tener que ver", "speaker": null}, {"start": 295.118, "end": 296.418, "text": "en posentajes", "speaker": null}, {"start": 296.418, "end": 298.618, "text": "ok", "speaker": null}, {"start": 298.618, "end": 300.198, "text": "bueno", "speaker": null}, {"start": 300.198, "end": 302.058, "text": "si eso es cierto", "speaker": null}, {"start": 302.058, "end": 304.59802, "text": "pero como ustedes son informáticos", "speaker": null}, {"start": 304.59802, "end": 307.078, "text": "vamos a echarles un golpe", "speaker": null}, {"start": 307.078, "end": 309.458, "text": "para que se les haga más fácil", "speaker": null}, {"start": 309.458, "end": 310.458, "text": "entender esto", "speaker": null}, {"start": 310.458, "end": 313.378, "text": "a mucha gente le cuesta el trabajo", "speaker": null}, {"start": 313.378, "end": 314.058, "text": "de entender", "speaker": null}, {"start": 314.058, "end": 317.818, "text": "los porcentajes", "speaker": null}, {"start": 317.818, "end": 321.578, "text": "ok, ¿qué podemos hacer?", "speaker": null}, {"start": 322.258, "end": 323.638, "text": "lo que podemos hacer", "speaker": null}, {"start": 323.638, "end": 325.278, "text": "para que a ustedes se les facilite", "speaker": null}, {"start": 325.278, "end": 326.478, "text": "la interpretación", "speaker": null}, {"start": 326.478, "end": 327.818, "text": "es", "speaker": null}, {"start": 327.818, "end": 331.49802, "text": "descomponer los términos conceptuales", "speaker": null}, {"start": 331.49802, "end": 333.09802, "text": "y llevarlos a dinero", "speaker": null}, {"start": 333.09802, "end": 337.038, "text": "¿cómo lo podemos hacer?", "speaker": null}, {"start": 338.158, "end": 339.838, "text": "muy sencillo", "speaker": null}, {"start": 339.838, "end": 342.55798, "text": "si la norma matemática me dice", "speaker": null}, {"start": 342.55798, "end": 347.038, "text": "que debo de manejar porcentajes", "speaker": null}, {"start": 347.038, "end": 350.638, "text": "la base porcentual es base 100", "speaker": null}, {"start": 350.638, "end": 353.918, "text": "o sea, nosotros tenemos que llegar a un 100% siempre", "speaker": null}, {"start": 353.918, "end": 355.65802, "text": "es correcto", "speaker": null}, {"start": 355.65802, "end": 359.258, "text": "pero la norma matemática me dice", "speaker": null}, {"start": 359.258, "end": 361.078, "text": "que un 100%", "speaker": null}, {"start": 361.078, "end": 363.998, "text": "equivale o lo puede expresar", "speaker": null}, {"start": 363.998, "end": 367.378, "text": "con 1.0", "speaker": null}, {"start": 367.378, "end": 371.67798, "text": "ustedes en su computadora", "speaker": null}, {"start": 371.67798, "end": 373.67798, "text": "un 100% lo expresan con 1.0", "speaker": null}, {"start": 374.438, "end": 377.478, "text": "digo, estoy tratando de acercarme lo más posible a ustedes", "speaker": null}, {"start": 377.478, "end": 379.838, "text": "¿voy bien o me regreso?", "speaker": null}, {"start": 380.978, "end": 382.61798, "text": "ok, entonces", "speaker": null}, {"start": 382.61798, "end": 384.11798, "text": "¿qué pasaría aquí?", "speaker": null}, {"start": 385.018, "end": 386.978, "text": "para que a ustedes se les haga más fácil", "speaker": null}, {"start": 386.978, "end": 388.61798, "text": "¿qué podemos hacer?", "speaker": null}, {"start": 389.258, "end": 390.338, "text": "Una simetría.", "speaker": null}, {"start": 391.498, "end": 394.658, "text": "Una simetría en función del dinero.", "speaker": null}, {"start": 395.818, "end": 397.958, "text": "Y para poder llevar a cabo esa simetría,", "speaker": null}, {"start": 398.658, "end": 403.378, "text": "me tendría que facilitar la vida con la mínima extensión monetaria.", "speaker": null}, {"start": 404.11798, "end": 407.17798, "text": "Es más fácil manejar cifras pequeñas que manejar cifras grandes.", "speaker": null}, {"start": 408.198, "end": 412.858, "text": "Entonces, ¿cuál sería, en este caso, la ecuación?", "speaker": null}, {"start": 414.978, "end": 419.17798, "text": "De F1.0, si yo me llevo a la mínima extensión monetaria,", "speaker": null}, {"start": 419.258, "end": 421.438, "text": "sería equivalente", "speaker": null}, {"start": 421.438, "end": 422.55798, "text": "al que se habló", "speaker": null}, {"start": 422.55798, "end": 424.358, "text": "de un peso.", "speaker": null}, {"start": 426.918, "end": 427.758, "text": "¿O no?", "speaker": null}, {"start": 429.098, "end": 430.538, "text": "Yo creo que entonces", "speaker": null}, {"start": 430.538, "end": 432.61798, "text": "un peso va a ser igual", "speaker": null}, {"start": 432.61798, "end": 436.518, "text": "a 100 centavos.", "speaker": null}, {"start": 439.778, "end": 441.658, "text": "Ahora, en vez de hablar", "speaker": null}, {"start": 441.658, "end": 444.018, "text": "de 100%,", "speaker": null}, {"start": 444.018, "end": 455.116, "text": "puedo expresarlo con el peso voy bien o no me regreso ahora s", "speaker": null}, {"start": 461.116, "end": 469.35602, "text": "creo que por cada peso de pasivo a corto plazo hay 1.7 pesos de activo corriente", "speaker": null}, {"start": 469.35602, "end": 470.656, "text": "por ejemplo", "speaker": null}, {"start": 470.656, "end": 473.156, "text": "pero no es así", "speaker": null}, {"start": 473.156, "end": 474.17603, "text": "no lo puedes ver así", "speaker": null}, {"start": 474.17603, "end": 477.57602, "text": "no puedes", "speaker": null}, {"start": 477.57602, "end": 479.256, "text": "imagínate que tú eres", "speaker": null}, {"start": 479.256, "end": 480.13602, "text": "el analista", "speaker": null}, {"start": 480.13602, "end": 482.256, "text": "no me interesa que seas informático", "speaker": null}, {"start": 482.256, "end": 484.91602, "text": "pero tú estás en el área de análisis", "speaker": null}, {"start": 484.91602, "end": 487.29602, "text": "imagínate que yo soy", "speaker": null}, {"start": 487.29602, "end": 488.656, "text": "un simple mortal Carlos", "speaker": null}, {"start": 488.656, "end": 490.73602, "text": "que yo no soy nada de diplomática", "speaker": null}, {"start": 490.73602, "end": 492.436, "text": "ni de contabilidad", "speaker": null}, {"start": 492.436, "end": 494.07602, "text": "ni de administración", "speaker": null}, {"start": 494.07602, "end": 495.276, "text": "yo soy un simple mortal", "speaker": null}, {"start": 495.276, "end": 496.91602, "text": "yo soy un", "speaker": null}, {"start": 496.91602, "end": 502.79602, "text": "Yo soy el dueño de una bodega central de abastos.", "speaker": null}, {"start": 502.976, "end": 504.13602, "text": "¿Alguien recuerda esa bodega?", "speaker": null}, {"start": 505.79602, "end": 506.516, "text": "¿Sí?", "speaker": null}, {"start": 506.85602, "end": 507.176, "text": "No, no.", "speaker": null}, {"start": 507.85602, "end": 510.316, "text": "Pero a Perispo se ha ido.", "speaker": null}, {"start": 511.63602, "end": 512.976, "text": "A Granosun se ha ido.", "speaker": null}, {"start": 514.096, "end": 515.356, "text": "A Perinón se ha ido.", "speaker": null}, {"start": 516.456, "end": 517.476, "text": "A Pericoapa.", "speaker": null}, {"start": 520.376, "end": 521.076, "text": "Ok.", "speaker": null}, {"start": 522.736, "end": 523.636, "text": "Yo no estoy bien.", "speaker": null}, {"start": 523.636, "end": 533.636, "text": "La gente morada alguna vez en la vida nos llevó a la central de Atracos, aquí en Iztaparrata, o la de Canepé, o cualquier otra de las centrales.", "speaker": null}, {"start": 533.636, "end": 536.636, "text": "Todas las ciudades centrales, escurridamente.", "speaker": null}, {"start": 536.636, "end": 539.636, "text": "¿Qué características marcan los centros de arreglos?", "speaker": null}, {"start": 539.636, "end": 543.636, "text": "Hay muchísimo negocio, de todo.", "speaker": null}, {"start": 543.636, "end": 548.636, "text": "¿Y los dueños de los negocios son arquitectos, ingenieros, doctores, médicos?", "speaker": null}, {"start": 548.636, "end": 552.636, "text": "No, son los comerciantes de toda la línea humana.", "speaker": null}, {"start": 552.636, "end": 553.256, "text": "marchantes", "speaker": null}, {"start": 553.256, "end": 556.356, "text": "yo te garantizo que no", "speaker": null}, {"start": 556.356, "end": 557.636, "text": "yo te quiero", "speaker": null}, {"start": 557.636, "end": 559.216, "text": "yo tengo que ir", "speaker": null}, {"start": 559.216, "end": 560.376, "text": "a la casa", "speaker": null}, {"start": 560.376, "end": 561.49603, "text": "a la casa", "speaker": null}, {"start": 561.49603, "end": 563.956, "text": "y cada uno de ellos", "speaker": null}, {"start": 563.956, "end": 566.976, "text": "no perdía ni la primera", "speaker": null}, {"start": 566.976, "end": 569.016, "text": "ni la primera", "speaker": null}, {"start": 569.016, "end": 571.336, "text": "pero cuando yo voy", "speaker": null}, {"start": 571.336, "end": 573.716, "text": "nada me creo que", "speaker": null}, {"start": 573.716, "end": 576.016, "text": "cuento el aprecio de ellos", "speaker": null}, {"start": 576.016, "end": 577.856, "text": "pero yo voy a entrar", "speaker": null}, {"start": 577.856, "end": 582.056, "text": "tú vas a ver", "speaker": null}, {"start": 582.056, "end": 583.056, "text": "que traen esos malditos", "speaker": null}, {"start": 583.056, "end": 585.636, "text": "y cuando meten", "speaker": null}, {"start": 585.636, "end": 586.81604, "text": "la chuchuma con la leche", "speaker": null}, {"start": 586.81604, "end": 587.296, "text": "¿qué sacan?", "speaker": null}, {"start": 588.596, "end": 589.736, "text": "miles de pesos", "speaker": null}, {"start": 589.736, "end": 592.336, "text": "los pagios de billetes", "speaker": null}, {"start": 592.336, "end": 594.176, "text": "casi cincuenta mil", "speaker": null}, {"start": 594.176, "end": 595.736, "text": "cincuenta mil", "speaker": null}, {"start": 595.736, "end": 597.096, "text": "cincuenta mil", "speaker": null}, {"start": 597.096, "end": 598.616, "text": "cuando yo voy a la licenciada", "speaker": null}, {"start": 598.616, "end": 599.776, "text": "ya el señor no va a caer", "speaker": null}, {"start": 599.776, "end": 600.836, "text": "me trae un chingadero", "speaker": null}, {"start": 600.836, "end": 601.616, "text": "que ya quemaste", "speaker": null}, {"start": 601.616, "end": 602.99603, "text": "pero voy a tener tres papeles", "speaker": null}, {"start": 602.99603, "end": 603.536, "text": "cabrón", "speaker": null}, {"start": 603.536, "end": 605.19604, "text": "eches un acolito", "speaker": null}, {"start": 605.19604, "end": 606.036, "text": "eches un tamalito", "speaker": null}, {"start": 606.036, "end": 607.31604, "text": "no, no, no", "speaker": null}, {"start": 607.31604, "end": 607.69604, "text": "¿cómo no?", "speaker": null}, {"start": 607.776, "end": 608.036, "text": "a ver", "speaker": null}, {"start": 608.036, "end": 609.276, "text": "Mike", "speaker": null}, {"start": 609.276, "end": 611.57605, "text": "ve y trae un acolito", "speaker": null}, {"start": 611.57605, "end": 617.376, "text": "y los demás sacan un cartón y guardan los cartones con una salta.", "speaker": null}, {"start": 617.496, "end": 618.196, "text": "¡No, no, no!", "speaker": null}, {"start": 618.196, "end": 622.696, "text": "Y los demás, los demás, los demás, los demás.", "speaker": null}, {"start": 624.696, "end": 625.516, "text": "¿Es bien o qué?", "speaker": null}, {"start": 626.596, "end": 627.596, "text": "Eso me va a enlajar.", "speaker": null}, {"start": 628.036, "end": 631.256, "text": "No, mira, maneja el arte del cartón.", "speaker": null}, {"start": 632.036, "end": 633.256, "text": "Así, con esas palabras.", "speaker": null}, {"start": 634.876, "end": 635.756, "text": "¿Cuánto es el mínimo?", "speaker": null}, {"start": 635.916, "end": 636.976, "text": "Tres cincuenta mil pesos.", "speaker": null}, {"start": 636.976, "end": 647.256, "text": "¿Pero qué crees? ¿Quieres el daño, la verdad? ¿Y qué crees? Que no te animaré, la prima.", "speaker": null}, {"start": 647.716, "end": 652.456, "text": "¿Por qué no se me contratan? ¿Por qué no saben cómo se llama la vez?", "speaker": null}, {"start": 653.19604, "end": 654.81604, "text": "Pero tienen obligaciones para ganar.", "speaker": null}, {"start": 654.81604, "end": 659.176, "text": "¿Por qué no se me contratan? ¿Por qué no se me contratan?", "speaker": null}, {"start": 662.43604, "end": 665.31604, "text": "Imagínate que me lo vas a decir.", "speaker": null}, {"start": 666.976, "end": 668.976, "text": "Gracias.", "speaker": null}, {"start": 700.054, "end": 704.214, "text": "Hay bastante ganancia incluso para pagar lo que debes sin problema.", "speaker": null}, {"start": 704.214, "end": 708.114, "text": "No, no hay nada de ganancia. Discúlpame, pero no hay ganancia.", "speaker": null}, {"start": 710.854, "end": 713.45404, "text": "Acuérdate de lo que vimos las clases pasadas, Charlie.", "speaker": null}, {"start": 720.034, "end": 723.69403, "text": "Cuando vimos el estado financiero, ¿qué de menos dijimos de los estados financieros, Charlie?", "speaker": null}, {"start": 725.654, "end": 726.494, "text": "Es como un balance.", "speaker": null}, {"start": 726.494, "end": 730.674, "text": "¿Qué me representa el balance?", "speaker": null}, {"start": 732.934, "end": 734.034, "text": "¿Qué cargo yo?", "speaker": null}, {"start": 734.974, "end": 736.114, "text": "No, ¿qué cargo se abone?", "speaker": null}, {"start": 737.554, "end": 739.054, "text": "Señores, dijimos", "speaker": null}, {"start": 739.054, "end": 741.054, "text": "que de este lado", "speaker": null}, {"start": 741.054, "end": 742.334, "text": "contablemente", "speaker": null}, {"start": 742.334, "end": 745.114, "text": "me representa lo que yo tengo", "speaker": null}, {"start": 745.114, "end": 747.914, "text": "y de este lado", "speaker": null}, {"start": 747.914, "end": 751.094, "text": "me representa lo que yo debo.", "speaker": null}, {"start": 752.474, "end": 754.63403, "text": "Luego entonces, si la razón", "speaker": null}, {"start": 754.63403, "end": 756.054, "text": "me dice", "speaker": null}, {"start": 756.054, "end": 759.034, "text": "que esta es la razón de capital de trabajo,", "speaker": null}, {"start": 759.614, "end": 761.27405, "text": "lo primero que tenemos que identificar", "speaker": null}, {"start": 761.27405, "end": 763.474, "text": "son los elementos, por eso se los puse aquí.", "speaker": null}, {"start": 764.814, "end": 766.45404, "text": "¿Cuáles serían los elementos, Mike?", "speaker": null}, {"start": 767.834, "end": 769.254, "text": "¿Dónde están esos elementos?", "speaker": null}, {"start": 774.95404, "end": 776.174, "text": "¿Los geométricos?", "speaker": null}, {"start": 776.614, "end": 778.594, "text": "Sí, o geométricos, o lo que sea.", "speaker": null}, {"start": 779.27405, "end": 779.934, "text": "¿En dónde están?", "speaker": null}, {"start": 779.934, "end": 780.374, "text": "¿Dónde están los elementos?", "speaker": null}, {"start": 780.374, "end": 781.77405, "text": "Tienes que identificarlos.", "speaker": null}, {"start": 786.054, "end": 794.45404, "text": "¿Ustedes son los analistas, no yo?", "speaker": null}, {"start": 795.39404, "end": 797.314, "text": "Ustedes son los profesionalistas, no yo.", "speaker": null}, {"start": 798.034, "end": 800.734, "text": "Ya creamos que yo soy el presidente de la chancada,", "speaker": null}, {"start": 801.374, "end": 803.554, "text": "pero ya creamos que yo, no sea la escuela,", "speaker": null}, {"start": 804.734, "end": 808.254, "text": "estoy poniendo en manos de ustedes mi negocio, que son mis asesores.", "speaker": null}, {"start": 810.714, "end": 813.254, "text": "Yo decidí que me los iba a llevar para allá afuera, para la realidad.", "speaker": null}, {"start": 813.254, "end": 815.65405, "text": "no nos iba a traer aquí", "speaker": null}, {"start": 815.65405, "end": 816.474, "text": "más una pizarra", "speaker": null}, {"start": 816.474, "end": 819.314, "text": "no nos estamos sacando", "speaker": null}, {"start": 819.314, "end": 821.374, "text": "un hilo, están hablando ustedes", "speaker": null}, {"start": 821.374, "end": 836.994, "text": "los escucho", "speaker": null}, {"start": 841.054, "end": 842.57404, "text": "eso fue bueno", "speaker": null}, {"start": 842.57404, "end": 847.034, "text": "No, me vinieron a la facultad a desayunar, a pasear.", "speaker": null}, {"start": 847.57404, "end": 848.954, "text": "¿Qué les preocupa a la niña?", "speaker": null}, {"start": 850.314, "end": 850.954, "text": "¿Verdad?", "speaker": null}, {"start": 851.814, "end": 852.77405, "text": "¿Qué les interesa?", "speaker": null}, {"start": 853.874, "end": 855.674, "text": "A mi padre los caballos.", "speaker": null}, {"start": 858.674, "end": 860.554, "text": "Vamos a ver si estamos porque hay que avanzar.", "speaker": null}, {"start": 861.234, "end": 863.714, "text": "Pues que... ¿qué hay?", "speaker": null}, {"start": 864.39404, "end": 866.794, "text": "No, ya, ¿qué hay?", "speaker": null}, {"start": 867.01404, "end": 867.974, "text": "¿Por qué está aquí?", "speaker": null}, {"start": 868.414, "end": 869.114, "text": "¿Qué le dicen?", "speaker": null}, {"start": 869.114, "end": 871.754, "text": "RZP es igual a", "speaker": null}, {"start": 871.754, "end": 872.89404, "text": "aquí está la fórmula", "speaker": null}, {"start": 872.89404, "end": 875.39404, "text": "dijimos que esto era para poder entender la fórmula", "speaker": null}, {"start": 875.39404, "end": 878.474, "text": "me dice que tengo un activo circulante", "speaker": null}, {"start": 878.474, "end": 880.07404, "text": "¿el activo circulante qué me representa?", "speaker": null}, {"start": 880.874, "end": 882.214, "text": "en la fórmula me representa", "speaker": null}, {"start": 882.214, "end": 883.174, "text": "el antecedente", "speaker": null}, {"start": 883.174, "end": 886.934, "text": "aquí tengo una división", "speaker": null}, {"start": 886.934, "end": 889.234, "text": "¿qué demora en la división?", "speaker": null}, {"start": 889.69403, "end": 891.094, "text": "la ecuación", "speaker": null}, {"start": 891.094, "end": 892.834, "text": "es una división", "speaker": null}, {"start": 892.834, "end": 895.794, "text": "luego entonces me dice que es una", "speaker": null}, {"start": 895.794, "end": 897.39404, "text": "ecuación geométrica", "speaker": null}, {"start": 897.39404, "end": 898.89404, "text": "un momento", "speaker": null}]