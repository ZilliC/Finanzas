[{"start": 0.0, "end": 11.36, "text": "A mí todavía me ha hecho la sorpresa lo que tocó Darés, todavía me ha hecho la sorpresa lo que tocó trabajar con sus colegas con ese plan de estudios.", "speaker": null}, {"start": 13.639999, "end": 18.859999, "text": "Yo no sé quién había hecho las calificaciones, qué hubiera sido.", "speaker": null}, {"start": 18.859999, "end": 19.859999, "text": "Gracias.", "speaker": null}, {"start": 48.86, "end": 50.420002, "text": "¿Qué dice?", "speaker": null}, {"start": 51.54, "end": 54.68, "text": "Para informarnos.", "speaker": null}, {"start": 59.98, "end": 62.58, "text": "Sistema financiero mexicano.", "speaker": null}, {"start": 63.28, "end": 67.18, "text": "Análisis en interpretación de estados financieros.", "speaker": null}, {"start": 67.66, "end": 69.16, "text": "Planeación financiera.", "speaker": null}, {"start": 70.04, "end": 71.46, "text": "El análisis en interpretación es este.", "speaker": null}, {"start": 73.38, "end": 76.24, "text": "Antes a ustedes se los enseñábamos.", "speaker": null}, {"start": 76.24, "end": 77.88, "text": "ahora", "speaker": null}, {"start": 77.88, "end": 79.799995, "text": "es la hora de pensar", "speaker": null}, {"start": 79.799995, "end": 83.899994, "text": "y no siempre", "speaker": null}, {"start": 83.899994, "end": 85.22, "text": "está tocando escasas", "speaker": null}, {"start": 85.22, "end": 92.939995, "text": "si, creo que si justo", "speaker": null}, {"start": 92.939995, "end": 94.899994, "text": "en general", "speaker": null}, {"start": 94.899994, "end": 96.64, "text": "del sistema mexicano", "speaker": null}, {"start": 96.64, "end": 97.36, "text": "financiero", "speaker": null}, {"start": 97.36, "end": 99.92, "text": "o sea como que tú", "speaker": null}, {"start": 99.92, "end": 101.71999, "text": "lo tratas de entender", "speaker": null}, {"start": 101.71999, "end": 103.0, "text": "pero si eso es como muy", "speaker": null}, {"start": 103.0, "end": 105.979996, "text": "muy fracturado, o sea las cosas que entiendes", "speaker": null}, {"start": 105.979996, "end": 107.81999, "text": "como una ausencia fraca, que si", "speaker": null}, {"start": 107.81999, "end": 110.079994, "text": "las fracas fracas, no.", "speaker": null}, {"start": 110.24, "end": 111.84, "text": "Y eso es bien importante.", "speaker": null}, {"start": 112.299995, "end": 112.84, "text": "Sí, pues sí.", "speaker": null}, {"start": 112.84, "end": 113.399994, "text": "Es bien importante.", "speaker": null}, {"start": 114.71999, "end": 116.159996, "text": "Yo te puedo decir", "speaker": null}, {"start": 116.159996, "end": 118.1, "text": "eso no", "speaker": null}, {"start": 118.1, "end": 119.63999, "text": "regularmente nos parece.", "speaker": null}, {"start": 120.619995, "end": 121.799995, "text": "Por ejemplo, nosotros hemos", "speaker": null}, {"start": 121.799995, "end": 124.799995, "text": "a los contadores les enseñamos a entender", "speaker": null}, {"start": 124.799995, "end": 126.03999, "text": "qué está pasando ahorita", "speaker": null}, {"start": 126.03999, "end": 127.259995, "text": "en la comunidad.", "speaker": null}, {"start": 128.92, "end": 130.51999, "text": "¿Por qué el gobierno está siendo", "speaker": null}, {"start": 130.51999, "end": 131.08, "text": "enterado?", "speaker": null}, {"start": 132.68, "end": 134.62, "text": "¿Por qué se están haciendo actos", "speaker": null}, {"start": 134.62, "end": 135.31999, "text": "de violación?", "speaker": null}, {"start": 135.98, "end": 138.48, "text": "Por ejemplo, con este gobierno.", "speaker": null}, {"start": 139.4, "end": 141.12, "text": "Están violando completamente las leyes.", "speaker": null}, {"start": 141.34, "end": 142.23999, "text": "Pero la gente no lo sabe.", "speaker": null}, {"start": 143.5, "end": 145.42, "text": "O no se da cuenta y no se da cuenta porque no lo sabe.", "speaker": null}, {"start": 145.64, "end": 146.28, "text": "No lo entiende.", "speaker": null}, {"start": 147.59999, "end": 149.76, "text": "Eso son los señores más valiosos.", "speaker": null}, {"start": 149.95999, "end": 150.45999, "text": "Ustedes son.", "speaker": null}, {"start": 151.28, "end": 154.54, "text": "Porque no lo contempla el plan de estudios.", "speaker": null}, {"start": 156.15999, "end": 158.15999, "text": "Pero si llegan, lo vemos.", "speaker": null}, {"start": 158.15999, "end": 161.56, "text": "Y te sientes, pero la van a matar.", "speaker": null}, {"start": 161.56, "end": 166.4, "text": "y yo, no, no creo que esté contigo", "speaker": null}, {"start": 166.4, "end": 167.86, "text": "te lo estoy enseñando con hechos", "speaker": null}, {"start": 167.86, "end": 169.84, "text": "pero yo estoy diciendo", "speaker": null}, {"start": 169.84, "end": 171.42, "text": "que tú no te sigas con esto", "speaker": null}, {"start": 171.42, "end": 174.5, "text": "es una verdadera descomunicación", "speaker": null}, {"start": 174.5, "end": 176.48, "text": "pues cómo no va a terminar", "speaker": null}, {"start": 176.48, "end": 178.52, "text": "si ya está todo", "speaker": null}, {"start": 178.52, "end": 182.5, "text": "lo básico", "speaker": null}, {"start": 182.5, "end": 184.9, "text": "y ahora tiene que aplicarse", "speaker": null}, {"start": 184.9, "end": 186.22, "text": "con aplicar lo que no vamos", "speaker": null}, {"start": 186.22, "end": 189.9, "text": "yo lo digo porque me han dicho", "speaker": null}, {"start": 189.9, "end": 191.9, "text": "¿Por qué qué?", "speaker": null}, {"start": 191.9, "end": 193.9, "text": "Muchos años tanto que va a ser", "speaker": null}, {"start": 193.9, "end": 195.9, "text": "en función de acuerdo con los programas", "speaker": null}, {"start": 195.9, "end": 197.9, "text": "de la certificada, toda la competencia", "speaker": null}, {"start": 197.9, "end": 199.9, "text": "que se está produciendo", "speaker": null}, {"start": 199.9, "end": 201.9, "text": "desde ese último", "speaker": null}, {"start": 201.9, "end": 203.9, "text": "nos hemos construido el modelo", "speaker": null}, {"start": 203.9, "end": 205.9, "text": "nuestro algún informático modelo", "speaker": null}, {"start": 205.9, "end": 207.9, "text": "que no veo otro", "speaker": null}, {"start": 207.9, "end": 209.9, "text": "porque eso lo invitan los informáticos", "speaker": null}, {"start": 209.9, "end": 211.9, "text": "y ellos son los que dicen", "speaker": null}, {"start": 211.9, "end": 213.9, "text": "esto es lo que necesitan los alumnos", "speaker": null}, {"start": 213.9, "end": 215.9, "text": "en el área de informática", "speaker": null}, {"start": 215.9, "end": 217.9, "text": "esto es lo que necesitan los administradores", "speaker": null}, {"start": 217.9, "end": 230.89801, "text": "administradores de la red de administraci Entonces ya se necesita se puede ver que para nosotros los contadores necesitan m derecho", "speaker": null}, {"start": 231.798, "end": 242.67801, "text": "más derecho, necesitan más psicología, porque ahora ya les dan nuestra materia psicológica.", "speaker": null}, {"start": 242.67801, "end": 246.67801, "text": "Ahorita sí es, hay que descomprimir a muchos de nuestros psicólogos.", "speaker": null}, {"start": 246.67801, "end": 250.67801, "text": "¿Por qué? Porque no son contadores, pero no mudan a los contadores.", "speaker": null}, {"start": 250.67801, "end": 252.67801, "text": "Es lo mismo para ustedes.", "speaker": null}, {"start": 252.67801, "end": 255.67801, "text": "Los psicólogos necesitan finanzas.", "speaker": null}, {"start": 255.67801, "end": 259.678, "text": "Háblalos de contas, que vengan a darles finanzas.", "speaker": null}, {"start": 259.678, "end": 263.678, "text": "Necesitan más administración, por eso hay coordinaciones.", "speaker": null}, {"start": 263.678, "end": 270.678, "text": "Coordinación de administración, coordinación de finanzas, coordinación de derecho, coordinación de MATE.", "speaker": null}, {"start": 270.678, "end": 274.358, "text": "Si te das cuenta, ustedes tienen muchos más temas de financiación que son ingenieros.", "speaker": null}, {"start": 277.578, "end": 281.258, "text": "En teoría nos mandan a traer a los especialistas para dar estudios.", "speaker": null}, {"start": 283.018, "end": 283.518, "text": "¿Me explico?", "speaker": null}, {"start": 283.99802, "end": 285.778, "text": "Los niños como especialistas, explícanos.", "speaker": null}, {"start": 286.558, "end": 287.958, "text": "Se le ocurrió esto.", "speaker": null}, {"start": 290.398, "end": 291.838, "text": "A un informático.", "speaker": null}, {"start": 293.878, "end": 295.678, "text": "A un informático se le ocurrió.", "speaker": null}, {"start": 298.418, "end": 299.238, "text": "¿Me explico?", "speaker": null}, {"start": 299.238, "end": 299.278, "text": "¿Me explico?", "speaker": null}, {"start": 299.278, "end": 301.598, "text": "¿Ustedes dicen señores", "speaker": null}, {"start": 301.598, "end": 303.61798, "text": "cómo quieren caminar?", "speaker": null}, {"start": 304.638, "end": 306.438, "text": "¿Si quieren caminar con boquitas", "speaker": null}, {"start": 306.438, "end": 308.078, "text": "o quieren empezar desde", "speaker": null}, {"start": 308.078, "end": 309.178, "text": "descalzos?", "speaker": null}, {"start": 310.898, "end": 312.918, "text": "No, pues ahora sí que usted es el experto.", "speaker": null}, {"start": 313.438, "end": 314.138, "text": "Yo no sé", "speaker": null}, {"start": 314.138, "end": 315.138, "text": "qué tanto aguante ustedes.", "speaker": null}, {"start": 316.418, "end": 316.978, "text": "¿Yo?", "speaker": null}, {"start": 318.138, "end": 320.178, "text": "Y yo no diría qué tanto aguante.", "speaker": null}, {"start": 320.858, "end": 322.21802, "text": "Cambiaría ese término.", "speaker": null}, {"start": 322.21802, "end": 322.61798, "text": "¿Qué?", "speaker": null}, {"start": 323.05798, "end": 325.658, "text": "Yo no lo cambiaría porque no sé", "speaker": null}, {"start": 325.658, "end": 326.71802, "text": "qué tanto quieren aprender.", "speaker": null}, {"start": 327.658, "end": 328.858, "text": "Todo lo que se pueda.", "speaker": null}, {"start": 329.278, "end": 335.158, "text": "Por mí, si usted tiene tiempo, hasta podría venir otras horas.", "speaker": null}, {"start": 336.678, "end": 339.518, "text": "Veamos la siguiente clase, porque usted tiene clase y yo también tengo clase.", "speaker": null}, {"start": 339.838, "end": 344.55798, "text": "Pero por mí, hasta venir otras dos horas después de eso, sin problema.", "speaker": null}, {"start": 345.758, "end": 347.978, "text": "Les pregunto porque tengo grupos que es al revés.", "speaker": null}, {"start": 348.078, "end": 350.578, "text": "No, no, no, no, déjenos lo que marquen por allá.", "speaker": null}, {"start": 352.978, "end": 354.738, "text": "Para el siguiente se va a decir, te va a dar chingada.", "speaker": null}, {"start": 355.378, "end": 356.078, "text": "Es como yo hoy.", "speaker": null}, {"start": 356.078, "end": 359.518, "text": "tengo el libro, es mayor que un hijo de otra casa", "speaker": null}, {"start": 359.518, "end": 360.918, "text": "y otro que", "speaker": null}, {"start": 360.918, "end": 361.978, "text": "los grandes cientos", "speaker": null}, {"start": 361.978, "end": 363.838, "text": "¿qué tamaño es?", "speaker": null}, {"start": 365.278, "end": 366.198, "text": "y ahorita ve", "speaker": null}, {"start": 366.198, "end": 368.318, "text": "esto no lo he visto", "speaker": null}, {"start": 368.318, "end": 370.958, "text": "es que es un nuevo hijo", "speaker": null}, {"start": 370.958, "end": 372.758, "text": "es que es un nuevo niño", "speaker": null}, {"start": 372.758, "end": 375.05798, "text": "no sé, igual que ustedes, no lo sé", "speaker": null}, {"start": 375.05798, "end": 376.758, "text": "aquí dice que ya lo sabes", "speaker": null}, {"start": 376.758, "end": 378.938, "text": "con la pena", "speaker": null}, {"start": 378.938, "end": 381.438, "text": "vamos a echarle su balanza", "speaker": null}, {"start": 381.438, "end": 383.15802, "text": "por huevones", "speaker": null}, {"start": 383.15802, "end": 387.698, "text": "Sí, de hecho sí me gustaría ir, pero tengo la otra de matemáticas.", "speaker": null}, {"start": 390.918, "end": 394.318, "text": "Bueno, entonces vamos a ampliar esto un poquito más.", "speaker": null}, {"start": 399.198, "end": 401.798, "text": "Ahora si no nos quedamos, nos quedamos.", "speaker": null}, {"start": 405.798, "end": 407.998, "text": "Precisamente nos quedamos con la clasificación, ¿no?", "speaker": null}, {"start": 409.438, "end": 410.258, "text": "Según yo, ¿no?", "speaker": null}, {"start": 410.258, "end": 412.778, "text": "Sí, empezamos ya a desmontar las fórmulas.", "speaker": null}, {"start": 413.15802, "end": 414.918, "text": "¿Es correcto? Ahí nos quedamos.", "speaker": null}, {"start": 417.238, "end": 418.05798, "text": "¿Sabe, Ibai?", "speaker": null}, {"start": 418.338, "end": 419.578, "text": "Nos vamos a hacer una cosa.", "speaker": null}, {"start": 420.958, "end": 422.618, "text": "Eso no lo pensaba hacer, pero", "speaker": null}, {"start": 422.618, "end": 424.71802, "text": "si realmente les interesa.", "speaker": null}, {"start": 425.318, "end": 425.65802, "text": "Por ahí.", "speaker": null}, {"start": 426.458, "end": 428.03802, "text": "Vamos a ver de dónde sale", "speaker": null}, {"start": 428.03802, "end": 430.898, "text": "esto y qué significa esto.", "speaker": null}, {"start": 431.958, "end": 432.258, "text": "¿Sabe?", "speaker": null}, {"start": 435.138, "end": 436.418, "text": "Yo no tengo tema.", "speaker": null}, {"start": 443.15802, "end": 444.858, "text": "Ok.", "speaker": null}, {"start": 445.036, "end": 447.29602, "text": "Ah, por aquí están.", "speaker": null}, {"start": 449.336, "end": 450.836, "text": "Es de la primera clase.", "speaker": null}, {"start": 452.816, "end": 454.95602, "text": "Bueno, por esta evidencia, hasta ahí.", "speaker": null}, {"start": 457.536, "end": 464.896, "text": "Bueno, si nosotros quisiéramos hacer análisis, empezar a comprender el análisis de Estados Unidos,", "speaker": null}, {"start": 465.256, "end": 467.73602, "text": "¿cómo lo tendríamos que hacer?", "speaker": null}, {"start": 468.756, "end": 469.91602, "text": "Pues muy fácil.", "speaker": null}, {"start": 469.91602, "end": 480.276, "text": "Lo único que vamos a hacer es tratar de entender las cifras, tratar de entender lo que me arroja el Estado de financiación.", "speaker": null}, {"start": 480.996, "end": 481.91602, "text": "Y esto está muy sencillo.", "speaker": null}, {"start": 484.896, "end": 487.536, "text": "Vamos a cerrarnos un Estado de financiación.", "speaker": null}, {"start": 499.91602, "end": 503.176, "text": "es más, vamos a cargar", "speaker": null}, {"start": 503.176, "end": 503.63602, "text": "dos", "speaker": null}, {"start": 503.63602, "end": 506.35602, "text": "¿vale?", "speaker": null}, {"start": 527.49603, "end": 529.476, "text": "bueno, nos mencionó un poco de", "speaker": null}, {"start": 529.476, "end": 532.476, "text": "que dependiendo nada más con la estructura", "speaker": null}, {"start": 532.476, "end": 534.896, "text": "podría inferirse hasta de que", "speaker": null}, {"start": 534.896, "end": 536.056, "text": "giro el alma", "speaker": null}, {"start": 536.056, "end": 537.576, "text": "ok", "speaker": null}, {"start": 537.576, "end": 539.536, "text": "bueno vamos a ver antes", "speaker": null}, {"start": 539.536, "end": 541.876, "text": "vamos a ver antes", "speaker": null}, {"start": 541.876, "end": 546.756, "text": "otra cosa para que se vayan", "speaker": null}, {"start": 546.756, "end": 547.896, "text": "ustedes cuando lleguen a esa", "speaker": null}, {"start": 547.896, "end": 558.356, "text": "para que ustedes vayan", "speaker": null}, {"start": 558.356, "end": 560.896, "text": "entrando al universo financiero", "speaker": null}, {"start": 560.896, "end": 562.156, "text": "muchachos", "speaker": null}, {"start": 562.156, "end": 570.116, "text": "aquí le explicamos", "speaker": null}, {"start": 570.116, "end": 571.896, "text": "cómo se compone el estado financiero", "speaker": null}, {"start": 571.896, "end": 574.596, "text": "cómo se ordenan las fuentes", "speaker": null}, {"start": 574.596, "end": 577.016, "text": "o no lo hicimos", "speaker": null}, {"start": 577.016, "end": 578.596, "text": "¿sí?", "speaker": null}, {"start": 578.596, "end": 578.636, "text": "¿sí?", "speaker": null}, {"start": 580.636, "end": 582.616, "text": "¿tienes un grado de", "speaker": null}, {"start": 582.616, "end": 583.43604, "text": "disponibilidad?", "speaker": null}, {"start": 583.716, "end": 586.396, "text": "¿cómo la técnica", "speaker": null}, {"start": 586.396, "end": 588.616, "text": "nos clasifica", "speaker": null}, {"start": 588.616, "end": 591.376, "text": "a los espaldas de la nación.", "speaker": null}, {"start": 591.616, "end": 593.216, "text": "Un otro es grado de exigibilidad.", "speaker": null}, {"start": 594.856, "end": 597.99603, "text": "Y ya veíamos que ustedes ahora ya no van a ver", "speaker": null}, {"start": 597.99603, "end": 600.49603, "text": "nada más como bienes y derechos,", "speaker": null}, {"start": 600.876, "end": 603.296, "text": "sino ahora van a tener que identificar las fuentes de inversión", "speaker": null}, {"start": 603.296, "end": 604.616, "text": "y las fuentes de financiamiento.", "speaker": null}, {"start": 605.896, "end": 606.416, "text": "Sí.", "speaker": null}, {"start": 606.416, "end": 606.516, "text": "Sí.", "speaker": null}, {"start": 611.616, "end": 612.336, "text": "Sí.", "speaker": null}, {"start": 612.336, "end": 612.656, "text": "Sí.", "speaker": null}, {"start": 614.256, "end": 615.776, "text": "Financiamiento externo y financiamiento", "speaker": null}, {"start": 615.776, "end": 616.396, "text": "interno.", "speaker": null}, {"start": 617.43604, "end": 619.69604, "text": "Ok, por eso lo vamos a ocupar más adelante.", "speaker": null}, {"start": 620.396, "end": 621.93604, "text": "Si quiere que veamos", "speaker": null}, {"start": 621.93604, "end": 623.336, "text": "el sistema financiero,", "speaker": null}, {"start": 624.516, "end": 625.976, "text": "vamos a tener que derivarnos", "speaker": null}, {"start": 625.976, "end": 627.376, "text": "para ver los financiamientos.", "speaker": null}, {"start": 628.416, "end": 629.916, "text": "Ahí lo vamos a ocupar esa parte.", "speaker": null}, {"start": 630.616, "end": 630.876, "text": "Bueno.", "speaker": null}, {"start": 631.796, "end": 633.556, "text": "Entonces decíamos, bueno, vamos a hacer un siguiente.", "speaker": null}, {"start": 633.556, "end": 634.716, "text": "Vamos a empezar ya", "speaker": null}, {"start": 634.716, "end": 637.556, "text": "a ver cómo van a ser, o cómo pueden", "speaker": null}, {"start": 637.556, "end": 638.956, "text": "ser ustedes en el análisis.", "speaker": null}, {"start": 642.336, "end": 648.156, "text": "Vamos a tener aquí, pensemos, una empresa.", "speaker": null}, {"start": 649.156, "end": 650.676, "text": "Con las siglas que ustedes tienen.", "speaker": null}, {"start": 652.736, "end": 654.676, "text": "Aquí vamos a tener otra empresa.", "speaker": null}, {"start": 654.676, "end": 685.234, "text": "Les voy a demostrar como para nosotros teniendo conociendo los m a nosotros no nos interesa una empresa que sea chica mediana grande si es comercializada si es transformadora si es de servicios no nos interesa", "speaker": null}, {"start": 686.234, "end": 692.274, "text": "Para nosotros, manejando los métodos de análisis, podemos determinar si la empresa está sana,", "speaker": null}, {"start": 692.274, "end": 695.57404, "text": "está enferma o está muy inmunda.", "speaker": null}, {"start": 695.57404, "end": 697.39404, "text": "y si estamos inmunos", "speaker": null}, {"start": 697.39404, "end": 698.474, "text": "tenemos que ayudarles", "speaker": null}, {"start": 698.474, "end": 700.63403, "text": "como los humanos, hagan de cuenta que", "speaker": null}, {"start": 700.63403, "end": 703.554, "text": "nosotros no vamos a hacer la función de un médico", "speaker": null}, {"start": 703.554, "end": 705.314, "text": "un médico que hace", "speaker": null}, {"start": 705.314, "end": 706.534, "text": "recibe a su paciente", "speaker": null}, {"start": 706.534, "end": 709.174, "text": "y de acuerdo a ciertas pruebas", "speaker": null}, {"start": 709.174, "end": 710.654, "text": "o ciertos análisis", "speaker": null}, {"start": 710.654, "end": 713.094, "text": "el médico te va a decir, ¿sabes qué?", "speaker": null}, {"start": 713.39404, "end": 714.034, "text": "no tienes problema", "speaker": null}, {"start": 714.034, "end": 716.934, "text": "o sea, no estás enfermo, ¿a qué viniste?", "speaker": null}, {"start": 717.354, "end": 718.474, "text": "te hagas tonto, vete a trabajar", "speaker": null}, {"start": 718.474, "end": 720.594, "text": "nada más viniste por la incapacidad", "speaker": null}, {"start": 720.594, "end": 722.934, "text": "y no te voy a dar incapacidad", "speaker": null}, {"start": 722.934, "end": 724.45404, "text": "por la incapacidad, vete a trabajar", "speaker": null}, {"start": 724.45404, "end": 726.794, "text": "o puedes ver", "speaker": null}, {"start": 726.794, "end": 728.474, "text": "si el paciente", "speaker": null}, {"start": 728.474, "end": 729.274, "text": "está enfermo", "speaker": null}, {"start": 729.274, "end": 730.614, "text": "y si está enfermo", "speaker": null}, {"start": 730.614, "end": 732.114, "text": "y tú sabes que tienes una infección", "speaker": null}, {"start": 732.114, "end": 733.69403, "text": "te voy a dar antibióticos", "speaker": null}, {"start": 733.69403, "end": 736.674, "text": "te duele, te voy a dar una analgesia", "speaker": null}, {"start": 736.674, "end": 738.69403, "text": "y así sucesión", "speaker": null}, {"start": 738.69403, "end": 739.994, "text": "o de plano", "speaker": null}, {"start": 739.994, "end": 741.294, "text": "abre la tijera", "speaker": null}, {"start": 741.294, "end": 743.69403, "text": "y te poniendo en orden tus papeles", "speaker": null}, {"start": 743.69403, "end": 748.614, "text": "no la vas a levantar", "speaker": null}, {"start": 749.174, "end": 750.63403, "text": "o la deuda", "speaker": null}, {"start": 750.63403, "end": 751.19403, "text": "si", "speaker": null}, {"start": 751.19403, "end": 753.954, "text": "su paciente se va a morir", "speaker": null}, {"start": 753.95404, "end": 758.45404, "text": "¿Cuándo? No lo sé, pero le doy máximo seis meses.", "speaker": null}, {"start": 759.414, "end": 762.434, "text": "Se puede morir mañana, se puede morir en un mes,", "speaker": null}, {"start": 762.814, "end": 765.63403, "text": "pero después de seis meses no la va a contar.", "speaker": null}, {"start": 766.51404, "end": 768.51404, "text": "Estoy buscando qué hacer con él.", "speaker": null}, {"start": 769.434, "end": 771.374, "text": "No sé si han dado cuenta que eso pasa en la vida de él.", "speaker": null}, {"start": 772.054, "end": 773.45404, "text": "Lo mismo pasa con los ingleses.", "speaker": null}, {"start": 774.89404, "end": 776.994, "text": "De hecho, muchas veces ustedes se la dejan de apoyar,", "speaker": null}, {"start": 776.994, "end": 779.434, "text": "porque están sufriendo, lo tienen como un símbolo,", "speaker": null}, {"start": 779.51404, "end": 782.63403, "text": "lo molestan, lo molestan, partizan.", "speaker": null}, {"start": 782.63403, "end": 784.214, "text": "ya mejor", "speaker": null}, {"start": 784.214, "end": 785.614, "text": "no", "speaker": null}, {"start": 785.614, "end": 787.554, "text": "aquí sí", "speaker": null}, {"start": 787.554, "end": 790.034, "text": "aquí sí cuando es necesario", "speaker": null}, {"start": 790.034, "end": 791.914, "text": "hay que ayudarle a alguien", "speaker": null}, {"start": 791.914, "end": 794.734, "text": "mejor la matamos antes", "speaker": null}, {"start": 794.734, "end": 795.994, "text": "de que sufra", "speaker": null}, {"start": 795.994, "end": 797.474, "text": "antes de que la despegase", "speaker": null}, {"start": 797.474, "end": 799.154, "text": "si no es bien", "speaker": null}, {"start": 799.154, "end": 801.334, "text": "como es en su sitio", "speaker": null}, {"start": 801.334, "end": 803.594, "text": "háganle cuenta a los perritos que son", "speaker": null}, {"start": 803.594, "end": 804.814, "text": "médicos", "speaker": null}, {"start": 804.814, "end": 806.794, "text": "un médico que hace", "speaker": null}, {"start": 806.794, "end": 809.89404, "text": "un médico normalmente que toma la temperatura", "speaker": null}, {"start": 809.89404, "end": 811.69403, "text": "te pesa, tu presión", "speaker": null}, {"start": 811.69403, "end": 814.334, "text": "y para le contar, ya te dice, ¿quién es este?", "speaker": null}, {"start": 814.994, "end": 818.874, "text": "Pero cuando te ve en ciertas condiciones diferentes,", "speaker": null}, {"start": 819.874, "end": 822.734, "text": "el médico no te puede diagnosticar nada más por verte y pesarte.", "speaker": null}, {"start": 823.594, "end": 824.414, "text": "¿Normalmente qué hace?", "speaker": null}, {"start": 824.934, "end": 825.77405, "text": "No pruebas.", "speaker": null}, {"start": 826.534, "end": 827.474, "text": "Vete a hacer un estudio.", "speaker": null}, {"start": 828.734, "end": 829.414, "text": "¿De qué?", "speaker": null}, {"start": 830.13403, "end": 832.474, "text": "Pues no sé, a lo mejor un estudio de orina,", "speaker": null}, {"start": 833.474, "end": 835.77405, "text": "a lo mejor un electrocardiograma,", "speaker": null}, {"start": 836.77405, "end": 839.63403, "text": "a lo mejor un encefalograma,", "speaker": null}, {"start": 839.63403, "end": 842.874, "text": "a lo mejor un estudio de plaquetas", "speaker": null}, {"start": 842.874, "end": 844.554, "text": "a lo mejor no lo sé", "speaker": null}, {"start": 844.554, "end": 846.434, "text": "lo que el médico presiente", "speaker": null}, {"start": 846.434, "end": 847.994, "text": "por donde puede estar tu problema", "speaker": null}, {"start": 847.994, "end": 850.794, "text": "y regularmente si les ha tocado ver", "speaker": null}, {"start": 850.794, "end": 851.874, "text": "estoy seguro que sí", "speaker": null}, {"start": 851.874, "end": 854.854, "text": "cuando se van al laboratorio y les entregan los estudios", "speaker": null}, {"start": 854.854, "end": 856.794, "text": "les dan puros numeritos", "speaker": null}, {"start": 856.794, "end": 859.69403, "text": "no sé si se han dado por ahí", "speaker": null}, {"start": 859.69403, "end": 862.39404, "text": "se los llevas al médico", "speaker": null}, {"start": 862.39404, "end": 864.474, "text": "y lo que le tenía", "speaker": null}, {"start": 864.474, "end": 866.89404, "text": "puta madre", "speaker": null}, {"start": 866.89404, "end": 868.754, "text": "él es diabético", "speaker": null}, {"start": 868.754, "end": 870.294, "text": "no", "speaker": null}, {"start": 870.294, "end": 871.854, "text": "aquí está", "speaker": null}, {"start": 871.854, "end": 874.13403, "text": "te llamabas", "speaker": null}, {"start": 874.13403, "end": 876.854, "text": "a partir de ahora te vamos a suministrar esto y esto", "speaker": null}, {"start": 876.854, "end": 878.674, "text": "ya no vas a poder comer esto", "speaker": null}, {"start": 878.674, "end": 880.474, "text": "vas a tener que limitar esto", "speaker": null}, {"start": 880.474, "end": 883.19403, "text": "máximo esto, esto si lo tienes que comer", "speaker": null}, {"start": 883.19403, "end": 884.114, "text": "esto no", "speaker": null}, {"start": 884.114, "end": 886.69403, "text": "no puedes hacer ejercicios", "speaker": null}, {"start": 886.69403, "end": 888.754, "text": "pesados", "speaker": null}, {"start": 888.754, "end": 890.69403, "text": "y cambia tu vida", "speaker": null}, {"start": 890.69403, "end": 892.914, "text": "es lo mismo", "speaker": null}, {"start": 892.914, "end": 895.094, "text": "aquí esos numeritos", "speaker": null}, {"start": 895.094, "end": 896.734, "text": "los vamos a sacar de la nariz", "speaker": null}, {"start": 896.734, "end": 898.714, "text": "y en base a esos numeritos", "speaker": null}, {"start": 898.714, "end": 899.694, "text": "que nos hagan para los hijos.", "speaker": null}]