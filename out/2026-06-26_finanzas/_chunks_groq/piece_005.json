0.698, "end": 361.578, "text": "porcentaje", "speaker": null}, {"start": 361.578, "end": 367.238, "text": "en este caso, mi solvencia", "speaker": null}, {"start": 367.238, "end": 369.15802, "text": "no tengo solvencia", "speaker": null}, {"start": 369.15802, "end": 372.03802, "text": "porque únicamente puedo cubrir", "speaker": null}, {"start": 372.03802, "end": 374.71802, "text": "el 57%", "speaker": null}, {"start": 374.71802, "end": 375.958, "text": "del directo", "speaker": null}, {"start": 375.958, "end": 381.318, "text": "no podría pagar", "speaker": null}, {"start": 381.318, "end": 385.398, "text": "aquí", "speaker": null}, {"start": 385.398, "end": 387.078, "text": "si puedo, ¿por qué?", "speaker": null}, {"start": 387.318, "end": 390.21802, "text": "porcentualmente, ¿cómo lo tendría que interpretar?", "speaker": null}, {"start": 390.21802, "end": 398.298, "text": "tienes el 171%", "speaker": null}, {"start": 398.298, "end": 399.898, "text": "de tu deuda", "speaker": null}, {"start": 399.898, "end": 402.418, "text": "estás arriba de tu deuda", "speaker": null}, {"start": 406.418, "end": 407.498, "text": "nos vamos a entender", "speaker": null}, {"start": 407.498, "end": 410.018, "text": "que maldito problema", "speaker": null}, {"start": 410.018, "end": 411.238, "text": "tiene nuestra gente", "speaker": null}, {"start": 411.238, "end": 417.838, "text": "no pues no", "speaker": null}, {"start": 417.838, "end": 420.178, "text": "entonces porque cuando les preguntamos", "speaker": null}, {"start": 420.178, "end": 420.61798, "text": "¿Cómo saben?", "speaker": null}, {"start": 425.578, "end": 427.35797, "text": "Sí, lo de la lectura, sí.", "speaker": null}, {"start": 427.918, "end": 428.958, "text": "Pero ya lo he puesto.", "speaker": null}, {"start": 430.85797, "end": 432.718, "text": "Ahora vamos a ver algo diferente.", "speaker": null}, {"start": 433.498, "end": 434.818, "text": "Vamos a ver una aritmética.", "speaker": null}, {"start": 436.55798, "end": 438.