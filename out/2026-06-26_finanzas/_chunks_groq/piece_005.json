[{"start": 0.0, "end": 3.9599998, "text": "Y aquí tengo un pasivo a corto plazo, ¿correcto?", "speaker": null}, {"start": 4.2999997, "end": 7.7799997, "text": "El pasivo que me representa el consecuente,", "speaker": null}, {"start": 8.26, "end": 11.599999, "text": "y como consecuencia este igual me va a llevar al resultado,", "speaker": null}, {"start": 11.74, "end": 15.04, "text": "porque yo quiero leer el resultado, ¿ok?", "speaker": null}, {"start": 15.58, "end": 19.26, "text": "Luego entonces, sustituyo el antecedente.", "speaker": null}, {"start": 20.52, "end": 23.14, "text": "Al sustituir el antecedente me representa el activo.", "speaker": null}, {"start": 23.779999, "end": 26.0, "text": "El activo que me dice lo que tengo.", "speaker": null}, {"start": 26.0, "end": 29.539999, "text": "¿cuál es el consecuente?", "speaker": null}, {"start": 29.78, "end": 30.44, "text": "el pasivo", "speaker": null}, {"start": 30.44, "end": 33.5, "text": "aquí está el pasivo, ¿qué me representa el pasivo?", "speaker": null}, {"start": 33.92, "end": 34.9, "text": "lo que debo", "speaker": null}, {"start": 34.9, "end": 38.62, "text": "entonces, si yo le voy a dar una lectura positiva", "speaker": null}, {"start": 38.62, "end": 41.02, "text": "comienzo con el antecedente", "speaker": null}, {"start": 41.02, "end": 42.6, "text": "termino con el consecuente", "speaker": null}, {"start": 42.6, "end": 44.68, "text": "luego entonces, mi empresa", "speaker": null}, {"start": 44.68, "end": 48.38, "text": "tiene un índice de 1.71", "speaker": null}, {"start": 48.38, "end": 52.32, "text": "comienzo con el antecedente", "speaker": null}, {"start": 52.32, "end": 53.46, "text": "¿quién es el antecedente?", "speaker": null}, {"start": 53.96, "end": 55.399998, "text": "el activo", "speaker": null}, {"start": 55.399998, "end": 68.159996, "text": "o sea lo que tengo, mi empresa cuenta con un peso 71 centavos para pagar cada peso que debo.", "speaker": null}, {"start": 71.52, "end": 76.7, "text": "Quiere decir entonces que mi empresa, si en este momento se hiciera exigible mi deuda,", "speaker": null}, {"start": 77.079994, "end": 81.14, "text": "porque es lo que debo, en ese momento me dijeran, sabes qué, no te puedo esperar,", "speaker": null}, {"start": 81.14, "end": 83.53999, "text": "quiero que me pagues lo que debes y quiero que me lo pagues ahorita.", "speaker": null}, {"start": 83.54, "end": 87.700005, "text": "¿Qué pasa?", "speaker": null}, {"start": 88.840004, "end": 92.16, "text": "Le puedo pagar", "speaker": null}, {"start": 92.16, "end": 95.9, "text": "su peso", "speaker": null}, {"start": 95.9, "end": 98.82, "text": "y todavía me quedan", "speaker": null}, {"start": 98.82, "end": 100.68, "text": "71 centavos", "speaker": null}, {"start": 100.68, "end": 102.4, "text": "para seguir trabajando.", "speaker": null}, {"start": 104.26, "end": 105.28, "text": "¿O no?", "speaker": null}, {"start": 106.54, "end": 108.86, "text": "Ahora puede seguir la lectura negativa.", "speaker": null}, {"start": 109.76, "end": 110.74, "text": "La lectura negativa", "speaker": null}, {"start": 110.74, "end": 113.02, "text": "me dice que comienzo con el consecuente.", "speaker": null}, {"start": 113.54, "end": 115.78, "text": "Y termino con el antecedente.", "speaker": null}, {"start": 115.92, "end": 119.46, "text": "Dijimos que es lo mismo, pero con diferentes palabras.", "speaker": null}, {"start": 121.58, "end": 128.9, "text": "Por cada peso que debo, mi empresa tiene un peso con 71 centavos para pagar.", "speaker": null}, {"start": 132.54, "end": 133.82, "text": "Me dice lo mismo.", "speaker": null}, {"start": 134.18001, "end": 138.88, "text": "Por cada peso que yo te debo, yo tengo un peso con 71 centavos para pagar.", "speaker": null}, {"start": 139.68001, "end": 140.8, "text": "¿Qué te estoy diciendo?", "speaker": null}, {"start": 140.8, "end": 144.16, "text": "que te puedo pagar en cualquier momento", "speaker": null}, {"start": 144.16, "end": 145.96, "text": "en el momento que tú quieras", "speaker": null}, {"start": 145.96, "end": 146.64, "text": "yo te pago", "speaker": null}, {"start": 146.64, "end": 152.52, "text": "ahora esquemáticamente", "speaker": null}, {"start": 152.52, "end": 154.64, "text": "vamos a verlo, si no lo quieren ver con números", "speaker": null}, {"start": 154.64, "end": 157.08, "text": "esto es lo que yo llevo", "speaker": null}, {"start": 157.08, "end": 158.84, "text": "y ahorita", "speaker": null}, {"start": 158.84, "end": 161.40001, "text": "me exigen pagar", "speaker": null}, {"start": 161.40001, "end": 168.76001, "text": "¿qué puede pasar?", "speaker": null}, {"start": 168.76001, "end": 171.86, "text": "me puedo pagar de lo que debo", "speaker": null}, {"start": 171.86, "end": 173.64, "text": "y todavía me sobra", "speaker": null}, {"start": 173.64, "end": 176.56, "text": "todo esto", "speaker": null}, {"start": 176.56, "end": 178.58, "text": "para hacer mi droga", "speaker": null}, {"start": 178.58, "end": 181.37999, "text": "no me pones en aprietos", "speaker": null}, {"start": 181.37999, "end": 184.26, "text": "mis deudas no me ponen en aprietos", "speaker": null}, {"start": 184.26, "end": 186.98, "text": "mi empresa está", "speaker": null}, {"start": 186.98, "end": 189.07999, "text": "aparentemente sana", "speaker": null}, {"start": 189.07999, "end": 193.28, "text": "quiere decir que mi empresa tiene", "speaker": null}, {"start": 193.28, "end": 195.2, "text": "solvencia", "speaker": null}, {"start": 195.2, "end": 199.08, "text": "Verifiquen la clasificación de sus razones", "speaker": null}, {"start": 199.08, "end": 202.04, "text": "¿Qué tipo de razón es esta?", "speaker": null}, {"start": 205.04, "end": 206.58, "text": "RCT, ¿cómo se clasifica?", "speaker": null}, {"start": 208.22, "end": 213.01999, "text": "Es una razón de solvencia", "speaker": null}, {"start": 213.01999, "end": 217.42, "text": "Es una prueba de solvencia", "speaker": null}, {"start": 217.42, "end": 219.04, "text": "¿Q